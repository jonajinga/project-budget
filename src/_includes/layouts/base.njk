<!doctype html>
<html lang="{{ site.language }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {# Opt into the cross-document View Transitions API. Browsers that
     support it (Chrome 126+, Edge 126+) wrap full-page navigations
     between same-origin documents in a smooth root-element
     transition; everywhere else this meta tag is a no-op. Honors
     prefers-reduced-motion automatically via the UA. #}
  <meta name="view-transition" content="same-origin">

  {% include "partials/theme-script.njk" %}

  {# Bunny Fonts — preconnect + stylesheet. font-display=swap is baked in.
     Stack matches Project Broadsheet: Playfair Display (masthead),
     Lora (headlines), Source Serif 4 (body), DM Sans (UI). #}
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin>
  <link rel="stylesheet" href="https://fonts.bunny.net/css?family=dm-sans:400,500,600,700|lora:400,500,600,700|playfair-display:400,700|source-serif-4:400,600&display=swap">

  {% include "partials/head-meta.njk" %}
  {% include "partials/structured-data.njk" %}

  <link rel="stylesheet" href="/assets/css/global.css?v={{ build.hash }}">

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="{{ site.themeColor }}">
  {# Service worker — stale-while-revalidate for /app/*, network-
     first for marketing pages. Registers silently after page load
     so the install doesn't block first paint. #}
  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", function () {
        navigator.serviceWorker.register("/sw.js").catch(function (err) {
          console.warn("SW registration failed:", err);
        });
      });
    }
  </script>

  {% if site.umamiWebsiteId %}
  <script defer src="https://cloud.umami.is/script.js" data-website-id="{{ site.umamiWebsiteId }}"></script>
  {% endif %}

  {% block head %}{% endblock %}
</head>
<body class="{% block bodyClass %}{% endblock %}">
  {% include "partials/skip-link.njk" %}
  {% include "partials/header.njk" %}

  {# Pagefind indexes only marketing pages. The presence of
     data-pagefind-body anywhere on the site tells Pagefind to ignore
     pages without it — so /app/* (which omits the attribute) is
     excluded automatically without a separate exclude pattern. #}
  <main id="main" tabindex="-1"
        {% if not (page.url and page.url.startsWith("/app/")) %}data-pagefind-body{% endif %}>
    {% block content %}{{ content | safe }}{% endblock %}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/main.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/util/dialog.js?v={{ build.hash }}" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
