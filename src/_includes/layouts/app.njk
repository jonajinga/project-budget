{% extends "layouts/base.njk" %}

{% block bodyClass %}layout-app{% endblock %}

{% block content %}
<div class="app-shell"
     x-data="{
       /* Default: closed on mobile (drawer hidden behind hamburger),
          open on desktop (sidebar column visible). LocalStorage
          override lets the user's last pick survive reloads on the
          SAME viewport class — we read it through matchMedia so a
          desktop user who closed the sidebar yesterday still starts
          closed today, but a mobile user always starts closed
          regardless of what they did on desktop. */
       sidebarOpen: (function () {
         try {
           var key = window.matchMedia('(min-width: 1024px)').matches
             ? 'projectbudget:sidebarOpen:desktop'
             : 'projectbudget:sidebarOpen:mobile';
           var stored = localStorage.getItem(key);
           if (stored !== null) return stored === '1';
         } catch (_e) {}
         return window.matchMedia('(min-width: 1024px)').matches;
       })(),
       _persistSidebar() {
         try {
           var key = window.matchMedia('(min-width: 1024px)').matches
             ? 'projectbudget:sidebarOpen:desktop'
             : 'projectbudget:sidebarOpen:mobile';
           localStorage.setItem(key, this.sidebarOpen ? '1' : '0');
         } catch (_e) {}
       }
     }"
     :class="{ 'app-shell--sidebar-closed': !sidebarOpen }"
     @open-sidebar.window="sidebarOpen = true; _persistSidebar()"
     @close-sidebar.window="sidebarOpen = false; _persistSidebar()"
     @toggle-sidebar.window="sidebarOpen = !sidebarOpen; _persistSidebar()">
  {% include "partials/app-shell.njk" %}
  {# Mobile backdrop — visible only when sidebarOpen and the sidebar
     is in its mobile slide-out state. Click anywhere off-sidebar to
     dismiss. WCAG-friendly: backdrop is purely decorative, the close
     button inside the sidebar is the keyboard-accessible affordance. #}
  <div class="app-sidebar-backdrop" x-show="sidebarOpen" x-cloak
       @click="$dispatch('close-sidebar')" aria-hidden="true"></div>
  <div class="app-sidebar-handle" role="separator" aria-orientation="vertical"
       aria-label="Resize sidebar" tabindex="0"
       data-tip="Drag to resize the sidebar. Double-click to reset to the default width."></div>
  <section class="app-main">
    {% include "partials/sample-banner.njk" %}
    {{ content | safe }}
  </section>
</div>
{% include "partials/fab-quick-add.njk" %}
{% include "partials/toast.njk" %}
{% endblock %}

{% block scripts %}
  {# Order matters: app.js registers the alpine:init listener BEFORE Alpine
     boots, so the store is set up by the time x-data binds. Popper must
     load before tippy. #}
  <script src="/assets/js/app.js?v={{ build.hash }}" type="module"></script>
  <script src="/assets/js/vendor/dexie.min.js" defer></script>
  {# Chart.js is used by every page that draws a chart — reports + the
     dashboard sparklines. D3 is only used by the spending treemap, so
     it loads only on /app/reports/spending/. Splitting saves ~280 KB
     on every page that doesn't need the treemap. #}
  {% if page.url and (page.url.startsWith("/app/reports/") or page.url == "/app/") %}
    <script src="/assets/js/vendor/chart.umd.min.js" defer></script>
  {% endif %}
  {% if page.url == "/app/reports/spending/" %}
    <script src="/assets/js/vendor/d3.min.js" defer></script>
  {% endif %}
  <script src="/assets/js/vendor/fuse.min.js" defer></script>
  <script src="/assets/js/vendor/papaparse.min.js" defer></script>
  <script src="/assets/js/vendor/popper.min.js" defer></script>
  <script src="/assets/js/vendor/tippy-bundle.min.js" defer></script>
  <script src="/assets/js/vendor/sortable.min.js" defer></script>
  <script src="/assets/js/vendor/alpine.min.js" defer></script>
  <script src="/assets/js/ui/sortable-bind.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/ui/command-palette.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/ui/report-table.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/ui/chart-type-picker.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/util/calc.js?v={{ build.hash }}" defer></script>
  {# dialog.js is loaded once in base.njk (covers app + marketing pages). #}
{% endblock %}
