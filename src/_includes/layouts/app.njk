{% extends "layouts/base.njk" %}

{% block bodyClass %}layout-app{% endblock %}

{% block content %}
<div class="app-shell"
     x-data="{
       /* Default: closed on mobile (drawer hidden behind hamburger),
          open on desktop (sidebar column visible). LocalStorage
          override lets the user's last pick survive reloads on the
          SAME viewport class — we read it through matchMedia so a
          desktop user who closed the sidebar yesterday still starts
          closed today, but a mobile user always starts closed
          regardless of what they did on desktop. */
       sidebarOpen: (function () {
         try {
           var key = window.matchMedia('(min-width: 1024px)').matches
             ? 'projectbudget:sidebarOpen:desktop'
             : 'projectbudget:sidebarOpen:mobile';
           var stored = localStorage.getItem(key);
           if (stored !== null) return stored === '1';
         } catch (_e) {}
         return window.matchMedia('(min-width: 1024px)').matches;
       })(),
       _persistSidebar() {
         try {
           var key = window.matchMedia('(min-width: 1024px)').matches
             ? 'projectbudget:sidebarOpen:desktop'
             : 'projectbudget:sidebarOpen:mobile';
           localStorage.setItem(key, this.sidebarOpen ? '1' : '0');
         } catch (_e) {}
       }
     }"
     :class="{ 'app-shell--sidebar-closed': !sidebarOpen }"
     @open-sidebar.window="sidebarOpen = true; _persistSidebar()"
     @close-sidebar.window="sidebarOpen = false; _persistSidebar()"
     @toggle-sidebar.window="sidebarOpen = !sidebarOpen; _persistSidebar()">
  {% include "partials/app-shell.njk" %}
  {# Mobile backdrop — visible only when sidebarOpen and the sidebar
     is in its mobile slide-out state. Click anywhere off-sidebar to
     dismiss. WCAG-friendly: backdrop is purely decorative, the close
     button inside the sidebar is the keyboard-accessible affordance. #}
  <div class="app-sidebar-backdrop" x-show="sidebarOpen" x-cloak
       @click="$dispatch('close-sidebar')" aria-hidden="true"></div>
  <div class="app-sidebar-handle" role="separator" aria-orientation="vertical"
       aria-label="Resize sidebar" tabindex="0"
       data-tip="Drag to resize the sidebar. Double-click to reset to the default width."></div>
  <section class="app-main">
    {% include "partials/sample-banner.njk" %}
    {{ content | safe }}
  </section>
  {# Loading overlay — visible only while the store is restoring
     data on first paint. Self-cleans the moment the store flips
     loading=false. x-cloak hides it until Alpine boots so static
     HTML doesn't flash the spinner. #}
  <div class="app-loading" x-show="$store.budget && $store.budget.loading" x-cloak
       role="status" aria-live="polite" aria-label="Loading your data">
    <span class="app-loading__spinner" aria-hidden="true"></span>
    <span class="app-loading__label">Loading…</span>
  </div>
</div>
{% include "partials/fab-quick-add.njk" %}
{% include "partials/toast.njk" %}
{% endblock %}

{% block scripts %}
  {# Order matters: app.js registers the alpine:init listener BEFORE Alpine
     boots, so the store is set up by the time x-data binds. Popper must
     load before tippy. #}
  <script src="/assets/js/app.js?v={{ build.hash }}" type="module"></script>
  {# lz-string for localStorage compression — loaded synchronously
     (no defer) so the persist layer can use it immediately on first
     paint. Only ~5 KB. #}
  <script src="/assets/js/vendor/lz-string.min.js"></script>
  <script src="/assets/js/vendor/dexie.min.js" defer></script>
  {# Chart.js is used by every page that draws a chart — reports + the
     dashboard sparklines. D3 is only used by the spending treemap, so
     it loads only on /app/reports/spending/. Splitting saves ~280 KB
     on every page that doesn't need the treemap. #}
  {% if page.url and (page.url.startsWith("/app/reports/") or page.url == "/app/") %}
    <script src="/assets/js/vendor/chart.umd.min.js" defer></script>
    {# Datalabels plugin: ~13 KB. Loaded alongside Chart.js so the
       chartjs.js applyChartDefaults() can Chart.register() it
       globally. Default display:false; individual charts opt in. #}
    <script src="/assets/js/vendor/chartjs-plugin-datalabels.min.js" defer></script>
  {% endif %}
  {# jsPDF (~357 KB) is dynamically loaded on first Export PDF click
     via pdf-export.js's ensureJsPDF() helper. Not loaded at page
     paint — saves the weight on every reports page initial load. #}
  {# D3: needed for the spending treemap + heatmap + sankey reports.
     Sankey additionally needs the d3-sankey plugin (~6 KB). #}
  {% if page.url == "/app/reports/spending/" or page.url == "/app/reports/heatmap/" or page.url == "/app/reports/sankey/" %}
    <script src="/assets/js/vendor/d3.min.js" defer></script>
  {% endif %}
  {% if page.url == "/app/reports/sankey/" %}
    <script src="/assets/js/vendor/d3-sankey.min.js" defer></script>
  {% endif %}
  <script src="/assets/js/vendor/fuse.min.js" defer></script>
  <script src="/assets/js/vendor/papaparse.min.js" defer></script>
  <script src="/assets/js/vendor/popper.min.js" defer></script>
  <script src="/assets/js/vendor/tippy-bundle.min.js" defer></script>
  <script src="/assets/js/vendor/sortable.min.js" defer></script>
  {# Page-specific Alpine factories — must load BEFORE Alpine boots so
     the x-data="…View()" attributes find their factories. All scripts
     are `defer` so they execute in document order. #}
  {% if page.url == "/app/register/" %}
    <script src="/assets/js/views/register-view.js?v={{ build.hash }}" defer></script>
  {% endif %}
  {% if page.url == "/app/budget/" %}
    <script src="/assets/js/views/budget-view.js?v={{ build.hash }}" defer></script>
  {% endif %}
  {% if page.url == "/app/calendar/" %}
    <script src="/assets/js/views/calendar-view.js?v={{ build.hash }}" defer></script>
  {% endif %}
  <script src="/assets/js/vendor/alpine.min.js" defer></script>
  <script src="/assets/js/ui/sortable-bind.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/ui/command-palette.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/ui/report-table.js?v={{ build.hash }}" defer></script>
  <script src="/assets/js/ui/chart-type-picker.js?v={{ build.hash }}" defer></script>
  {# Shared CSV-export helper used by every report's Alpine factory.
     Module export attaches window.pbExportCSV so inline scripts can
     call it without an import. Loaded on reports + a few other
     pages that have Export buttons. #}
  <script src="/assets/js/ui/csv-export.js?v={{ build.hash }}" type="module"></script>
  {# Global save-view listener — turns pb:save-view events from any
     page into entries in projectbudget:savedViews, captures the
     live URL so filters are recall-able with one click. #}
  <script src="/assets/js/ui/save-view.js?v={{ build.hash }}" defer></script>
  {# Per-report PDF export — uses the already-conditional jsPDF
     vendor. Only loaded on reports pages. #}
  {% if page.url and page.url.startsWith("/app/reports/") %}
    <script src="/assets/js/ui/pdf-export.js?v={{ build.hash }}" defer></script>
    {# Visit logger — writes /app/reports/<slug>/ visits to localStorage
       so the hub can render a "Recents" strip. Skips the hub itself. #}
    <script>
      (function () {
        try {
          var path = location.pathname.replace(/\/+$/, "/");
          if (path === "/app/reports/" || !/^\/app\/reports\/[^\/]+\/$/.test(path)) return;
          var slug = path.split("/").filter(Boolean).pop();
          var key  = "projectbudget:report:recent";
          var raw  = localStorage.getItem(key);
          var list = raw ? JSON.parse(raw) : [];
          list = (list || []).filter(function (e) { return e && e.slug && e.slug !== slug; });
          list.unshift({ slug: slug, visited: new Date().toISOString() });
          localStorage.setItem(key, JSON.stringify(list.slice(0, 10)));
        } catch (e) { /* localStorage unavailable — silently skip. */ }
      }());
    </script>
  {% endif %}
  <script src="/assets/js/util/calc.js?v={{ build.hash }}" defer></script>
  {# dialog.js is loaded once in base.njk (covers app + marketing pages). #}
{% endblock %}
