<footer class="site-footer" role="contentinfo">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">{{ site.title }}</p>
      <p class="site-footer__tagline">{{ site.tagline }}</p>
    </div>

    {# All utility links on a single horizontal row. Union of nav.main
       (sans the CTA + features anchor) + nav.footer + GitHub so users
       can reach everything in one glance without scanning two stacks. #}
    <nav class="site-footer__nav" aria-label="Footer">
      <ul class="site-footer__links">
        <li><a href="/docs/">Docs</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/glossary/">Glossary</a></li>
        <li><a href="/open-source/">Open source</a></li>
        {% for item in nav.footer %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
        <li><a href="{{ site.repo }}" rel="noopener">GitHub</a></li>
      </ul>
    </nav>

    <p class="site-footer__copy">
      &copy; {% currentYear %} {{ site.title }}. {{ site.license }} licensed.
      Website by <a href="https://pikespeakwebdesigns.com" rel="noopener">Pikes Peak Web Designs</a>.
    </p>
  </div>
</footer>
