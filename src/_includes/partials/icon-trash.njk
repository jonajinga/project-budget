{# Canonical trash-can icon (Lucide "trash-2"). One source of truth so
   every delete affordance across the site shows the same glyph.
   Usage:
     {% from "partials/icon-trash.njk" import iconTrash %}
     {{ iconTrash() }}     -- default 18px
     {{ iconTrash(14) }}    -- explicit size
   Fill is currentColor so callers control color via parent CSS. #}
{% macro iconTrash(size=18) -%}
