{% set isApp = page.url and page.url.startsWith("/app/") %}

<header class="site-header {{ 'site-header--app' if isApp else 'site-header--marketing' }}" role="banner">

  {% if isApp %}
    {# ---- App-mode header: hamburger | profile | theme toggle ---- #}
    <div class="container site-header__inner site-header__inner--app">
      <button type="button"
              class="site-header__hamburger"
              aria-controls="site-menu"
              aria-expanded="false"
              aria-label="Open menu"
              data-tip="Open the main menu — site links, documentation, and settings.">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <a class="site-header__profile" href="/app/profiles/"
         x-data
         data-tip="Click to manage profiles or switch to a different one.">
        <span class="site-header__profile-eyebrow">Profile</span>
        <span class="site-header__profile-name"
              x-text="$store.budget && $store.budget.profile ? $store.budget.profile.name : 'No profile yet'"></span>
      </a>

      <div class="site-header__actions">
        <button type="button"
                class="site-header__search"
                aria-label="Search the site"
                data-tip="Search docs, blog, glossary (Ctrl+K / Cmd+K)."
                onclick="window.ProjectBudget && window.ProjectBudget.openSearch && window.ProjectBudget.openSearch()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <button type="button"
                class="theme-toggle"
                aria-label="Toggle color theme"
                data-tip="Switch between light and dark themes."
                onclick="window.ProjectBudget && window.ProjectBudget.toggleTheme && window.ProjectBudget.toggleTheme()">
          <svg class="theme-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="theme-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
      </div>
    </div>
  {% else %}
    {# ---- Marketing header: single wordmark + horizontal nav ---- #}
    <div class="container site-header__inner">
      <a href="/" class="site-header__brand" aria-label="{{ site.title }} home">
        <span class="brand__mark">{{ site.title }}</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <ul class="site-nav__list">
          {% for item in nav.main %}
            <li>
              <a href="{{ item.url }}"
                 class="site-nav__link{% if item.cta %} site-nav__link--cta{% endif %}"
                 {% if page.url == item.url %}aria-current="page"{% endif %}>
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="site-header__actions">
        <button type="button"
                class="site-header__search"
                aria-label="Search the site"
                onclick="window.ProjectBudget && window.ProjectBudget.openSearch && window.ProjectBudget.openSearch()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <button type="button"
                class="site-header__hamburger site-header__hamburger--mobile"
                aria-controls="site-menu"
                aria-expanded="false"
                aria-label="Open menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <button type="button"
                class="theme-toggle"
                aria-label="Toggle color theme"
                onclick="window.ProjectBudget && window.ProjectBudget.toggleTheme && window.ProjectBudget.toggleTheme()">
          <svg class="theme-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="theme-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
      </div>
    </div>
  {% endif %}

  {# ---- Slide-out menu (vanilla JS via main.js) ---- #}
  <div class="site-menu-backdrop" hidden></div>

  <aside class="site-menu" id="site-menu" aria-label="Site menu">
    <div class="site-menu__head">
      <p class="site-menu__brand">{{ site.title }}</p>
      <button type="button" class="site-menu__close" aria-label="Close menu">&times;</button>
    </div>

    {% if isApp %}
      <p class="site-menu__group-label">In this app</p>
      <ul class="site-menu__list">
        {% for item in nav.app %}
          <li><a href="{{ item.url }}" class="site-menu__link">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    {% endif %}

    <p class="site-menu__group-label">Project Budget</p>
    <ul class="site-menu__list">
      <li><a href="/" class="site-menu__link">Home</a></li>
      {% for item in nav.main %}
        <li><a href="{{ item.url }}" class="site-menu__link">{{ item.label }}</a></li>
      {% endfor %}
    </ul>

    <p class="site-menu__group-label">More</p>
    <ul class="site-menu__list">
      {% for item in nav.footer %}
        <li><a href="{{ item.url }}" class="site-menu__link">{{ item.label }}</a></li>
      {% endfor %}
    </ul>
  </aside>

  {% include "partials/search-modal.njk" %}
</header>
