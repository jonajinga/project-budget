{% set isApp = page.url and page.url.startsWith("/app/") %}

<header class="site-header {{ 'site-header--app' if isApp else 'site-header--marketing' }}" role="banner">

  {% if isApp %}
    {# ---- App-mode header: hamburger | profile | theme toggle ---- #}
    <div class="container site-header__inner site-header__inner--app">
      {# In app mode the hamburger TOGGLES the app sidebar (Budget /
         Register / Calendar / Balances / Profile switcher). The
         button keeps its own `open` flag in sync with the layout's
         sidebarOpen by listening to the same window events the
         layout listens to. Clicking the button dispatches
         toggle-sidebar (the layout flips its state); the button
         mirrors that on the matching event for aria-expanded +
         label, so the same button opens AND closes the drawer. #}
      <button type="button"
              class="site-header__hamburger"
              aria-controls="app-sidebar"
              x-data="{ open: false }"
              @open-sidebar.window="open = true"
              @close-sidebar.window="open = false"
              @toggle-sidebar.window="open = !open"
              :aria-expanded="open.toString()"
              :aria-label="open ? 'Close app navigation' : 'Open app navigation'"
              :data-tip="open ? 'Close the app sidebar.' : 'Open the app sidebar — Budget, Register, Calendar, Balances, and profile switcher.'"
              @click="$dispatch('toggle-sidebar')">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <a class="site-header__profile" href="/app/"
         x-data
         data-tip="Open the dashboard for this profile.">
        <span class="site-header__profile-name"
              x-text="$store.budget && $store.budget.profile ? $store.budget.profile.name : 'No profile yet'"></span>
      </a>

      <div class="site-header__actions" x-data>
        {# Undo / redo — hidden when there's nothing to undo so the
           header stays clean. Tippy shows the last action label. #}
        <button type="button"
                class="site-header__iconbtn"
                @click="$store.budget.undo()"
                x-show="$store.budget && $store.budget.canUndo && $store.budget.canUndo()"
                x-cloak
                :data-tip="'Undo: ' + ($store.budget.undoLabel() || 'last action') + ' (Ctrl/⌘+Z)'"
                aria-label="Undo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
        </button>
        <button type="button"
                class="site-header__iconbtn"
                @click="$store.budget.redo()"
                x-show="$store.budget && $store.budget.canRedo && $store.budget.canRedo()"
                x-cloak
                :data-tip="'Redo: ' + ($store.budget.redoLabel() || 'last undone action') + ' (Ctrl/⌘+Shift+Z)'"
                aria-label="Redo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 14 20 9 15 4"/><path d="M4 20v-7a4 4 0 0 1 4-4h12"/></svg>
        </button>
        <button type="button"
                class="site-header__search"
                aria-label="Search the site"
                data-tip="Search docs, blog, glossary (Ctrl+K / Cmd+K)."
                onclick="window.ProjectBudget && window.ProjectBudget.openSearch && window.ProjectBudget.openSearch()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        {% include "partials/theme-picker.njk" %}
      </div>
    </div>
  {% else %}
    {# ---- Marketing header: single wordmark + horizontal nav ---- #}
    <div class="container site-header__inner">
      <a href="/" class="site-header__brand" aria-label="{{ site.title }} home">
        <span class="brand__mark">{{ site.title }}</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <ul class="site-nav__list">
          {% for item in nav.main %}
            <li>
              <a href="{{ item.url }}"
                 class="site-nav__link{% if item.cta %} site-nav__link--cta{% endif %}"
                 {% if page.url == item.url %}aria-current="page"{% endif %}>
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="site-header__actions">
        <button type="button"
                class="site-header__search"
                aria-label="Search the site"
                onclick="window.ProjectBudget && window.ProjectBudget.openSearch && window.ProjectBudget.openSearch()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <button type="button"
                class="site-header__hamburger site-header__hamburger--mobile"
                aria-controls="site-menu"
                aria-expanded="false"
                aria-label="Open menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        {% include "partials/theme-picker.njk" %}
      </div>
    </div>
  {% endif %}

  {# Slide-out site-menu is only rendered on marketing pages now —
     on /app/* the hamburger opens the app-sidebar (which also
     carries a Project Budget section with all the marketing links),
     so this second menu would just duplicate it. #}
  {% if not isApp %}
    <div class="site-menu-backdrop" hidden></div>

    <aside class="site-menu" id="site-menu" aria-label="Site menu">
      <div class="site-menu__head">
        <p class="site-menu__brand">{{ site.title }}</p>
        <button type="button" class="site-menu__close" aria-label="Close menu">&times;</button>
      </div>

      <p class="site-menu__group-label">Project Budget</p>
      <ul class="site-menu__list">
        <li><a href="/" class="site-menu__link">Home</a></li>
        {% for item in nav.main %}
          <li><a href="{{ item.url }}" class="site-menu__link">{{ item.label }}</a></li>
        {% endfor %}
        {% for item in nav.footer %}
          <li><a href="{{ item.url }}" class="site-menu__link">{{ item.label }}</a></li>
        {% endfor %}
        <li><a href="{{ site.repo }}" class="site-menu__link" rel="noopener">GitHub</a></li>
      </ul>
    </aside>
  {% endif %}

  {% include "partials/search-modal.njk" %}
</header>
