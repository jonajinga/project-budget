{# Reusable kebab overflow menu (⋮ → popover).

   Use it for any row/header/toolbar that has 3+ secondary actions
   you want to collapse behind a single trigger. Pure Alpine + CSS;
   no Tippy, no Popper — keeps the bundle clean and the menu opens
   instantly even on first paint.

   Usage:
     {% from "partials/overflow-menu.njk" import overflow %}
     {% call overflow(label="Account actions", align="right") %}
       <li role="none">
         <button type="button" role="menuitem" class="overflow-menu__item"
                 @click="$store.budget.foo(); open = false">Foo</button>
       </li>
       <li role="none">
         <button type="button" role="menuitem" class="overflow-menu__item"
                 @click="bar(); open = false">Bar</button>
       </li>
     {% endcall %}

   Callers set `open = false` after invoking an action so the menu
   closes — Alpine bindings inside the call block have access to the
   outer `open` because the x-data is on the wrapping element.

   `align` controls left/right anchor of the popover; default "right"
   (menu hangs to the left of the kebab, which is the right pattern
   for action buttons aligned to the right edge of a row).
#}
{% macro overflow(label="More actions", align="right", triggerClass="") %}
<div x-data="{ open: false }"
     class="overflow-menu"
     @keydown.escape.window="open = false"
     @click.outside="open = false">
  <button type="button"
          class="btn btn--icon overflow-menu__trigger {{ triggerClass }}"
          :class="open ? 'is-open' : ''"
          :aria-expanded="open.toString()"
          aria-haspopup="menu"
          aria-label="{{ label }}"
          data-tip="{{ label }}"
          @click="open = !open">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <circle cx="12" cy="6"  r="2"/>
      <circle cx="12" cy="12" r="2"/>
      <circle cx="12" cy="18" r="2"/>
    </svg>
  </button>
  <ul class="overflow-menu__list overflow-menu__list--{{ align }}"
      role="menu"
      x-show="open"
      x-cloak
      x-transition.opacity.duration.120ms>
    {{ caller() }}
  </ul>
</div>
{% endmacro %}
