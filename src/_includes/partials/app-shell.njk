<aside id="app-sidebar" class="app-sidebar" :class="{ 'is-open': sidebarOpen }"
       aria-label="App navigation"
       @keydown.escape.window="sidebarOpen = false">
  <button class="app-sidebar__close"
          type="button"
          @click="sidebarOpen = false"
          aria-label="Close app menu">&times;</button>

  {% include "partials/profile-switcher.njk" %}

  <nav class="app-nav" aria-label="App sections">
    <ul class="app-nav__list">
      {% for item in nav.app %}
        <li>
          <a href="{{ item.url }}"
             class="app-nav__link"
             @click="sidebarOpen = false"
             {% if page.url == item.url %}aria-current="page"{% endif %}>
            <svg class="app-nav__icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true">{{ item.icon | safe }}</svg>
            <span class="app-nav__label">{{ item.label }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  {# Account groups + balances. Renders only when a profile is active and has accounts. #}
  <div class="app-sidebar__accounts" x-data x-show="$store.budget.profile && $store.budget.profile.accounts.length" x-cloak>
    <p class="app-sidebar__heading">Accounts</p>
    <template x-for="group in $store.budget.accountGroupsView()" :key="group.group ? group.group.id : '__ungrouped'">
      <div class="acct-group">
        <button type="button" class="acct-group__head"
                @click="group.group && $store.budget.toggleAccountGroupCollapsed(group.group.id)"
                :aria-expanded="group.group && !$store.budget.isAcctGroupCollapsed(group.group.id) ? 'true' : 'false'"
                :disabled="!group.group">
          <span class="group-toggle__chevron" :class="group.group && $store.budget.isAcctGroupCollapsed(group.group.id) ? 'is-collapsed' : ''" aria-hidden="true">&#9662;</span>
          <span x-text="group.group ? group.group.name : 'Other'"></span>
        </button>
        <ul class="acct-group__list" x-show="!(group.group && $store.budget.isAcctGroupCollapsed(group.group.id))" x-cloak>
          <template x-for="a in group.accounts" :key="a.id">
            <li>
              <a class="acct-link" :href="'/app/register/?account=' + a.id">
                <span class="acct-link__name" x-text="a.name"></span>
                <span class="acct-link__balance"
                      :class="{ 'is-negative': $store.budget.accountBalance(a.id) < 0 }"
                      x-text="(($store.budget.accountBalance(a.id) || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span>
              </a>
            </li>
          </template>
        </ul>
      </div>
    </template>
    <div class="acct-totals">
      <p><span>On-budget</span><span x-text="(($store.budget.onBudgetTotal() || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span></p>
      <p><span>Net worth</span><span x-text="(($store.budget.netWorth() || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span></p>
    </div>
  </div>

  <div class="app-sidebar__footer">
    {# Save-status pill: dot + label communicates that the app is
       saving as you go. "Ready" is the steady state; saving / saved
       overlay it briefly on mutation. Tippy spells out the meaning. #}
    <div class="save-status"
         x-data
         :class="$store.budget && $store.budget.lastSavedLabel ? 'save-status--saved' : 'save-status--ready'"
         role="status"
         aria-live="polite"
         data-tip="Auto-save status. Your profile is written to this browser's localStorage on every change — no network call, no account required.">
      <span class="save-status__dot" aria-hidden="true"></span>
      <span class="save-status__label">
        <span class="save-status__eyebrow">Auto-save</span>
        <span class="save-status__state"
              x-text="$store.budget && $store.budget.lastSavedLabel ? $store.budget.lastSavedLabel : 'Ready · all changes saved'"></span>
      </span>
    </div>

    {# Exit affordance — separated from the save indicator so users
       don't read "Back to site" as part of the save state. Marked as
       a secondary action with an arrow icon for affordance clarity. #}
    <a class="app-sidebar__exit" href="/"
       data-tip="Leave the app shell and return to the public Project Budget website. Your data stays put.">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      <span>Back to public site</span>
    </a>
  </div>
</aside>

