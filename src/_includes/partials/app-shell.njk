<aside id="app-sidebar" class="app-sidebar" :class="{ 'is-open': sidebarOpen }"
       aria-label="App navigation"
       @keydown.escape.window="$dispatch('close-sidebar')">
  <button class="app-sidebar__close"
          type="button"
          @click="$dispatch('close-sidebar')"
          aria-label="Close app menu">&times;</button>

  {% include "partials/profile-switcher.njk" %}

  {# Sidebar nav — each section is collapsible. Collapsed state is
     persisted per-section in localStorage so the user's pick survives
     reloads + profile switches. The section containing the active
     page auto-expands on mount so deep links remain visible.

     The nav data is emitted via a <script> tag rather than inlined
     into x-data because the icon SVGs contain double quotes that
     would otherwise close the attribute prematurely. #}
  <script>
    window.__pbAppNav = {{ nav.app | dump | safe }};
    window.__pbAppNavUrl = "{{ page.url }}";
  </script>
  <nav class="app-nav"
       aria-label="App sections"
       x-data="appNav(window.__pbAppNav, window.__pbAppNavUrl)"
       x-init="init()">
    <template x-for="(sec, i) in sections" :key="sec.key">
      <div class="app-nav__group-wrap">
        <div class="app-nav__section-block">
          <button type="button"
                  class="app-nav__section-head"
                  :aria-expanded="(!collapsed[sec.key]).toString()"
                  @click="toggle(sec.key)"
                  :data-tip="(collapsed[sec.key] ? 'Expand' : 'Collapse') + ' the ' + sec.section + ' section.'">
            <span class="app-nav__section-chevron" :class="collapsed[sec.key] ? 'is-collapsed' : ''" aria-hidden="true">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
            <span class="app-nav__section-label" x-text="sec.section"></span>
          </button>
          <ul class="app-nav__list" x-show="!collapsed[sec.key]" x-cloak>
            <template x-for="item in sec.items" :key="item.url">
              <li>
                <a :href="item.url"
                   class="app-nav__link"
                   :aria-current="item.url === currentUrl ? 'page' : null"
                   @click="$dispatch('close-sidebar')">
                  <svg class="app-nav__icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                       aria-hidden="true" x-html="item.icon"></svg>
                  <span class="app-nav__label" x-text="item.label"></span>
                </a>
              </li>
            </template>
          </ul>
        </div>

        {# Accounts panel sits right under the Daily section so balances
           are visible without scrolling past Data / Insights / etc.
           It's its own collapsible section block (same chrome as the
           nav sections) and only shows when the active profile has
           accounts. #}
        <template x-if="i === 0">
          <div class="app-nav__section-block app-sidebar__accounts"
               x-show="($store.budget._listVersion, $store.budget.profile && $store.budget.profile.accounts.length)" x-cloak>
            <button type="button"
                    class="app-nav__section-head"
                    :aria-expanded="(!collapsed.accounts).toString()"
                    @click="toggle('accounts')"
                    :data-tip="(collapsed.accounts ? 'Expand' : 'Collapse') + ' the Balances section.'">
              <span class="app-nav__section-chevron" :class="collapsed.accounts ? 'is-collapsed' : ''" aria-hidden="true">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
              <span class="app-nav__section-label">Balances</span>
            </button>
            <div x-show="!collapsed.accounts" x-cloak>
              {# Inline the _listVersion read so Alpine tracks the dep
                 in the binding scope. Without this the cross-store
                 read inside accountGroupsView() doesn't always
                 propagate to the sidebar after addAccountGroup. #}
              <template x-for="group in ($store.budget._listVersion, $store.budget.accountGroupsView())" :key="group.group ? group.group.id : '__ungrouped'">
                <div class="acct-group">
                  <button type="button" class="acct-group__head"
                          @click="group.group && $store.budget.toggleAccountGroupCollapsed(group.group.id)"
                          :aria-expanded="group.group && !$store.budget.isAcctGroupCollapsed(group.group.id) ? 'true' : 'false'"
                          :disabled="!group.group"
                          :data-tip="group.group ? ($store.budget.isAcctGroupCollapsed(group.group.id) ? 'Expand to see ' + group.accounts.length + ' account' + (group.accounts.length === 1 ? '' : 's') : 'Collapse this group') : ''">
                    {# Match the outer .app-nav__section-chevron treatment — same
                       inline SVG at the same 10x10 size — so the inner group
                       chevrons read at the same weight as the section chevrons
                       above. The downward-pointing arrow rotates 90deg
                       counter-clockwise when collapsed (is-collapsed). #}
                    <span class="app-nav__section-chevron" :class="group.group && $store.budget.isAcctGroupCollapsed(group.group.id) ? 'is-collapsed' : ''" aria-hidden="true">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </span>
                    <span class="acct-group__name" x-text="group.group ? group.group.name : 'Other'"></span>
                    {# Right-side meta cluster: count pill + group total.
                       Both are always visible so the user always sees
                       (a) how many accounts live in this group and
                       (b) the rolled-up balance for the group, whether
                       expanded or collapsed. #}
                    <span class="acct-group__meta" x-show="group.group" x-cloak>
                      <span class="acct-group__count"
                            x-text="group.accounts.length"
                            :data-tip="group.accounts.length + ' account' + (group.accounts.length === 1 ? '' : 's') + ' in this group'"></span>
                      <span class="acct-group__total"
                            :class="acctGroupTotal(group) < 0 ? 'is-negative' : ''"
                            x-text="fmtCompactCents(acctGroupTotal(group))"></span>
                    </span>
                  </button>
                  <ul class="acct-group__list" x-show="!(group.group && $store.budget.isAcctGroupCollapsed(group.group.id))" x-cloak>
                    <template x-for="a in group.accounts" :key="a.id">
                      <li>
                        <a class="acct-link" :href="'/app/register/?account=' + a.id">
                          <span class="acct-link__name">
                            <span x-text="a.name"></span>
                            {# Capital E next to any account flagged
                               excludeFromNetWorth so users can tell at
                               a glance which accounts the dashboard +
                               sidebar net-worth roll-up is skipping
                               (529s, escrow, employer-held RSUs). #}
                            <span class="acct-link__excl-flag"
                                  x-show="a.excludeFromNetWorth" x-cloak
                                  data-tip="Excluded from net worth. Balance is tracked and visible but not counted toward Net worth."
                                  aria-label="Excluded from net worth">E</span>
                          </span>
                          <span class="acct-link__balance"
                                :class="{ 'is-negative': $store.budget.accountBalance(a.id) < 0 }"
                                x-text="(($store.budget.accountBalance(a.id) || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span>
                        </a>
                      </li>
                    </template>
                  </ul>
                </div>
              </template>
              {# Totals breakdown. Order tells a story:
                 On-budget + Tracking → Net worth, then Excluded
                 sits below Net worth (since it's NOT included in it)
                 + Net+excluded is the grand total. Tracking + Excluded
                 + Net+excluded rows hide when they'd be zero. */ #}
              <div class="acct-totals">
                <p><span>On-budget</span><span x-text="(($store.budget.onBudgetTotal() || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span></p>
                <p x-show="trackingNetTotal() !== 0" x-cloak>
                  <span>Tracking</span>
                  <span :class="trackingNetTotal() < 0 ? 'amount--outflow' : ''"
                        x-text="(trackingNetTotal() / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span>
                </p>
                <p class="acct-totals__sum"><span>Net worth</span><span x-text="(($store.budget.netWorth() || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span></p>
                <p x-show="excludedFromNetWorthTotal() !== 0" x-cloak>
                  <span>Excluded</span>
                  <span :class="excludedFromNetWorthTotal() < 0 ? 'amount--outflow' : ''"
                        x-text="(excludedFromNetWorthTotal() / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span>
                </p>
                <p x-show="excludedFromNetWorthTotal() !== 0" x-cloak class="acct-totals__sum">
                  <span>Net + excluded</span>
                  <span x-text="((($store.budget.netWorth() || 0) + excludedFromNetWorthTotal()) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span>
                </p>
              </div>
            </div>
          </div>
        </template>
      </div>
    </template>
  </nav>

  <div class="app-sidebar__footer">
    {# Save-status pill: dot + label communicates that the app is
       saving as you go. "Ready" is the steady state; saving / saved
       overlay it briefly on mutation. Tippy spells out the meaning. #}
    <div class="save-status"
         x-data
         :class="$store.budget && $store.budget.lastSavedLabel ? 'save-status--saved' : 'save-status--ready'"
         role="status"
         aria-live="polite"
         data-tip="Auto-save status. Your profile is written to this browser's localStorage on every change — no network call, no account required.">
      <span class="save-status__dot" aria-hidden="true"></span>
      <span class="save-status__label">
        <span class="save-status__eyebrow">Auto-save</span>
        <span class="save-status__state"
              x-text="$store.budget && $store.budget.lastSavedLabel ? $store.budget.lastSavedLabel : 'Ready · all changes saved'"></span>
      </span>
    </div>

    {# Exit affordance — separated from the save indicator so users
       don't read "Back to site" as part of the save state. Marked as
       a secondary action with an arrow icon for affordance clarity. #}
    <a class="app-sidebar__exit" href="/"
       data-tip="Leave the app shell and return to the public Project Budget website. Your data stays put.">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      <span>Back to public site</span>
    </a>
  </div>
</aside>

<script>
/* Sidebar nav factory — manages collapsible section state.
   - sections: array of { section, key, items, defaultCollapsed? } from nav.app
   - currentUrl: current page.url so we know which section to auto-open
   Per-section collapsed state persists in localStorage at
   projectbudget:nav:collapsed:<key>. The section containing the
   active page is force-expanded on init so deep links stay visible
   even if the user previously collapsed it. */
function appNav(sections, currentUrl) {
  return {
    sections: sections,
    currentUrl: currentUrl,
    collapsed: {},

    init() {
      var self = this;
      sections.forEach(function (sec) {
        var stored = null;
        try { stored = localStorage.getItem("projectbudget:nav:collapsed:" + sec.key); }
        catch (_e) {}
        var isCollapsed = stored == null ? !!sec.defaultCollapsed : stored === "1";
        /* Override: if the active page lives in this section, expand it. */
        var hasActive = sec.items.some(function (i) { return i.url === currentUrl; });
        if (hasActive) isCollapsed = false;
        self.collapsed[sec.key] = isCollapsed;
      });
      /* Accounts panel is rendered inside the nav (after Daily) but
         not in the sections array — seed its collapsed state too so
         the toggle works the first time. Defaults to expanded. */
      var acctStored = null;
      try { acctStored = localStorage.getItem("projectbudget:nav:collapsed:accounts"); }
      catch (_e) {}
      this.collapsed.accounts = acctStored === "1";
    },

    toggle(key) {
      this.collapsed[key] = !this.collapsed[key];
      try { localStorage.setItem("projectbudget:nav:collapsed:" + key, this.collapsed[key] ? "1" : "0"); }
      catch (_e) {}
    },

    /* Net of every tracking account excluding those flagged
       exclude-from-net-worth. Drives the sidebar "Tracking" line so
       users see the math: on-budget + tracking = net worth.

       Both subtotals are SIGNED sums of accountBalance() — tracking
       liabilities (auto loan, mortgage, etc.) carry a negative
       running balance because the user owes that money. So the net
       is asset + liability (not asset - liability — subtracting a
       negative inflates the result, the bug that made the prior
       "$143,500" reading not square with Net worth). */
    trackingNetTotal() {
      var s = window.Alpine && window.Alpine.store && window.Alpine.store("budget");
      if (!s || !s.profile) return 0;
      void s._listVersion;
      return s.trackingAssetTotal() + s.trackingLiabilityTotal();
    },

    /* Sum every account flagged excludeFromNetWorth across the whole
       active profile. Drives the sidebar "Excluded" line + the "Net
       + excluded" all-in total so users see both their working net
       worth and the full asset picture. */
    excludedFromNetWorthTotal() {
      var s = window.Alpine && window.Alpine.store && window.Alpine.store("budget");
      if (!s || !s.profile) return 0;
      void s._listVersion;
      var sum = 0;
      s.profile.accounts.forEach(function (a) {
        if (a.closedAt) return;
        if (!a.excludeFromNetWorth) return;
        sum += s.accountBalance(a.id);
      });
      return sum;
    },

    /* Sum every account balance in a single group. Powers the
       collapsed-state ($12.5k) pill on each acct-group header. */
    acctGroupTotal(group) {
      if (!group || !group.accounts) return 0;
      var s = window.Alpine && window.Alpine.store && window.Alpine.store("budget");
      if (!s) return 0;
      var sum = 0;
      for (var i = 0; i < group.accounts.length; i++) {
        sum += s.accountBalance(group.accounts[i].id);
      }
      return sum;
    },

    /* Cents -> compact display ($12.5k, $1.2M, -$983). Keeps the
       sidebar tight when groups collapse. */
    /* Cents → compact display with magnitude-aware precision. The
       prior version always rounded thousands to 1 decimal, which
       gave noisy readings like "$754.2k" for $754,186 (the .2
       implies ~$200 of precision that doesn't exist in the rounding).
       Now we drop the decimal once the leading value is >=100, so
       hundreds of thousands / millions read clean ($754k, $1.2M)
       while small/medium magnitudes keep one decimal for resolution
       ($1.2k, $57.5k). Uses Math.round (half-up) for true standard
       rounding rather than Number.toFixed which can banker's-round
       in edge cases. */
    fmtCompactCents(c) {
      var n = (c || 0) / 100;
      var sign = n < 0 ? "-" : "";
      var abs = Math.abs(n);
      if (abs >= 1000000) {
        var m = abs / 1000000;
        var mShown = m >= 100 ? Math.round(m) : (Math.round(m * 10) / 10);
        return sign + "$" + mShown + "M";
      }
      if (abs >= 1000) {
        var k = abs / 1000;
        var kShown = k >= 100 ? Math.round(k) : (Math.round(k * 10) / 10);
        return sign + "$" + kShown + "k";
      }
      return sign + "$" + Math.round(abs);
    },
  };
}
</script>

