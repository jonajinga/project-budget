{# Theme picker — replaces the old 2-state moon/sun toggle. The
   button still shows sun (in dark themes) or moon (in light themes)
   for instant recognition + cycles within a pair on click. A small
   chevron caret next to the icon opens the full picker dropdown so
   users can jump straight to Dracula / Solarized / Catppuccin / etc.
   without going to Settings → Appearance.

   window.ProjectBudget.themes + .currentTheme + .applyTheme are
   exported by main.js — this picker reads from them so the source of
   truth stays in one place. #}
<div class="theme-picker"
     x-data="themePicker()" x-init="init()"
     @keydown.escape.window="open = false"
     @click.outside="open = false">
  {# Single trigger — sun/moon icon for the current scheme; click
     opens the dropdown to pick any theme. The old split-button
     (icon + chevron) merged into one since the chevron's only job
     was to open the same menu. @click.outside lives on the wrapper
     (not the menu) so clicking the trigger button doesn't fire an
     immediate close after open. #}
  <button type="button"
          class="theme-picker__trigger"
          :aria-expanded="open.toString()"
          aria-haspopup="menu"
          aria-label="Choose a theme"
          data-tip="Switch theme."
          @click="open = !open">
    <svg x-show="scheme === 'dark'" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
    <svg x-show="scheme !== 'dark'" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
  </button>

  <div class="theme-picker__menu" x-show="open" x-cloak role="menu">
    <p class="theme-picker__group-label">Light</p>
    <ul class="theme-picker__list">
      <template x-for="t in lightThemes()" :key="t.id">
        <li>
          <button type="button" class="theme-picker__item"
                  :class="t.id === activeId ? 'is-active' : ''"
                  @click="pick(t.id)">
            <span class="theme-picker__swatch" :data-theme-preview="t.id" aria-hidden="true"></span>
            <span class="theme-picker__label" x-text="t.label"></span>
            <span class="theme-picker__check" x-show="t.id === activeId" aria-hidden="true">&#10003;</span>
          </button>
        </li>
      </template>
    </ul>
    <p class="theme-picker__group-label">Dark</p>
    <ul class="theme-picker__list">
      <template x-for="t in darkThemes()" :key="t.id">
        <li>
          <button type="button" class="theme-picker__item"
                  :class="t.id === activeId ? 'is-active' : ''"
                  @click="pick(t.id)">
            <span class="theme-picker__swatch" :data-theme-preview="t.id" aria-hidden="true"></span>
            <span class="theme-picker__label" x-text="t.label"></span>
            <span class="theme-picker__check" x-show="t.id === activeId" aria-hidden="true">&#10003;</span>
          </button>
        </li>
      </template>
    </ul>
    <p class="theme-picker__footer">
      <a href="/app/settings/">Full appearance options &rsaquo;</a>
    </p>
  </div>
</div>

<script>
/* Hoisted so both header instances (app + marketing) share one
   factory definition without duplicating it inline. The factory
   itself stays light — it just reads the global theme list, tracks
   open state, and forwards picks to window.ProjectBudget.applyTheme. */
function themePicker() {
  return {
    open: false,
    activeId: "light",
    scheme: "light",
    /* Bumped on each pb:theme-change to force the list getters to
       re-evaluate. Themes themselves are read LIVE from
       window.ProjectBudget.themes on every render so the dropdown
       never stays empty if main.js loads after the picker's init
       (slow mobile / cold SW cache). */
    _tick: 0,

    init() {
      var self = this;
      this._sync();
      window.addEventListener("pb:theme-change", function () {
        self._tick += 1;
        self._sync();
      });
    },
    _sync() {
      var PB = window.ProjectBudget;
      if (!PB || !PB.currentTheme) return;
      this.activeId = PB.currentTheme();
      var active = this.activeId;
      var def = (PB.themes || []).find(function (t) { return t.id === active; });
      this.scheme = def ? def.scheme : "light";
    },

    /* Read live from window.ProjectBudget — never cache. main.js sets
       window.ProjectBudget.themes during its module init; if the
       picker rendered before that completed, the next open just sees
       the populated list. */
    _allThemes() {
      void this._tick;
      return (window.ProjectBudget && window.ProjectBudget.themes) || [];
    },
    lightThemes() { return this._allThemes().filter(function (t) { return t.scheme === "light"; }); },
    darkThemes()  { return this._allThemes().filter(function (t) { return t.scheme === "dark"; }); },

    quickToggle() {
      if (window.ProjectBudget && window.ProjectBudget.toggleTheme) window.ProjectBudget.toggleTheme();
    },
    pick(id) {
      if (window.ProjectBudget && window.ProjectBudget.applyTheme) window.ProjectBudget.applyTheme(id);
      this.open = false;
    },
  };
}
</script>
