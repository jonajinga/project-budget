<div class="fab-quick-add" x-data="quickAddFab()" x-init="init()">
  <button type="button" class="fab-quick-add__btn"
          @click="open = true"
          x-show="$store.budget.profile"
          x-cloak
          data-touch="compact"
          aria-label="Quick-add transaction"
          data-tip="Add a transaction. Shortcut: press N anywhere outside a field.">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
  </button>

  <div class="modal-backdrop" x-show="open" x-cloak @keydown.escape.window="open = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="fab-quick-add-title"
         @click.outside="open = false">
      <button class="modal__close" type="button" @click="open = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="fab-quick-add-title">Add transaction</h3>
      <form @submit.prevent="submit()">
        {# Outflow / Inflow toggle — the canonical sign indicator
           across every add-transaction surface. Mobile keypads can't
           type a minus sign; this toggle is how the user marks
           direction. Also filters the category dropdown to match. #}
        <div class="txn-type-toggle" role="radiogroup" aria-label="Transaction type" style="margin-bottom: var(--space-sm);">
          <button type="button" class="txn-type-toggle__opt"
                  :class="form.type === 'outflow' ? 'is-active' : ''"
                  :aria-pressed="(form.type === 'outflow').toString()"
                  @click="form.type = 'outflow'; form.categoryId = ''">
            <span aria-hidden="true">−</span> Outflow
          </button>
          <button type="button" class="txn-type-toggle__opt"
                  :class="form.type === 'inflow' ? 'is-active' : ''"
                  :aria-pressed="(form.type === 'inflow').toString()"
                  @click="form.type = 'inflow'; form.categoryId = ''">
            <span aria-hidden="true">+</span> Inflow
          </button>
        </div>
        <div class="form-stack">
          <div class="field">
            <label class="field__label" for="qa-account">Account</label>
            <select class="select" id="qa-account" x-model="form.accountId" required
                    data-tip="Which account this transaction posts to. Choose the account where the money moved (e.g. Checking for a debit-card swipe).">
              <option value="">Select account</option>
              <template x-for="a in openAccounts()" :key="a.id">
                <option :value="a.id" x-text="a.name"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label class="field__label" for="qa-date">Date</label>
            <input class="input" id="qa-date" type="date" x-model="form.date" required
                   data-tip="When the transaction actually occurred. Defaults to today.">
          </div>
          <div class="field" style="position: relative;">
            <label class="field__label" for="qa-payee">Payee</label>
            <input class="input" id="qa-payee" type="text" x-model="form.payeeName"
                   @input="refreshSuggestions()" @focus="refreshSuggestions()"
                   @blur="setTimeout(() => payeeSuggestions = [], 150)"
                   autocomplete="off" placeholder="Trader Joe's, Acme Industries, …"
                   data-tip="Who you paid (or who paid you). Auto-suggests as you type; picking a known payee pre-fills its usual category.">
            <ul class="payee-suggest" x-show="payeeSuggestions.length" x-cloak>
              <template x-for="p in payeeSuggestions" :key="p.id">
                <li>
                  <button type="button" @mousedown.prevent="pickPayee(p)"
                          x-text="p.name + ' (' + p.useCount + ')'"></button>
                </li>
              </template>
            </ul>
          </div>
          <div class="field">
            <label class="field__label" for="qa-amount">Amount</label>
            <input class="input" id="qa-amount" type="text" x-model="form.amount"
                   placeholder="12.34 · or 12+8.99" inputmode="decimal" required
                   data-tip="Enter a positive number — the Outflow / Inflow toggle above sets the sign. Calculator: type expressions like 12.50 + 8.99.">
            <p class="field__hint calc-preview" x-show="calcPreview(form.amount)" x-cloak x-text="calcPreview(form.amount)"></p>
          </div>
          <div class="field">
            <label class="field__label" for="qa-category">Category</label>
            <select class="select" id="qa-category" x-model="form.categoryId"
                    data-tip="Envelope budget category this transaction draws from. Leave uncategorized to assign later from the register.">
              <option value="">(uncategorized)</option>
              <template x-for="c in selectableCategoriesForType(form.type)" :key="c.id">
                <option :value="c.id" x-text="c.name"></option>
              </template>
            </select>
            <p class="field__hint"
               x-show="form.type === 'inflow' && !selectableCategoriesForType('inflow').length" x-cloak>
              No income categories yet — create one in a group marked as "Income".
            </p>
          </div>
          <div class="field">
            <label class="field__label" for="qa-memo">Memo (optional)</label>
            <input class="input" id="qa-memo" type="text" x-model="form.memo"
                   data-tip="Short note for your future self — what the transaction was for, who you split it with, etc.">
          </div>
          <span class="cluster" style="gap: var(--space-2xs); color: var(--fg-muted); align-items: center;">
            <button type="button"
                    class="cleared-toggle"
                    :aria-pressed="form.cleared.toString()"
                    @click="form.cleared = !form.cleared"
                    :data-tip="form.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'">
              <span x-show="form.cleared">&#10003;</span>
            </button>
            <span>Cleared</span>
          </span>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit"
                  data-tip="Add this transaction to the register.">Add transaction</button>
          <button class="btn btn--ghost" type="button" @click="open = false"
                  data-tip="Discard the form and close.">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function quickAddFab() {
  return {
    open: false,
    /* `amount` is always positive; `type` drives the sign at submit
       time so mobile users never need to type a minus. Default
       outflow because that's the common case. */
    form: { accountId: "", payeeName: "", amount: "", categoryId: "", memo: "", cleared: false, date: "", type: "outflow" },
    payeeSuggestions: [],

    init() {
      this.form.date = new Date().toISOString().slice(0, 10);
      var self = this;
      /* Command-palette + future external triggers can open the FAB. */
      document.addEventListener("pb:quick-add-open", function () {
        self.open = true;
        self.$nextTick(function () {
          var input = document.getElementById("qa-amount");
          if (input) input.focus();
        });
      });
    },

    openAccounts() {
      var p = this.$store.budget.profile;
      if (!p) return [];
      return p.accounts.filter(function (a) { return !a.closedAt; })
        .sort(function (a, b) { return a.name.localeCompare(b.name); });
    },
    selectableCategories() {
      var s = this.$store.budget;
      if (!s.profile) return [];
      return s.categoriesFlat().filter(function (c) { return !s.isPaymentCategory(c.id); });
    },
    /* Filter by transaction type: outflow shows expense-group cats,
       inflow shows income-group cats. Mirrors the register form. */
    selectableCategoriesForType(type) {
      var s = this.$store.budget;
      return this.selectableCategories().filter(function (c) {
        var isIncome = s.isIncomeCategory(c.id);
        if (type === "inflow") return isIncome;
        return !isIncome;
      });
    },
    refreshSuggestions() {
      this.payeeSuggestions = this.$store.budget.suggestPayees(this.form.payeeName, 6);
      var match = this.payeeSuggestions.find(function (p) {
        return p.name.toLowerCase() === (this.form.payeeName || "").toLowerCase();
      }.bind(this));
      if (match && match.lastCategoryId && !this.form.categoryId) {
        this.form.categoryId = match.lastCategoryId;
      }
    },
    pickPayee(p) {
      this.form.payeeName = p.name;
      if (p.lastCategoryId && !this.form.categoryId) this.form.categoryId = p.lastCategoryId;
      this.payeeSuggestions = [];
    },
    parseDollars(s) {
      if (s == null || s === "") return 0;
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var clean = String(s).replace(/[$,\s]/g, "").trim();
      if (/^\(.*\)$/.test(clean)) clean = "-" + clean.slice(1, -1);
      var n = Number(clean);
      return isFinite(n) ? Math.round(n * 100) : 0;
    },
    calcPreview(s) { return (window.PBCalc ? window.PBCalc.formatExpressionPreview(s) : ""); },
    submit() {
      if (!this.form.accountId) return;
      /* Toggle wins on sign; raw input is normalised to absolute
         first so a stray minus sign doesn't double-flip the result. */
      var raw = this.parseDollars(this.form.amount);
      var signed = Math.abs(raw) * (this.form.type === "inflow" ? 1 : -1);
      this.$store.budget.addTransaction({
        accountId: this.form.accountId,
        date: this.form.date,
        payeeName: this.form.payeeName,
        categoryId: this.form.categoryId || null,
        amount: signed,
        memo: this.form.memo,
        cleared: this.form.cleared,
      });
      this.$store.budget.pushToast("Transaction added.");
      var keepAccount = this.form.accountId;
      var keepType = this.form.type;
      this.form = {
        accountId: keepAccount, payeeName: "", amount: "",
        categoryId: "", memo: "", cleared: false,
        date: new Date().toISOString().slice(0, 10),
        type: keepType,
      };
      this.payeeSuggestions = [];
      this.open = false;
    },
  };
}
</script>
