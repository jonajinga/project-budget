<div class="search-modal" id="search-modal" hidden role="dialog" aria-modal="true" aria-label="Command palette and search">
  <div class="search-modal__backdrop" data-search-close></div>
  <div class="search-modal__panel">
    <div class="search-modal__head">
      <svg class="search-modal__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input class="search-modal__input" type="search" id="site-search-input"
             placeholder="Type a command, page, or search term…"
             aria-label="Command palette query"
             autocomplete="off">
      <button type="button" class="search-modal__close" data-search-close aria-label="Close">&times;</button>
    </div>
    <div class="search-modal__body">
      <p class="search-modal__hint" id="search-hint">
        Type a command (e.g. "budget", "add transaction", "switch profile") or "?" then a query to search the docs. Press <kbd>Esc</kbd> to close, <kbd>Ctrl/Cmd&nbsp;+&nbsp;K</kbd> to open from anywhere.
      </p>
      <section class="search-modal__section" id="search-actions-section" hidden>
        <p class="search-modal__section-label">Actions</p>
        <ul class="search-modal__results" id="search-actions"></ul>
      </section>
      <section class="search-modal__section" id="search-docs-section" hidden>
        <p class="search-modal__section-label">Docs &amp; pages</p>
        <ul class="search-modal__results" id="search-results"></ul>
      </section>
    </div>
  </div>
</div>
