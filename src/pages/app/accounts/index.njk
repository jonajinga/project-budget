---
layout: layouts/app.njk
title: "Accounts"
description: "Cash, checking, savings, credit cards, and off-budget tracking accounts."
permalink: /app/accounts/
eleventyExcludeFromCollections: true
---
{% from "partials/overflow-menu.njk" import overflow %}
<div class="app-page" x-data="accountsView()">
  <header class="app-page__header">
    <h1 class="app-page__title">Accounts</h1>
    <div class="cluster">
      <button class="btn btn--icon" type="button"
              @click="showHelp = true"
              aria-label="About accounts"
              data-tip="How on-budget vs tracking accounts work, plus reorder tips.">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="8"/><line x1="12" y1="12" x2="12" y2="16"/></svg>
      </button>
      <button class="btn btn--icon" type="button"
              @click="showGroup = true"
              aria-label="New group"
              data-tip="New group — organizes the sidebar (Daily, Reserves, Debts, Investments). Drag accounts into them.">
        {# Lucide "folder-plus" — folder with + glyph. #}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          <line x1="12" y1="11" x2="12" y2="17"/>
          <line x1="9" y1="14" x2="15" y2="14"/>
        </svg>
      </button>
      <button class="btn btn--icon" type="button"
              @click="showAccount = true"
              aria-label="Add account"
              data-tip="Add a new account (cash, checking, savings, credit card, or tracking).">
        {# Lucide "plus" — primary add affordance, accent-tinted so it
           still reads as the headline action even at icon size. #}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--accent);">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>
  </header>

  <p class="app-page__lead" x-show="!$store.budget.profile" x-cloak>
    Create or switch to a profile before adding accounts.
  </p>

  <p class="app-page__lead" x-show="$store.budget.profile && !$store.budget.profile.accounts.length" x-cloak>
    No accounts yet. Start with your everyday checking account, then add savings, credit cards, and any tracking accounts for investments or loans.
  </p>

  {# Info / help modal — opened by the (i) icon in the header. #}
  <div class="modal-backdrop" x-show="showHelp" x-cloak @keydown.escape.window="showHelp = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="acct-help-title" @click.outside="showHelp = false">
      <button class="modal__close" type="button" @click="showHelp = false" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="acct-help-title">About accounts</h3>
      <div class="prose">
        <p>Cash, checking, savings, and credit-card accounts are <strong>on-budget</strong>: every dollar in them needs to be assigned to a category. Investment and loan accounts are <strong>tracking</strong>: they count toward net worth but do not affect Ready to Assign.</p>
        <p><strong>Reorder:</strong> use the Move up / Move down items in each row's kebab menu (⋮).</p>
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="showHelp = false">Got it</button>
      </div>
    </div>
  </div>

  {# Stat cards. Live snapshot of every on-budget + tracking balance,
     account count, and total net worth. Reuses .rec-summary chrome so
     the visual rhythm matches /app/scheduled/ and the budget page. #}
  {# Tile order tells a story: count → in-budget → tracked → excluded
     → working net worth → all-in (net + excluded). The 6col modifier
     fires only when accounts are flagged excluded; otherwise it
     stays a tidy 4-up. #}
  <section class="rec-summary"
           :class="excludedCount() > 0 ? 'rec-summary--6col' : ''"
           x-show="$store.budget.profile && $store.budget.profile.accounts.length" x-cloak>
    <div class="rec-summary__tile rec-summary__tile--accent" data-tip="Total accounts in this profile (on-budget + tracking + excluded).">
      <span class="rec-summary__label">Accounts</span>
      <span class="rec-summary__value" x-text="accountCount()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--inflow" data-tip="Sum of every on-budget account balance (cash, checking, savings, credit cards).">
      <span class="rec-summary__label">On budget</span>
      <span class="rec-summary__value"
            :class="$store.budget.onBudgetTotal() < 0 ? 'amount--outflow' : ''"
            x-text="formatCents($store.budget.onBudgetTotal())"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--accent" data-tip="Sum of tracking assets minus tracking liabilities (investments, loans). Excluded accounts are skipped.">
      <span class="rec-summary__label">Tracking</span>
      <span class="rec-summary__value"
            :class="trackingNet() < 0 ? 'amount--outflow' : ''"
            x-text="formatCents(trackingNet())"></span>
    </div>
    {# Excluded-from-net-worth roll-up — shown only when at least one
       account in the profile has the flag, so households without any
       529s / escrow / RSU accounts don't see a confusing $0 tile. #}
    <div class="rec-summary__tile rec-summary__tile--accent"
         x-show="excludedCount() > 0" x-cloak
         data-tip="Sum of every account flagged exclude-from-net-worth — kids' 529s, escrow accounts, employer-held RSUs. Tracked + visible but not counted in the Net worth tile.">
      <span class="rec-summary__label">Excluded from NW</span>
      <span class="rec-summary__value"
            :class="excludedTotal() < 0 ? 'amount--outflow' : ''"
            x-text="formatCents(excludedTotal())"></span>
      <span style="font-size: var(--fs-xs); color: var(--fg-muted); margin-top: 2px; display: block;"
            x-text="excludedCount() + (excludedCount() === 1 ? ' account' : ' accounts')"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--net" data-tip="Net worth across every account (excluded accounts skipped).">
      <span class="rec-summary__label">Net worth</span>
      <span class="rec-summary__value"
            :class="$store.budget.netWorth() < 0 ? 'amount--outflow' : 'amount--inflow'"
            x-text="formatCents($store.budget.netWorth())"></span>
    </div>
    {# All-in total = Net worth + Excluded. Same render gate as the
       Excluded tile so the row stays a clean 4-up when no accounts
       are flagged out. #}
    <div class="rec-summary__tile rec-summary__tile--inflow"
         x-show="excludedCount() > 0" x-cloak
         data-tip="Net worth plus every excluded balance. The full asset picture — useful when you want to see total wealth regardless of whose money it's earmarked for.">
      <span class="rec-summary__label">Net + excluded</span>
      <span class="rec-summary__value"
            :class="($store.budget.netWorth() + excludedTotal()) < 0 ? 'amount--outflow' : 'amount--inflow'"
            x-text="formatCents($store.budget.netWorth() + excludedTotal())"></span>
    </div>
  </section>

  <div data-sortable-list data-sortable-kind="acct-group">
    <template x-for="(group, gIdx) in $store.budget.accountGroupsView()" :key="group.group ? group.group.id : '__ungrouped'">
      <section class="card cat-group"
               :data-sortable-id="group.group?.id"
               style="margin-bottom: var(--space-md);">
        <header style="display: flex; align-items: center; justify-content: space-between; gap: var(--space-2xs); margin-bottom: var(--space-sm); flex-wrap: nowrap;">
          <div class="cluster" style="gap: var(--space-2xs); min-width: 0; flex: 1 1 auto;">
            <button type="button" class="group-toggle"
                    @click="group.group && $store.budget.toggleAccountGroupCollapsed(group.group.id)"
                    :aria-expanded="group.group && !$store.budget.isAcctGroupCollapsed(group.group.id) ? 'true' : 'false'"
                    :disabled="!group.group">
              <span class="group-toggle__chevron" :class="group.group && $store.budget.isAcctGroupCollapsed(group.group.id) ? 'is-collapsed' : ''" aria-hidden="true">&#9662;</span>
              <h2 class="card__title" style="margin: 0;" x-text="group.group ? group.group.name : 'Other accounts'"></h2>
              <span class="group-toggle__count"
                    x-text="group.accounts.length + (group.accounts.length === 1 ? ' account' : ' accounts')"></span>
              <span class="group-toggle__total"
                    :class="groupTotalCents(group) < 0 ? 'amount--outflow' : ''"
                    x-text="formatCents(groupTotalCents(group))"
                    :data-tip="'Total balance across ' + group.accounts.length + ' account' + (group.accounts.length === 1 ? '' : 's') + ' in this group.'"></span>
              {# Excluded-from-net-worth subtotal — only renders when at
                 least one account in the group has the flag, so groups
                 without any 529 / escrow / RSU accounts stay clean. #}
              <span class="group-toggle__total group-toggle__total--excluded"
                    x-show="groupExcludedCents(group) !== 0" x-cloak
                    x-text="'excl. ' + formatCents(groupExcludedCents(group))"
                    :data-tip="'Of the total above, ' + formatCents(groupExcludedCents(group)) + ' belongs to accounts flagged exclude-from-net-worth and is not counted in the dashboard net-worth roll-up.'"></span>
            </button>
          </div>
          {# 5 group-level actions (Add / Move up / Move down / Rename
             / Remove) collapse into one kebab so the header row never
             wraps on phones. Same pattern used on the budget page
             group headers. #}
          <div x-show="group.group" x-cloak>
            {% call overflow(label="Group actions") %}
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        @click="open = false; openAddForGroup(group.group.id)">+ Add account…</button>
              </li>
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        @click="open = false; PBDialog.prompt({ title: 'Rename account group', label: 'Group name', defaultValue: group.group.name, okLabel: 'Rename' }).then(n => { if (n) $store.budget.renameAccountGroup(group.group.id, n); })">Rename group…</button>
              </li>
              <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        :disabled="gIdx === 0"
                        @click="open = false; $store.budget.moveAccountGroup(group.group.id, Math.max(0, gIdx - 1))">Move group up</button>
              </li>
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        :disabled="gIdx >= ($store.budget.profile.accountGroups.length - 1)"
                        @click="open = false; $store.budget.moveAccountGroup(group.group.id, gIdx + 1)">Move group down</button>
              </li>
              <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                        @click="open = false; PBDialog.confirm({ title: 'Remove this account group?', message: 'Accounts inside this group will be unassigned but kept. Their balances and transaction history stay intact.', confirmLabel: 'Remove group', danger: true }).then(ok => { if (ok) $store.budget.deleteAccountGroup(group.group.id) })">Remove group</button>
              </li>
            {% endcall %}
          </div>
        </header>

        <table class="table has-card-fallback" x-show="!(group.group && $store.budget.isAcctGroupCollapsed(group.group.id))" x-cloak>
          <thead>
            <tr>
              <th scope="col">Name</th>
              <th scope="col">Type</th>
              <th scope="col" class="num">Balance</th>
              <th scope="col" class="num"></th>
            </tr>
          </thead>
          <tbody>
            <template x-for="(a, aIdx) in group.accounts" :key="a.id">
              <tr class="cat-row">
                <td>
                  <a :href="'/app/register/?account=' + a.id" x-text="a.name"></a>
                  <span x-show="a.excludeFromNetWorth" x-cloak class="badge"
                        style="margin-left: var(--space-2xs);"
                        data-tip="This account is tracked + visible but its balance is skipped when computing net worth.">excluded</span>
                </td>
                <td x-text="$store.budget.ACCOUNT_TYPES.find(t => t.value === a.type)?.label || a.type"></td>
                <td class="num" :class="$store.budget.accountBalance(a.id) < 0 ? 'amount--outflow' : ''"
                    x-text="formatCents($store.budget.accountBalance(a.id))"></td>
                <td class="num" @click.stop>
                  {# All per-row actions live in the kebab at every
                     viewport. No inline buttons. #}
                  {% call overflow(label="Account actions") %}
                    <li role="none">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              @click="open = false; openReconcile(a)">Reconcile…</button>
                    </li>
                    <li role="none">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              @click="open = false; openEdit(a)">Edit…</button>
                    </li>
                    <li role="none">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              :disabled="aIdx === 0"
                              @click="open = false; $store.budget.moveAccount(a.id, group.group?.id, Math.max(0, aIdx - 1))">Move up</button>
                    </li>
                    <li role="none">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              :disabled="aIdx >= (group.accounts.length - 1)"
                              @click="open = false; $store.budget.moveAccount(a.id, group.group?.id, aIdx + 1)">Move down</button>
                    </li>
                    <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
                    <li role="none">
                      <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                              @click="open = false; startDelete(a)">Delete account</button>
                    </li>
                  {% endcall %}
                </td>
              </tr>
            </template>
          </tbody>
        </table>

        {# Mobile account cards — table hides at <600px. Each card: account
           name (linked to register) + type badge · balance · kebab with
           Edit / Move up / Move down / Delete. Drag handles are dropped
           on touch since touch + drag is awkward. #}
        <ul class="data-cards acct-cards"
            x-show="!(group.group && $store.budget.isAcctGroupCollapsed(group.group.id))" x-cloak
            data-no-tippy>
          <template x-for="(a, aIdx) in group.accounts" :key="a.id">
            <li class="data-card">
              <div class="data-card__primary">
                <a class="data-card__title" :href="'/app/register/?account=' + a.id" x-text="a.name"></a>
                <span class="data-card__sub">
                  <span x-text="$store.budget.ACCOUNT_TYPES.find(t => t.value === a.type)?.label || a.type"></span>
                  <span x-show="a.excludeFromNetWorth" x-cloak> · excluded from net worth</span>
                </span>
              </div>
              <span class="data-card__amount"
                    :class="$store.budget.accountBalance(a.id) < 0 ? 'amount--outflow' : ''"
                    x-text="formatCents($store.budget.accountBalance(a.id))"></span>
              {% call overflow(label="Account actions") %}
                <li role="none">
                  <button type="button" role="menuitem" class="overflow-menu__item"
                          @click="open = false; openReconcile(a)">Reconcile…</button>
                </li>
                <li role="none">
                  <button type="button" role="menuitem" class="overflow-menu__item"
                          @click="open = false; openEdit(a)">Edit…</button>
                </li>
                <li role="none">
                  <button type="button" role="menuitem" class="overflow-menu__item"
                          :disabled="aIdx === 0"
                          @click="open = false; $store.budget.moveAccount(a.id, group.group?.id, Math.max(0, aIdx - 1))">Move up</button>
                </li>
                <li role="none">
                  <button type="button" role="menuitem" class="overflow-menu__item"
                          :disabled="aIdx >= (group.accounts.length - 1)"
                          @click="open = false; $store.budget.moveAccount(a.id, group.group?.id, aIdx + 1)">Move down</button>
                </li>
                <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
                <li role="none">
                  <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                          @click="open = false; startDelete(a)">Delete account</button>
                </li>
              {% endcall %}
            </li>
          </template>
        </ul>
      </section>
    </template>
  </div>

  {# Inline disclosure replaces the old "About accounts" modal —
     same content, but no modal-open click for the user, no full
     dialog stealing the viewport on mobile. #}

  {# Add-account modal #}
  <div class="modal-backdrop" x-show="showAccount" x-cloak @keydown.escape.window="showAccount = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showAccount = false">
      <button class="modal__close" type="button" @click="showAccount = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title">Add account</h3>
      <form @submit.prevent="submitAccount()">
        <div class="form-stack">
          <div class="field">
            <label class="field__label" for="acct-name">Account name</label>
            <input class="input" id="acct-name" type="text" x-model="newAccount.name" required autofocus
                   data-tip="A short, recognizable name — what you'd call this account in conversation (e.g. 'Chase Checking', 'Amex Gold').">
          </div>
          <div class="field">
            <label class="field__label" for="acct-type">Type</label>
            <select class="select" id="acct-type" x-model="newAccount.type"
                    data-tip="On-budget: checking, savings, cash, credit card — affect Ready to Assign. Tracking: investments and loans — affect net worth only.">
              <template x-for="t in $store.budget.ACCOUNT_TYPES" :key="t.value">
                <option :value="t.value" x-text="t.label"></option>
              </template>
            </select>
            <p class="field__hint">Credit-card accounts auto-create a paired payment category in your budget.</p>
          </div>
          <div class="field">
            <label class="field__label" for="acct-group">Group</label>
            <select class="select" id="acct-group" x-model="newAccount.groupId"
                    data-tip="Groups organize the sidebar (Daily, Reserves, Debts, Investments). Leave as '(no group)' to add it later.">
              <option value="">(no group)</option>
              <template x-for="g in $store.budget.profile?.accountGroups || []" :key="g.id">
                <option :value="g.id" x-text="g.name"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label class="field__label" for="acct-opening">Opening balance</label>
            <input class="input" id="acct-opening" type="text" x-model="newAccount.openingBalance"
                   placeholder="0.00" inputmode="decimal"
                   data-tip="Today's balance for the account. Calculator works here — '1234.56' or '500+700' both accepted.">
            <p class="field__hint">For credit cards and loans, enter the current balance you owe as a negative number (e.g. -1234.56).</p>
          </div>
          <div class="field">
            <label class="acct-exclude">
              <input type="checkbox" x-model="newAccount.excludeFromNetWorth">
              <span>
                <strong>Exclude from net worth</strong>
                <span class="acct-exclude__hint">Keep the balance visible in the sidebar but skip it when computing net worth. Common for kids' 529s, escrow accounts, employer-held RSUs you can't liquidate.</span>
              </span>
            </label>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Create account</button>
          <button class="btn btn--ghost" type="button" @click="showAccount = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Edit-account modal #}
  <div class="modal-backdrop" x-show="editId" x-cloak @keydown.escape.window="editId = null">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="editId = null">
      <button class="modal__close" type="button" @click="editId = null" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title">Edit account</h3>
      <form @submit.prevent="saveEdit()">
        <div class="form-stack">
          <div class="field">
            <label class="field__label" for="edit-name">Name</label>
            <input class="input" id="edit-name" type="text" x-model="editForm.name" required
                   data-tip="Renaming an account updates it everywhere — sidebar, register, reports, and recurring templates.">
          </div>
          <div class="field">
            <label class="field__label" for="edit-type">Type</label>
            <select class="select" id="edit-type" x-model="editForm.type"
                    data-tip="Switching to credit card auto-creates a paired payment category. Switching away removes it.">
              <template x-for="t in $store.budget.ACCOUNT_TYPES" :key="t.value">
                <option :value="t.value" x-text="t.label"></option>
              </template>
            </select>
            <p class="field__hint">Changing the type also flips whether the account counts toward Ready to Assign.</p>
          </div>
          <div class="field">
            <label class="field__label" for="edit-group">Group</label>
            <select class="select" id="edit-group" x-model="editForm.groupId"
                    data-tip="Move this account into a different sidebar group, or set '(no group)' to leave it ungrouped.">
              <option value="">(no group)</option>
              <template x-for="g in $store.budget.profile?.accountGroups || []" :key="g.id">
                <option :value="g.id" x-text="g.name"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label class="field__label" for="edit-opening">Opening balance</label>
            <input class="input" id="edit-opening" type="text" x-model="editForm.openingBalance"
                   placeholder="0.00" inputmode="decimal"
                   data-tip="Calculator works here — type '8500.00' or '8000 + 500' and it evaluates on save. Changes shift every historical balance by the difference.">
            <p class="field__hint">Changing this shifts every historical and current balance by the difference. Take a manual snapshot first if you're not sure.</p>
          </div>
          <div class="field">
            <label class="acct-exclude">
              <input type="checkbox" x-model="editForm.excludeFromNetWorth">
              <span>
                <strong>Exclude from net worth</strong>
                <span class="acct-exclude__hint">Keep the balance visible in the sidebar but skip it when computing net worth. Common for kids' 529s, escrow accounts, employer-held RSUs you can't liquidate.</span>
              </span>
            </label>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit"
                  data-tip="Apply name, type, group, and opening-balance changes.">Save changes</button>
          <button class="btn btn--ghost" type="button" @click="editId = null"
                  data-tip="Discard changes and close the dialog.">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Add-group modal #}
  <div class="modal-backdrop" x-show="showGroup" x-cloak @keydown.escape.window="showGroup = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showGroup = false">
      <button class="modal__close" type="button" @click="showGroup = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">New account group</h3>
      <p style="color: var(--fg-muted);">
        Groups organize accounts in the sidebar — for example, Daily, Reserves, Debts, Investments.
      </p>
      <form @submit.prevent="submitGroup()">
        <div class="field" style="margin-top: var(--space-sm);">
          <label class="field__label" for="grp-name">Group name</label>
          <input class="input" id="grp-name" type="text" x-model="newGroup.name" required autofocus>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Create group</button>
          <button class="btn btn--ghost" type="button" @click="showGroup = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Delete account confirm #}
  <div class="modal-backdrop" x-show="deleteAccountId" x-cloak @keydown.escape.window="deleteAccountId = null">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="deleteAccountId = null">
      <button class="modal__close" type="button" @click="deleteAccountId = null" aria-label="Close">&times;</button>
      <h3 class="modal__title">Delete account</h3>
      <p style="color: var(--fg-muted);">
        Deleting an account also removes every transaction in it. There is no undo for account deletion (profile-level backups still cover this, though).
      </p>
      <p style="margin-top: var(--space-sm);">
        To confirm, type the account name exactly:
        <strong x-text="$store.budget.findAccount(deleteAccountId)?.name"></strong>
      </p>
      <form @submit.prevent="doDelete()">
        <div class="field" style="margin-top: var(--space-sm);">
          <input class="input" type="text" x-model="deleteAccountValue" required autofocus>
        </div>
        <div class="form-actions">
          <button class="btn btn--danger" type="submit">Delete account</button>
          <button class="btn btn--ghost" type="button" @click="deleteAccountId = null">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Reconcile modal — opened by the row kebab → Reconcile…. A 3-step
     wizard: 1) type the statement ending balance, 2) review the diff
     and tick cleared rows until it matches, 3) confirm. Replaces the
     standalone /app/quick-reconcile/ page. #}
  <div class="modal-backdrop" x-show="reconcile.acctId" x-cloak
       @keydown.escape.window="closeReconcile()">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="rec-title"
         @click.outside="closeReconcile()" style="max-width: 720px;">
      <button class="modal__close" type="button" @click="closeReconcile()" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="rec-title">
        Reconcile <span x-text="reconcileAccountName()"></span>
      </h3>

      {# Step 1 — type ending balance #}
      <div x-show="reconcile.step === 1" x-cloak>
        <p style="color: var(--fg-muted);">
          Currently cleared: <strong x-text="formatCents(reconcileClearedBalance())"></strong>.
          Type the ending balance from your statement to see the difference.
        </p>
        <form @submit.prevent="reconcileCheckDiff()" class="form-stack" style="margin-top: var(--space-sm);">
          <div class="field">
            <label class="field__label" for="rec-ending">Statement ending balance</label>
            <input class="input" id="rec-ending" type="text" inputmode="decimal"
                   x-model="reconcile.endingInput"
                   placeholder="0.00" autofocus required>
            <p class="field__hint">Calculator works here — '1234.56' or '500 + 700'.</p>
          </div>
          <div class="form-actions">
            <button class="btn btn--primary" type="submit">Check difference</button>
            <button class="btn btn--ghost" type="button" @click="closeReconcile()">Cancel</button>
          </div>
        </form>
      </div>

      {# Step 2 — diff + pending cleared rows #}
      <div x-show="reconcile.step === 2" x-cloak>
        <div class="qr-diff-grid">
          <div>
            <p class="qr-diff-label">Cleared in app</p>
            <p class="qr-diff-value" x-text="formatCents(reconcileClearedBalance())"></p>
          </div>
          <div>
            <p class="qr-diff-label">Statement says</p>
            <p class="qr-diff-value" x-text="formatCents(reconcile.endingCents)"></p>
          </div>
          <div>
            <p class="qr-diff-label">Difference</p>
            <p class="qr-diff-value"
               :class="reconcileDiff() === 0 ? 'amount--inflow' : 'amount--outflow'"
               x-text="formatCents(reconcileDiff())"></p>
          </div>
        </div>

        <p x-show="reconcileDiff() === 0" x-cloak
           style="margin-top: var(--space-md); color: var(--ok); font-weight: 700;">
          Balances match. Mark every cleared row below as reconciled to finish.
        </p>
        <p x-show="reconcileDiff() !== 0" x-cloak
           style="margin-top: var(--space-md); color: var(--danger); font-weight: 700;">
          The numbers don't match. Tick / untick the <em>cleared</em> column on the rows below to find the gap.
        </p>

        <h4 style="margin-top: var(--space-md);">
          Cleared but not reconciled (<span x-text="reconcilePendingRows().length"></span>)
        </h4>
        <table class="table">
          <thead>
            <tr>
              <th>Date</th><th>Payee</th><th>Category</th>
              <th class="num">Amount</th><th class="num">Cleared</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="t in reconcilePendingRows()" :key="t.id">
              <tr>
                <td x-text="t.date"></td>
                <td x-text="$store.budget.payeeName(t.payeeId) || '—'"></td>
                <td x-text="$store.budget.categoryName(t.categoryId) || 'Uncategorized'"></td>
                <td class="num"
                    :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                    x-text="formatCents(t.amount)"></td>
                <td class="num">
                  <button type="button" class="cleared-toggle"
                          :aria-pressed="t.cleared.toString()"
                          @click="reconcileToggleCleared(t.id)">
                    <span x-show="t.cleared" aria-hidden="true">&#10003;</span>
                  </button>
                </td>
              </tr>
            </template>
            <tr x-show="!reconcilePendingRows().length" x-cloak>
              <td colspan="5" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No pending cleared rows.</td>
            </tr>
          </tbody>
        </table>

        <div class="form-actions">
          <button class="btn btn--primary" type="button"
                  @click="reconcileFinish()"
                  :disabled="reconcileDiff() !== 0">Mark all reconciled</button>
          <button class="btn btn--ghost" type="button" @click="reconcile.step = 1">Edit ending balance</button>
        </div>
      </div>

      {# Step 3 — done #}
      <div x-show="reconcile.step === 3" x-cloak class="prose">
        <p>Every cleared row in <strong x-text="reconcileAccountName()"></strong> through today is reconciled.</p>
        <div class="form-actions">
          <button class="btn btn--primary" type="button" @click="closeReconcile()">Done</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function accountsView() {
  return {
    showHelp: false,
    showAccount: false,
    showGroup: false,
    editId: null,
    editForm: { name: "", type: "checking", groupId: "", openingBalance: "", excludeFromNetWorth: false },
    deleteAccountId: null,
    deleteAccountValue: "",
    newAccount: { name: "", type: "checking", groupId: "", openingBalance: "", excludeFromNetWorth: false },
    newGroup: { name: "" },
    /* Reconcile flow — replaces the standalone /app/quick-reconcile/
       page. step 1 = type the statement ending balance; step 2 =
       review diff + tick cleared rows; step 3 = done. acctId is set
       by the kebab → Reconcile… action. */
    reconcile: { acctId: null, step: 1, endingInput: "", endingCents: 0 },

    /* Drag/drop handled by SortableJS via
       /assets/js/ui/sortable-bind.js. Markup carries data-sortable-*. */

    resetNewAccount() { this.newAccount = { name: "", type: "checking", groupId: "", openingBalance: "", excludeFromNetWorth: false }; },
    resetNewGroup()   { this.newGroup   = { name: "" }; },

    parseDollars(s) {
      if (s == null || s === "") return 0;
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var clean = String(s).replace(/[$,\s]/g, "").trim();
      if (/^\(.*\)$/.test(clean)) clean = "-" + clean.slice(1, -1);
      var n = Number(clean);
      return isFinite(n) ? Math.round(n * 100) : 0;
    },
    formatCents(c) {
      return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD" });
    },

    /* ---- Stat-card aggregates ---- */
    accountCount() {
      void this.$store.budget._listVersion;
      return this.$store.budget.profile ? this.$store.budget.profile.accounts.length : 0;
    },
    trackingNet() {
      void this.$store.budget._listVersion;
      var s = this.$store.budget;
      if (!s.profile) return 0;
      /* trackingLiabilityTotal returns a SIGNED sum (negative for
         money owed), so add — subtracting a negative inflates the
         net. Bug fix: prior `- s.trackingLiabilityTotal()` made an
         $18.5k auto loan show as +$18.5k instead of -$18.5k, so
         Tracking read $143.5k instead of $106.5k for a profile
         whose actual non-excluded tracking net is 401k − auto loan. */
      return s.trackingAssetTotal() + s.trackingLiabilityTotal();
    },
    /* Sum of every account flagged excludeFromNetWorth across the
       whole profile. Drives the "Excluded from NW" stat tile so the
       roll-up sitting outside Net Worth is visible at a glance. */
    excludedTotal() {
      void this.$store.budget._listVersion;
      var s = this.$store.budget;
      if (!s.profile) return 0;
      var sum = 0;
      s.profile.accounts.forEach(function (a) {
        if (a.closedAt) return;
        if (!a.excludeFromNetWorth) return;
        sum += s.accountBalance(a.id);
      });
      return sum;
    },
    excludedCount() {
      void this.$store.budget._listVersion;
      var s = this.$store.budget;
      if (!s.profile) return 0;
      return s.profile.accounts.filter(function (a) {
        return !a.closedAt && a.excludeFromNetWorth;
      }).length;
    },
    /* Sum of every account balance in a single group. Used to surface
       per-group totals in the header so collapsed groups still convey
       their net value at a glance. */
    groupTotalCents(group) {
      void this.$store.budget._listVersion;
      if (!group || !group.accounts) return 0;
      var s = this.$store.budget;
      var sum = 0;
      for (var i = 0; i < group.accounts.length; i++) {
        sum += s.accountBalance(group.accounts[i].id);
      }
      return sum;
    },
    /* Sum of accounts in the group flagged excludeFromNetWorth so
       users can see how much of the group total is sitting outside
       their net-worth roll-up (529s, escrow, etc.). Returns 0 when
       no excluded accounts exist so the badge stays hidden. */
    groupExcludedCents(group) {
      void this.$store.budget._listVersion;
      if (!group || !group.accounts) return 0;
      var s = this.$store.budget;
      var sum = 0;
      for (var i = 0; i < group.accounts.length; i++) {
        var a = group.accounts[i];
        if (!a.excludeFromNetWorth) continue;
        sum += s.accountBalance(a.id);
      }
      return sum;
    },
    /* Open the Add-account modal with the group preselected so users
       can drop a new account straight into the right bucket from the
       group header instead of picking from the dropdown by hand. */
    openAddForGroup(groupId) {
      this.resetNewAccount();
      this.newAccount.groupId = groupId || "";
      this.showAccount = true;
    },

    submitAccount() {
      this.$store.budget.addAccount({
        name: this.newAccount.name,
        type: this.newAccount.type,
        groupId: this.newAccount.groupId || null,
        openingBalance: this.parseDollars(this.newAccount.openingBalance),
        excludeFromNetWorth: !!this.newAccount.excludeFromNetWorth,
      });
      this.resetNewAccount();
      this.showAccount = false;
    },
    submitGroup() {
      this.$store.budget.addAccountGroup(this.newGroup.name);
      this.resetNewGroup();
      this.showGroup = false;
    },
    openEdit(a) {
      this.editId = a.id;
      this.editForm = {
        name: a.name,
        type: a.type,
        groupId: a.groupId || "",
        openingBalance: ((a.openingBalance || 0) / 100).toFixed(2),
        excludeFromNetWorth: !!a.excludeFromNetWorth,
      };
    },
    saveEdit() {
      if (!this.editId) return;
      this.$store.budget.updateAccount(this.editId, {
        name: this.editForm.name,
        type: this.editForm.type,
        groupId: this.editForm.groupId || null,
        openingBalance: this.parseDollars(this.editForm.openingBalance),
        excludeFromNetWorth: !!this.editForm.excludeFromNetWorth,
      });
      this.editId = null;
    },
    startDelete(a) { this.deleteAccountId = a.id; this.deleteAccountValue = ""; },
    doDelete() {
      if (!this.deleteAccountId) return;
      if (this.$store.budget.deleteAccount(this.deleteAccountId, this.deleteAccountValue)) {
        this.deleteAccountId = null;
      }
    },

    /* ---- Reconcile flow (moved from /app/quick-reconcile/) ---- */
    openReconcile(a) {
      this.reconcile = { acctId: a.id, step: 1, endingInput: "", endingCents: 0 };
    },
    closeReconcile() {
      this.reconcile = { acctId: null, step: 1, endingInput: "", endingCents: 0 };
    },
    reconcileAccountName() {
      var a = this.$store.budget.findAccount(this.reconcile.acctId);
      return a ? a.name : "";
    },
    reconcileClearedBalance() {
      void this.$store.budget._listVersion;
      var id = this.reconcile.acctId;
      var p = this.$store.budget.profile;
      if (!p || !id) return 0;
      var a = this.$store.budget.findAccount(id);
      var sum = a ? (a.openingBalance || 0) : 0;
      p.transactions.forEach(function (t) {
        if (t.accountId !== id) return;
        if (!t.cleared) return;
        sum += t.amount;
      });
      return sum;
    },
    reconcileCheckDiff() {
      this.reconcile.endingCents = this.parseDollars(this.reconcile.endingInput);
      this.reconcile.step = 2;
    },
    reconcileDiff() {
      return this.reconcile.endingCents - this.reconcileClearedBalance();
    },
    reconcilePendingRows() {
      void this.$store.budget._listVersion;
      var id = this.reconcile.acctId;
      var p = this.$store.budget.profile;
      if (!p || !id) return [];
      return p.transactions
        .filter(function (t) { return t.accountId === id && t.cleared && !t.reconciled; })
        .sort(function (a, b) { return b.date.localeCompare(a.date); });
    },
    reconcileToggleCleared(txnId) {
      var t = this.$store.budget.profile.transactions.find(function (x) { return x.id === txnId; });
      if (t) this.$store.budget.updateTransaction(txnId, { cleared: !t.cleared });
    },
    reconcileFinish() {
      var self = this;
      var rows = this.reconcilePendingRows();
      rows.forEach(function (t) {
        self.$store.budget.updateTransaction(t.id, { reconciled: true });
      });
      this.reconcile.step = 3;
      this.$store.budget.pushToast("Reconciled " + rows.length + " row" + (rows.length === 1 ? "" : "s") + ".");
    },

  };
}
</script>

<style>
  /* Align the per-row kebab with the group-header kebab. The header
     kebab sits at the card's inner right edge; per-row kebabs were
     ~12px to the left because of the .table cell's default right
     padding. Drop the last-cell padding-right so both kebabs share
     the same X coordinate. */
  .cat-group .table th:last-child,
  .cat-group .table td:last-child {
    padding-right: 0;
    width: 1%;
    white-space: nowrap;
  }
  .cat-group .table td:last-child > .overflow-menu {
    margin-left: auto;
    display: inline-flex;
  }

  /* Shared diff-grid for the inline reconcile modal — three big tiles
     showing cleared / statement / difference side by side. Stacks
     to one column on phones. */
  .qr-diff-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-md); margin-top: var(--space-md); }
  @media (max-width: 599px) { .qr-diff-grid { grid-template-columns: 1fr; } }
  .qr-diff-grid > div { padding: var(--space-md); background: var(--bg-elevated); border: 1px solid var(--border-soft); border-radius: var(--radius-input); }
  .qr-diff-label { margin: 0; font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg-muted); font-weight: 700; }
  .qr-diff-value { margin: var(--space-2xs) 0 0; font-family: var(--font-display); font-size: var(--fs-xl); font-variant-numeric: tabular-nums; }
</style>
