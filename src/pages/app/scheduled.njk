---
layout: layouts/app.njk
title: "Recurring"
description: "Manage recurring transactions: edit, post on demand, skip, or remove."
permalink: /app/scheduled/
eleventyExcludeFromCollections: true
---
{% from "partials/icon-trash.njk" import iconTrash %}
{% from "partials/overflow-menu.njk" import overflow %}
<div class="app-page" x-data="scheduledView()" x-init="init()">
  <header class="app-page__header">
    <h1 class="app-page__title">Recurring transactions</h1>
    <div class="cluster">
      <button class="btn btn--icon" type="button"
              @click="showHelp = true"
              aria-label="About recurring transactions"
              data-tip="How templates, frequencies, and the approval queue work.">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="8"/><line x1="12" y1="12" x2="12" y2="16"/></svg>
      </button>
      <button class="btn btn--primary" type="button" @click="openCreate()" :disabled="!$store.budget.profile">+ Add recurring</button>
    </div>
  </header>

  {# Info / help modal — opened by the (i) icon in the header. #}
  <div class="modal-backdrop" x-show="showHelp" x-cloak @keydown.escape.window="showHelp = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="rec-help-title" @click.outside="showHelp = false">
      <button class="modal__close" type="button" @click="showHelp = false" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="rec-help-title">About recurring transactions</h3>
      <div class="prose">
        <p>Templates sit in a queue. When the due date arrives, the entry surfaces in the <a href="/app/register/">register</a> for you to approve or skip — it never posts automatically.</p>
        <p><strong>Frequency:</strong> pick from weekly, biweekly, monthly, semi-monthly, quarterly, annual, or build a custom interval (every <em>N</em> days / weeks / months).</p>
        <p><strong>Inflow vs outflow:</strong> any template with a positive amount is an inflow (income, refunds); negative amounts are outflows (bills, subscriptions). The summary tiles let you filter the list by kind.</p>
        <p><strong>Post on demand:</strong> use the row's <em>Post now</em> action to apply the template ahead of schedule. <em>Skip</em> advances the next-due date without posting.</p>
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="showHelp = false">Got it</button>
      </div>
    </div>
  </div>

  {# Summary tiles — quick view of monthly cash flow committed to
     recurring. Every tile is a button that wires straight into the
     filter toolbar below: click Inflow to filter to inflows, Outflow
     to filter to outflows, Active templates / Net monthly to clear
     filters back to the full set. Active filter gets a ring so the
     user can see which tile is driving the visible list. #}
  <section class="rec-summary" x-show="$store.budget.profile && $store.budget.profile.scheduled.length" x-cloak>
    <button type="button" class="rec-summary__tile rec-summary__tile--accent"
            :class="filterKind === 'all' ? 'is-active' : ''"
            :aria-pressed="(filterKind === 'all').toString()"
            @click="filterKind = 'all'"
            data-tip="Show every active template — clear the inflow/outflow filter.">
      <span class="rec-summary__label">Active templates</span>
      <span class="rec-summary__value" x-text="totalCount()"></span>
    </button>
    <button type="button" class="rec-summary__tile rec-summary__tile--inflow"
            :class="filterKind === 'inflow' ? 'is-active' : ''"
            :aria-pressed="(filterKind === 'inflow').toString()"
            @click="filterKind = 'inflow'"
            data-tip="Filter the table to inflow templates only.">
      <span class="rec-summary__label">Monthly inflow</span>
      <span class="rec-summary__value amount--inflow" x-text="formatCents(monthlyInflow())"></span>
    </button>
    <button type="button" class="rec-summary__tile rec-summary__tile--outflow"
            :class="filterKind === 'outflow' ? 'is-active' : ''"
            :aria-pressed="(filterKind === 'outflow').toString()"
            @click="filterKind = 'outflow'"
            data-tip="Filter the table to outflow templates only.">
      <span class="rec-summary__label">Monthly outflow</span>
      <span class="rec-summary__value amount--outflow" x-text="formatCents(monthlyOutflow())"></span>
    </button>
    <button type="button" class="rec-summary__tile rec-summary__tile--net"
            :class="filterKind === 'all' ? 'is-active' : ''"
            :aria-pressed="(filterKind === 'all').toString()"
            @click="filterKind = 'all'"
            data-tip="Show everything (inflows + outflows).">
      <span class="rec-summary__label">Net monthly</span>
      <span class="rec-summary__value"
            :class="monthlyNet() < 0 ? 'amount--outflow' : (monthlyNet() > 0 ? 'amount--inflow' : '')"
            x-text="formatCents(monthlyNet())"></span>
    </button>
  </section>

  <section class="card">
    <div class="rec-toolbar">
      <div class="rec-toolbar__search field">
        <label class="visually-hidden" for="rec-search">Search recurring</label>
        <input class="input" id="rec-search" type="search"
               x-model="searchQuery"
               placeholder="Search payee, memo, account, category…">
      </div>
      <div class="rec-toolbar__filters">
        <div class="field">
          <label class="visually-hidden" for="rec-account">Account</label>
          <select class="select" id="rec-account" x-model="filterAccountId">
            <option value="">All accounts</option>
            <template x-for="a in openAccounts()" :key="a.id">
              <option :value="a.id" x-text="a.name"></option>
            </template>
          </select>
        </div>
        <div class="field">
          <label class="visually-hidden" for="rec-freq">Frequency</label>
          <select class="select" id="rec-freq" x-model="filterFrequency">
            <option value="">All frequencies</option>
            <template x-for="f in $store.budget.FREQUENCIES" :key="f.value">
              <option :value="f.value" x-text="f.label"></option>
            </template>
          </select>
        </div>
        <div class="field">
          <label class="visually-hidden" for="rec-kind">Kind</label>
          <select class="select" id="rec-kind" x-model="filterKind">
            <option value="all">Inflows + outflows</option>
            <option value="inflow">Inflows only</option>
            <option value="outflow">Outflows only</option>
          </select>
        </div>
        <div class="field">
          <label class="visually-hidden" for="rec-sort">Sort by</label>
          <select class="select" id="rec-sort" x-model="sortKey">
            <option value="nextDate">Sort: next date</option>
            <option value="amount">Sort: amount</option>
            <option value="payee">Sort: payee</option>
            <option value="frequency">Sort: frequency</option>
          </select>
        </div>
      </div>
      <p class="rec-toolbar__count" x-show="hasActiveFilter()" x-cloak>
        <span x-text="filtered().length"></span> of <span x-text="totalCount()"></span> showing
      </p>
    </div>

    {# ---- Mobile card list (<600px). Mirrors the register's
       responsive pattern: table on desktop, stacked cards on phones.
       Same data, different layout — never both visible. #}
    <ul class="rec-cards" x-show="$store.budget.profile && filtered().length" x-cloak
        aria-label="Recurring transactions">
      <template x-for="s in filtered()" :key="'card-' + s.id">
        <li class="rec-card" :id="'card-edit-' + s.id">
          <header class="rec-card__head">
            <p class="rec-card__date" x-text="formatNextDate(s.nextDate)"></p>
            <p class="rec-card__amount"
               :class="s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
               x-text="formatCents(s.template.amount)"></p>
          </header>
          <p class="rec-card__payee" x-text="s.template.payeeName || $store.budget.payeeName(s.template.payeeId) || '—'"></p>
          <dl class="rec-card__meta">
            <div><dt>Frequency</dt><dd x-text="$store.budget.frequencyLabel(s)"></dd></div>
            <div><dt>Account</dt><dd x-text="$store.budget.findAccount(s.template.accountId)?.name || '—'"></dd></div>
            <div><dt>Category</dt>
              <dd x-text="$store.budget.categoryName(s.template.categoryId) || 'Uncategorized'"
                  :style="$store.budget.categoryName(s.template.categoryId) ? '' : 'color: var(--fg-muted); font-style: italic;'"></dd>
            </div>
            <div x-show="s.template.memo" x-cloak><dt>Memo</dt><dd x-text="s.template.memo"></dd></div>
          </dl>
          {# Post now stays inline as the primary action; the rest
             (Edit / Skip / Pause / Remove) collapse into a kebab. #}
          <div class="rec-card__actions">
            <button class="btn btn--primary btn--sm rec-post" type="button"
                    @click="postNow(s.id)"
                    x-show="!s.paused" x-cloak
                    data-tip="Post now and advance the next date.">Post now</button>
            {% call overflow(label="Recurring template actions") %}
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        @click="open = false; openEdit(s)">Edit…</button>
              </li>
              <li role="none" x-show="!s.paused">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        @click="open = false; $store.budget.skipScheduled(s.id)">Skip next occurrence</button>
              </li>
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item"
                        @click="open = false; $store.budget.setSchedulePaused(s.id, !s.paused)"
                        x-text="s.paused ? 'Resume' : 'Pause indefinitely'"></button>
              </li>
              <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
              <li role="none">
                <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                        @click="open = false; PBDialog.confirm({ title: 'Remove this recurring template?', message: 'The template stops queuing future occurrences. Posted transactions it already generated stay in the register.', confirmLabel: 'Remove template', danger: true }).then(ok => { if (ok) $store.budget.removeSchedule(s.id) })">Remove template</button>
              </li>
            {% endcall %}
          </div>
        </li>
      </template>
    </ul>

    <table class="table rec-table" x-show="$store.budget.profile && filtered().length" x-cloak>
      <thead>
        <tr>
          <th scope="col" style="white-space: nowrap;">Next date</th>
          <th scope="col">Frequency</th>
          <th scope="col">Account</th>
          <th scope="col">Payee</th>
          <th scope="col">Category</th>
          <th scope="col" class="num">Amount</th>
          <th scope="col" class="num" style="width: 1%; white-space: nowrap;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="s in filtered()" :key="s.id">
          <tr :id="'edit-' + s.id" :class="s.paused ? 'rec-row--paused' : ''">
            {# Each cell is click-to-edit (except paused rows). Same
               pattern as the register inline editor: single sign-flip
               chip on amount; @click.stop on cells with kebab/action
               buttons so the row-click handler doesn't fire. #}
            <td class="cell--edit" style="white-space: nowrap;"
                :class="{ 'is-locked': s.paused }"
                @click.stop="startCellEdit(s, 'nextDate', s.nextDate)">
              <template x-if="!isEditingCell(s, 'nextDate')">
                <span>
                  <span x-text="formatNextDate(s.nextDate)"></span>
                  <span x-show="s.paused" x-cloak class="badge badge--paused"
                        data-tip="Paused — won't queue until resumed.">Paused</span>
                </span>
              </template>
              <template x-if="isEditingCell(s, 'nextDate')">
                <input type="date" class="input cell-input"
                       :data-cell-input="s.id + ':nextDate'"
                       x-model="cellEdit.draft"
                       @blur="commitCell(s)"
                       @keydown.enter.prevent="commitCell(s)"
                       @keydown.escape.prevent="cancelCellEdit()">
              </template>
            </td>
            <td class="cell--edit"
                :class="{ 'is-locked': s.paused }"
                @click.stop="startCellEdit(s, 'frequency', s.frequency || 'monthly')">
              <template x-if="!isEditingCell(s, 'frequency')">
                <span x-text="$store.budget.frequencyLabel(s)"></span>
              </template>
              <template x-if="isEditingCell(s, 'frequency')">
                <select class="select cell-input"
                        :data-cell-input="s.id + ':frequency'"
                        x-model="cellEdit.draft"
                        @blur="commitCell(s)"
                        @change="commitCell(s)"
                        @keydown.escape.prevent="cancelCellEdit()">
                  <template x-for="opt in frequencyOptions()" :key="opt.value">
                    <option :value="opt.value" x-text="opt.label"></option>
                  </template>
                </select>
              </template>
            </td>
            <td class="cell--edit"
                :class="{ 'is-locked': s.paused }"
                @click.stop="startCellEdit(s, 'accountId', s.template.accountId)">
              <template x-if="!isEditingCell(s, 'accountId')">
                <span x-text="$store.budget.findAccount(s.template.accountId)?.name || '—'"></span>
              </template>
              <template x-if="isEditingCell(s, 'accountId')">
                <select class="select cell-input"
                        :data-cell-input="s.id + ':accountId'"
                        x-model="cellEdit.draft"
                        @blur="commitCell(s)"
                        @change="commitCell(s)"
                        @keydown.escape.prevent="cancelCellEdit()">
                  <template x-for="a in ($store.budget.profile?.accounts || []).filter(a => !a.closedAt)" :key="a.id">
                    <option :value="a.id" x-text="a.name"></option>
                  </template>
                </select>
              </template>
            </td>
            {# Payee cell is a two-target click: the payee strong text
               edits the payee; the memo line below it edits the
               memo. Each has its own click handler so clicking memo
               doesn't accidentally focus the payee input. #}
            <td class="cell--edit rec-payee-cell"
                :class="{ 'is-locked': s.paused }">
              <template x-if="!isEditingCell(s, 'payeeName') && !isEditingCell(s, 'memo')">
                <span class="rec-payee-stack">
                  <button type="button" class="rec-payee-stack__name cell--edit"
                          @click.stop="startCellEdit(s, 'payeeName', s.template.payeeName || $store.budget.payeeName(s.template.payeeId) || '')">
                    <strong x-text="s.template.payeeName || $store.budget.payeeName(s.template.payeeId) || '—'"></strong>
                  </button>
                  <button type="button" class="rec-payee-stack__memo cell--edit"
                          :class="!s.template.memo ? 'is-placeholder' : ''"
                          @click.stop="startCellEdit(s, 'memo', s.template.memo || '')"
                          x-text="s.template.memo || '+ Add memo'"></button>
                </span>
              </template>
              <template x-if="isEditingCell(s, 'payeeName')">
                <input type="text" class="input cell-input"
                       :data-cell-input="s.id + ':payeeName'"
                       x-model="cellEdit.draft"
                       autocomplete="off"
                       @blur="commitCell(s)"
                       @keydown.enter.prevent="commitCell(s)"
                       @keydown.escape.prevent="cancelCellEdit()">
              </template>
              <template x-if="isEditingCell(s, 'memo')">
                <input type="text" class="input cell-input"
                       :data-cell-input="s.id + ':memo'"
                       x-model="cellEdit.draft"
                       autocomplete="off"
                       placeholder="Memo (optional)"
                       @blur="commitCell(s)"
                       @keydown.enter.prevent="commitCell(s)"
                       @keydown.escape.prevent="cancelCellEdit()">
              </template>
            </td>
            <td class="cell--edit"
                :class="{ 'is-locked': s.paused }"
                :style="$store.budget.categoryName(s.template.categoryId) ? '' : 'color: var(--fg-muted); font-style: italic;'"
                @click.stop="startCellEdit(s, 'categoryId', s.template.categoryId || '')">
              <template x-if="!isEditingCell(s, 'categoryId')">
                <span x-text="$store.budget.categoryName(s.template.categoryId) || 'Uncategorized'"></span>
              </template>
              <template x-if="isEditingCell(s, 'categoryId')">
                <select class="select cell-input"
                        :data-cell-input="s.id + ':categoryId'"
                        x-model="cellEdit.draft"
                        @blur="commitCell(s)"
                        @change="commitCell(s)"
                        @keydown.escape.prevent="cancelCellEdit()">
                  <option value="">(uncategorized)</option>
                  <template x-for="c in inlineCategories(s.template.amount < 0 ? 'outflow' : 'inflow')" :key="c.id">
                    <option :value="c.id" x-text="c.name"></option>
                  </template>
                </select>
              </template>
            </td>
            <td class="num cell--edit cell--amount"
                :class="[s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow', s.paused ? 'is-locked' : '']"
                @click.stop="startCellEdit(s, 'amount', (Math.abs(s.template.amount || 0) / 100).toFixed(2))">
              <template x-if="!isEditingCell(s, 'amount')">
                <span x-text="formatCents(s.template.amount)"></span>
              </template>
              <template x-if="isEditingCell(s, 'amount')">
                <span class="cell-amount-edit"
                      @keydown.escape.prevent="cancelCellEdit()">
                  <button type="button"
                          class="cell-sign-flip"
                          :class="cellEdit.sign === 'inflow' ? 'is-in' : 'is-out'"
                          :title="cellEdit.sign === 'outflow' ? 'Outflow. Tap to flip.' : 'Inflow. Tap to flip.'"
                          @mousedown.prevent
                          @click.stop="setCellSign(cellEdit.sign === 'outflow' ? 'inflow' : 'outflow')">
                    <span aria-hidden="true" x-text="cellEdit.sign === 'outflow' ? '−' : '+'"></span>
                  </button>
                  <input type="text" inputmode="decimal" class="input cell-input num"
                         :data-cell-input="s.id + ':amount'"
                         x-model="cellEdit.draft"
                         @blur="commitCell(s)"
                         @keydown.enter.prevent="commitCell(s)"
                         @keydown.escape.prevent="cancelCellEdit()">
                </span>
              </template>
            </td>
            <td class="num" @click.stop>
              <div class="cluster" style="justify-content: flex-end; flex-wrap: nowrap; gap: var(--space-3xs);">
                <button class="btn btn--primary btn--sm rec-post" type="button"
                        @click="postNow(s.id)"
                        x-show="!s.paused" x-cloak
                        data-tip="Post this occurrence as a real transaction now and advance the next date.">Post</button>
                {% call overflow(label="Recurring template actions") %}
                  <li role="none">
                    <button type="button" role="menuitem" class="overflow-menu__item"
                            @click="open = false; openEdit(s)">Edit…</button>
                  </li>
                  <li role="none" x-show="!s.paused">
                    <button type="button" role="menuitem" class="overflow-menu__item"
                            @click="open = false; $store.budget.skipScheduled(s.id)">Skip next occurrence</button>
                  </li>
                  <li role="none">
                    <button type="button" role="menuitem" class="overflow-menu__item"
                            @click="open = false; $store.budget.setSchedulePaused(s.id, !s.paused)"
                            x-text="s.paused ? 'Resume' : 'Pause indefinitely'"></button>
                  </li>
                  <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
                  <li role="none">
                    <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                            @click="open = false; PBDialog.confirm({ title: 'Remove this recurring template?', message: 'The template stops queuing future occurrences. Posted transactions it already generated stay in the register.', confirmLabel: 'Remove template', danger: true }).then(ok => { if (ok) $store.budget.removeSchedule(s.id) })">Remove template</button>
                  </li>
                {% endcall %}
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>

    <p x-show="$store.budget.profile && $store.budget.profile.scheduled.length && !filtered().length" x-cloak
       style="color: var(--fg-muted); padding: var(--space-md) 0; margin: 0; text-align: center;">
      No recurring transactions match the current filters.
      <button class="btn btn--ghost btn--sm" type="button" @click="clearFilters()" style="margin-left: var(--space-2xs);">Clear filters</button>
    </p>

    <p x-show="!$store.budget.profile || !$store.budget.profile.scheduled.length" x-cloak
       style="color: var(--fg-muted); padding: var(--space-md) 0; margin: 0;">
      No recurring transactions yet. Click <em>+ Add recurring</em> to add one.
    </p>
  </section>

  {# Create / Edit modal — same form, mode flips which store call fires #}
  <div class="modal-backdrop" x-show="show" x-cloak @keydown.escape.window="close()">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="rc-modal-title" @click.outside="close()">
      <button class="modal__close" type="button" @click="close()" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="rc-modal-title">
        <span x-text="mode === 'edit' ? 'Edit recurring transaction' : 'Add recurring transaction'"></span>
      </h3>
      <form @submit.prevent="submit()">
        <div class="form-stack">
          <div class="field">
            <label class="field__label" for="rc-account">Account</label>
            <select class="select" id="rc-account" x-model="form.accountId" required>
              <option value="">Select account</option>
              <template x-for="a in openAccounts()" :key="a.id">
                <option :value="a.id" x-text="a.name"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label class="field__label" for="rc-freq">Frequency</label>
            <select class="select" id="rc-freq" x-model="form.frequency">
              <template x-for="f in $store.budget.FREQUENCIES" :key="f.value">
                <option :value="f.value" x-text="f.label"></option>
              </template>
            </select>
          </div>
          <div class="field" x-show="form.frequency === 'custom'" x-cloak>
            <label class="field__label" for="rc-custom-interval">Every</label>
            <input class="input" id="rc-custom-interval" type="number" min="1" step="1"
                   x-model.number="form.customInterval" inputmode="numeric"
                   :required="form.frequency === 'custom'">
          </div>
          <div class="field" x-show="form.frequency === 'custom'" x-cloak>
            <label class="field__label" for="rc-custom-unit">Unit</label>
            <select class="select" id="rc-custom-unit" x-model="form.customUnit">
              <template x-for="u in $store.budget.CUSTOM_UNITS" :key="u.value">
                <option :value="u.value" x-text="u.label"></option>
              </template>
            </select>
            <p class="field__hint" x-show="form.customInterval && form.customUnit"
               x-text="'Reads as: every ' + form.customInterval + ' ' + form.customUnit + '.'"></p>
          </div>
          <div class="field">
            <label class="field__label" for="rc-payee">Payee</label>
            <input class="input" id="rc-payee" type="text" x-model="form.payeeName">
          </div>
          <div class="field">
            <label class="field__label" for="rc-category">Category</label>
            <select class="select" id="rc-category" x-model="form.categoryId">
              <option value="">(uncategorized)</option>
              <template x-for="c in selectableCategories()" :key="c.id">
                <option :value="c.id" x-text="c.name"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label class="field__label" for="rc-amount">Amount</label>
            <input class="input" id="rc-amount" type="text" x-model="form.amount" inputmode="decimal" placeholder="-50.00 · or 40+10" required
                   data-tip="Calculator: type expressions like 12.50 + 8.99 or 100 - 25 * 2 — they evaluate on save.">
            <p class="field__hint">Negative = outflow.</p>
            <p class="field__hint calc-preview" x-show="calcPreview(form.amount)" x-cloak x-text="calcPreview(form.amount)"></p>
          </div>
          <div class="field">
            <label class="field__label" for="rc-next">
              <span x-text="mode === 'edit' ? 'Next due date' : 'First due date'"></span>
            </label>
            <input class="input" id="rc-next" type="date" x-model="form.nextDate" required>
          </div>
          <div class="field">
            <label class="field__label" for="rc-memo">Memo (optional)</label>
            <input class="input" id="rc-memo" type="text" x-model="form.memo">
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">
            <span x-text="mode === 'edit' ? 'Save changes' : 'Add recurring'"></span>
          </button>
          <button class="btn btn--ghost" type="button" @click="close()">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function scheduledView() {
  return {
    showHelp: false,
    show: false,
    mode: "create", // 'create' | 'edit'
    editId: null,
    /* Inline cell editor — same per-cell click-to-edit UX as the
       register. `cellEdit.txnId === s.id && cellEdit.field === 'date'`
       means the Next-date cell renders an input instead of static
       text. `cellEdit.sign` only applies to the amount cell. */
    cellEdit: { txnId: null, field: null, draft: "", sign: "outflow" },
    /* Toolbar state — drives filtered() + the summary. */
    searchQuery: "",
    filterAccountId: "",
    filterFrequency: "",
    filterKind: "all",
    sortKey: "nextDate",
    form: {
      accountId: "", payeeName: "", categoryId: "", amount: "", memo: "",
      frequency: "monthly", customInterval: 2, customUnit: "weeks", nextDate: "",
    },

    /* Format YYYY-MM-DD as "Jun 26, 2026" so the column doesn't wrap. */
    formatNextDate(iso) {
      if (!iso) return "—";
      var parts = iso.split("-").map(Number);
      var d = new Date(parts[0], (parts[1] || 1) - 1, parts[2] || 1);
      return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
    },

    /* All schedules (defensive — used by counts + summary). */
    allSchedules() {
      var p = this.$store.budget.profile;
      return (p && p.scheduled) ? p.scheduled : [];
    },
    totalCount() { return this.allSchedules().length; },

    hasActiveFilter() {
      return !!(this.searchQuery || this.filterAccountId ||
                this.filterFrequency || this.filterKind !== "all");
    },
    clearFilters() {
      this.searchQuery = "";
      this.filterAccountId = "";
      this.filterFrequency = "";
      this.filterKind = "all";
    },

    /* Toolbar-driven view of the schedule list. */
    filtered() {
      var self = this;
      var q = (this.searchQuery || "").trim().toLowerCase();
      var out = this.allSchedules().filter(function (s) {
        if (self.filterAccountId && s.template.accountId !== self.filterAccountId) return false;
        if (self.filterFrequency && s.frequency !== self.filterFrequency) return false;
        if (self.filterKind === "inflow"  && (s.template.amount || 0) <= 0) return false;
        if (self.filterKind === "outflow" && (s.template.amount || 0) >= 0) return false;
        if (q) {
          var payee = (s.template.payeeName || self.$store.budget.payeeName(s.template.payeeId) || "").toLowerCase();
          var cat   = (self.$store.budget.categoryName(s.template.categoryId) || "").toLowerCase();
          var acct  = (self.$store.budget.findAccount(s.template.accountId)?.name || "").toLowerCase();
          var memo  = (s.template.memo || "").toLowerCase();
          if (payee.indexOf(q) < 0 && cat.indexOf(q) < 0 && acct.indexOf(q) < 0 && memo.indexOf(q) < 0) return false;
        }
        return true;
      });
      var key = this.sortKey;
      out.sort(function (a, b) {
        if (key === "amount") return (a.template.amount || 0) - (b.template.amount || 0);
        if (key === "payee") {
          var ap = (a.template.payeeName || self.$store.budget.payeeName(a.template.payeeId) || "").toLowerCase();
          var bp = (b.template.payeeName || self.$store.budget.payeeName(b.template.payeeId) || "").toLowerCase();
          return ap.localeCompare(bp);
        }
        if (key === "frequency") return (a.frequency || "").localeCompare(b.frequency || "");
        /* nextDate (default) */
        return (a.nextDate || "").localeCompare(b.nextDate || "");
      });
      return out;
    },

    /* Normalize any cadence to an approximate per-month cents figure so
       the summary tiles compare apples to apples (weekly × 4.33, etc.). */
    _monthlyCents(s) {
      var amt = s.template.amount || 0;
      switch (s.frequency) {
        case "daily":    return Math.round(amt * 30.44);
        case "weekly":   return Math.round(amt * 4.345);
        case "biweekly": return Math.round(amt * 2.1725);
        case "monthly":  return amt;
        case "yearly":   return Math.round(amt / 12);
        case "custom": {
          var n = Math.max(1, Math.round(s.customInterval || 1));
          var u = s.customUnit || "months";
          if (u === "days")   return Math.round(amt * (30.44 / n));
          if (u === "weeks")  return Math.round(amt * (4.345 / n));
          if (u === "months") return Math.round(amt / n);
          if (u === "years")  return Math.round(amt / (12 * n));
          return amt;
        }
        default: return amt;
      }
    },
    monthlyInflow() {
      var self = this;
      return this.allSchedules().reduce(function (sum, s) {
        var m = self._monthlyCents(s);
        return m > 0 ? sum + m : sum;
      }, 0);
    },
    monthlyOutflow() {
      var self = this;
      return this.allSchedules().reduce(function (sum, s) {
        var m = self._monthlyCents(s);
        return m < 0 ? sum + m : sum;
      }, 0);
    },
    monthlyNet() { return this.monthlyInflow() + this.monthlyOutflow(); },

    init() {
      /* If the URL is /app/scheduled/#edit-<id>, open the edit modal
         for that schedule on load. Used by calendar entries to deep-link. */
      var hash = (window.location.hash || "").replace(/^#/, "");
      if (hash.indexOf("edit-") === 0) {
        var id = hash.slice("edit-".length);
        var self = this;
        /* Defer one tick so the store has loaded the active profile. */
        this.$nextTick(function () {
          var p = self.$store.budget.profile;
          if (!p) return;
          var s = (p.scheduled || []).find(function (x) { return x.id === id; });
          if (s) self.openEdit(s);
        });
      }
    },

    parseDollars(s) {
      if (s == null || s === "") return 0;
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var c = String(s).replace(/[$,\s]/g, "").trim();
      if (/^\(.*\)$/.test(c)) c = "-" + c.slice(1, -1);
      var n = Number(c);
      return isFinite(n) ? Math.round(n * 100) : 0;
    },
    calcPreview(s) { return (window.PBCalc ? window.PBCalc.formatExpressionPreview(s) : ""); },
    formatCents(c) {
      return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD" });
    },

    openAccounts() {
      var p = this.$store.budget.profile;
      if (!p) return [];
      return p.accounts.filter(function (a) { return !a.closedAt; })
        .sort(function (a, b) { return a.name.localeCompare(b.name); });
    },
    selectableCategories() {
      var s = this.$store.budget;
      if (!s.profile) return [];
      return s.categoriesFlat().filter(function (c) { return !s.isPaymentCategory(c.id); });
    },

    resetForm() {
      this.form = {
        accountId: "", payeeName: "", categoryId: "", amount: "", memo: "",
        frequency: "monthly", customInterval: 2, customUnit: "weeks", nextDate: "",
      };
    },

    openCreate() {
      this.resetForm();
      this.mode = "create";
      this.editId = null;
      this.show = true;
    },
    openEdit(s) {
      this.mode = "edit";
      this.editId = s.id;
      this.form = {
        accountId: s.template.accountId || "",
        payeeName: s.template.payeeName || this.$store.budget.payeeName(s.template.payeeId) || "",
        categoryId: s.template.categoryId || "",
        amount: ((s.template.amount || 0) / 100).toFixed(2),
        memo: s.template.memo || "",
        frequency: s.frequency || "monthly",
        customInterval: s.customInterval || 2,
        customUnit: s.customUnit || "weeks",
        nextDate: s.nextDate || "",
      };
      this.show = true;
    },
    close() {
      this.show = false;
      this.mode = "create";
      this.editId = null;
      /* Drop the deep-link hash so re-opening the page is clean. */
      if (window.history && window.history.replaceState) {
        window.history.replaceState(null, "", window.location.pathname);
      }
    },

    submit() {
      if (!this.form.accountId || !this.form.nextDate) return;
      var isCustom = this.form.frequency === "custom";
      var template = {
        accountId: this.form.accountId,
        payeeId: null,
        payeeName: this.form.payeeName,
        amount: this.parseDollars(this.form.amount),
        memo: this.form.memo,
        categoryId: this.form.categoryId || null,
      };
      if (this.mode === "edit" && this.editId) {
        this.$store.budget.updateSchedule(this.editId, {
          template: template,
          frequency: this.form.frequency,
          customInterval: isCustom ? Math.max(1, Math.round(Number(this.form.customInterval) || 1)) : null,
          customUnit: isCustom ? this.form.customUnit : null,
          nextDate: this.form.nextDate,
        });
        this.$store.budget.pushToast("Recurring transaction updated.");
      } else {
        this.$store.budget.addSchedule({
          template: template,
          frequency: this.form.frequency,
          customInterval: isCustom ? Math.max(1, Math.round(Number(this.form.customInterval) || 1)) : null,
          customUnit: isCustom ? this.form.customUnit : null,
          nextDate: this.form.nextDate,
        });
        this.$store.budget.pushToast("Recurring transaction added.");
      }
      this.close();
    },

    postNow(id) {
      this.$store.budget.postScheduled(id);
      this.$store.budget.pushToast("Posted. Next date advanced.");
    },

    /* ---- Inline cell editing — desktop table ---- */
    isEditingCell(s, field) {
      return this.cellEdit.txnId === s.id && this.cellEdit.field === field;
    },
    startCellEdit(s, field, initialValue) {
      if (!s || s.paused) return;
      var amt = (s.template && s.template.amount) || 0;
      this.cellEdit = {
        txnId: s.id,
        field: field,
        draft: initialValue == null ? "" : String(initialValue),
        sign: amt < 0 ? "outflow" : "inflow",
      };
      var self = this;
      this.$nextTick(function () {
        var input = document.querySelector('[data-cell-input="' + s.id + ':' + field + '"]');
        if (input) {
          input.focus();
          if (input.select) input.select();
        }
      });
    },
    setCellSign(sign) {
      if (this.cellEdit.field !== "amount") return;
      this.cellEdit.sign = sign;
      var id = this.cellEdit.txnId;
      this.$nextTick(function () {
        var input = document.querySelector('[data-cell-input="' + id + ':amount"]');
        if (input) input.focus();
      });
    },
    cancelCellEdit() {
      this.cellEdit = { txnId: null, field: null, draft: "", sign: "outflow" };
    },
    /* Build a patch that touches only the cellEdit field. Template
       changes need a full template replacement since the domain
       helper assigns `template` whole-object. Frequency / nextDate
       are top-level patch fields. */
    commitCell(s) {
      if (this.cellEdit.txnId !== s.id || !this.cellEdit.field) return;
      var field = this.cellEdit.field;
      var raw = this.cellEdit.draft;
      var patch = {};
      var tmpl = Object.assign({}, s.template || {});
      switch (field) {
        case "nextDate":
          if (!raw) { this.cancelCellEdit(); return; }
          patch.nextDate = raw;
          break;
        case "frequency":
          patch.frequency = raw || "monthly";
          break;
        case "accountId":
          tmpl.accountId = raw || tmpl.accountId;
          patch.template = tmpl;
          break;
        case "categoryId":
          tmpl.categoryId = raw || null;
          patch.template = tmpl;
          break;
        case "payeeName":
          tmpl.payeeName = (raw || "").trim();
          /* Clear stale payeeId so the post-now flow re-upserts the
             payee under its new name. */
          tmpl.payeeId = null;
          patch.template = tmpl;
          break;
        case "memo":
          tmpl.memo = raw || "";
          patch.template = tmpl;
          break;
        case "amount":
          var n = Number(String(raw).replace(/[$,\s]/g, ""));
          if (!isFinite(n)) { this.cancelCellEdit(); return; }
          var cents = Math.round(Math.abs(n) * 100);
          tmpl.amount = this.cellEdit.sign === "outflow" ? -cents : cents;
          patch.template = tmpl;
          break;
        default:
          this.cancelCellEdit();
          return;
      }
      this.$store.budget.updateSchedule(s.id, patch);
      this.cancelCellEdit();
    },
    /* Selectable category lists for inline edit, filtered by sign. */
    inlineCategories(sign) {
      var st = this.$store.budget;
      if (!st.profile) return [];
      var flat = st.categoriesFlat ? st.categoriesFlat() : [];
      return flat.filter(function (c) { return !st.isPaymentCategory || !st.isPaymentCategory(c.id); });
    },
    /* Frequency options for the inline select. */
    frequencyOptions() {
      return [
        { value: "weekly",       label: "Weekly" },
        { value: "biweekly",     label: "Every two weeks" },
        { value: "monthly",      label: "Monthly" },
        { value: "semi-monthly", label: "Semi-monthly" },
        { value: "quarterly",    label: "Quarterly" },
        { value: "annual",       label: "Annual" },
      ];
    },
  };
}
</script>
