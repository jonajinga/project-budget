---
layout: layouts/app.njk
title: "Register"
description: "All transactions across all accounts."
permalink: /app/register/
eleventyExcludeFromCollections: true
---
{% from "partials/icon-trash.njk" import iconTrash %}
{% from "partials/overflow-menu.njk" import overflow %}
<div class="app-page" x-data="registerView()" x-init="init()">

  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">
        <span x-text="filterAccountId ? ($store.budget.findAccount(filterAccountId)?.name || 'Register') : 'All accounts'"></span>
      </h1>
    </div>
    {# Primary "Add transaction" is covered by the persistent FAB on every
       app page (src/_includes/layouts/app.njk:62). Header keeps only the
       account-scoped actions; Transfer / Reconcile / Save view collapse
       into a single kebab so the row stays one line at 360px. #}
    {% call overflow(label="Register actions") %}
      <li role="none">
        <button type="button" role="menuitem" class="overflow-menu__item"
                :disabled="!hasAccounts"
                @click="open = false; showTransfer = true">Transfer between accounts</button>
      </li>
      <li role="none" x-show="filterAccountId" x-cloak>
        <button type="button" role="menuitem" class="overflow-menu__item"
                @click="open = false; showReconcile = true">Reconcile this account</button>
      </li>
      <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
      <li role="none">
        <button type="button" role="menuitem" class="overflow-menu__item"
                @click="open = false; saveCurrentView()">Save current view</button>
      </li>
    {% endcall %}
  </header>

  <p class="app-page__lead" x-show="!hasAccounts" x-cloak>
    Add an account before entering transactions.
    <a href="/app/accounts/">Go to accounts</a>.
  </p>

  {# Account stats — six tiles laid out as a single row at desktop.
     Uncleared is omitted because it equals (Working − Cleared), and
     "this month" suffixes are dropped because the register view's
     header already names the month context. Labels stay nowrap. #}
  <section class="acct-stats" x-show="filterAccountId && hasAccounts" x-cloak
           role="group" aria-label="Account summary">
    <article class="acct-stat">
      <p class="acct-stat__label">Working balance</p>
      <p class="acct-stat__value"
         :class="$store.budget.accountBalance(filterAccountId) < 0 ? 'is-negative' : ''"
         x-text="formatCents($store.budget.accountBalance(filterAccountId))"></p>
    </article>
    <article class="acct-stat"
             :data-tip="'Uncleared: ' + formatCents($store.budget.accountBalance(filterAccountId) - $store.budget.accountClearedBalance(filterAccountId))">
      <p class="acct-stat__label">Cleared</p>
      <p class="acct-stat__value"
         x-text="formatCents($store.budget.accountClearedBalance(filterAccountId))"></p>
    </article>
    <article class="acct-stat">
      <p class="acct-stat__label">Transactions</p>
      <p class="acct-stat__value" x-text="acctTxnCount()"></p>
    </article>
    <article class="acct-stat acct-stat--income">
      <p class="acct-stat__label">Inflow</p>
      <p class="acct-stat__value" x-text="formatCents(acctMonthInflow())"></p>
    </article>
    <article class="acct-stat acct-stat--expense">
      <p class="acct-stat__label">Outflow</p>
      <p class="acct-stat__value" x-text="formatCents(acctMonthOutflow())"></p>
    </article>
    <article class="acct-stat acct-stat--spark" x-show="acctSparkline()" x-cloak>
      <p class="acct-stat__label">30-day trend</p>
      <template x-if="acctSparkline()">
        <svg class="acct-spark"
             :class="'acct-spark--' + acctSparkline().trend"
             viewBox="0 0 100 30" preserveAspectRatio="none"
             role="img"
             :aria-label="'Balance trend: ' + acctSparkline().trend + ', current ' + formatCents(acctSparkline().last)">
          <path :d="acctSparkline().path" fill="none" stroke="currentColor" stroke-width="1.4" vector-effect="non-scaling-stroke"></path>
        </svg>
      </template>
    </article>
  </section>

  {# Due scheduled queue #}
  <section class="card" x-show="hasAccounts && due.length" x-cloak style="border-left: 4px solid var(--warn);">
    <h2 class="card__title">Recurring transactions due</h2>
    <p class="card__body" style="margin-bottom: var(--space-sm);">
      Review each one before it posts. You can skip an occurrence to push the next date forward without recording it.
    </p>
    <table class="table">
      <thead><tr><th>Date</th><th>Account</th><th>Payee</th><th class="num">Amount</th><th class="num">Actions</th></tr></thead>
      <tbody>
        <template x-for="s in due" :key="s.id">
          <tr>
            <td x-text="s.nextDate"></td>
            <td x-text="$store.budget.findAccount(s.template.accountId)?.name || '—'"></td>
            <td x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></td>
            <td class="num" x-text="formatCents(s.template.amount)"></td>
            <td class="num">
              <div class="cluster" style="justify-content: flex-end;">
                <button class="btn btn--primary btn--sm" type="button" @click="postNow(s.id)">Post</button>
                <button class="btn btn--ghost btn--sm" type="button" @click="$store.budget.skipScheduled(s.id); refreshDue();">Skip</button>
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </section>

  {# Add transaction is handled by the persistent FAB
     (src/_includes/partials/fab-quick-add.njk, mounted in
     src/_includes/layouts/app.njk:62 on every app page). The
     inline add form that used to live here was a duplicate of
     the FAB modal with worse mobile ergonomics. #}

  {# Register table #}
  <section class="register" x-show="hasAccounts" x-cloak>
    <div class="register__toolbar">
      <div class="register__filters">
        {# Searchable account filter — type to narrow the dropdown,
           click an option to select, Esc to close. The hidden state
           filterAccountId still drives the rest of the page. #}
        <div class="acct-combo" @click.outside="acctComboOpen = false" @keydown.escape="acctComboOpen = false">
          <input class="input acct-combo__input" type="text"
                 aria-label="Filter by account"
                 :value="acctFilterLabel()"
                 @focus="acctComboOpen = true; acctQuery = ''"
                 @input="acctQuery = $event.target.value; acctComboOpen = true"
                 placeholder="All accounts">
          <button type="button" class="acct-combo__chevron" tabindex="-1"
                  @click="acctComboOpen = !acctComboOpen"
                  aria-label="Toggle account filter">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <ul class="acct-combo__list" x-show="acctComboOpen" x-cloak>
            <li>
              <button type="button" class="acct-combo__option"
                      @click="filterAccountId = ''; acctComboOpen = false; acctQuery = ''; updateUrl()">
                All accounts
              </button>
            </li>
            <template x-for="a in acctComboFiltered()" :key="a.id">
              <li>
                <button type="button" class="acct-combo__option"
                        :class="filterAccountId === a.id ? 'is-active' : ''"
                        @click="filterAccountId = a.id; acctComboOpen = false; acctQuery = ''; updateUrl()">
                  <span x-text="a.name"></span>
                  <span class="acct-combo__balance"
                        x-text="(($store.budget.accountBalance(a.id) || 0) / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' })"></span>
                </button>
              </li>
            </template>
            <li x-show="!acctComboFiltered().length" x-cloak class="acct-combo__empty">No matches</li>
          </ul>
        </div>
        <input class="input register__search" type="search"
               aria-label="Search payee or memo"
               x-model.debounce.300ms="search"
               @input.debounce.300ms="updateUrl()"
               placeholder="Search payee or memo">
      </div>
      <div class="cluster register__toolbar-actions">
        <p class="register__count">
          <span x-text="visibleTransactions().length"></span> shown
        </p>
      </div>
    </div>

    <table class="register__table" x-show="!isMobile" x-cloak data-no-tippy>
      <thead>
        <tr>
          <th scope="col" class="col-select">
            <input type="checkbox" class="register__bulk-check"
                   :checked="allVisibleSelected()"
                   :aria-checked="someVisibleSelected() && !allVisibleSelected() ? 'mixed' : (allVisibleSelected() ? 'true' : 'false')"
                   @change="toggleSelectAllVisible()"
                   aria-label="Select all visible transactions"
                   data-tip="Select / deselect every transaction currently shown.">
          </th>
          <th scope="col" class="col-date" data-tip="Date the transaction occurred.">Date</th>
          <th scope="col" data-tip="Account the entry belongs to.">Account</th>
          <th scope="col" class="col-payee" data-tip="Payee or transfer description.">Payee</th>
          <th scope="col" data-tip="Category assigned to this entry. Splits show a 'split (N)' badge.">Category</th>
          <th scope="col" data-tip="Short note. Optional.">Memo</th>
          <th scope="col" class="num" data-tip="Negative = outflow (red). Positive = inflow (green).">Amount</th>
          <th scope="col" class="col-cleared" data-tip="Cleared = posted at your bank. Reconciled (R) means it's locked from edits.">
            <span aria-label="Cleared">C</span>
          </th>
          <th scope="col" class="num" data-tip="Edit, split, delete, or unlock the row.">Actions</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="t in pagedTransactions()" :key="t.id">
          <tr :data-txn-id="t.id"
              :class="{ 'register__row--reconciled': t.reconciled, 'register__row--editing': editingId === t.id, 'register__row--selected': isTxnSelected(t.id) }"
              @click="onRowClick(t, $event)">
            {# Per-row select checkbox — always visible. Bulk actions
               (recategorize, rename, delete) light up the floating bar
               whenever ≥1 row is selected. #}
            <td class="col-select" @click.stop>
              <input type="checkbox" class="register__bulk-check"
                     :checked="isTxnSelected(t.id)"
                     @change="toggleTxnSelected(t.id)"
                     :disabled="t.reconciled"
                     :aria-label="'Select ' + ($store.budget.payeeName(t.payeeId) || 'transaction')">
            </td>
            {# Display mode — each cell is click-to-edit. Reconciled
               rows + transfer pairs skip the click (use kebab → Edit
               instead). The single-cell editor swaps a focused input
               for the static text and commits on blur/Enter. #}
            <template x-if="editingId !== t.id">
              <td class="col-date cell--edit"
                  :class="{ 'is-locked': t.reconciled || t.transferTxnId }"
                  :data-tip="t.date"
                  @click.stop="startCellEdit(t, 'date', t.date)">
                <template x-if="!isEditingCell(t, 'date')">
                  <span x-html="fmtDateCell(t.date)"></span>
                </template>
                <template x-if="isEditingCell(t, 'date')">
                  <input type="date" class="input cell-input"
                         :data-cell-input="t.id + ':date'"
                         x-model="cellEdit.draft"
                         @blur="commitCell(t)"
                         @keydown.enter.prevent="commitCell(t)"
                         @keydown.escape.prevent="cancelCellEdit()">
                </template>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="cell--edit"
                  :class="{ 'is-locked': t.reconciled || t.transferTxnId }"
                  :data-tip="$store.budget.findAccount(t.accountId)?.name || ''"
                  @click.stop="startCellEdit(t, 'accountId', t.accountId)">
                <template x-if="!isEditingCell(t, 'accountId')">
                  <span x-text="$store.budget.findAccount(t.accountId)?.name || '—'"></span>
                </template>
                <template x-if="isEditingCell(t, 'accountId')">
                  <select class="select cell-input"
                          :data-cell-input="t.id + ':accountId'"
                          x-model="cellEdit.draft"
                          @blur="commitCell(t)"
                          @change="commitCell(t)"
                          @keydown.escape.prevent="cancelCellEdit()">
                    <template x-for="a in openAccounts" :key="a.id">
                      <option :value="a.id" x-text="a.name"></option>
                    </template>
                  </select>
                </template>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="col-payee cell--edit"
                  :class="{ 'is-locked': t.reconciled || t.transferTxnId }"
                  :data-tip="t.transferTxnId ? 'Paired transfer entry.' : ($store.budget.payeeName(t.payeeId) || '')"
                  @click.stop="!t.transferTxnId && startCellEdit(t, 'payeeName', $store.budget.payeeName(t.payeeId) || '')">
                <template x-if="!isEditingCell(t, 'payeeName')">
                  <span x-text="t.transferTxnId ? ('Transfer ' + ($store.budget.findAccount(otherSide(t).accountId)?.name || '')) : ($store.budget.payeeName(t.payeeId) || '—')"></span>
                </template>
                <template x-if="isEditingCell(t, 'payeeName')">
                  <input type="text" class="input cell-input"
                         :data-cell-input="t.id + ':payeeName'"
                         x-model="cellEdit.draft"
                         autocomplete="off"
                         @blur="commitCell(t)"
                         @keydown.enter.prevent="commitCell(t)"
                         @keydown.escape.prevent="cancelCellEdit()">
                </template>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="cell--edit"
                  :class="{ 'is-locked': t.reconciled || t.transferTxnId || t.splits }"
                  :data-tip="$store.budget.categoryName(t.categoryId) || ''"
                  @click.stop="!t.splits && startCellEdit(t, 'categoryId', t.categoryId || '')">
                <template x-if="!isEditingCell(t, 'categoryId')">
                  <span>
                    <span x-show="!t.splits" x-cloak x-text="$store.budget.categoryName(t.categoryId) || (t.transferTxnId ? '' : '—')"></span>
                    <span x-show="t.splits" x-cloak class="badge"
                          :data-tip="'This transaction is split across ' + (t.splits?.length || 0) + ' categories.'">split (<span x-text="t.splits?.length"></span>)</span>
                  </span>
                </template>
                <template x-if="isEditingCell(t, 'categoryId')">
                  <select class="select cell-input"
                          :data-cell-input="t.id + ':categoryId'"
                          x-model="cellEdit.draft"
                          @blur="commitCell(t)"
                          @change="commitCell(t)"
                          @keydown.escape.prevent="cancelCellEdit()">
                    <option value="">(uncategorized)</option>
                    <template x-for="c in selectableCategoriesForType(t.amount < 0 ? 'outflow' : 'inflow')" :key="c.id">
                      <option :value="c.id" x-text="c.name"></option>
                    </template>
                  </select>
                </template>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="cell--edit"
                  :class="{ 'is-locked': t.reconciled || t.transferTxnId }"
                  :data-tip="t.memo || ''"
                  style="color: var(--fg-muted);"
                  @click.stop="startCellEdit(t, 'memo', t.memo || '')">
                <template x-if="!isEditingCell(t, 'memo')">
                  <span x-text="t.memo || ''"></span>
                </template>
                <template x-if="isEditingCell(t, 'memo')">
                  <input type="text" class="input cell-input"
                         :data-cell-input="t.id + ':memo'"
                         x-model="cellEdit.draft"
                         @blur="commitCell(t)"
                         @keydown.enter.prevent="commitCell(t)"
                         @keydown.escape.prevent="cancelCellEdit()">
                </template>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="num cell--edit cell--amount"
                  :class="[t.amount < 0 ? 'amount--outflow' : 'amount--inflow', (t.reconciled || t.transferTxnId) ? 'is-locked' : '']"
                  :data-tip="(t.amount < 0 ? 'Outflow ' : 'Inflow ') + formatCents(Math.abs(t.amount))"
                  @click.stop="startCellEdit(t, 'amount', (Math.abs(t.amount) / 100).toFixed(2))">
                <template x-if="!isEditingCell(t, 'amount')">
                  <span x-text="formatCents(t.amount)"></span>
                </template>
                <template x-if="isEditingCell(t, 'amount')">
                  {# Single sign-flip chip — tap to flip outflow ↔
                     inflow. Compact (~20px), clear state (red − /
                     green +), and never blurs the input because
                     @mousedown.prevent keeps focus. #}
                  <span class="cell-amount-edit"
                        @keydown.escape.prevent="cancelCellEdit()">
                    <button type="button"
                            class="cell-sign-flip"
                            :class="cellEdit.sign === 'inflow' ? 'is-in' : 'is-out'"
                            :title="cellEdit.sign === 'outflow' ? 'Outflow (negative). Tap to flip.' : 'Inflow (positive). Tap to flip.'"
                            :aria-label="cellEdit.sign === 'outflow' ? 'Outflow. Tap to switch to inflow.' : 'Inflow. Tap to switch to outflow.'"
                            @mousedown.prevent
                            @click.stop="setCellSign(cellEdit.sign === 'outflow' ? 'inflow' : 'outflow')">
                      <span aria-hidden="true" x-text="cellEdit.sign === 'outflow' ? '−' : '+'"></span>
                    </button>
                    <input type="text" inputmode="decimal" class="input cell-input num"
                           :data-cell-input="t.id + ':amount'"
                           x-model="cellEdit.draft"
                           @blur="commitCell(t)"
                           @keydown.enter.prevent="commitCell(t)"
                           @keydown.escape.prevent="cancelCellEdit()">
                  </span>
                </template>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="col-cleared">
                <button type="button"
                        class="cleared-toggle"
                        :aria-pressed="t.cleared.toString()"
                        :aria-label="t.reconciled ? 'Reconciled and locked' : (t.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared')"
                        :data-locked="t.reconciled.toString()"
                        @click="toggleCleared(t)"
                        :data-tip="t.reconciled ? 'Reconciled and locked. Unlock to change.' : (t.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).')">
                  <span x-show="t.cleared" aria-hidden="true">&#10003;</span>
                </button>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="num" @click.stop>
                <div class="cluster" style="justify-content: flex-end; flex-wrap: nowrap; gap: var(--space-3xs);">
                  {# Edit / Split / Unlock / Recurring / Delete collapse
                     into a kebab so the row stops carrying 4-5 icons
                     across its right edge. @click.stop on the cell stops
                     the row-click handler from interpreting kebab clicks
                     as row selection. #}
                  {% call overflow(label="Transaction actions") %}
                    <li role="none" x-show="!t.reconciled && !t.transferTxnId">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              @click="open = false; startEdit(t)">Edit…</button>
                    </li>
                    <li role="none" x-show="!t.reconciled && !t.transferTxnId">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              @click="open = false; openSplits(t)">Split into categories…</button>
                    </li>
                    <li role="none" x-show="!t.reconciled && !t.transferTxnId && !t.splits">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              @click="open = false; openMakeRecurring(t)">Make recurring…</button>
                    </li>
                    <li role="none" x-show="t.reconciled">
                      <button type="button" role="menuitem" class="overflow-menu__item"
                              @click="open = false; unlock(t)">Unlock to edit</button>
                    </li>
                    <li role="none" class="overflow-menu__sep" aria-hidden="true" x-show="!t.reconciled"></li>
                    <li role="none" x-show="!t.reconciled">
                      <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                              @click="open = false; del(t)">Delete transaction</button>
                    </li>
                  {% endcall %}
                </div>
              </td>
            </template>

            {# Edit mode #}
            <template x-if="editingId === t.id">
              <td><input class="input" type="date" x-model="edit.date" aria-label="Date" @keydown.escape="cancelEdit()"></td>
            </template>
            <template x-if="editingId === t.id">
              <td>
                <select class="select" x-model="edit.accountId" aria-label="Account">
                  <template x-for="a in openAccounts" :key="a.id">
                    <option :value="a.id" x-text="a.name"></option>
                  </template>
                </select>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td><input class="input" type="text" x-model="edit.payeeName" aria-label="Payee"></td>
            </template>
            <template x-if="editingId === t.id">
              <td>
                <select class="select" x-model="edit.categoryId" aria-label="Category">
                  <option value="">(uncategorized)</option>
                  <template x-for="c in selectableCategoriesForType(edit.type)" :key="c.id">
                    <option :value="c.id" x-text="c.name"></option>
                  </template>
                </select>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td><input class="input" type="text" x-model="edit.memo" aria-label="Memo"></td>
            </template>
            <template x-if="editingId === t.id">
              <td class="num">
                {# Stack the Outflow/Inflow toggle ABOVE the amount
                   input so the column stays narrow but the sign
                   indicator is always visible. The amount field is
                   always positive; the toggle drives the sign. #}
                <div class="register__edit-amount-stack">
                  <div class="txn-type-toggle txn-type-toggle--sm" role="radiogroup" aria-label="Type">
                    <button type="button" class="txn-type-toggle__opt"
                            :class="edit.type === 'outflow' ? 'is-active' : ''"
                            :aria-pressed="(edit.type === 'outflow').toString()"
                            @click="edit.type = 'outflow'">
                      <span aria-hidden="true">−</span> Out
                    </button>
                    <button type="button" class="txn-type-toggle__opt"
                            :class="edit.type === 'inflow' ? 'is-active' : ''"
                            :aria-pressed="(edit.type === 'inflow').toString()"
                            @click="edit.type = 'inflow'">
                      <span aria-hidden="true">+</span> In
                    </button>
                  </div>
                  <input class="input" type="text" x-model="edit.amount"
                         inputmode="decimal" aria-label="Amount"
                         style="text-align: right;"
                         placeholder="0.00">
                </div>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td class="col-cleared">
                <button type="button"
                        class="cleared-toggle"
                        :aria-pressed="edit.cleared.toString()"
                        :aria-label="edit.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared'"
                        @click="edit.cleared = !edit.cleared"
                        :data-tip="edit.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'">
                  <span x-show="edit.cleared" aria-hidden="true">&#10003;</span>
                </button>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td class="num">
                <div class="cluster register__edit-actions">
                  <button class="btn btn--primary btn--sm" type="button" @click="saveEdit()">Save</button>
                  <button class="btn btn--ghost btn--sm" type="button" @click="cancelEdit()">Cancel</button>
                </div>
              </td>
            </template>
          </tr>
        </template>

        <tr x-show="!visibleTransactions().length" x-cloak>
          <td colspan="9" style="text-align: center; padding: var(--space-lg); color: var(--fg-muted);">
            No transactions match the current filter.
          </td>
        </tr>
        {# Load-more sentinel row. Auto-bumps via the scroll-into-view
           handler so users who scroll near the bottom get more rows
           without having to click. The button is the keyboard / no-JS
           fallback path. #}
        <tr x-show="hasMoreToShow()" x-cloak class="register__load-more-row">
          <td colspan="9" style="text-align: center; padding: var(--space-md);">
            <button type="button" class="btn btn--ghost btn--sm"
                    @click="showMore()"
                    data-load-more-sentinel>
              <span>Load 50 more</span>
              <span style="color: var(--fg-muted); margin-left: var(--space-2xs);">
                (<span x-text="visibleTransactions().length - pagedTransactions().length"></span> remaining)
              </span>
            </button>
          </td>
        </tr>
      </tbody>
    </table>

    {# Mobile card list — replaces the 8-column table under 600px wide. #}
    <ul class="register__cards" x-show="isMobile" x-cloak data-no-tippy>
      <template x-for="t in pagedTransactions()" :key="t.id">
        <li class="register__card"
            :class="{ 'is-expanded': expandedTxnId === t.id, 'is-reconciled': t.reconciled, 'is-editing': editingId === t.id, 'is-selected': isTxnSelected(t.id) }">
          {# Persistent select checkbox on mobile cards — sits inline
             before the tap-to-expand summary so it doesn't fight for
             the tap. The Select-mode toggle was dropped; the checkbox
             is always visible and tapping it opens the bulk bar. #}
          <label class="register__card-select">
            <input type="checkbox" class="register__bulk-check"
                   :checked="isTxnSelected(t.id)"
                   @change="toggleTxnSelected(t.id)"
                   :disabled="t.reconciled"
                   :aria-label="'Select ' + ($store.budget.payeeName(t.payeeId) || 'transaction')">
          </label>
          {# Compact summary — tap to expand. Becomes a heading button so it
             is keyboard reachable; the inner card form (when expanded) is
             still tab-navigable normally. #}
          <button type="button" class="register__card-summary"
                  x-show="editingId !== t.id"
                  @click="expandedTxnId = (expandedTxnId === t.id ? null : t.id)"
                  :aria-expanded="(expandedTxnId === t.id).toString()">
            <span class="register__card-date" x-text="t.date"></span>
            <span class="register__card-payee"
                  x-text="t.transferTxnId ? ('Transfer ' + ($store.budget.findAccount(otherSide(t).accountId)?.name || '')) : ($store.budget.payeeName(t.payeeId) || '(no payee)')"></span>
            <span class="register__card-amount"
                  :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="formatCents(t.amount)"></span>
            <span class="register__card-meta">
              <span x-show="!t.splits" x-cloak x-text="$store.budget.categoryName(t.categoryId) || (t.transferTxnId ? 'Transfer' : 'Uncategorized')"></span>
              <span x-show="t.splits" x-cloak class="badge">split (<span x-text="t.splits?.length"></span>)</span>
              <span x-show="t.cleared" x-cloak class="register__card-cleared-flag" aria-label="Cleared">&#10003; cleared</span>
            </span>
          </button>

          {# Expanded details — appear only when this card is the active one
             and not in edit mode. #}
          <div class="register__card-details" x-show="expandedTxnId === t.id && editingId !== t.id" x-cloak>
            <dl class="register__card-dl">
              <div><dt>Account</dt><dd x-text="$store.budget.findAccount(t.accountId)?.name || '—'"></dd></div>
              <div x-show="t.memo" x-cloak><dt>Memo</dt><dd x-text="t.memo"></dd></div>
            </dl>
            <div class="cluster" style="flex-wrap: wrap;">
              <button type="button" class="cleared-toggle"
                      :aria-pressed="t.cleared.toString()"
                      :aria-label="t.reconciled ? 'Reconciled and locked' : (t.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared')"
                      :data-locked="t.reconciled.toString()"
                      @click="toggleCleared(t)"
                      title="Toggle cleared">
                <span x-show="t.cleared" aria-hidden="true">&#10003;</span>
              </button>
              <button class="btn btn--ghost btn--sm" type="button" @click="startEdit(t)" x-show="!t.reconciled && !t.transferTxnId">Edit</button>
              <button class="btn btn--ghost btn--sm" type="button" @click="openSplits(t)" x-show="!t.reconciled && !t.transferTxnId">Split</button>
              <button class="btn btn--ghost btn--sm" type="button" @click="unlock(t)" x-show="t.reconciled">Unlock</button>
              <button class="btn btn--danger btn--sm" type="button" @click="del(t)" x-show="!t.reconciled">Delete</button>
            </div>
          </div>

          {# Inline edit form for mobile — stacked vertically since
             cell-by-cell edit doesn't fit in 360px. #}
          <div class="register__card-edit" x-show="editingId === t.id" x-cloak>
            <div class="field">
              <label class="field__label">Date</label>
              <input class="input" type="date" x-model="edit.date">
            </div>
            <div class="field">
              <label class="field__label">Account</label>
              <select class="select" x-model="edit.accountId">
                <template x-for="a in openAccounts" :key="a.id">
                  <option :value="a.id" x-text="a.name"></option>
                </template>
              </select>
            </div>
            <div class="field">
              <label class="field__label">Payee</label>
              <input class="input" type="text" x-model="edit.payeeName">
            </div>
            <div class="field">
              <label class="field__label">Type</label>
              <div class="txn-type-toggle" role="radiogroup" aria-label="Transaction type">
                <button type="button" class="txn-type-toggle__opt"
                        :class="edit.type === 'outflow' ? 'is-active' : ''"
                        :aria-pressed="edit.type === 'outflow'"
                        @click="edit.type = 'outflow'; edit.categoryId = ''">
                  <span aria-hidden="true">−</span> Outflow
                </button>
                <button type="button" class="txn-type-toggle__opt"
                        :class="edit.type === 'inflow' ? 'is-active' : ''"
                        :aria-pressed="edit.type === 'inflow'"
                        @click="edit.type = 'inflow'; edit.categoryId = ''">
                  <span aria-hidden="true">+</span> Inflow
                </button>
              </div>
            </div>
            <div class="field">
              <label class="field__label">Category</label>
              <select class="select" x-model="edit.categoryId">
                <option value="">(uncategorized)</option>
                <template x-for="c in selectableCategoriesForType(edit.type)" :key="c.id">
                  <option :value="c.id" x-text="c.name"></option>
                </template>
              </select>
            </div>
            <div class="field">
              <label class="field__label">Amount</label>
              <input class="input" type="text" x-model="edit.amount" inputmode="decimal" style="text-align: right;" placeholder="Enter a positive number">
            </div>
            <div class="field">
              <label class="field__label">Memo</label>
              <input class="input" type="text" x-model="edit.memo">
            </div>
            <span class="cluster" style="gap: var(--space-2xs); align-items: center;">
              <button type="button"
                      class="cleared-toggle"
                      :aria-pressed="edit.cleared.toString()"
                      :aria-label="edit.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared'"
                      @click="edit.cleared = !edit.cleared"
                      :data-tip="edit.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'">
                <span x-show="edit.cleared" aria-hidden="true">&#10003;</span>
              </button>
              <span>Cleared</span>
            </span>
            <div class="form-actions">
              <button class="btn btn--primary btn--sm" type="button" @click="saveEdit()">Save</button>
              <button class="btn btn--ghost btn--sm" type="button" @click="cancelEdit()">Cancel</button>
            </div>
          </div>
        </li>
      </template>

      <li class="register__card-empty" x-show="!visibleTransactions().length" x-cloak>
        No transactions match the current filter.
      </li>
      <li class="register__card-empty" x-show="hasMoreToShow()" x-cloak>
        <button type="button" class="btn btn--ghost btn--sm"
                @click="showMore()"
                x-intersect.once="onSentinelIntersect()">
          <span>Load 50 more</span>
          <span style="color: var(--fg-muted); margin-left: var(--space-2xs);">
            (<span x-text="visibleTransactions().length - pagedTransactions().length"></span> remaining)
          </span>
        </button>
      </li>
    </ul>
  </section>

  {# Transfer modal #}
  <div class="modal-backdrop" x-show="showTransfer" x-cloak @keydown.escape.window="showTransfer = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showTransfer = false">
      <button class="modal__close" type="button" @click="showTransfer = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">Transfer between accounts</h3>
      <form @submit.prevent="submitTransfer()">
        <div class="form-stack">
          <div class="form-row">
            <div class="field">
              <label class="field__label" for="tr-from">From</label>
              <select class="select" id="tr-from" x-model="transferForm.fromAccountId" required>
                <option value="">Select account</option>
                <template x-for="a in openAccounts" :key="a.id"><option :value="a.id" x-text="a.name"></option></template>
              </select>
            </div>
            <div class="field">
              <label class="field__label" for="tr-to">To</label>
              <select class="select" id="tr-to" x-model="transferForm.toAccountId" required>
                <option value="">Select account</option>
                <template x-for="a in openAccounts" :key="a.id"><option :value="a.id" x-text="a.name"></option></template>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="field">
              <label class="field__label" for="tr-amount">Amount</label>
              <input class="input" id="tr-amount" type="text" x-model="transferForm.amount" inputmode="decimal" placeholder="0.00" required>
            </div>
            <div class="field">
              <label class="field__label" for="tr-date">Date</label>
              <input class="input" id="tr-date" type="date" x-model="transferForm.date" required>
            </div>
          </div>
          <div class="field">
            <label class="field__label" for="tr-memo">Memo (optional)</label>
            <input class="input" id="tr-memo" type="text" x-model="transferForm.memo">
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Transfer</button>
          <button class="btn btn--ghost" type="button" @click="showTransfer = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Reconcile modal #}
  <div class="modal-backdrop" x-show="showReconcile" x-cloak @keydown.escape.window="showReconcile = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showReconcile = false">
      <button class="modal__close" type="button" @click="showReconcile = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">Reconcile account</h3>
      <p style="color: var(--fg-muted);">
        Enter the ending balance from your latest statement. Project Budget will compare it with the cleared balance for the account.
      </p>
      <form @submit.prevent="checkReconcile()">
        <div class="form-row" style="margin-top: var(--space-sm);">
          <div class="field">
            <label class="field__label" for="rc-balance">Statement ending balance</label>
            <input class="input" id="rc-balance" type="text" x-model="reconcileForm.statementBalance" inputmode="decimal" required>
          </div>
          <div class="field">
            <label class="field__label">Cleared in Project Budget</label>
            <p class="input" style="background: var(--bg-alt); margin: 0;" x-text="formatCents($store.budget.accountClearedBalance(filterAccountId))"></p>
          </div>
        </div>

        <div x-show="reconcileForm.checked" x-cloak style="margin-top: var(--space-sm);">
          <p x-show="reconcileForm.diff === 0" style="color: var(--ok);">
            Balances match. You are ready to reconcile.
          </p>
          <p x-show="reconcileForm.diff !== 0" style="color: var(--warn);">
            Difference: <strong x-text="formatCents(reconcileForm.diff)"></strong>.
            You can add an adjustment transaction to close the gap before reconciling.
          </p>
        </div>

        <div class="form-actions">
          <button class="btn btn--secondary" type="submit" x-show="!reconcileForm.checked">Check</button>
          <button class="btn btn--primary" type="button" x-show="reconcileForm.checked && reconcileForm.diff === 0" @click="finishReconcile()">Mark cleared as reconciled</button>
          <button class="btn btn--secondary" type="button" x-show="reconcileForm.checked && reconcileForm.diff !== 0" @click="addAdjustmentAndReconcile()">Add adjustment and reconcile</button>
          <button class="btn btn--ghost" type="button" @click="showReconcile = false">Close</button>
        </div>
      </form>
    </div>
  </div>

  {# Make recurring modal — turn an existing transaction into a
     recurring template. Pre-populates from the source row; user
     just picks frequency + next date. #}
  <div class="modal-backdrop" x-show="showMakeRecurring" x-cloak @keydown.escape.window="showMakeRecurring = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="mr-title" @click.outside="showMakeRecurring = false" style="max-width: 540px;">
      <button class="modal__close" type="button" @click="showMakeRecurring = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="mr-title">Make recurring</h3>
      <p style="color: var(--fg-muted); margin-top: var(--space-2xs);">
        <strong x-text="recurringForm.payeeName || '(no payee)'"></strong>
        · <span x-text="formatCents(recurringForm.amount)"></span>
        · <span x-text="$store.budget.findAccount(recurringForm.accountId)?.name || ''"></span>
      </p>
      <form @submit.prevent="submitMakeRecurring()">
        <div class="form-stack">
          <div class="field">
            <label class="field__label" for="mr-frequency">How often?</label>
            <select class="select" id="mr-frequency" x-model="recurringForm.frequency"
                    @change="onRecurringFreqChange()">
              <option value="daily">Daily</option>
              <option value="weekly">Weekly</option>
              <option value="biweekly">Every two weeks</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
              <option value="custom">Custom…</option>
            </select>
          </div>
          <div class="field" x-show="recurringForm.frequency === 'custom'" x-cloak>
            <label class="field__label" for="mr-custom-interval">Every</label>
            <div class="cluster" style="gap: var(--space-2xs);">
              <input class="input" id="mr-custom-interval" type="number" min="1" step="1"
                     x-model.number="recurringForm.customInterval" style="max-width: 6rem;">
              <select class="select" x-model="recurringForm.customUnit" style="max-width: 10rem;">
                <option value="days">days</option>
                <option value="weeks">weeks</option>
                <option value="months">months</option>
                <option value="years">years</option>
              </select>
            </div>
          </div>
          <div class="field">
            <label class="field__label" for="mr-next-date">Next occurrence</label>
            <input class="input" id="mr-next-date" type="date" x-model="recurringForm.nextDate" required>
            <p class="field__hint">Defaults to one frequency after the source transaction's date. Adjust if needed.</p>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Create recurring template</button>
          <button class="btn btn--ghost" type="button" @click="showMakeRecurring = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Split editor modal #}
  <div class="modal-backdrop" x-show="splitTxnId" x-cloak @keydown.escape.window="splitTxnId = null">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="splitTxnId = null" style="max-width: 720px;">
      <button class="modal__close" type="button" @click="splitTxnId = null" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title">Split transaction</h3>
      <p style="color: var(--fg-muted);">
        Divide this transaction across multiple categories. The sum of the splits becomes the transaction's amount.
      </p>
      <p style="margin-top: var(--space-sm);">
        Current total:
        <strong x-text="formatCents(splitSum())"></strong>
      </p>

      <table class="table" style="margin-top: var(--space-sm);">
        <thead>
          <tr>
            <th>Category</th>
            <th>Memo</th>
            <th class="num">Amount</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <template x-for="(s, i) in splitForm" :key="i">
            <tr>
              <td>
                <select class="select" x-model="s.categoryId">
                  <option value="">(uncategorized)</option>
                  <template x-for="c in selectableCategories" :key="c.id">
                    <option :value="c.id" x-text="c.name"></option>
                  </template>
                </select>
              </td>
              <td><input class="input" type="text" x-model="s.memo"></td>
              <td class="num"><input class="input" type="text" x-model="s.amount" inputmode="decimal" style="text-align: right;"></td>
              <td>
                <button class="modal__close split-remove" type="button"
                        @click="splitForm.splice(i, 1)"
                        aria-label="Remove split row"
                        data-tip="Remove this split row.">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
                </button>
              </td>
            </tr>
          </template>
        </tbody>
      </table>

      <div class="form-actions">
        <button class="btn btn--secondary btn--sm" type="button" @click="splitForm.push({ categoryId: '', memo: '', amount: '' })">Add split row</button>
        <button class="btn btn--primary" type="button" @click="saveSplits()">Save splits</button>
        <button class="btn btn--ghost" type="button" @click="$store.budget.setSplits(splitTxnId, null); splitTxnId = null;">Clear splits</button>
        <button class="btn btn--ghost" type="button" @click="splitTxnId = null">Cancel</button>
      </div>
    </div>
  </div>

  {# Floating bulk-actions bar — visible only when at least one txn
     is selected. Mirrors the pattern on /app/budget/ for category
     bulk-clear. Operations are atomic via the store's batchMutate. #}
  <div class="bulk-actions-bar" x-show="selectedTxnIds.length" x-cloak role="region" aria-label="Bulk transaction actions">
    <div class="bulk-actions-bar__count">
      <strong x-text="selectedTxnIds.length"></strong>
      <span x-text="selectedTxnIds.length === 1 ? 'transaction selected' : 'transactions selected'"></span>
    </div>
    <div class="cluster" style="gap: var(--space-2xs); flex-wrap: wrap;">
      <button type="button" class="btn btn--primary btn--sm" @click="openBulkRecategorize()"
              data-tip="Reassign every selected transaction to one category.">Recategorize</button>
      <span class="bulk-actions-bar__more bulk-actions-bar__more--desktop">
        <button type="button" class="btn btn--secondary btn--sm" @click="openBulkRename()"
                data-tip="Set the payee on every selected transaction.">Rename payee</button>
        <button type="button" class="btn btn--secondary btn--sm" @click="openBulkShift()"
                data-tip="Shift every selected transaction's date by a number of days.">Shift dates</button>
        <button type="button" class="btn btn--danger btn--sm" @click="bulkDelete()"
                data-tip="Move every selected transaction to Trash. Recoverable for 30 days.">Delete</button>
      </span>
      <span class="bulk-actions-bar__more bulk-actions-bar__more--mobile">
        {% call overflow(label="More bulk actions") %}
          <li role="none">
            <button type="button" role="menuitem" class="overflow-menu__item"
                    @click="open = false; openBulkRename()">Rename payee</button>
          </li>
          <li role="none">
            <button type="button" role="menuitem" class="overflow-menu__item"
                    @click="open = false; openBulkShift()">Shift dates</button>
          </li>
          <li role="none" class="overflow-menu__sep" aria-hidden="true"></li>
          <li role="none">
            <button type="button" role="menuitem" class="overflow-menu__item overflow-menu__item--danger"
                    @click="open = false; bulkDelete()">Delete selected</button>
          </li>
        {% endcall %}
      </span>
      <button type="button" class="btn btn--ghost btn--sm" @click="clearTxnSelection()"
              data-tip="Deselect every row and exit selection mode.">Cancel</button>
    </div>
  </div>

  {# Bulk recategorize modal #}
  <div class="modal-backdrop" x-show="showBulkRecat" x-cloak @keydown.escape.window="showBulkRecat = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="bulk-recat-title"
         @click.outside="showBulkRecat = false" style="max-width: 480px;">
      <button class="modal__close" type="button" @click="showBulkRecat = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="bulk-recat-title">Recategorize selected</h3>
      <p style="color: var(--fg-muted);">
        Reassign every selected transaction to the chosen category. Split rows and reconciled rows are skipped.
      </p>
      <div class="field" style="margin-top: var(--space-sm);">
        <label class="field__label" for="bulk-recat-cat">New category</label>
        <select class="select" id="bulk-recat-cat" x-model="bulkRecatTarget">
          <option value="">(uncategorized)</option>
          <template x-for="c in selectableCategories" :key="c.id">
            <option :value="c.id" x-text="c.name"></option>
          </template>
        </select>
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="applyBulkRecategorize()">Apply</button>
        <button class="btn btn--ghost" type="button" @click="showBulkRecat = false">Cancel</button>
      </div>
    </div>
  </div>

  {# Bulk rename payee modal #}
  <div class="modal-backdrop" x-show="showBulkRename" x-cloak @keydown.escape.window="showBulkRename = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="bulk-rename-title"
         @click.outside="showBulkRename = false" style="max-width: 480px;">
      <button class="modal__close" type="button" @click="showBulkRename = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="bulk-rename-title">Set payee on selected</h3>
      <p style="color: var(--fg-muted);">
        Sets the same payee on every selected transaction. Transfer and reconciled rows are skipped.
      </p>
      <div class="field" style="margin-top: var(--space-sm);">
        <label class="field__label" for="bulk-rename-input">Payee name</label>
        <input class="input" id="bulk-rename-input" type="text" x-model="bulkRenameTarget"
               autocomplete="off" placeholder="e.g. Trader Joe's">
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="applyBulkRename()"
                :disabled="!bulkRenameTarget.trim()">Apply</button>
        <button class="btn btn--ghost" type="button" @click="showBulkRename = false">Cancel</button>
      </div>
    </div>
  </div>

  {# Bulk date-shift modal #}
  <div class="modal-backdrop" x-show="showBulkShift" x-cloak @keydown.escape.window="showBulkShift = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="bulk-shift-title"
         @click.outside="showBulkShift = false" style="max-width: 480px;">
      <button class="modal__close" type="button" @click="showBulkShift = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="bulk-shift-title">Shift dates</h3>
      <p style="color: var(--fg-muted);">
        Move every selected transaction by a number of days. Positive
        shifts forward, negative shifts backward. Reconciled rows are
        skipped.
      </p>
      <div class="field" style="margin-top: var(--space-sm);">
        <label class="field__label" for="bulk-shift-input">Days (positive or negative)</label>
        <input class="input" id="bulk-shift-input" type="number" step="1"
               x-model.number="bulkShiftDelta"
               placeholder="e.g. -7 to move back one week">
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="applyBulkShift()"
                :disabled="!Number.isFinite(bulkShiftDelta) || bulkShiftDelta === 0">Apply</button>
        <button class="btn btn--ghost" type="button" @click="showBulkShift = false">Cancel</button>
      </div>
    </div>
  </div>
</div>

