---
layout: layouts/app.njk
title: "Register"
description: "All transactions across all accounts."
permalink: /app/register/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="registerView()" x-init="init()">

  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">
        <span x-text="filterAccountId ? ($store.budget.findAccount(filterAccountId)?.name || 'Register') : 'All accounts'"></span>
      </h1>
      <p class="app-page__lead" x-show="filterAccountId" x-cloak>
        Balance:
        <strong x-text="formatCents($store.budget.accountBalance(filterAccountId))"></strong>
        &middot; cleared
        <span x-text="formatCents($store.budget.accountClearedBalance(filterAccountId))"></span>
      </p>
    </div>
    <div class="cluster">
      <button class="btn btn--primary" type="button"
              x-show="hasAccounts" x-cloak
              @click="showAdd = true; $nextTick(() => document.getElementById('t-date')?.focus())"
              data-tip="Add a new transaction to the register.">+ Add transaction</button>
      <button class="btn btn--secondary" type="button" @click="showTransfer = true" :disabled="!hasAccounts"
              data-tip="Move money between two of your own accounts. Creates a paired entry on each side.">Transfer</button>
      <button class="btn btn--secondary" type="button" @click="showReconcile = true" x-show="filterAccountId" x-cloak
              data-tip="Match the cleared balance to your statement. Closes any gap with an adjustment, then locks cleared transactions.">Reconcile</button>
    </div>
  </header>

  <p class="app-page__lead" x-show="!hasAccounts" x-cloak>
    Add an account before entering transactions.
    <a href="/app/accounts/">Go to accounts</a>.
  </p>

  {# Due scheduled queue #}
  <section class="card" x-show="hasAccounts && due.length" x-cloak style="border-left: 4px solid var(--warn);">
    <h2 class="card__title">Recurring transactions due</h2>
    <p class="card__body" style="margin-bottom: var(--space-sm);">
      Review each one before it posts. You can skip an occurrence to push the next date forward without recording it.
    </p>
    <table class="table">
      <thead><tr><th>Date</th><th>Account</th><th>Payee</th><th class="num">Amount</th><th class="num">Actions</th></tr></thead>
      <tbody>
        <template x-for="s in due" :key="s.id">
          <tr>
            <td x-text="s.nextDate"></td>
            <td x-text="$store.budget.findAccount(s.template.accountId)?.name || '—'"></td>
            <td x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></td>
            <td class="num" x-text="formatCents(s.template.amount)"></td>
            <td class="num">
              <div class="cluster" style="justify-content: flex-end;">
                <button class="btn btn--primary btn--sm" type="button" @click="postNow(s.id)">Post</button>
                <button class="btn btn--ghost btn--sm" type="button" @click="$store.budget.skipScheduled(s.id); refreshDue();">Skip</button>
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </section>

  {# Add transaction — hidden until the header "+ Add transaction"
     button opens it. No redundant CTA card. #}
  <section class="card register__add" x-show="hasAccounts && showAdd" x-cloak>
    <div x-transition.opacity>
      <div class="cluster" style="justify-content: space-between; align-items: baseline; margin-bottom: var(--space-sm);">
        <h2 class="card__title" style="margin: 0;">Add transaction</h2>
        <button class="btn btn--ghost btn--sm" type="button" @click="showAdd = false">Cancel</button>
      </div>
      <form @submit.prevent="submitAdd(); showAdd = false">
        <div class="form-row register__add-grid">
          <div class="field">
            <label class="field__label" for="t-date">Date</label>
            <input class="input" id="t-date" type="date" x-model="form.date" required>
          </div>
          <div class="field">
            <label class="field__label" for="t-payee">Payee</label>
            <input class="input" id="t-payee" type="text" x-model="form.payeeName"
                   @input="updatePayeeSuggestions()" @focus="updatePayeeSuggestions()" @blur="setTimeout(() => payeeSuggestions = [], 150)"
                   autocomplete="off">
            <ul class="payee-suggest" x-show="payeeSuggestions.length" x-cloak>
              <template x-for="p in payeeSuggestions" :key="p.id">
                <li>
                  <button type="button" @mousedown.prevent="pickPayee(p)" x-text="p.name + ' (' + p.useCount + ')'"></button>
                </li>
              </template>
            </ul>
          </div>
          <div class="field">
            <label class="field__label" for="t-cat">Category</label>
            <select class="select" id="t-cat" x-model="form.categoryId">
              <option value="">(uncategorized)</option>
              <template x-for="c in selectableCategories" :key="c.id">
                <option :value="c.id" x-text="c.name"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label class="field__label" for="t-amount">Amount</label>
            <input class="input" id="t-amount" type="text" x-model="form.amount" placeholder="-12.34 · or 12+8.99"
                   inputmode="decimal" required
                   data-tip="Calculator: type expressions like 12.50 + 8.99 or 100 - 25 * 2 — they evaluate on save.">
            <p class="field__hint calc-preview" x-show="calcPreview(form.amount)" x-cloak x-text="calcPreview(form.amount)"></p>
          </div>
          <div class="field">
            <label class="field__label" for="t-account">Account</label>
            <select class="select" id="t-account" x-model="form.accountId" required>
              <template x-for="a in openAccounts" :key="a.id">
                <option :value="a.id" x-text="a.name"></option>
              </template>
            </select>
          </div>
        </div>
        <div class="field" style="margin-top: var(--space-sm);">
          <label class="field__label" for="t-memo">Memo (optional)</label>
          <input class="input" id="t-memo" type="text" x-model="form.memo">
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Add transaction</button>
          <button class="btn btn--ghost" type="button" @click="showAdd = false">Cancel</button>
          <span class="cluster" style="gap: var(--space-2xs); color: var(--fg-muted); align-items: center;">
            <button type="button"
                    class="cleared-toggle"
                    :aria-pressed="form.cleared.toString()"
                    :aria-label="form.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'"
                    @click="form.cleared = !form.cleared"
                    :data-tip="form.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'">
              <span x-show="form.cleared" aria-hidden="true">&#10003;</span>
            </button>
            <span>Cleared</span>
          </span>
        </div>
      </form>
    </div>
  </section>

  {# Register table #}
  <section class="register" x-show="hasAccounts" x-cloak>
    <div class="register__toolbar">
      <div class="register__filters">
        <select class="select" aria-label="Filter by account"
                x-model="filterAccountId" @change="updateUrl()">
          <option value="">All accounts</option>
          <template x-for="a in openAccounts" :key="a.id">
            <option :value="a.id" x-text="a.name"></option>
          </template>
        </select>
        <input class="input register__search" type="search"
               aria-label="Search payee or memo"
               x-model="search"
               placeholder="Search payee or memo">
      </div>
      <p class="register__count">
        <span x-text="visibleTransactions().length"></span> shown
      </p>
    </div>

    <table class="register__table" x-show="!isMobile" x-cloak>
      <thead>
        <tr>
          <th scope="col" class="col-date" data-tip="Date the transaction occurred.">Date</th>
          <th scope="col" data-tip="Account the entry belongs to.">Account</th>
          <th scope="col" class="col-payee" data-tip="Payee or transfer description.">Payee</th>
          <th scope="col" data-tip="Category assigned to this entry. Splits show a 'split (N)' badge.">Category</th>
          <th scope="col" data-tip="Short note. Optional.">Memo</th>
          <th scope="col" class="num" data-tip="Negative = outflow (red). Positive = inflow (green).">Amount</th>
          <th scope="col" class="col-cleared" data-tip="Cleared = posted at your bank. Reconciled (R) means it's locked from edits.">
            <span aria-label="Cleared">C</span>
          </th>
          <th scope="col" class="num" data-tip="Edit, split, delete, or unlock the row.">Actions</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="t in visibleTransactions()" :key="t.id">
          <tr :data-txn-id="t.id"
              :class="{ 'register__row--reconciled': t.reconciled, 'register__row--editing': editingId === t.id }">
            {# Display mode #}
            <template x-if="editingId !== t.id">
              <td class="col-date"
                  :data-tip="t.date">
                <span x-html="fmtDateCell(t.date)"></span>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td x-text="$store.budget.findAccount(t.accountId)?.name || '—'"
                  :data-tip="$store.budget.findAccount(t.accountId)?.name || ''"></td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="col-payee"
                  x-text="t.transferTxnId ? ('Transfer ' + ($store.budget.findAccount(otherSide(t).accountId)?.name || '')) : ($store.budget.payeeName(t.payeeId) || '—')"
                  :data-tip="t.transferTxnId ? 'Paired transfer entry.' : ($store.budget.payeeName(t.payeeId) || '')"></td>
            </template>
            <template x-if="editingId !== t.id">
              <td>
                <span x-show="!t.splits" x-cloak x-text="$store.budget.categoryName(t.categoryId) || (t.transferTxnId ? '' : '—')"
                      :data-tip="$store.budget.categoryName(t.categoryId) || ''"></span>
                <span x-show="t.splits" x-cloak class="badge"
                      :data-tip="'This transaction is split across ' + (t.splits?.length || 0) + ' categories.'">split (<span x-text="t.splits?.length"></span>)</span>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td x-text="t.memo" :data-tip="t.memo || ''" style="color: var(--fg-muted);"></td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="num" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'" x-text="formatCents(t.amount)"
                  :data-tip="(t.amount < 0 ? 'Outflow ' : 'Inflow ') + formatCents(Math.abs(t.amount))"></td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="col-cleared">
                <button type="button"
                        class="cleared-toggle"
                        :aria-pressed="t.cleared.toString()"
                        :aria-label="t.reconciled ? 'Reconciled and locked' : (t.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared')"
                        :data-locked="t.reconciled.toString()"
                        @click="toggleCleared(t)"
                        :data-tip="t.reconciled ? 'Reconciled and locked. Unlock to change.' : (t.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).')">
                  <span x-show="t.cleared" aria-hidden="true">&#10003;</span>
                </button>
              </td>
            </template>
            <template x-if="editingId !== t.id">
              <td class="num">
                <div class="cluster" style="justify-content: flex-end; flex-wrap: nowrap; gap: var(--space-3xs);">
                  <button class="btn btn--icon" type="button" @click="startEdit(t)" x-show="!t.reconciled && !t.transferTxnId"
                          aria-label="Edit transaction"
                          data-tip="Edit this transaction inline.">
                    {# Lucide "pencil" — pencil with eraser end + clear
                       angled body. Matches the trash/split weight. #}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M17 3a2.85 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5z"></path>
                      <line x1="15" y1="5" x2="19" y2="9"></line>
                    </svg>
                  </button>
                  <button class="btn btn--icon" type="button" @click="openSplits(t)" x-show="!t.reconciled && !t.transferTxnId"
                          aria-label="Split transaction"
                          data-tip="Divide this transaction across multiple categories (groceries + household, for example).">
                    {# Lucide "git-fork" — one stem branching into two: the
                       canonical split metaphor. #}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="6" cy="5" r="2"></circle>
                      <circle cx="18" cy="5" r="2"></circle>
                      <circle cx="12" cy="19" r="2"></circle>
                      <path d="M6 7v3a2 2 0 002 2h8a2 2 0 002-2V7"></path>
                      <line x1="12" y1="12" x2="12" y2="17"></line>
                    </svg>
                  </button>
                  <button class="btn btn--icon" type="button" @click="unlock(t)" x-show="t.reconciled"
                          aria-label="Unlock reconciled transaction"
                          data-tip="Unlock this reconciled entry so you can edit it.">
                    {# Lucide "unlock" — shackle hinged open on one side. #}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 019.9-1"></path>
                    </svg>
                  </button>
                  <button class="btn btn--icon" type="button" @click="del(t)" x-show="!t.reconciled"
                          aria-label="Delete transaction"
                          data-tip="Permanently delete this transaction."
                          style="color: var(--danger);">
                    {# Lucide "trash-2" — clearer lid handle and body
                       lines than the hand-rolled trash glyph. #}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"></path>
                      <path d="M10 11v6M14 11v6"></path>
                      <path d="M9 6V4a2 2 0 012-2h2a2 2 0 012 2v2"></path>
                    </svg>
                  </button>
                </div>
              </td>
            </template>

            {# Edit mode #}
            <template x-if="editingId === t.id">
              <td><input class="input" type="date" x-model="edit.date" aria-label="Date" @keydown.escape="cancelEdit()"></td>
            </template>
            <template x-if="editingId === t.id">
              <td>
                <select class="select" x-model="edit.accountId" aria-label="Account">
                  <template x-for="a in openAccounts" :key="a.id">
                    <option :value="a.id" x-text="a.name"></option>
                  </template>
                </select>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td><input class="input" type="text" x-model="edit.payeeName" aria-label="Payee"></td>
            </template>
            <template x-if="editingId === t.id">
              <td>
                <select class="select" x-model="edit.categoryId" aria-label="Category">
                  <option value="">(uncategorized)</option>
                  <template x-for="c in selectableCategories" :key="c.id">
                    <option :value="c.id" x-text="c.name"></option>
                  </template>
                </select>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td><input class="input" type="text" x-model="edit.memo" aria-label="Memo"></td>
            </template>
            <template x-if="editingId === t.id">
              <td class="num"><input class="input" type="text" x-model="edit.amount" inputmode="decimal" aria-label="Amount" style="text-align: right;"></td>
            </template>
            <template x-if="editingId === t.id">
              <td class="col-cleared">
                <button type="button"
                        class="cleared-toggle"
                        :aria-pressed="edit.cleared.toString()"
                        :aria-label="edit.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared'"
                        @click="edit.cleared = !edit.cleared"
                        :data-tip="edit.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'">
                  <span x-show="edit.cleared" aria-hidden="true">&#10003;</span>
                </button>
              </td>
            </template>
            <template x-if="editingId === t.id">
              <td class="num">
                <div class="cluster register__edit-actions">
                  <button class="btn btn--primary btn--sm" type="button" @click="saveEdit()">Save</button>
                  <button class="btn btn--ghost btn--sm" type="button" @click="cancelEdit()">Cancel</button>
                </div>
              </td>
            </template>
          </tr>
        </template>

        <tr x-show="!visibleTransactions().length" x-cloak>
          <td colspan="8" style="text-align: center; padding: var(--space-lg); color: var(--fg-muted);">
            No transactions match the current filter.
          </td>
        </tr>
      </tbody>
    </table>

    {# Mobile card list — replaces the 8-column table under 600px wide. #}
    <ul class="register__cards" x-show="isMobile" x-cloak>
      <template x-for="t in visibleTransactions()" :key="t.id">
        <li class="register__card"
            :class="{ 'is-expanded': expandedTxnId === t.id, 'is-reconciled': t.reconciled, 'is-editing': editingId === t.id }">
          {# Compact summary — tap to expand. Becomes a heading button so it
             is keyboard reachable; the inner card form (when expanded) is
             still tab-navigable normally. #}
          <button type="button" class="register__card-summary"
                  x-show="editingId !== t.id"
                  @click="expandedTxnId = (expandedTxnId === t.id ? null : t.id)"
                  :aria-expanded="(expandedTxnId === t.id).toString()">
            <span class="register__card-date" x-text="t.date"></span>
            <span class="register__card-payee"
                  x-text="t.transferTxnId ? ('Transfer ' + ($store.budget.findAccount(otherSide(t).accountId)?.name || '')) : ($store.budget.payeeName(t.payeeId) || '(no payee)')"></span>
            <span class="register__card-amount"
                  :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="formatCents(t.amount)"></span>
            <span class="register__card-meta">
              <span x-show="!t.splits" x-cloak x-text="$store.budget.categoryName(t.categoryId) || (t.transferTxnId ? 'Transfer' : 'Uncategorized')"></span>
              <span x-show="t.splits" x-cloak class="badge">split (<span x-text="t.splits?.length"></span>)</span>
              <span x-show="t.cleared" x-cloak class="register__card-cleared-flag" aria-label="Cleared">&#10003; cleared</span>
            </span>
          </button>

          {# Expanded details — appear only when this card is the active one
             and not in edit mode. #}
          <div class="register__card-details" x-show="expandedTxnId === t.id && editingId !== t.id" x-cloak>
            <dl class="register__card-dl">
              <div><dt>Account</dt><dd x-text="$store.budget.findAccount(t.accountId)?.name || '—'"></dd></div>
              <div x-show="t.memo" x-cloak><dt>Memo</dt><dd x-text="t.memo"></dd></div>
            </dl>
            <div class="cluster" style="flex-wrap: wrap;">
              <button type="button" class="cleared-toggle"
                      :aria-pressed="t.cleared.toString()"
                      :aria-label="t.reconciled ? 'Reconciled and locked' : (t.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared')"
                      :data-locked="t.reconciled.toString()"
                      @click="toggleCleared(t)"
                      title="Toggle cleared">
                <span x-show="t.cleared" aria-hidden="true">&#10003;</span>
              </button>
              <button class="btn btn--ghost btn--sm" type="button" @click="startEdit(t)" x-show="!t.reconciled && !t.transferTxnId">Edit</button>
              <button class="btn btn--ghost btn--sm" type="button" @click="openSplits(t)" x-show="!t.reconciled && !t.transferTxnId">Split</button>
              <button class="btn btn--ghost btn--sm" type="button" @click="unlock(t)" x-show="t.reconciled">Unlock</button>
              <button class="btn btn--danger btn--sm" type="button" @click="del(t)" x-show="!t.reconciled">Delete</button>
            </div>
          </div>

          {# Inline edit form for mobile — stacked vertically since
             cell-by-cell edit doesn't fit in 360px. #}
          <div class="register__card-edit" x-show="editingId === t.id" x-cloak>
            <div class="field">
              <label class="field__label">Date</label>
              <input class="input" type="date" x-model="edit.date">
            </div>
            <div class="field">
              <label class="field__label">Account</label>
              <select class="select" x-model="edit.accountId">
                <template x-for="a in openAccounts" :key="a.id">
                  <option :value="a.id" x-text="a.name"></option>
                </template>
              </select>
            </div>
            <div class="field">
              <label class="field__label">Payee</label>
              <input class="input" type="text" x-model="edit.payeeName">
            </div>
            <div class="field">
              <label class="field__label">Category</label>
              <select class="select" x-model="edit.categoryId">
                <option value="">(uncategorized)</option>
                <template x-for="c in selectableCategories" :key="c.id">
                  <option :value="c.id" x-text="c.name"></option>
                </template>
              </select>
            </div>
            <div class="field">
              <label class="field__label">Amount</label>
              <input class="input" type="text" x-model="edit.amount" inputmode="decimal" style="text-align: right;">
            </div>
            <div class="field">
              <label class="field__label">Memo</label>
              <input class="input" type="text" x-model="edit.memo">
            </div>
            <span class="cluster" style="gap: var(--space-2xs); align-items: center;">
              <button type="button"
                      class="cleared-toggle"
                      :aria-pressed="edit.cleared.toString()"
                      :aria-label="edit.cleared ? 'Cleared. Click to uncheck.' : 'Mark as cleared'"
                      @click="edit.cleared = !edit.cleared"
                      :data-tip="edit.cleared ? 'Marked as cleared. Click to uncheck.' : 'Mark as cleared (posted at bank).'">
                <span x-show="edit.cleared" aria-hidden="true">&#10003;</span>
              </button>
              <span>Cleared</span>
            </span>
            <div class="form-actions">
              <button class="btn btn--primary btn--sm" type="button" @click="saveEdit()">Save</button>
              <button class="btn btn--ghost btn--sm" type="button" @click="cancelEdit()">Cancel</button>
            </div>
          </div>
        </li>
      </template>

      <li class="register__card-empty" x-show="!visibleTransactions().length" x-cloak>
        No transactions match the current filter.
      </li>
    </ul>
  </section>

  {# Transfer modal #}
  <div class="modal-backdrop" x-show="showTransfer" x-cloak @keydown.escape.window="showTransfer = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showTransfer = false">
      <button class="modal__close" type="button" @click="showTransfer = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">Transfer between accounts</h3>
      <form @submit.prevent="submitTransfer()">
        <div class="form-stack">
          <div class="form-row">
            <div class="field">
              <label class="field__label" for="tr-from">From</label>
              <select class="select" id="tr-from" x-model="transferForm.fromAccountId" required>
                <option value="">Select account</option>
                <template x-for="a in openAccounts" :key="a.id"><option :value="a.id" x-text="a.name"></option></template>
              </select>
            </div>
            <div class="field">
              <label class="field__label" for="tr-to">To</label>
              <select class="select" id="tr-to" x-model="transferForm.toAccountId" required>
                <option value="">Select account</option>
                <template x-for="a in openAccounts" :key="a.id"><option :value="a.id" x-text="a.name"></option></template>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="field">
              <label class="field__label" for="tr-amount">Amount</label>
              <input class="input" id="tr-amount" type="text" x-model="transferForm.amount" inputmode="decimal" placeholder="0.00" required>
            </div>
            <div class="field">
              <label class="field__label" for="tr-date">Date</label>
              <input class="input" id="tr-date" type="date" x-model="transferForm.date" required>
            </div>
          </div>
          <div class="field">
            <label class="field__label" for="tr-memo">Memo (optional)</label>
            <input class="input" id="tr-memo" type="text" x-model="transferForm.memo">
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Transfer</button>
          <button class="btn btn--ghost" type="button" @click="showTransfer = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Reconcile modal #}
  <div class="modal-backdrop" x-show="showReconcile" x-cloak @keydown.escape.window="showReconcile = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showReconcile = false">
      <button class="modal__close" type="button" @click="showReconcile = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">Reconcile account</h3>
      <p style="color: var(--fg-muted);">
        Enter the ending balance from your latest statement. Project Budget will compare it with the cleared balance for the account.
      </p>
      <form @submit.prevent="checkReconcile()">
        <div class="form-row" style="margin-top: var(--space-sm);">
          <div class="field">
            <label class="field__label" for="rc-balance">Statement ending balance</label>
            <input class="input" id="rc-balance" type="text" x-model="reconcileForm.statementBalance" inputmode="decimal" required>
          </div>
          <div class="field">
            <label class="field__label">Cleared in Project Budget</label>
            <p class="input" style="background: var(--bg-alt); margin: 0;" x-text="formatCents($store.budget.accountClearedBalance(filterAccountId))"></p>
          </div>
        </div>

        <div x-show="reconcileForm.checked" x-cloak style="margin-top: var(--space-sm);">
          <p x-show="reconcileForm.diff === 0" style="color: var(--ok);">
            Balances match. You are ready to reconcile.
          </p>
          <p x-show="reconcileForm.diff !== 0" style="color: var(--warn);">
            Difference: <strong x-text="formatCents(reconcileForm.diff)"></strong>.
            You can add an adjustment transaction to close the gap before reconciling.
          </p>
        </div>

        <div class="form-actions">
          <button class="btn btn--secondary" type="submit" x-show="!reconcileForm.checked">Check</button>
          <button class="btn btn--primary" type="button" x-show="reconcileForm.checked && reconcileForm.diff === 0" @click="finishReconcile()">Mark cleared as reconciled</button>
          <button class="btn btn--secondary" type="button" x-show="reconcileForm.checked && reconcileForm.diff !== 0" @click="addAdjustmentAndReconcile()">Add adjustment and reconcile</button>
          <button class="btn btn--ghost" type="button" @click="showReconcile = false">Close</button>
        </div>
      </form>
    </div>
  </div>

  {# Split editor modal #}
  <div class="modal-backdrop" x-show="splitTxnId" x-cloak @keydown.escape.window="splitTxnId = null">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="splitTxnId = null" style="max-width: 720px;">
      <button class="modal__close" type="button" @click="splitTxnId = null" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title">Split transaction</h3>
      <p style="color: var(--fg-muted);">
        Divide this transaction across multiple categories. The sum of the splits becomes the transaction's amount.
      </p>
      <p style="margin-top: var(--space-sm);">
        Current total:
        <strong x-text="formatCents(splitSum())"></strong>
      </p>

      <table class="table" style="margin-top: var(--space-sm);">
        <thead>
          <tr>
            <th>Category</th>
            <th>Memo</th>
            <th class="num">Amount</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <template x-for="(s, i) in splitForm" :key="i">
            <tr>
              <td>
                <select class="select" x-model="s.categoryId">
                  <option value="">(uncategorized)</option>
                  <template x-for="c in selectableCategories" :key="c.id">
                    <option :value="c.id" x-text="c.name"></option>
                  </template>
                </select>
              </td>
              <td><input class="input" type="text" x-model="s.memo"></td>
              <td class="num"><input class="input" type="text" x-model="s.amount" inputmode="decimal" style="text-align: right;"></td>
              <td>
                <button class="modal__close split-remove" type="button"
                        @click="splitForm.splice(i, 1)"
                        aria-label="Remove split row"
                        data-tip="Remove this split row.">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
                </button>
              </td>
            </tr>
          </template>
        </tbody>
      </table>

      <div class="form-actions">
        <button class="btn btn--secondary btn--sm" type="button" @click="splitForm.push({ categoryId: '', memo: '', amount: '' })">Add split row</button>
        <button class="btn btn--primary" type="button" @click="saveSplits()">Save splits</button>
        <button class="btn btn--ghost" type="button" @click="$store.budget.setSplits(splitTxnId, null); splitTxnId = null;">Clear splits</button>
        <button class="btn btn--ghost" type="button" @click="splitTxnId = null">Cancel</button>
      </div>
    </div>
  </div>
</div>

<script>
function registerView() {
  return {
    filterAccountId: "",
    search: "",
    showTransfer: false,
    showReconcile: false,
    editingId: null,
    payeeSuggestions: [],
    due: [],
    splitTxnId: null,
    splitForm: [],
    isMobile: false,
    expandedTxnId: null,
    showAdd: false,

    form: { date: "", payeeName: "", amount: "", accountId: "", categoryId: "", memo: "", cleared: false },
    edit: { date: "", accountId: "", payeeName: "", categoryId: "", memo: "", amount: "", cleared: false },
    transferForm: { fromAccountId: "", toAccountId: "", amount: "", date: "", memo: "" },
    reconcileForm: { statementBalance: "", checked: false, diff: 0 },

    init() {
      var params = new URL(window.location.href).searchParams;
      var acct = params.get("account");
      if (acct) this.filterAccountId = acct;
      /* ?q=<text> — sent from report drill-throughs (e.g. "click a
         payee bar to see all its transactions"). Pre-fills the search
         box; Fuse.js then handles fuzzy matching at render time. */
      var q = params.get("q");
      if (q) this.search = q;
      var today = new Date().toISOString().slice(0, 10);
      this.form.date = today;
      this.transferForm.date = today;
      this.form.accountId = this.filterAccountId || (this.openAccounts[0]?.id || "");
      this.refreshDue();
      /* Mobile/desktop split — below 600px the table is unusable
         (8 columns at 360px). Render compact cards instead. */
      var self = this;
      var mq = window.matchMedia("(max-width: 599px)");
      this.isMobile = mq.matches;
      var onChange = function (e) { self.isMobile = e.matches; };
      if (mq.addEventListener) mq.addEventListener("change", onChange);
      else if (mq.addListener) mq.addListener(onChange);

      /* ?focus=<txnId> — sent from the budget drill-down. Find the
         row and scroll + flash it once Alpine has rendered. The
         row matches via data-txn-id (added on the <tr>). */
      var focusId = params.get("focus");
      if (focusId) {
        this.$nextTick(function () {
          /* Defer one more tick so visibleTransactions() has populated. */
          setTimeout(function () {
            var row = document.querySelector('[data-txn-id="' + focusId + '"]');
            if (!row) return;
            row.scrollIntoView({ behavior: "smooth", block: "center" });
            row.classList.add("register__row--focus");
            setTimeout(function () { row.classList.remove("register__row--focus"); }, 2200);
          }, 60);
        });
      }
    },

    get hasAccounts() {
      return !!(this.$store.budget.profile && this.$store.budget.profile.accounts.some(a => !a.closedAt));
    },

    get openAccounts() {
      var p = this.$store.budget.profile;
      if (!p) return [];
      return p.accounts.filter(a => !a.closedAt).sort((a, b) => a.name.localeCompare(b.name));
    },

    /* Hide payment categories from the dropdown — they're derived, not
       directly selectable. */
    get selectableCategories() {
      var self = this;
      return this.$store.budget.categoriesFlat().filter(c => !self.$store.budget.isPaymentCategory(c.id));
    },

    refreshDue() { this.due = this.$store.budget.dueScheduled(); },
    postNow(id) { this.$store.budget.postScheduled(id); this.refreshDue(); },

    visibleTransactions() {
      /* Touch the list-version counter so Alpine re-runs this when a
         transaction is updated/added/deleted. Without this read, row-level
         x-if fragments that branched between display/edit modes can hold
         stale bindings (e.g. cleared toggle still showing the old state
         after Save). */
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p) return [];
      var q = (this.search || "").trim();
      var self = this;
      var pool = p.transactions
        .filter(t => !self.filterAccountId || t.accountId === self.filterAccountId);
      if (!q) {
        return pool.sort((a, b) => a.date < b.date ? 1 : (a.date > b.date ? -1 : 0));
      }
      /* Fuzzy search via Fuse.js when available; falls back to a plain
         substring match (same behavior as before) for any environment
         where Fuse failed to load. Index is rebuilt per call because the
         caller (Alpine x-for) already does so on every store mutation;
         building Fuse on ~5k rows costs <5ms. */
      if (typeof window.Fuse === "function") {
        var docs = pool.map(t => ({
          t: t,
          payee: self.$store.budget.payeeName(t.payeeId) || "",
          category: self.$store.budget.categoryName(t.categoryId) || "",
          memo: t.memo || "",
          amount: ((t.amount || 0) / 100).toFixed(2),
        }));
        var fuse = new window.Fuse(docs, {
          includeScore: true,
          threshold: 0.35,
          ignoreLocation: true,
          minMatchCharLength: 2,
          keys: [
            { name: "payee",    weight: 3 },
            { name: "category", weight: 1.5 },
            { name: "memo",     weight: 1 },
            { name: "amount",   weight: 0.5 },
          ],
        });
        return fuse.search(q).map(r => r.item.t)
          .sort((a, b) => a.date < b.date ? 1 : (a.date > b.date ? -1 : 0));
      }
      /* Fallback: substring on payee + memo (legacy behavior). */
      var ql = q.toLowerCase();
      return pool.filter(t => {
        var payee = (self.$store.budget.payeeName(t.payeeId) || "").toLowerCase();
        return payee.indexOf(ql) !== -1 || (t.memo || "").toLowerCase().indexOf(ql) !== -1;
      }).sort((a, b) => a.date < b.date ? 1 : (a.date > b.date ? -1 : 0));
    },

    otherSide(t) {
      if (!t.transferTxnId) return t;
      return this.$store.budget.profile.transactions.find(x => x.id === t.transferTxnId) || t;
    },

    formatCents(c) { return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD" }); },

    /* "May 15" big + "2026" muted on one line. Keeps the column narrow
       and easy to scan, while exposing the full ISO via the row's
       data-tip. Uses a span structure so we can style each part. */
    fmtDateCell(iso) {
      if (!iso) return "";
      var parts = iso.split("-").map(Number);
      var d = new Date(parts[0], (parts[1] || 1) - 1, parts[2] || 1);
      var md = d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
      var y  = d.getFullYear();
      return "<strong>" + md + "</strong> " + y;
    },

    parseDollars(s) {
      /* Prefer the YNAB-style calculator parser if it's loaded — lets
         users type "12.50 + 8.99", "100 - 25 * 2", "(50)" etc. and have
         them evaluate before save. Falls back to the simple parser if
         PBCalc hasn't booted (e.g. degraded JS environment). */
      if (s == null || s === "") return 0;
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var clean = String(s).replace(/[$,\s]/g, "").trim();
      if (/^\(.*\)$/.test(clean)) clean = "-" + clean.slice(1, -1);
      var n = Number(clean);
      return isFinite(n) ? Math.round(n * 100) : 0;
    },
    /* "= $X.XX" hint when the user types a math expression in an
       amount input. Empty when no operator is present. */
    calcPreview(s) { return (window.PBCalc ? window.PBCalc.formatExpressionPreview(s) : ""); },

    updateUrl() {
      var base = window.location.pathname;
      var qs = this.filterAccountId ? ("?account=" + this.filterAccountId) : "";
      history.replaceState(null, "", base + qs);
    },

    submitAdd() {
      if (!this.form.accountId) return;
      this.$store.budget.addTransaction({
        accountId: this.form.accountId,
        date: this.form.date,
        payeeName: this.form.payeeName,
        categoryId: this.form.categoryId || null,
        amount: this.parseDollars(this.form.amount),
        memo: this.form.memo,
        cleared: this.form.cleared,
      });
      var keepAccount = this.form.accountId;
      var today = new Date().toISOString().slice(0, 10);
      this.form = { date: today, payeeName: "", amount: "", accountId: keepAccount, categoryId: "", memo: "", cleared: false };
      this.payeeSuggestions = [];
    },

    updatePayeeSuggestions() {
      this.payeeSuggestions = this.$store.budget.suggestPayees(this.form.payeeName, 6);
      /* If a known payee, pre-fill category from its last assignment. */
      var match = this.payeeSuggestions.find(p => p.name.toLowerCase() === (this.form.payeeName || "").toLowerCase());
      if (match && match.lastCategoryId && !this.form.categoryId) {
        this.form.categoryId = match.lastCategoryId;
      }
    },

    pickPayee(p) {
      this.form.payeeName = p.name;
      if (p.lastCategoryId && !this.form.categoryId) this.form.categoryId = p.lastCategoryId;
      this.payeeSuggestions = [];
    },

    startEdit(t) {
      this.editingId = t.id;
      this.edit = {
        date: t.date,
        accountId: t.accountId,
        payeeName: this.$store.budget.payeeName(t.payeeId),
        categoryId: t.categoryId || "",
        memo: t.memo,
        amount: ((t.amount || 0) / 100).toFixed(2),
        cleared: t.cleared,
      };
    },

    saveEdit() {
      if (!this.editingId) return;
      this.$store.budget.updateTransaction(this.editingId, {
        date: this.edit.date,
        accountId: this.edit.accountId,
        payeeName: this.edit.payeeName,
        categoryId: this.edit.categoryId || null,
        memo: this.edit.memo,
        amount: this.parseDollars(this.edit.amount),
        cleared: this.edit.cleared,
      });
      this.editingId = null;
    },

    cancelEdit() { this.editingId = null; },

    toggleCleared(t) {
      if (t.reconciled) return;
      this.$store.budget.updateTransaction(t.id, { cleared: !t.cleared });
    },

    unlock(t) {
      var self = this;
      window.PBDialog.confirm({
        title: "Unlock this reconciled transaction?",
        message: "Reconciled entries are locked so the cleared balance stays in sync with your statement. Unlocking means you'll need to reconcile the account again to re-lock it.",
        confirmLabel: "Unlock transaction",
        danger: true,
      }).then(function (ok) {
        if (ok) self.$store.budget.unlockReconciled(t.id);
      });
    },

    del(t) {
      var self = this;
      window.PBDialog.confirm({
        title: "Delete this transaction?",
        message: "This permanently removes the entry from the register and adjusts the account balance. You can recover it from a profile backup if needed.",
        confirmLabel: "Delete transaction",
        danger: true,
      }).then(function (ok) {
        if (ok) self.$store.budget.deleteTransaction(t.id);
      });
    },

    /* ---- Splits ---- */
    openSplits(t) {
      this.splitTxnId = t.id;
      if (t.splits && t.splits.length) {
        this.splitForm = t.splits.map(s => ({
          categoryId: s.categoryId || "",
          memo: s.memo || "",
          amount: ((s.amount || 0) / 100).toFixed(2),
        }));
      } else {
        this.splitForm = [
          { categoryId: t.categoryId || "", memo: "", amount: ((t.amount || 0) / 100).toFixed(2) },
          { categoryId: "", memo: "", amount: "0.00" },
        ];
      }
    },

    splitSum() {
      var self = this;
      return this.splitForm.reduce(function (sum, s) { return sum + self.parseDollars(s.amount); }, 0);
    },

    saveSplits() {
      if (!this.splitTxnId) return;
      var self = this;
      var splits = this.splitForm
        .filter(s => self.parseDollars(s.amount) !== 0)
        .map(s => ({ categoryId: s.categoryId || null, amount: self.parseDollars(s.amount), memo: s.memo || "" }));
      this.$store.budget.setSplits(this.splitTxnId, splits.length >= 2 ? splits : null);
      this.splitTxnId = null;
    },

    /* ---- Transfer ---- */
    submitTransfer() {
      var f = this.transferForm;
      if (!f.fromAccountId || !f.toAccountId || f.fromAccountId === f.toAccountId) return;
      this.$store.budget.transfer({
        fromAccountId: f.fromAccountId,
        toAccountId: f.toAccountId,
        amount: this.parseDollars(f.amount),
        date: f.date,
        memo: f.memo,
      });
      this.transferForm = { fromAccountId: "", toAccountId: "", amount: "", date: new Date().toISOString().slice(0, 10), memo: "" };
      this.showTransfer = false;
    },

    /* ---- Reconciliation ---- */
    checkReconcile() {
      var cents = this.parseDollars(this.reconcileForm.statementBalance);
      var status = this.$store.budget.reconcileStatus(this.filterAccountId, cents);
      this.reconcileForm.diff = status.diff;
      this.reconcileForm.checked = true;
    },

    finishReconcile() {
      this.$store.budget.applyReconcile(this.filterAccountId);
      this.reconcileForm = { statementBalance: "", checked: false, diff: 0 };
      this.showReconcile = false;
    },

    addAdjustmentAndReconcile() {
      this.$store.budget.addAdjustment(
        this.filterAccountId,
        this.reconcileForm.diff,
        new Date().toISOString().slice(0, 10),
        "Reconciliation adjustment"
      );
      this.$store.budget.applyReconcile(this.filterAccountId);
      this.reconcileForm = { statementBalance: "", checked: false, diff: 0 };
      this.showReconcile = false;
    },
  };
}
</script>
