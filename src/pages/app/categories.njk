---
layout: layouts/app.njk
title: "Categories"
description: "Category groups, categories, and goals. Drag to reorder, drop into another group to move."
permalink: /app/categories/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="categoriesView()">
  <header class="app-page__header">
    <h1 class="app-page__title">Categories</h1>
    <div class="cluster">
      <button class="btn btn--icon" type="button"
              @click="showHelp = true"
              aria-label="About categories"
              data-tip="How groups, categories, goals, and reordering work.">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="8"/><line x1="12" y1="12" x2="12" y2="16"/></svg>
      </button>
      <button class="btn btn--ghost btn--sm" type="button"
              x-show="hasGroups"
              x-cloak
              @click="$store.budget.setAllCatGroupsCollapsed(!$store.budget.allCatGroupsCollapsed())"
              :data-tip="$store.budget.allCatGroupsCollapsed() ? 'Expand every category group at once.' : 'Collapse every category group at once.'"
              x-text="$store.budget.allCatGroupsCollapsed() ? 'Expand all' : 'Collapse all'"></button>
      <button class="btn btn--secondary" type="button" @click="showGroup = true">New group</button>
    </div>
  </header>

  <p class="app-page__lead" x-show="!hasGroups" x-cloak>
    Start by creating a group, then add categories inside it.
  </p>

  {# Stat cards. Live summary of the category list — total groups +
     categories, how many have goals set, and the sum of every monthly
     target. Reuses the .rec-summary chrome from the scheduled page so
     the visual rhythm matches across app pages. #}
  <section class="rec-summary" x-show="hasGroups" x-cloak>
    <div class="rec-summary__tile rec-summary__tile--accent" data-tip="Number of category groups in this profile.">
      <span class="rec-summary__label">Groups</span>
      <span class="rec-summary__value" x-text="groupCount()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--accent" data-tip="Total categories across every group.">
      <span class="rec-summary__label">Categories</span>
      <span class="rec-summary__value" x-text="categoryCount()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--inflow" data-tip="Categories that have a goal set.">
      <span class="rec-summary__label">With goals</span>
      <span class="rec-summary__value" x-text="goalCount() + ' / ' + categoryCount()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--net" data-tip="Sum of every monthly-fixed and top-up goal target.">
      <span class="rec-summary__label">Monthly target</span>
      <span class="rec-summary__value" x-text="formatCents(monthlyTargetCents())"></span>
    </div>
  </section>

  <div data-sortable-list data-sortable-kind="cat-group">
    <template x-for="(group, gIdx) in $store.budget.categoryGroupsView()" :key="group.group ? group.group.id : '__ungrouped'">
      <section class="card cat-group"
               :data-sortable-id="group.group?.id"
               style="margin-bottom: var(--space-md);">
        <header class="cat-group__head" style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-sm); gap: var(--space-sm);">
          <div class="cluster" style="gap: var(--space-2xs); min-width: 0;">
            <span class="dnd-handle"
                  :aria-label="'Drag to reorder group ' + (group.group?.name || '')"
                  x-show="group.group" aria-hidden="false">&#9776;</span>
            {# Collapse toggle — chevron + group title together form
               one clickable affordance. Uses the budget store's
               existing per-group collapse state so the same toggle
               persists across the /app/budget/ + /app/categories/
               views. Ungrouped block has no collapse state. #}
            <button type="button" class="group-toggle"
                    @click="group.group && $store.budget.toggleCategoryGroupCollapsed(group.group.id)"
                    :aria-expanded="group.group && !$store.budget.isCatGroupCollapsed(group.group.id) ? 'true' : 'false'"
                    :disabled="!group.group"
                    :data-tip="group.group ? ($store.budget.isCatGroupCollapsed(group.group.id) ? 'Expand this group.' : 'Collapse this group.') : ''">
              <span class="group-toggle__chevron"
                    :class="group.group && $store.budget.isCatGroupCollapsed(group.group.id) ? 'is-collapsed' : ''"
                    aria-hidden="true">&#9662;</span>
              <h2 class="card__title" style="margin: 0; min-width: 0; overflow: hidden; text-overflow: ellipsis;"
                  x-text="group.group ? group.group.name : 'Ungrouped'"></h2>
              <span class="group-toggle__count" x-show="group.group" x-cloak
                    x-text="group.categories.length + (group.categories.length === 1 ? ' category' : ' categories')"></span>
            </button>
          </div>
          <div class="cluster">
            <button class="btn btn--icon" type="button"
                    x-show="group.group"
                    :disabled="gIdx === 0"
                    @click="$store.budget.moveCategoryGroup(group.group.id, Math.max(0, gIdx - 1))"
                    aria-label="Move group up"
                    data-tip="Move this group up.">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="4 10 8 6 12 10"></polyline>
              </svg>
            </button>
            <button class="btn btn--icon" type="button"
                    x-show="group.group"
                    :disabled="gIdx >= ($store.budget.profile.categoryGroups.length - 1)"
                    @click="$store.budget.moveCategoryGroup(group.group.id, gIdx + 1)"
                    aria-label="Move group down"
                    data-tip="Move this group down.">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="4 6 8 10 12 6"></polyline>
              </svg>
            </button>
            <button class="btn btn--secondary btn--sm" type="button"
                    @click="addCatGroupId = group.group ? group.group.id : ''; addCatName = ''; showCat = true;"
                    :disabled="!group.group">Add category</button>
            <button class="btn btn--ghost btn--sm" type="button"
                    x-show="group.group"
                    @click="PBDialog.prompt({ title: 'Rename group', label: 'Group name', defaultValue: group.group.name, okLabel: 'Rename' }).then(n => { if (n) $store.budget.renameCategoryGroup(group.group.id, n); })">Rename</button>
            <button class="btn btn--danger btn--sm" type="button"
                    x-show="group.group"
                    @click="PBDialog.confirm({ title: 'Remove this group?', message: 'Categories inside this group will be unassigned but kept. Their activity and goals stay intact.', confirmLabel: 'Remove group', danger: true }).then(ok => { if (ok) $store.budget.deleteCategoryGroup(group.group.id); })">Remove</button>
          </div>
        </header>

        <div x-show="!(group.group && $store.budget.isCatGroupCollapsed(group.group.id))" x-cloak>
        <table class="table">
          <thead>
            <tr>
              <th style="width: 2.5rem;" aria-label="Drag handle"></th>
              <th>Category</th>
              <th>Goal</th>
              <th class="num">Target</th>
              <th class="num">Actions</th>
            </tr>
          </thead>
          <tbody data-sortable-list data-sortable-kind="categories" :data-sortable-group-id="group.group?.id || ''">
            <template x-for="(c, cIdx) in group.categories" :key="c.id">
              <tr class="cat-row" :data-sortable-id="c.id">
                <td>
                  <span class="dnd-handle"
                        :aria-label="'Drag to reorder ' + c.name">&#9776;</span>
                </td>
                <td>
                  <span x-text="c.name"></span>
                  <span x-show="$store.budget.isPaymentCategory(c.id)" class="badge" style="margin-left: var(--space-2xs);">card payment</span>
                </td>
                <td x-text="goalLabel(c.id)" style="color: var(--fg-muted);"></td>
                <td class="num" x-text="goalTargetLabel(c.id)"></td>
                <td class="num">
                  <div class="cluster" style="justify-content: flex-end;">
                    <button class="btn btn--icon" type="button"
                            :disabled="cIdx === 0"
                            @click="$store.budget.moveCategory(c.id, group.group?.id, Math.max(0, cIdx - 1))"
                            aria-label="Move category up"
                            data-tip="Move up within this group.">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="4 10 8 6 12 10"></polyline>
                      </svg>
                    </button>
                    <button class="btn btn--icon" type="button"
                            :disabled="cIdx >= (group.categories.length - 1)"
                            @click="$store.budget.moveCategory(c.id, group.group?.id, cIdx + 1)"
                            aria-label="Move category down"
                            data-tip="Move down within this group.">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="4 6 8 10 12 6"></polyline>
                      </svg>
                    </button>
                    <button class="btn btn--ghost btn--sm" type="button" @click="openGoal(c)">Goal</button>
                    <button class="btn btn--ghost btn--sm" type="button"
                            @click="PBDialog.prompt({ title: 'Rename category', label: 'Category name', defaultValue: c.name, okLabel: 'Rename' }).then(n => { if (n) $store.budget.renameCategory(c.id, n); })">Rename</button>
                    <button class="btn btn--danger btn--sm" type="button"
                            x-show="!$store.budget.isPaymentCategory(c.id)"
                            @click="PBDialog.confirm({ title: 'Delete this category?', message: c.name + ' will be removed. Its activity becomes uncategorized but stays in the register. Goals on this category are removed.', confirmLabel: 'Delete category', danger: true }).then(ok => { if (ok) $store.budget.deleteCategory(c.id); })">Delete</button>
                  </div>
                </td>
              </tr>
            </template>
            <tr x-show="!group.categories.length" x-cloak>
              <td colspan="5" style="color: var(--fg-muted); padding: var(--space-sm);">
                No categories yet. Drag one here from another group, or click <em>Add category</em>.
              </td>
            </tr>
          </tbody>
        </table>
        </div>
      </section>
    </template>
  </div>

  {# New group modal #}
  <div class="modal-backdrop" x-show="showGroup" x-cloak @keydown.escape.window="showGroup = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showGroup = false">
      <button class="modal__close" type="button" @click="showGroup = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">New category group</h3>
      <form @submit.prevent="$store.budget.addCategoryGroup(newGroupName); newGroupName = ''; showGroup = false;">
        <div class="field">
          <label class="field__label" for="cg-name">Group name</label>
          <input class="input" id="cg-name" type="text" x-model="newGroupName" required autofocus>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Create group</button>
          <button class="btn btn--ghost" type="button" @click="showGroup = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# New category modal #}
  <div class="modal-backdrop" x-show="showCat" x-cloak @keydown.escape.window="showCat = false">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="showCat = false">
      <button class="modal__close" type="button" @click="showCat = false" aria-label="Close">&times;</button>
      <h3 class="modal__title">New category</h3>
      <form @submit.prevent="$store.budget.addCategory({ groupId: addCatGroupId, name: addCatName }); showCat = false;">
        <div class="field">
          <label class="field__label">Group</label>
          <p class="input" style="background: var(--bg-alt); margin: 0;"
             x-text="$store.budget.findCategoryGroup(addCatGroupId)?.name || ''"></p>
        </div>
        <div class="field" style="margin-top: var(--space-sm);">
          <label class="field__label" for="cat-name">Category name</label>
          <input class="input" id="cat-name" type="text" x-model="addCatName" required autofocus>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Create category</button>
          <button class="btn btn--ghost" type="button" @click="showCat = false">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  {# Info / help modal — hosts the "what is this page" + reorder
     instructions that previously sat above the table as lead copy.
     Pulling them into a modal keeps the header tight and lets us
     show the icon-rich reorder hint without it dominating the page. #}
  <div class="modal-backdrop" x-show="showHelp" x-cloak @keydown.escape.window="showHelp = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="cat-help-title" @click.outside="showHelp = false">
      <button class="modal__close" type="button" @click="showHelp = false" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="cat-help-title">About categories</h3>
      <div class="prose">
        <p>Categories live inside groups (for example: Immediate Obligations, True Expenses, Quality of Life). Add a goal to any category to track how much you should assign each month.</p>
        <p><strong>Reorder:</strong> grab the <span class="dnd-handle dnd-handle--inline" aria-hidden="true"></span> handle to drag a row or group, drop it where you want it. On touch devices use the up / down buttons in the row.</p>
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="showHelp = false">Got it</button>
      </div>
    </div>
  </div>

  {# Goal modal #}
  <div class="modal-backdrop" x-show="goalCatId" x-cloak @keydown.escape.window="goalCatId = null">
    <div class="modal" role="dialog" aria-modal="true" @click.outside="goalCatId = null">
      <button class="modal__close" type="button" @click="goalCatId = null" aria-label="Close">&times;</button>
      <h3 class="modal__title">Goal for <span x-text="$store.budget.categoryName(goalCatId)"></span></h3>
      <form @submit.prevent="saveGoal()">
        <div class="form-stack">
          <div class="field">
            <label class="field__label" for="g-type">Goal type</label>
            <select class="select" id="g-type" x-model="goalForm.type">
              <template x-for="t in $store.budget.GOAL_TYPES" :key="t.value">
                <option :value="t.value" x-text="t.label"></option>
              </template>
            </select>
            <p class="field__hint" x-text="goalTypeHint()"></p>
          </div>
          <div class="form-row">
            <div class="field">
              <label class="field__label" for="g-target">Target amount</label>
              <input class="input" id="g-target" type="text" x-model="goalForm.target" inputmode="decimal" placeholder="0.00" required>
            </div>
            <div class="field" x-show="goalForm.type === 'targetByDate'" x-cloak>
              <label class="field__label" for="g-date">By date</label>
              <input class="input" id="g-date" type="date" x-model="goalForm.byDate">
            </div>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn--primary" type="submit">Save goal</button>
          <button class="btn btn--ghost" type="button" @click="removeGoal()" x-show="$store.budget.findGoal(goalCatId)">Remove goal</button>
          <button class="btn btn--ghost" type="button" @click="goalCatId = null">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function categoriesView() {
  return {
    showHelp: false,
    showGroup: false,
    showCat: false,
    addCatGroupId: "",
    addCatName: "",
    newGroupName: "",
    goalCatId: null,
    goalForm: { type: "monthlyFixed", target: "", byDate: "" },

    /* Drag/drop is handled by SortableJS via
       /assets/js/ui/sortable-bind.js. Markup carries data-sortable-list
       + data-sortable-id; on drop the binding layer calls
       store.moveCategory / moveCategoryGroup. */

    get hasGroups() {
      return !!(this.$store.budget.profile && this.$store.budget.profile.categoryGroups.length);
    },

    parseDollars(s) {
      if (s == null || s === "") return 0;
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var clean = String(s).replace(/[$,\s]/g, "").trim();
      if (/^\(.*\)$/.test(clean)) clean = "-" + clean.slice(1, -1);
      var n = Number(clean);
      return isFinite(n) ? Math.round(n * 100) : 0;
    },
    calcPreview(s) { return (window.PBCalc ? window.PBCalc.formatExpressionPreview(s) : ""); },

    formatCents(c) {
      return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD" });
    },

    /* ---- Stat-card aggregates ---- */
    groupCount() {
      void this.$store.budget._listVersion;
      return this.$store.budget.profile ? this.$store.budget.profile.categoryGroups.length : 0;
    },
    categoryCount() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p) return 0;
      /* Exclude card-payment categories — they're system-created and
         counting them inflates the user-visible category total. */
      var self = this;
      return p.categories.filter(function (c) {
        return !self.$store.budget.isPaymentCategory(c.id);
      }).length;
    },
    goalCount() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p || !p.goals) return 0;
      return p.goals.length;
    },
    monthlyTargetCents() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p || !p.goals) return 0;
      /* Only fixed-monthly and top-up goals carry a clear monthly cost;
         refill-up-to depends on prior balance, target-by-date depends
         on the deadline math. Summing only the deterministic ones
         keeps the headline number honest. */
      return p.goals.reduce(function (sum, g) {
        if (g.type === "monthlyFixed" || g.type === "monthlyTopUp") return sum + (g.target || 0);
        return sum;
      }, 0);
    },

    goalLabel(catId) {
      var g = this.$store.budget.findGoal(catId);
      if (!g) return "—";
      var def = this.$store.budget.GOAL_TYPES.find(t => t.value === g.type);
      return def ? def.label : g.type;
    },

    goalTargetLabel(catId) {
      var g = this.$store.budget.findGoal(catId);
      return g ? this.formatCents(g.target) : "";
    },

    goalTypeHint() {
      switch (this.goalForm.type) {
        case "monthlyFixed": return "Assign at least this amount every month.";
        case "monthlyTopUp": return "Add this amount on top of whatever rolled over from last month.";
        case "refillUpTo":   return "After spending, top the category balance back up to this number.";
        case "targetByDate": return "Save up to this number by the chosen date.";
      }
      return "";
    },

    openGoal(c) {
      this.goalCatId = c.id;
      var g = this.$store.budget.findGoal(c.id);
      if (g) {
        this.goalForm = {
          type: g.type,
          target: ((g.target || 0) / 100).toFixed(2),
          byDate: g.byDate || "",
        };
      } else {
        this.goalForm = { type: "monthlyFixed", target: "", byDate: "" };
      }
    },

    saveGoal() {
      this.$store.budget.addGoal({
        categoryId: this.goalCatId,
        type: this.goalForm.type,
        target: this.parseDollars(this.goalForm.target),
        byDate: this.goalForm.byDate || null,
      });
      this.goalCatId = null;
    },

    removeGoal() {
      this.$store.budget.removeGoal(this.goalCatId);
      this.goalCatId = null;
    },
  };
}
</script>
