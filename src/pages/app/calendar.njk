        outflow += c.totalOutflow || 0;
        count   += (c.posted ? c.posted.length : 0) + (c.scheduled ? c.scheduled.length : 0);
      });
      return { inflow: inflow, outflow: outflow, net: inflow + outflow, count: count };
    },

    /* ---------- year-day modal ----------
