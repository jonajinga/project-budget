---
layout: layouts/app.njk
title: "Calendar"
description: "Day, Week, Month, and Year views of posted transactions and upcoming recurring entries."
permalink: /app/calendar/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="calendarView()" x-init="init()">

  {# ---- Toolbar ---------------------------------------------------- #}
  <header class="cal-toolbar">
    <div class="cal-toolbar__row">
      <div class="cal-toolbar__views" role="tablist" aria-label="Calendar view">
        <template x-for="v in views" :key="v.value">
          <button type="button"
                  class="cal-toolbar__view"
                  role="tab"
                  :class="{ 'is-active': v.value === view }"
                  :aria-selected="(v.value === view).toString()"
                  @click="view = v.value"
                  x-text="v.label"></button>
        </template>
      </div>

      <div class="cal-toolbar__nav">
        <button type="button" class="btn btn--ghost btn--sm"
                @click="step(-1)" :aria-label="'Previous ' + view">&larr;</button>
        <button type="button" class="btn btn--secondary btn--sm"
                @click="jumpToday()">Today</button>
        <button type="button" class="btn btn--ghost btn--sm"
                @click="step(1)" :aria-label="'Next ' + view">&rarr;</button>
        {# Server-side h1 fallback so screen readers + pre-hydration
           crawlers always see a page heading. Alpine swaps in the
           dynamic label (e.g. "May 2026") once hydrated. #}
        <h1 class="cal-toolbar__title" x-text="anchorLabel() || 'Calendar'">Calendar</h1>
      </div>

      {# Right-aligned actions cluster — display toggles + Save view.
         Per-view toggles swap in/out via x-show; Save view is always
         visible. Lives in its own slot so it doesn't crowd the title. #}
      <div class="cal-toolbar__actions">
        <label class="cal-toolbar__toggle"
               :class="showDayTotals ? 'is-on' : ''"
               x-show="view === 'month' || view === 'week' || view === 'day'" x-cloak
               data-tip="Show inline In / Out / Net rollups inside each day cell and each week-number column.">
          <input type="checkbox" x-model="showDayTotals" class="visually-hidden">
          <span class="cal-toolbar__toggle-switch" aria-hidden="true">
            <span class="cal-toolbar__toggle-knob"></span>
          </span>
          <span class="cal-toolbar__toggle-label">Grid totals</span>
        </label>
        <label class="cal-toolbar__toggle"
               :class="yearShowNet ? 'is-on' : ''"
               x-show="view === 'year'" x-cloak
               data-tip="Replace each day's date number with its net $ for the day. Week-number column hides so the cell has room for the amount. Toggle off to return to date numbers.">
          <input type="checkbox" x-model="yearShowNet" class="visually-hidden">
          <span class="cal-toolbar__toggle-switch" aria-hidden="true">
            <span class="cal-toolbar__toggle-knob"></span>
          </span>
          <span class="cal-toolbar__toggle-label">Net $ instead of dates</span>
        </label>
        <button type="button" class="btn btn--ghost btn--sm" @click="saveCurrentView()"
                data-tip="Save this month + view as a recall-able view in /app/templates/.">Save view</button>
      </div>
    </div>

    {# ---- View controls — span selector + display toggles on the
       same row. Visible on day / week / month views. Defaults to 1
       span; the number input accepts any custom value. #}
    <div class="cal-toolbar__row cal-toolbar__row--span"
         x-show="view === 'month' || view === 'week' || view === 'day'" x-cloak>
      <span class="cal-toolbar__span-label"
            x-text="view === 'month' ? 'Months to show:' : (view === 'week' ? 'Weeks to show:' : 'Days to show:')"></span>
      <div class="cal-toolbar__span-buttons" role="group"
           :aria-label="view === 'month' ? 'Number of months' : (view === 'week' ? 'Number of weeks' : 'Number of days')">
        <template x-for="opt in (view === 'month' ? monthSpanPresets : (view === 'week' ? weekSpanPresets : daySpanPresets))" :key="opt.value">
          <button type="button"
                  class="cal-toolbar__span-btn"
                  :class="{ 'is-active': (view === 'month' ? monthSpan : (view === 'week' ? weekSpan : daySpan)) === opt.value }"
                  @click="setSpan(opt.value)"
                  x-text="opt.label"></button>
        </template>
        <label class="cal-toolbar__span-custom">
          <span class="visually-hidden">Custom number</span>
          <input type="number" min="1" max="60" step="1"
                 :value="view === 'month' ? monthSpan : (view === 'week' ? weekSpan : daySpan)"
                 @change="setSpan(parseInt($event.target.value, 10) || 1)"
                 data-tip="Type any number from 1 to 60.">
        </label>
      </div>
    </div>

    {# Mobile disclosure — hides the search + filter row behind a
       "Filters" button on phones so the calendar grid lands above
       the fold. Hidden on tablet+ (filters always visible). #}
    <button type="button"
            class="btn btn--ghost btn--sm cal-toolbar__filters-toggle"
            @click="filtersOpen = !filtersOpen"
            :aria-expanded="filtersOpen.toString()"
            data-tip="Show or hide search + account/kind filters."
            x-text="filtersOpen ? 'Hide filters' : 'Filters' + ((searchQuery || filterAccountId || filterKind !== 'all') ? ' · active' : '')"></button>

    <div class="cal-toolbar__row cal-toolbar__row--filters"
         :data-collapsed="(!filtersOpen).toString()">
      <div class="field cal-toolbar__search">
        <label class="visually-hidden" for="cal-search">Search payee, memo, category</label>
        <input class="input" id="cal-search" type="search"
               x-model="searchQuery"
               placeholder="Search payee, memo, category…">
      </div>
      <div class="field cal-toolbar__filter">
        <label class="visually-hidden" for="cal-account">Account filter</label>
        <select class="select" id="cal-account" x-model="filterAccountId">
          <option value="">All accounts</option>
          <template x-for="a in openAccounts()" :key="a.id">
            <option :value="a.id" x-text="a.name"></option>
          </template>
        </select>
      </div>
      <div class="field cal-toolbar__filter">
        <label class="visually-hidden" for="cal-kind">Kind filter</label>
        <select class="select" id="cal-kind" x-model="filterKind">
          <option value="all">Posted + Scheduled</option>
          <option value="posted">Posted only</option>
          <option value="scheduled">Scheduled only</option>
          <option value="inflow">Inflows only</option>
          <option value="outflow">Outflows only</option>
        </select>
      </div>
      <p class="cal-toolbar__count" x-show="searchQuery || filterAccountId || filterKind !== 'all'" x-cloak>
        <span x-text="visibleCount()"></span> matching entries in view
      </p>
    </div>
  </header>

  <p class="app-page__lead" x-show="!$store.budget.profile" x-cloak>
    Load or create a profile to see its calendar.
  </p>

  {# ---- Year view --------------------------------------------------- #}
  <section x-show="$store.budget.profile && view === 'year'" x-cloak>
    <dl class="cal-period-totals" aria-label="Year totals">
      <div class="cal-period-totals__tile"
           :data-tip="'Total money in across the visible year: ' + formatCents(yearTotals().inflow) + '.'">
        <dt>Inflow</dt>
        <dd class="amount--inflow" x-text="formatCents(yearTotals().inflow)"></dd>
      </div>
      <div class="cal-period-totals__tile"
           :data-tip="'Total money out across the visible year: ' + formatCents(yearTotals().outflow) + '.'">
        <dt>Outflow</dt>
        <dd class="amount--outflow" x-text="formatCents(yearTotals().outflow)"></dd>
      </div>
      <div class="cal-period-totals__tile"
           :data-tip="'Net = inflow + outflow for the year. Positive means more money came in than went out.'">
        <dt>Net</dt>
        <dd :class="yearTotals().net < 0 ? 'amount--outflow' : 'amount--inflow'" x-text="formatCents(yearTotals().net)"></dd>
      </div>
      <div class="cal-period-totals__tile cal-period-totals__tile--muted"
           :data-tip="'Number of entries (posted + scheduled) visible in this year.'">
        <dt>Entries</dt>
        <dd x-text="yearTotals().count"></dd>
      </div>
    </dl>

  <div class="cal-year">
    <template x-for="mm in monthsOfYear()" :key="mm.iso">
      <article class="cal-mini" :class="yearShowNet ? 'cal-mini--net' : ''">
        <header class="cal-mini__head">
          <button type="button" class="cal-mini__title-btn"
                  @click="view = 'month'; anchorISO = mm.iso + '-01'"
                  :aria-label="'Open ' + mm.label">
            <h2 class="cal-mini__title" x-text="mm.label"></h2>
          </button>
          {# Labeled stats — IN / OUT / NET for the month. In and Out
             are clickable to open the period transactions modal. #}
          <dl class="cal-mini__totals" aria-label="Month totals">
            <button type="button" class="cal-mini__stat cal-mini__stat--clickable"
                    @click="openPeriodModal('Inflows — ' + mm.label, 'Money in for the month', 'in', miniCells(mm.iso))"
                    data-tip="See every inflow in this month.">
              <dt>In</dt>
              <dd class="amount--inflow" x-text="formatCents(miniMonthTotals(mm.iso).inflow)"></dd>
            </button>
            <button type="button" class="cal-mini__stat cal-mini__stat--clickable"
                    @click="openPeriodModal('Outflows — ' + mm.label, 'Money out for the month', 'out', miniCells(mm.iso))"
                    data-tip="See every outflow in this month.">
              <dt>Out</dt>
              <dd class="amount--outflow" x-text="formatCents(miniMonthTotals(mm.iso).outflow)"></dd>
            </button>
            <div class="cal-mini__stat cal-mini__stat--net">
              <dt>Net</dt>
              <dd :class="miniMonthTotals(mm.iso).net < 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="formatCents(miniMonthTotals(mm.iso).net)"></dd>
            </div>
          </dl>
        </header>
        {# Header row: WK label on the left, 7 weekday initials on
           the right. Mirrors .cal-mini__row's flex layout so the
           columns line up vertically with the day cells below. #}
        <div class="cal-mini__row cal-mini__row--head" aria-hidden="true">
          <span class="cal-mini__wknum cal-mini__wknum--head">Wk</span>
          <div class="cal-mini__row-cells cal-mini__row-cells--weekdays">
            <span>S</span><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span>
          </div>
        </div>
        {# One row per week. Leading column is the ISO week number
           (clickable to open the period modal scoped to that week);
           the day cells live in a nested 7-col grid so the parent
           flex layout can't break across rows. #}
        <div class="cal-mini__rows">
          <template x-for="wk in miniWeeks(mm.iso)" :key="wk.weekKey">
            <div class="cal-mini__row">
              <button type="button"
                      class="cal-mini__wknum cal-mini__wknum--btn"
                      :disabled="!wk.startISO"
                      @click="wk.startISO && openPeriodModal('Week ' + wk.weekNumber + ' — ' + mm.label, 'Money in/out + entries for week ' + wk.weekNumber, 'all', wk.cells)"
                      :data-tip="wk.startISO ? ('Week ' + wk.weekNumber + ' · In ' + formatCents(_periodTotalsFor(wk.cells).inflow) + ' · Out ' + formatCents(_periodTotalsFor(wk.cells).outflow) + ' · Net ' + formatCents(_periodTotalsFor(wk.cells).net) + ' · ' + _periodTotalsFor(wk.cells).count + ' entries') : ''"
                      x-text="wk.weekNumber"></button>
              <div class="cal-mini__row-cells">
                <template x-for="cell in wk.cells" :key="cell.key">
                  <span class="cal-mini__cell"
                        :class="{
                          'cal-mini__cell--blank': cell.blank,
                          'cal-mini__cell--today': cell.isToday,
                          'cal-mini__cell--has':   !cell.blank && cell.count > 0,
                          'cal-mini__cell--hot':   !cell.blank && (cell.intensity || 0) >= 25
                        }"
                        :style="!cell.blank && cell.intensity > 0 ? ('--intensity: ' + cell.intensity) : ''">
                    <button type="button"
                            x-show="!cell.blank"
                            class="cal-mini__day"
                            :class="yearShowNet ? 'cal-mini__day--net' : ''"
                            @click="openYearDay(cell.iso)"
                            :aria-label="'Open ' + cell.iso">
                      <span x-show="!yearShowNet" x-text="cell.day"></span>
                      <span x-show="yearShowNet"
                            :class="(cell.totalInflow + cell.totalOutflow) < 0 ? 'amount--outflow' : ((cell.totalInflow + cell.totalOutflow) > 0 ? 'amount--inflow' : 'cal-mini__day-zero')"
                            x-text="(cell.totalInflow + cell.totalOutflow) === 0 ? '·' : fmtCompact(cell.totalInflow + cell.totalOutflow)"></span>
                    </button>
                  </span>
                </template>
              </div>
            </div>
          </template>
        </div>
      </article>
    </template>
  </div>
  </section>

  {# ---- Month view -------------------------------------------------- #}
  <section x-show="$store.budget.profile && view === 'month'" x-cloak>
    {# Primary month-view block — wrapped in the same .cal-extra-month
       card chrome as the extras below so all month blocks look
       identical. Header drops the --primary modifier. #}
    <article class="cal-extra-month">
    <header class="cal-extra-month__head">
      <h3 class="cal-extra-month__title" x-text="monthLabel(anchorMonthISO())"></h3>
      <dl class="cal-extra-period__totals" aria-label="Month totals">
        <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                @click="openPeriodModal('Inflows — ' + monthLabel(anchorMonthISO()), 'Money in for the month', 'in', monthCells())"
                data-tip="See every inflow in this month.">
          <dt>In</dt>
          <dd class="amount--inflow" x-text="formatCents(monthTotals().inflow)"></dd>
        </button>
        <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                @click="openPeriodModal('Outflows — ' + monthLabel(anchorMonthISO()), 'Money out for the month', 'out', monthCells())"
                data-tip="See every outflow in this month.">
          <dt>Out</dt>
          <dd class="amount--outflow" x-text="formatCents(monthTotals().outflow)"></dd>
        </button>
        <div class="cal-extra-period__stat cal-extra-period__stat--net">
          <dt>Net</dt>
          <dd :class="monthTotals().net < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="formatCents(monthTotals().net)"></dd>
        </div>
        <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                @click="openPeriodModal('All entries — ' + monthLabel(anchorMonthISO()), 'Every transaction in the month', 'all', monthCells())"
                data-tip="See every entry in this month.">
          <dt>Entries</dt>
          <dd x-text="monthTotals().count"></dd>
        </button>
      </dl>
    </header>

  <div class="cal" :class="{ 'cal--no-totals': !showDayTotals }">
    <div class="cal__main">
    {# Header row mirrors the row layout below: WK column + 7 day
       labels in their own grid container. #}
    <div class="cal__weekdays" aria-hidden="true">
      <span class="cal__wknum cal__wknum--head">Wk</span>
      <div class="cal__weekdays-days">
        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>
    </div>
    {# One row per week. Leading column is the ISO week-number
       button (clickable to open the period transactions modal
       scoped to that week's cells); the day cells live in a nested
       7-col grid so the parent flex layout can't break across rows. #}
    <div class="cal__grid" role="grid" :aria-label="'Calendar for ' + monthLabel(anchorMonthISO())">
      <template x-for="wk in monthWeeks()" :key="wk.weekKey">
        <div class="cal__week-row">
          <button type="button"
                  class="cal__wknum cal__wknum--btn"
                  :disabled="!wk.startISO"
                  @click="wk.startISO && openPeriodModal('Week ' + wk.weekNumber + ' — ' + monthLabel(anchorMonthISO()), 'Money in/out + entries for week ' + wk.weekNumber, 'all', wk.cells)"
                  :data-tip="wk.startISO ? ('Week ' + wk.weekNumber + ' · click to see every entry') : ''">
            <span class="cal__wknum-num">Wk <span x-text="wk.weekNumber"></span></span>
            <template x-if="showDayTotals && wk.startISO && _periodTotalsFor(wk.cells).count > 0">
              <span class="cal__wknum-stats">
                <span class="cal__wknum-stat" x-show="_periodTotalsFor(wk.cells).inflow > 0">
                  <span class="cal__wknum-stat-label">In</span>
                  <span class="cal__wknum-stat-value amount--inflow"
                        x-text="fmtCompact(_periodTotalsFor(wk.cells).inflow)"></span>
                </span>
                <span class="cal__wknum-stat" x-show="_periodTotalsFor(wk.cells).outflow < 0">
                  <span class="cal__wknum-stat-label">Out</span>
                  <span class="cal__wknum-stat-value amount--outflow"
                        x-text="fmtCompact(_periodTotalsFor(wk.cells).outflow)"></span>
                </span>
                <span class="cal__wknum-stat cal__wknum-stat--net">
                  <span class="cal__wknum-stat-label">Net</span>
                  <span class="cal__wknum-stat-value"
                        :class="_periodTotalsFor(wk.cells).net < 0 ? 'amount--outflow' : 'amount--inflow'"
                        x-text="fmtCompact(_periodTotalsFor(wk.cells).net)"></span>
                </span>
                <span class="cal__wknum-stat">
                  <span class="cal__wknum-stat-label">Entries</span>
                  <span class="cal__wknum-stat-value"
                        x-text="_periodTotalsFor(wk.cells).count"></span>
                </span>
              </span>
            </template>
          </button>
          <div class="cal__week-row-cells">
      <template x-for="cell in wk.cells" :key="cell.key">
        <div class="cal__cell"
            :class="{
              'cal__cell--blank':    cell.blank,
              'cal__cell--today':    cell.isToday,
              'cal__cell--selected': cell.iso && cell.iso === selectedISO,
              'cal__cell--has':      !cell.blank && (cell.posted.length + cell.scheduled.length) > 0,
              'cal__cell--other-month': cell.otherMonth
            }">
          <template x-if="!cell.blank">
            <div class="cal__cell-inner">
              <button type="button"
                      class="cal__day-btn"
                      @click="selectedISO = cell.iso"
                      @dblclick="view = 'day'; anchorISO = cell.iso"
                      :aria-label="'Open ' + cell.iso">
                <span class="cal__day-num" x-text="cell.day"></span>
              </button>

              {# Entry list — mirrors the week-view card style so a
                 month cell reads as a mini day-column. Cap at 3 to keep
                 cells from blowing past row height. #}
              <ul class="cal__entries" x-show="(cell.posted || []).length + (cell.scheduled || []).length > 0">
                <template x-for="t in (cell.posted || []).slice(0, 3)" :key="'p-' + t.id">
                  <li>
                    <button type="button"
                            class="cal__entry cal__entry--clickable"
                            :class="t.amount < 0 ? 'cal__entry--out' : 'cal__entry--in'"
                            @click.stop="openTxn(t.id)">
                      <span class="cal__entry-payee"
                            x-text="$store.budget.payeeName(t.payeeId) || (t.transferTxnId ? 'Transfer' : '—')"></span>
                      <span class="cal__entry-amt"
                            :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                            x-text="fmtCompact(t.amount)"></span>
                    </button>
                  </li>
                </template>
                <template x-for="s in (cell.scheduled || []).slice(0, Math.max(0, 3 - (cell.posted || []).length))" :key="'s-' + s.id">
                  <li>
                    <a class="cal__entry cal__entry--clickable cal__entry--scheduled"
                       :href="'/app/scheduled/#edit-' + s.id"
                       @click.stop>
                      <span class="cal__entry-payee"
                            x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></span>
                      <span class="cal__entry-amt"
                            :class="s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                            x-text="fmtCompact(s.template.amount)"></span>
                    </a>
                  </li>
                </template>
                <li x-show="((cell.posted || []).length + (cell.scheduled || []).length) > 3" x-cloak>
                  <button type="button"
                          class="cal__entry-more"
                          @click="selectedISO = cell.iso"
                          x-text="'+ ' + (((cell.posted || []).length + (cell.scheduled || []).length) - 3) + ' more'"></button>
                </li>
              </ul>

              {# Per-day rollup — In / Out on one compact row, Net on
                 its own emphasized row beneath. Uses fmtCompact so
                 even at narrow cell widths the digits fit. Hidden
                 via the showDayTotals toolbar toggle. #}
              <div class="cal__cell-totals"
                   x-show="showDayTotals && (cell.totalInflow !== 0 || cell.totalOutflow !== 0)"
                   x-cloak>
                <div class="cal__cell-totals-row">
                  <span class="cal__cell-total cal__cell-total--in"
                        x-show="cell.totalInflow > 0" x-cloak>
                    <span class="cal__cell-total-label">In</span>
                    <span class="cal__cell-total-value amount--inflow"
                          x-text="fmtCompact(cell.totalInflow)"></span>
                  </span>
                  <span class="cal__cell-total cal__cell-total--out"
                        x-show="cell.totalOutflow < 0" x-cloak>
                    <span class="cal__cell-total-label">Out</span>
                    <span class="cal__cell-total-value amount--outflow"
                          x-text="fmtCompact(cell.totalOutflow)"></span>
                  </span>
                </div>
                <div class="cal__cell-total cal__cell-total--net">
                  <span class="cal__cell-total-label">Net</span>
                  <span class="cal__cell-total-value"
                        :class="(cell.totalInflow + cell.totalOutflow) < 0 ? 'amount--outflow' : 'amount--inflow'"
                        x-text="fmtCompact(cell.totalInflow + cell.totalOutflow)"></span>
                </div>
              </div>
            </div>
          </template>
        </div>
      </template>
          </div>
        </div>
      </template>
    </div>
    </div>

  </div>
  </article>

  {# Extra months (when monthSpan > 1) — stacked beneath the primary
     grid. Each gets its own header label + grid. No detail panel per
     extra month — the single global detail aside above stays in sync. #}
  <template x-for="mb in monthsToRender().slice(1)" :key="mb.monthISO">
    <article class="cal-extra-month">
      <header class="cal-extra-month__head">
        <h3 class="cal-extra-month__title" x-text="mb.label"></h3>
        <dl class="cal-extra-period__totals" aria-label="Month totals">
          <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                  @click="openPeriodModal('Inflows — ' + mb.label, 'Money in for the month', 'in', monthCellsFor(mb.anchorISO))"
                  data-tip="See every inflow in this month.">
            <dt>In</dt>
            <dd class="amount--inflow" x-text="formatCents(_periodTotalsFor(monthCellsFor(mb.anchorISO)).inflow)"></dd>
          </button>
          <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                  @click="openPeriodModal('Outflows — ' + mb.label, 'Money out for the month', 'out', monthCellsFor(mb.anchorISO))"
                  data-tip="See every outflow in this month.">
            <dt>Out</dt>
            <dd class="amount--outflow" x-text="formatCents(_periodTotalsFor(monthCellsFor(mb.anchorISO)).outflow)"></dd>
          </button>
          <div class="cal-extra-period__stat cal-extra-period__stat--net">
            <dt>Net</dt>
            <dd :class="_periodTotalsFor(monthCellsFor(mb.anchorISO)).net < 0 ? 'amount--outflow' : 'amount--inflow'"
                x-text="formatCents(_periodTotalsFor(monthCellsFor(mb.anchorISO)).net)"></dd>
          </div>
          <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                  @click="openPeriodModal('All entries — ' + mb.label, 'Every transaction in the month', 'all', monthCellsFor(mb.anchorISO))"
                  data-tip="See every entry in this month.">
            <dt>Entries</dt>
            <dd x-text="_periodTotalsFor(monthCellsFor(mb.anchorISO)).count"></dd>
          </button>
        </dl>
      </header>
      {# Mirror the primary month-view's row-based structure: header
         row with WK label + 7 day labels, then one .cal__week-row
         per week containing the WK button + a nested 7-col grid of
         cells. The old flat .cal__cell-under-ol layout no longer
         had matching CSS rules (the .cal__grid rules expect
         .cal__week-row children), so the extra months were
         collapsing into a single vertical column. #}
      <div class="cal__weekdays" aria-hidden="true">
        <span class="cal__wknum cal__wknum--head">Wk</span>
        <div class="cal__weekdays-days">
          <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
        </div>
      </div>
      <div class="cal__grid" role="grid" :aria-label="'Calendar for ' + mb.label">
        <template x-for="wk in monthWeeks(mb.anchorISO)" :key="'mw-' + mb.monthISO + '-' + wk.weekKey">
          <div class="cal__week-row">
            <button type="button"
                    class="cal__wknum cal__wknum--btn"
                    :disabled="!wk.startISO"
                    @click="wk.startISO && openPeriodModal('Week ' + wk.weekNumber + ' — ' + mb.label, 'Money in/out + entries for week ' + wk.weekNumber, 'all', wk.cells)"
                    :data-tip="wk.startISO ? ('Week ' + wk.weekNumber + ' · click to see every entry') : ''">
              <span class="cal__wknum-num">Wk <span x-text="wk.weekNumber"></span></span>
            </button>
            <div class="cal__week-row-cells">
              <template x-for="cell in wk.cells" :key="'mc-' + mb.monthISO + '-' + cell.key">
                <div class="cal__cell"
                     :class="{
                       'cal__cell--blank':    cell.blank,
                       'cal__cell--today':    cell.isToday,
                       'cal__cell--selected': cell.iso && cell.iso === selectedISO,
                       'cal__cell--has':      !cell.blank && (cell.posted.length + cell.scheduled.length) > 0,
                       'cal__cell--other-month': cell.otherMonth
                     }">
                  <template x-if="!cell.blank">
                    <div class="cal__cell-inner">
                      <button type="button" class="cal__day-btn"
                              @click="selectedISO = cell.iso"
                              @dblclick="view = 'day'; anchorISO = cell.iso"
                              :aria-label="'Open ' + cell.iso">
                        <span class="cal__day-num" x-text="cell.day"></span>
                      </button>
                      <ul class="cal__entries" x-show="(cell.posted || []).length + (cell.scheduled || []).length > 0">
                        <template x-for="t in (cell.posted || []).slice(0, 3)" :key="'mp-' + mb.monthISO + '-' + t.id">
                          <li>
                            <button type="button" class="cal__entry cal__entry--clickable"
                                    :class="t.amount < 0 ? 'cal__entry--out' : 'cal__entry--in'"
                                    @click.stop="openTxn(t.id)">
                              <span class="cal__entry-payee" x-text="$store.budget.payeeName(t.payeeId) || (t.transferTxnId ? 'Transfer' : '—')"></span>
                              <span class="cal__entry-amt" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                                    x-text="fmtCompact(t.amount)"></span>
                            </button>
                          </li>
                        </template>
                        <template x-for="s in (cell.scheduled || []).slice(0, Math.max(0, 3 - (cell.posted || []).length))" :key="'ms-' + mb.monthISO + '-' + s.id">
                          <li>
                            <a class="cal__entry cal__entry--clickable cal__entry--scheduled"
                               :href="'/app/scheduled/#edit-' + s.id"
                               @click.stop>
                              <span class="cal__entry-payee" x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></span>
                              <span class="cal__entry-amt" :class="s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                                    x-text="fmtCompact(s.template.amount)"></span>
                            </a>
                          </li>
                        </template>
                        <li x-show="((cell.posted || []).length + (cell.scheduled || []).length) > 3" x-cloak>
                          <button type="button" class="cal__entry-more"
                                  @click="selectedISO = cell.iso"
                                  x-text="'+ ' + (((cell.posted || []).length + (cell.scheduled || []).length) - 3) + ' more'"></button>
                        </li>
                      </ul>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </div>
        </template>
      </div>
    </article>
  </template>
  </section>

  {# ---- Week view --------------------------------------------------- #}
  <section x-show="$store.budget.profile && view === 'week'" x-cloak>
    {# Primary week-view block — wrapped in the same .cal-extra-week
       card chrome as the extras below for visual consistency. #}
    <article class="cal-extra-week">
    <header class="cal-extra-week__head">
      <h3 class="cal-extra-week__title" x-text="anchorLabel()"></h3>
      <dl class="cal-extra-period__totals" aria-label="Week totals">
        <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                @click="openPeriodModal('Inflows — ' + anchorLabel(), 'Money in for the week', 'in', weekCells())"
                data-tip="See every inflow in this week.">
          <dt>In</dt>
          <dd class="amount--inflow" x-text="formatCents(weekTotals().inflow)"></dd>
        </button>
        <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                @click="openPeriodModal('Outflows — ' + anchorLabel(), 'Money out for the week', 'out', weekCells())"
                data-tip="See every outflow in this week.">
          <dt>Out</dt>
          <dd class="amount--outflow" x-text="formatCents(weekTotals().outflow)"></dd>
        </button>
        <div class="cal-extra-period__stat cal-extra-period__stat--net">
          <dt>Net</dt>
          <dd :class="weekTotals().net < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="formatCents(weekTotals().net)"></dd>
        </div>
        <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                @click="openPeriodModal('All entries — ' + anchorLabel(), 'Every transaction in the week', 'all', weekCells())"
                data-tip="See every entry in this week.">
          <dt>Entries</dt>
          <dd x-text="weekTotals().count"></dd>
        </button>
      </dl>
    </header>

  <div class="cal-week">
    <ol class="cal-week__strip">
      <template x-for="cell in weekCells()" :key="cell.iso">
        <li class="cal-week__day"
            :class="{
              'is-today': cell.isToday,
              'is-empty': !(cell.posted.length + cell.scheduled.length)
            }">
          <header class="cal-week__head">
            <p class="cal-week__weekday" x-text="cell.weekday"></p>
            <p class="cal-week__date">
              <button type="button" class="cal-week__date-btn"
                      @click="view = 'day'; anchorISO = cell.iso"
                      :aria-label="'Open ' + cell.iso">
                <span x-text="cell.dayMonth"></span>
              </button>
            </p>
          </header>
          <ul class="cal-week__list" x-show="cell.posted.length + cell.scheduled.length">
            <template x-for="t in cell.posted" :key="'p' + t.id">
              <li>
                <button type="button"
                        class="cal-week__entry cal-week__entry--posted cal-week__entry--clickable"
                        @click="openTxn(t.id)">
                  <span class="cal-week__entry-payee" x-text="$store.budget.payeeName(t.payeeId) || (t.transferTxnId ? 'Transfer' : '—')"></span>
                  <span class="cal-week__entry-amt" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                        x-text="formatCents(t.amount)"></span>
                </button>
              </li>
            </template>
            <template x-for="s in cell.scheduled" :key="'s' + s.id">
              <li>
                <a class="cal-week__entry cal-week__entry--scheduled cal-week__entry--clickable"
                   :href="'/app/scheduled/#edit-' + s.id"
                   title="Scheduled (not posted)">
                  <span class="cal-week__entry-payee" x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></span>
                  <span class="cal-week__entry-amt" :class="s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                        x-text="formatCents(s.template.amount)"></span>
                </a>
              </li>
            </template>
          </ul>
          <p class="cal-week__empty" x-show="!(cell.posted.length + cell.scheduled.length)" x-cloak>—</p>
          {# Per-day totals — pinned to the bottom via margin-top: auto
             on .cal-week__totals so In/Out/Net line up across the row
             even when each day has different entry counts. Hidden
             via the showDayTotals toolbar toggle. #}
          <dl class="cal-week__totals"
              x-show="showDayTotals && (cell.totalInflow !== 0 || cell.totalOutflow !== 0)"
              x-cloak>
            <div class="cal-week__total" x-show="cell.totalInflow > 0" x-cloak>
              <dt>In</dt>
              <dd class="amount--inflow" x-text="formatCents(cell.totalInflow)"></dd>
            </div>
            <div class="cal-week__total" x-show="cell.totalOutflow < 0" x-cloak>
              <dt>Out</dt>
              <dd class="amount--outflow" x-text="formatCents(cell.totalOutflow)"></dd>
            </div>
            <div class="cal-week__total cal-week__total--net">
              <dt>Net</dt>
              <dd :class="(cell.totalInflow + cell.totalOutflow) < 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="formatCents(cell.totalInflow + cell.totalOutflow)"></dd>
            </div>
          </dl>
        </li>
      </template>
    </ol>
  </div>
  </article>

  {# Extra weeks (when weekSpan > 1) — stacked below the primary
     strip. Each extra week has its own label header + 7-day strip. #}
  <template x-for="wb in weeksToRender().slice(1)" :key="wb.startISO">
    <article class="cal-extra-week">
      <header class="cal-extra-week__head">
        <h3 class="cal-extra-week__title" x-text="wb.label"></h3>
        <dl class="cal-extra-period__totals" aria-label="Week totals">
          <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                  @click="openPeriodModal('Inflows — ' + wb.label, 'Money in for the week', 'in', weekCellsFor(wb.startISO))"
                  data-tip="See every inflow in this week.">
            <dt>In</dt>
            <dd class="amount--inflow" x-text="formatCents(_periodTotalsFor(weekCellsFor(wb.startISO)).inflow)"></dd>
          </button>
          <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                  @click="openPeriodModal('Outflows — ' + wb.label, 'Money out for the week', 'out', weekCellsFor(wb.startISO))"
                  data-tip="See every outflow in this week.">
            <dt>Out</dt>
            <dd class="amount--outflow" x-text="formatCents(_periodTotalsFor(weekCellsFor(wb.startISO)).outflow)"></dd>
          </button>
          <div class="cal-extra-period__stat cal-extra-period__stat--net">
            <dt>Net</dt>
            <dd :class="_periodTotalsFor(weekCellsFor(wb.startISO)).net < 0 ? 'amount--outflow' : 'amount--inflow'"
                x-text="formatCents(_periodTotalsFor(weekCellsFor(wb.startISO)).net)"></dd>
          </div>
          <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                  @click="openPeriodModal('All entries — ' + wb.label, 'Every transaction in the week', 'all', weekCellsFor(wb.startISO))"
                  data-tip="See every entry in this week.">
            <dt>Entries</dt>
            <dd x-text="_periodTotalsFor(weekCellsFor(wb.startISO)).count"></dd>
          </button>
        </dl>
      </header>
      <ol class="cal-week__strip">
        <template x-for="cell in weekCellsFor(wb.startISO)" :key="'w' + wb.startISO + cell.iso">
          <li class="cal-week__day"
              :class="{ 'is-today': cell.isToday,
                        'is-empty': !(cell.posted.length + cell.scheduled.length) }">
            <header class="cal-week__head">
              <p class="cal-week__weekday" x-text="cell.weekday"></p>
              <p class="cal-week__date">
                <button type="button" class="cal-week__date-btn"
                        @click="view = 'day'; anchorISO = cell.iso"
                        :aria-label="'Open ' + cell.iso">
                  <span x-text="cell.dayMonth"></span>
                </button>
              </p>
            </header>
            <ul class="cal-week__list" x-show="cell.posted.length + cell.scheduled.length">
              <template x-for="t in cell.posted" :key="'p' + wb.startISO + t.id">
                <li>
                  <button type="button"
                          class="cal-week__entry cal-week__entry--posted cal-week__entry--clickable"
                          @click="openTxn(t.id)">
                    <span class="cal-week__entry-payee" x-text="$store.budget.payeeName(t.payeeId) || (t.transferTxnId ? 'Transfer' : '—')"></span>
                    <span class="cal-week__entry-amt" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                          x-text="formatCents(t.amount)"></span>
                  </button>
                </li>
              </template>
              <template x-for="s in cell.scheduled" :key="'s' + wb.startISO + s.id">
                <li>
                  <a class="cal-week__entry cal-week__entry--scheduled cal-week__entry--clickable"
                     :href="'/app/scheduled/#edit-' + s.id">
                    <span class="cal-week__entry-payee" x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></span>
                    <span class="cal-week__entry-amt" :class="s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                          x-text="formatCents(s.template.amount)"></span>
                  </a>
                </li>
              </template>
            </ul>
            <p class="cal-week__empty" x-show="!(cell.posted.length + cell.scheduled.length)" x-cloak>—</p>
          </li>
        </template>
      </ol>
    </article>
  </template>
  </section>

  {# ---- Day view ---------------------------------------------------- #}
  <section x-show="$store.budget.profile && view === 'day'" x-cloak>
    <template x-for="(db, dIdx) in daysToRender()" :key="db.iso">
      <article class="cal-day-block"
               :class="dIdx === 0 ? 'cal-day-block--primary' : ''">
        <header class="cal-extra-week__head"
                :class="dIdx === 0 ? 'cal-extra-week__head--primary' : ''">
          <h3 class="cal-extra-week__title" x-text="db.label"></h3>
          <dl class="cal-extra-period__totals" aria-label="Day totals">
            <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                    @click="openPeriodModal('Inflows — ' + db.label, 'Money in for the day', 'in', [dayData(db.iso)])"
                    data-tip="See every inflow on this day.">
              <dt>In</dt>
              <dd class="amount--inflow" x-text="formatCents(dayData(db.iso).totalInflow)"></dd>
            </button>
            <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                    @click="openPeriodModal('Outflows — ' + db.label, 'Money out for the day', 'out', [dayData(db.iso)])"
                    data-tip="See every outflow on this day.">
              <dt>Out</dt>
              <dd class="amount--outflow" x-text="formatCents(dayData(db.iso).totalOutflow)"></dd>
            </button>
            <div class="cal-extra-period__stat cal-extra-period__stat--net">
              <dt>Net</dt>
              <dd :class="(dayData(db.iso).totalInflow + dayData(db.iso).totalOutflow) < 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="formatCents(dayData(db.iso).totalInflow + dayData(db.iso).totalOutflow)"></dd>
            </div>
            <button type="button" class="cal-extra-period__stat cal-extra-period__stat--clickable"
                    @click="openPeriodModal('All entries — ' + db.label, 'Every transaction on the day', 'all', [dayData(db.iso)])"
                    data-tip="See every entry on this day.">
              <dt>Entries</dt>
              <dd x-text="dayData(db.iso).posted.length + dayData(db.iso).scheduled.length"></dd>
            </button>
          </dl>
        </header>

        <div>
          <p x-show="!(dayData(db.iso).posted.length + dayData(db.iso).scheduled.length)" x-cloak
             style="color: var(--fg-muted); padding: var(--space-md) 0; text-align: center; margin: 0;">
            Nothing posted or scheduled on this day.
          </p>
          <section x-show="dayData(db.iso).posted.length" x-cloak>
            <h4 class="cal__detail-section">Posted (<span x-text="dayData(db.iso).posted.length"></span>)</h4>
            <ul class="cal-day__list">
              <template x-for="t in dayData(db.iso).posted" :key="'p' + db.iso + t.id">
                <li>
                  <button type="button"
                          class="cal-day__row cal-day__row--clickable"
                          :class="t.amount < 0 ? 'cal__row--out' : 'cal__row--in'"
                          @click="openTxn(t.id)">
                    <div>
                      <p class="cal-day__row-payee" x-text="$store.budget.payeeName(t.payeeId) || (t.transferTxnId ? 'Transfer' : '—')"></p>
                      <p class="cal-day__row-meta">
                        <span x-text="$store.budget.findAccount(t.accountId)?.name || ''"></span>
                        <span x-show="t.categoryId" x-text="' · ' + ($store.budget.categoryName(t.categoryId) || '')"></span>
                        <span x-show="t.memo" x-text="' · ' + t.memo"></span>
                      </p>
                    </div>
                    <span class="cal-day__row-amount" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                          x-text="formatCents(t.amount)"></span>
                  </button>
                </li>
              </template>
            </ul>
          </section>
          <section x-show="dayData(db.iso).scheduled.length" x-cloak>
            <h4 class="cal__detail-section">Upcoming (scheduled) (<span x-text="dayData(db.iso).scheduled.length"></span>)</h4>
            <ul class="cal-day__list">
              <template x-for="s in dayData(db.iso).scheduled" :key="'s' + db.iso + s.id">
                <li>
                  <a class="cal-day__row cal-day__row--clickable"
                     :class="s.template.amount < 0 ? 'cal__row--out' : 'cal__row--in'"
                     :href="'/app/scheduled/#edit-' + s.id">
                    <div>
                      <p class="cal-day__row-payee" x-text="$store.budget.payeeName(s.template.payeeId) || s.template.payeeName || '—'"></p>
                      <p class="cal-day__row-meta">
                        <span x-text="$store.budget.findAccount(s.template.accountId)?.name || ''"></span>
                        <span x-text="' · ' + $store.budget.frequencyLabel(s)"></span>
                      </p>
                    </div>
                    <span class="cal-day__row-amount" :class="s.template.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                          x-text="formatCents(s.template.amount)"></span>
                  </a>
                </li>
              </template>
            </ul>
          </section>
        </div>
      </article>
    </template>
  </section>

  {# ---- Period transactions modal ----
     Opened from a stat button (In / Out / Entries) on any period
     header. Shows the title (kind + range), a subtitle, and the
     clickable transaction list. Posted rows open the txn edit
     modal; scheduled rows deep-link to /app/scheduled/. #}
  <div class="modal-backdrop" x-show="periodModalOpen" x-cloak
       @keydown.escape.window="closePeriodModal()">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="cal-period-title"
         @click.outside="closePeriodModal()" style="max-width: 680px;">
      <button class="modal__close" type="button" @click="closePeriodModal()" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="cal-period-title"
          style="margin: 0 0 var(--space-2xs);" x-text="periodModalTitle"></h3>
      <p style="color: var(--fg-muted); margin: 0 0 var(--space-md);"
         x-text="periodModalSubtitle"></p>

      {# Filter strip — In / Out / Entries become buttons that
         narrow the list below. Net stays a static stat. Selected
         stat is highlighted; a "Clear filter" pill appears whenever
         the kind isn't 'all'. #}
      <dl class="cal-extra-period__totals period-modal__filters"
          aria-label="Period totals — click to filter"
          style="margin: 0 0 var(--space-md);">
        <button type="button"
                class="cal-extra-period__stat cal-extra-period__stat--clickable"
                :class="periodModalKind === 'in' ? 'is-active' : ''"
                @click="periodModalKind = 'in'"
                :aria-pressed="(periodModalKind === 'in').toString()"
                data-tip="Filter the list below to inflows only.">
          <dt>In</dt>
          <dd class="amount--inflow" x-text="formatCents(periodModalTotals().inflow)"></dd>
        </button>
        <button type="button"
                class="cal-extra-period__stat cal-extra-period__stat--clickable"
                :class="periodModalKind === 'out' ? 'is-active' : ''"
                @click="periodModalKind = 'out'"
                :aria-pressed="(periodModalKind === 'out').toString()"
                data-tip="Filter the list below to outflows only.">
          <dt>Out</dt>
          <dd class="amount--outflow" x-text="formatCents(periodModalTotals().outflow)"></dd>
        </button>
        <div class="cal-extra-period__stat cal-extra-period__stat--net">
          <dt>Net</dt>
          <dd :class="periodModalTotals().net < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="formatCents(periodModalTotals().net)"></dd>
        </div>
        <button type="button"
                class="cal-extra-period__stat cal-extra-period__stat--clickable"
                :class="periodModalKind === 'all' ? 'is-active' : ''"
                @click="periodModalKind = 'all'"
                :aria-pressed="(periodModalKind === 'all').toString()"
                data-tip="Show every entry in this period.">
          <dt>Entries</dt>
          <dd x-text="periodModalTotals().count"></dd>
        </button>
      </dl>

      <p class="period-modal__active-filter" x-show="periodModalKind !== 'all'" x-cloak>
        <span x-text="'Showing ' + (periodModalKind === 'in' ? 'inflows' : 'outflows') + ' only · '"></span>
        <button type="button" class="period-modal__clear" @click="periodModalKind = 'all'"
                data-tip="Show every entry in this period (no filter).">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
          Clear filter
        </button>
      </p>

      <div x-show="!periodModalTxns().count" x-cloak
           style="color: var(--fg-muted); padding: var(--space-md) 0; text-align: center;">
        No matching entries in this period.
      </div>

      <section x-show="periodModalTxns().posted.length" x-cloak>
        <h4 class="cal__detail-section">Posted (<span x-text="periodModalTxns().posted.length"></span>)</h4>
        <ul class="cal-day__list">
          <template x-for="t in periodModalTxns().posted" :key="t.id">
            <li>
              <button type="button"
                      class="cal-day__row cal-day__row--clickable"
                      :class="t.amount < 0 ? 'cal__row--out' : 'cal__row--in'"
                      @click="closePeriodModal(); openTxn(t.id)">
                <div>
                  <p class="cal-day__row-payee" x-text="$store.budget.payeeName(t.payeeId) || (t.transferTxnId ? 'Transfer' : '—')"></p>
                  <p class="cal-day__row-meta">
                    <span x-text="t.date"></span>
                    <span x-text="' · ' + ($store.budget.findAccount(t.accountId)?.name || '')"></span>
                    <span x-show="t.categoryId" x-text="' · ' + ($store.budget.categoryName(t.categoryId) || '')"></span>
                  </p>
                </div>
                <span class="cal-day__row-amount" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                      x-text="formatCents(t.amount)"></span>
              </button>
            </li>
          </template>
        </ul>
      </section>

      <section x-show="periodModalTxns().scheduled.length" x-cloak style="margin-top: var(--space-md);">
