---
layout: layouts/app.njk
title: "Quick reconcile"
description: "Reconcile one account at a time — type the ending balance from your statement, the app handles the diff."
permalink: /app/quick-reconcile/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="quickReconcile()" x-init="init()">
  <header class="app-page__header">
    <div>
      <p class="eyebrow">Reconcile</p>
      <h1 class="app-page__title">Quick reconcile</h1>
      <p class="app-page__lead">
        Pick an account, type the ending balance from your statement, and the app shows you the difference plus the cleared-but-not-reconciled rows that explain it. Faster than ticking each row.
      </p>
    </div>
    <a class="btn btn--ghost btn--sm" href="/app/register/">Open full register</a>
  </header>

  {# Step 1 — pick the account #}
  <section class="card" x-show="step === 1" x-cloak>
    <h2 class="card__title">1. Pick the account to reconcile</h2>
    <p style="color: var(--fg-muted);">Last reconciled date shows next to each account — pick the one whose statement is in front of you.</p>
    <ul class="qr-accounts">
      <template x-for="a in accounts()" :key="a.id">
        <li>
          <button type="button" class="qr-account" @click="pickAccount(a.id)">
            <span class="qr-account__name" x-text="a.name"></span>
            <span class="qr-account__meta">
              <span x-text="$store.budget.ACCOUNT_TYPES.find(t => t.value === a.type)?.label || a.type"></span>
              <span> · cleared </span>
              <strong x-text="formatCents(clearedBalance(a.id))"></strong>
            </span>
          </button>
        </li>
      </template>
    </ul>
  </section>

  {# Step 2 — type the ending balance #}
  <section class="card" x-show="step === 2" x-cloak>
    <h2 class="card__title">2. Type the ending balance from your statement</h2>
    <p style="color: var(--fg-muted);">
      Account: <strong x-text="account()?.name"></strong>.
      Currently cleared balance: <strong x-text="formatCents(clearedBalance(acctId))"></strong>.
    </p>
    <form @submit.prevent="checkDiff()" class="form-stack" style="margin-top: var(--space-sm);">
      <div class="field">
        <label class="field__label" for="qr-ending">Statement ending balance</label>
        <input class="input" id="qr-ending" type="text" x-model="endingInput" inputmode="decimal" placeholder="0.00" autofocus required>
        <p class="field__hint">Calculator works here — '1234.56' or '500 + 700'.</p>
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="submit">Check difference</button>
        <button class="btn btn--ghost" type="button" @click="step = 1">Back</button>
      </div>
    </form>
  </section>

  {# Step 3 — review diff + cleared-not-reconciled rows #}
  <section class="card" x-show="step === 3" x-cloak>
    <h2 class="card__title">3. Review the difference</h2>
    <div class="qr-diff-grid">
      <div>
        <p class="qr-diff-label">Cleared in app</p>
        <p class="qr-diff-value" x-text="formatCents(clearedBalance(acctId))"></p>
      </div>
      <div>
        <p class="qr-diff-label">Statement says</p>
        <p class="qr-diff-value" x-text="formatCents(endingCents)"></p>
      </div>
      <div>
        <p class="qr-diff-label">Difference</p>
        <p class="qr-diff-value" :class="diff() === 0 ? 'amount--inflow' : 'amount--outflow'"
           x-text="formatCents(diff())"></p>
      </div>
    </div>

    <div x-show="diff() === 0" x-cloak style="margin-top: var(--space-md);">
      <p style="color: var(--ok); font-weight: 700;">Balances match. Mark every cleared row below as reconciled to finish.</p>
    </div>
    <div x-show="diff() !== 0" x-cloak style="margin-top: var(--space-md);">
      <p style="color: var(--danger); font-weight: 700;">
        The numbers don't match. Most reconciliation issues are missing transactions or a duplicate. Walk down the list below and tick / untick the <em>cleared</em> column to find the gap.
      </p>
    </div>

    <h3 style="margin-top: var(--space-md);">Cleared but not reconciled (<span x-text="pendingRows().length"></span>)</h3>
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Payee</th>
          <th>Category</th>
          <th class="num">Amount</th>
          <th class="num">Cleared</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="t in pendingRows()" :key="t.id">
          <tr>
            <td x-text="t.date"></td>
            <td x-text="$store.budget.payeeName(t.payeeId) || '—'"></td>
            <td x-text="$store.budget.categoryName(t.categoryId) || 'Uncategorized'"></td>
            <td class="num" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'" x-text="formatCents(t.amount)"></td>
            <td class="num">
              <button type="button" class="cleared-toggle"
                      :aria-pressed="t.cleared.toString()"
                      @click="toggleCleared(t.id)">
                <span x-show="t.cleared">&#10003;</span>
              </button>
            </td>
          </tr>
        </template>
        <tr x-show="!pendingRows().length" x-cloak>
          <td colspan="5" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No pending cleared rows.</td>
        </tr>
      </tbody>
    </table>

    <div class="form-actions" style="margin-top: var(--space-md);">
      <button class="btn btn--primary" type="button" @click="finishReconcile()" :disabled="diff() !== 0">Mark all reconciled</button>
      <button class="btn btn--ghost" type="button" @click="step = 2">Edit ending balance</button>
      <a class="btn btn--ghost" :href="'/app/register/?account=' + acctId">Open in register</a>
    </div>
  </section>

  {# Step 4 — done #}
  <section class="card prose" x-show="step === 4" x-cloak style="border-left: 4px solid var(--ok);">
    <h2>Reconciled.</h2>
    <p>Every cleared row in <strong x-text="account()?.name"></strong> through today is marked reconciled. Pick another account or close this page.</p>
    <div class="cluster" style="margin-top: var(--space-sm);">
      <button class="btn btn--primary btn--sm" type="button" @click="reset()">Reconcile another account</button>
      <a class="btn btn--ghost btn--sm" :href="'/app/register/?account=' + acctId">Open in register</a>
    </div>
  </section>
</div>

<script>
function quickReconcile() {
  return {
    step: 1,
    acctId: "",
    endingInput: "",
    endingCents: 0,

    init() {
      /* If a URL ?account= param is provided, jump straight into step 2. */
      try {
        var url = new URL(window.location.href);
        var aid = url.searchParams.get("account");
        if (aid) this.pickAccount(aid);
      } catch (_e) {}
    },

    accounts() {
      var p = this.$store.budget.profile;
      if (!p) return [];
      return p.accounts.filter(function (a) { return !a.closedAt; })
        .sort(function (a, b) { return a.name.localeCompare(b.name); });
    },
    account() {
      return this.$store.budget.findAccount(this.acctId);
    },

    formatCents(c) {
      return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD" });
    },
    parseDollars(s) {
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var n = Number(String(s || "").replace(/[$,\s]/g, ""));
      return isFinite(n) ? Math.round(n * 100) : 0;
    },

    /* Cleared balance = opening + all cleared transactions. */
    clearedBalance(id) {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p || !id) return 0;
      var a = this.$store.budget.findAccount(id);
      var sum = a ? (a.openingBalance || 0) : 0;
      p.transactions.forEach(function (t) {
        if (t.accountId !== id) return;
        if (!t.cleared) return;
        sum += t.amount;
      });
      return sum;
    },

    pickAccount(id) {
      this.acctId = id;
      this.step = 2;
    },

    checkDiff() {
      this.endingCents = this.parseDollars(this.endingInput);
      this.step = 3;
    },

    diff() {
      return this.endingCents - this.clearedBalance(this.acctId);
    },

    pendingRows() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p) return [];
      var id = this.acctId;
      return p.transactions
        .filter(function (t) { return t.accountId === id && t.cleared && !t.reconciled; })
        .sort(function (a, b) { return b.date.localeCompare(a.date); });
    },

    toggleCleared(txnId) {
      var t = this.$store.budget.profile.transactions.find(function (x) { return x.id === txnId; });
      if (t) this.$store.budget.updateTransaction(txnId, { cleared: !t.cleared });
    },

    finishReconcile() {
      var self = this;
      var rows = this.pendingRows();
      rows.forEach(function (t) {
        self.$store.budget.updateTransaction(t.id, { reconciled: true });
      });
      this.step = 4;
      this.$store.budget.pushToast("Reconciled " + rows.length + " row" + (rows.length === 1 ? "" : "s") + ".");
    },

    reset() {
      this.step = 1;
      this.acctId = "";
      this.endingInput = "";
      this.endingCents = 0;
    },
  };
}
</script>

<style>
  .qr-accounts { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2xs); }
  .qr-account { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-md); width: 100%; padding: var(--space-sm) var(--space-md); background: var(--bg-elevated); border: 1px solid var(--border-strong); border-radius: var(--radius-input); color: var(--fg); cursor: pointer; text-align: left; font: inherit; transition: background var(--t-fast), border-color var(--t-fast); }
  .qr-account:hover { background: var(--bg-alt); border-color: var(--accent); }
  .qr-account__name { font-weight: 700; font-family: var(--font-display); }
  .qr-account__meta { color: var(--fg-muted); font-size: var(--fs-sm); }
  .qr-diff-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-md); margin-top: var(--space-md); }
  @media (max-width: 599px) { .qr-diff-grid { grid-template-columns: 1fr; } }
  .qr-diff-grid > div { padding: var(--space-md); background: var(--bg-elevated); border: 1px solid var(--border-soft); border-radius: var(--radius-input); }
  .qr-diff-label { margin: 0; font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg-muted); font-weight: 700; }
  .qr-diff-value { margin: var(--space-2xs) 0 0; font-family: var(--font-display); font-size: var(--fs-xl); font-variant-numeric: tabular-nums; }
</style>
