---
layout: layouts/app.njk
title: "Dashboard"
description: "Your active budget at a glance — ready to assign, net worth, this month's flow, upcoming bills, goal progress, and alerts."
permalink: /app/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="dashboardView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Dashboard</h1>
      <p class="app-page__lead">
        <span x-show="$store.budget.profile" x-text="$store.budget.profile?.name"></span>
        <span x-show="!$store.budget.profile" x-cloak>No active profile.</span>
      </p>
    </div>
  </header>

  {# ---- Empty state ---- #}
  <div class="empty-state" x-show="!$store.budget.profile" x-cloak>
    <h2 class="empty-state__title">Create your first profile</h2>
    <p class="empty-state__body">
      A profile is a complete budget — its own accounts, categories, transactions, and goals. Create as many as you need and switch between them whenever you like. Profiles are stored only in this browser.
    </p>
    <div class="empty-state__actions">
      <a class="btn btn--primary" href="/app/profiles/">Create a profile</a>
      <a class="btn btn--secondary" href="/app/import/">Import a JSON export</a>
    </div>
  </div>

  <div x-show="$store.budget.profile" x-cloak>

    {# ==== Quick-add transaction (inline, dashboard) ==== #}
    <section class="card dash-quick" x-show="quickHasAccounts()" x-cloak>
      <form class="dash-quick__form" @submit.prevent="quickAddSubmit()">
        <div class="dash-quick__field">
          <label class="field__label" for="qa-date">Date</label>
          <input class="input" id="qa-date" type="date" x-model="quickForm.date" required>
        </div>
        <div class="dash-quick__field dash-quick__field--wide">
          <label class="field__label" for="qa-payee">Payee</label>
          <input class="input" id="qa-payee" type="text" x-model="quickForm.payeeName"
                 placeholder="e.g. Whole Foods" autocomplete="off">
        </div>
        <div class="dash-quick__field">
          <label class="field__label" for="qa-amount">Amount</label>
          <input class="input" id="qa-amount" type="text" x-model="quickForm.amount"
                 placeholder="-25.00" inputmode="decimal" required>
        </div>
        <div class="dash-quick__field">
          <label class="field__label" for="qa-account">Account</label>
          <select class="select" id="qa-account" x-model="quickForm.accountId" required>
            <template x-for="a in quickAccounts()" :key="a.id">
              <option :value="a.id" x-text="a.name"></option>
            </template>
          </select>
        </div>
        <div class="dash-quick__field">
          <label class="field__label" for="qa-cat">Category</label>
          <select class="select" id="qa-cat" x-model="quickForm.categoryId">
            <option value="">(auto)</option>
            <template x-for="c in $store.budget.categoriesFlat()" :key="c.id">
              <option :value="c.id" x-text="c.name"></option>
            </template>
          </select>
        </div>
        <button class="btn btn--primary dash-quick__submit" type="submit">Add</button>
      </form>
    </section>

    {# ==== Hero band: greeting, month, and a one-line insight ==== #}
    <section class="dash-hero" aria-label="Today's summary">
      <div class="dash-hero__greeting">
        <p class="dash-hero__eyebrow" x-text="heroEyebrow()"></p>
        <h2 class="dash-hero__title" x-text="heroTitle()"></h2>
        <p class="dash-hero__insight" x-text="heroInsight()"></p>
      </div>
      <div class="dash-hero__metric">
        <p class="dash-hero__metric-label">Net worth</p>
        <p class="dash-hero__metric-value"
           :class="$store.budget.netWorth() < 0 ? 'amount--outflow' : ''"
           x-text="fmt($store.budget.netWorth())"></p>
        <p class="dash-hero__metric-trend"
           :class="netWorthDelta().pct >= 0 ? 'is-positive' : 'is-negative'">
          <span x-text="(netWorthDelta().pct >= 0 ? '↑ ' : '↓ ') + Math.abs(netWorthDelta().pct).toFixed(1) + '%'"></span>
          <span class="dash-hero__metric-sub">vs 6 months ago</span>
        </p>
      </div>
    </section>

    {# ==== Band B: 6-tile KPI row ==== #}
    {# Reuses .rec-summary chrome from /app/scheduled/ for consistent
       semantic-rail tiles; each tile is an <a> so the whole card is
       clickable and lands on the page that lets you act on the number. #}
    <section class="dashboard__kpis" aria-label="Key indicators">
      <a class="rec-summary__tile dashboard__kpi"
         :class="$store.budget.readyToAssign() < 0 ? 'rec-summary__tile--outflow' : 'rec-summary__tile--inflow'"
         href="/app/budget/"
         data-tip="Dollars not yet assigned to any category this month. Click to open the budget.">
        <span class="rec-summary__label">Ready to assign</span>
        <span class="rec-summary__value"
              :class="$store.budget.readyToAssign() < 0 ? 'amount--outflow' : ''"
              x-text="fmt($store.budget.readyToAssign())"></span>
        <span class="dashboard__kpi-sub" x-text="$store.budget.currentMonth"></span>
      </a>

      <a class="rec-summary__tile rec-summary__tile--net dashboard__kpi"
         href="/app/reports/net-worth/"
         data-tip="On-budget balances plus tracking assets minus tracking liabilities.">
        <span class="rec-summary__label">Net worth</span>
        <span class="rec-summary__value"
              :class="$store.budget.netWorth() < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="fmt($store.budget.netWorth())"></span>
        <span class="dashboard__kpi-sub">On budget + tracking</span>
      </a>

      <a class="rec-summary__tile dashboard__kpi"
         :class="thisMonthNet() < 0 ? 'rec-summary__tile--outflow' : 'rec-summary__tile--inflow'"
         href="/app/reports/income-expense/"
         data-tip="Income minus expenses for the current month.">
        <span class="rec-summary__label">This month's net</span>
        <span class="rec-summary__value"
              :class="thisMonthNet() < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="fmt(thisMonthNet())"></span>
        <span class="dashboard__kpi-sub" x-text="'In ' + fmtCompact(thisMonthIncome()) + ' · Out ' + fmtCompact(thisMonthExpense())"></span>
      </a>

      <a class="rec-summary__tile dashboard__kpi"
         :class="savingsBandClass()"
         href="/app/reports/savings-rate/"
         data-tip="Trailing 3-month savings rate (income minus expenses, divided by income).">
        <span class="rec-summary__label">Savings rate</span>
        <span class="rec-summary__value"
              x-text="savingsRateLabel()"></span>
        <span class="dashboard__kpi-sub">3-month rolling</span>
      </a>

      <a class="rec-summary__tile rec-summary__tile--accent dashboard__kpi"
         href="/app/scheduled/"
         data-tip="Scheduled transactions hitting within the next 7 days.">
        <span class="rec-summary__label">Next 7 days</span>
        <span class="rec-summary__value"
              :class="upcoming7().totalNet < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="fmt(upcoming7().totalNet)"></span>
        <span class="dashboard__kpi-sub" x-text="upcoming7().items.length + ' due'"></span>
      </a>

      <a class="rec-summary__tile dashboard__kpi"
         :class="overspent().count > 0 ? 'rec-summary__tile--outflow' : 'rec-summary__tile--inflow'"
         href="/app/budget/"
         data-tip="Categories whose available balance is below zero this month.">
        <span class="rec-summary__label">Overspent</span>
        <span class="rec-summary__value"
              :class="overspent().count > 0 ? 'amount--outflow' : ''"
              x-text="overspent().count"></span>
        <span class="dashboard__kpi-sub" x-text="overspent().count > 0 ? ('Deficit ' + fmtCompact(overspent().totalDeficit)) : 'Everything covered'"></span>
      </a>
    </section>

    {# ==== Smart insights ==== #}
    <section class="card" x-show="insights().length" x-cloak>
      <div class="dashboard__card-head">
        <h2>Insights</h2>
        <span style="color: var(--fg-muted); font-size: var(--fs-xs);" x-text="insights().length + ' signal' + (insights().length === 1 ? '' : 's')"></span>
      </div>
      <ul class="dash-insights">
        <template x-for="ins in insights()" :key="ins.id">
          <li class="dash-insight" :class="'dash-insight--' + ins.severity">
            <span class="dash-insight__icon" aria-hidden="true" x-text="ins.icon"></span>
            <div class="dash-insight__body">
              <p class="dash-insight__title" x-text="ins.title"></p>
              <p class="dash-insight__detail" x-text="ins.detail"></p>
            </div>
            <a class="dash-insight__cta" x-show="ins.href" x-cloak :href="ins.href" x-text="ins.cta || 'View'"></a>
          </li>
        </template>
      </ul>
    </section>

    {# ==== Account balances grid ==== #}
    <section class="card" x-show="allAccountsForGrid().length" x-cloak>
      <div class="dashboard__card-head">
        <h2>Account balances</h2>
        <a href="/app/accounts/">Manage accounts &rsaquo;</a>
      </div>
      <ul class="dash-accts">
        <template x-for="a in allAccountsForGrid()" :key="a.id">
          <li class="dash-acct">
            <a class="dash-acct__link" :href="'/app/register/?account=' + a.id">
              <span class="dash-acct__group" x-text="a.groupName || 'Other'"></span>
              <span class="dash-acct__name">
                <span x-text="a.name"></span>
                <span class="dash-acct__flag" x-show="a.excludeFromNetWorth" x-cloak
                      data-tip="Excluded from net worth.">E</span>
              </span>
              <span class="dash-acct__balance"
                    :class="a.balance < 0 ? 'is-negative' : ''"
                    x-text="fmt(a.balance)"></span>
            </a>
          </li>
        </template>
      </ul>
    </section>

    {# ==== Cash flow this month (mini sankey, pure CSS) ==== #}
    <section class="card" x-show="flowThisMonth().total > 0" x-cloak>
      <div class="dashboard__card-head">
        <h2>Cash flow this month</h2>
        <a href="/app/reports/sankey/">Full sankey &rsaquo;</a>
      </div>
      <div class="dash-flow">
        <ul class="dash-flow__col dash-flow__col--in">
          <li class="dash-flow__col-head">Income sources</li>
          <template x-for="row in flowThisMonth().sources" :key="'src-' + row.name">
            <li class="dash-flow__row">
              <span class="dash-flow__row-bar">
                <span class="dash-flow__row-fill dash-flow__row-fill--in"
                      :style="'--pct:' + row.pct + '%'"></span>
              </span>
              <span class="dash-flow__row-meta">
                <span class="dash-flow__row-name" x-text="row.name"></span>
                <span class="dash-flow__row-amt" x-text="fmt(row.value)"></span>
              </span>
            </li>
          </template>
          <li x-show="!flowThisMonth().sources.length" x-cloak class="dash-flow__empty">No income yet.</li>
        </ul>

        <div class="dash-flow__pivot">
          <span class="dash-flow__pivot-label">Net</span>
          <span class="dash-flow__pivot-value"
                :class="flowThisMonth().net < 0 ? 'amount--outflow' : 'amount--inflow'"
                x-text="fmt(flowThisMonth().net)"></span>
          <span class="dash-flow__pivot-sub">
            <span x-text="fmt(flowThisMonth().income)"></span> in
            &middot;
            <span x-text="fmt(flowThisMonth().expense)"></span> out
          </span>
        </div>

        <ul class="dash-flow__col dash-flow__col--out">
          <li class="dash-flow__col-head">Top spending</li>
          <template x-for="row in flowThisMonth().sinks" :key="'sink-' + row.name">
            <li class="dash-flow__row dash-flow__row--right">
              <span class="dash-flow__row-meta">
                <span class="dash-flow__row-name" x-text="row.name"></span>
                <span class="dash-flow__row-amt" x-text="fmt(row.value)"></span>
              </span>
              <span class="dash-flow__row-bar">
                <span class="dash-flow__row-fill dash-flow__row-fill--out"
                      :style="'--pct:' + row.pct + '%'"></span>
              </span>
            </li>
          </template>
          <li x-show="!flowThisMonth().sinks.length" x-cloak class="dash-flow__empty">No spending yet.</li>
        </ul>
      </div>
    </section>

    {# ==== Band C: This month — sparkline + top categories ==== #}
    <div class="dashboard__row dashboard__row--2col">
      <section class="card">
        <div class="dashboard__card-head">
          <h2>Income vs expense</h2>
          <a href="/app/reports/income-expense/">Full report &rsaquo;</a>
        </div>
        <div class="chart dashboard__chart" id="dash-chart-ie"></div>
      </section>

      <section class="card">
        <div class="dashboard__card-head">
          <h2>Top categories this month</h2>
          <a href="/app/reports/spending/">All spending &rsaquo;</a>
        </div>
        <p x-show="!topCategoriesRows().length" x-cloak style="color: var(--fg-muted); margin: 0;">No spending yet this month.</p>
        <ul class="dash-cat-bars" x-show="topCategoriesRows().length" x-cloak>
          <template x-for="r in topCategoriesRows()" :key="r.categoryId">
            <li class="dash-cat-bars__row">
              <a :href="'/app/register/?category=' + r.categoryId" x-text="r.category"></a>
              <span class="dash-cat-bars__amount" x-text="fmt(r.value)"></span>
              <span class="dash-cat-bars__bar">
                <span class="dash-cat-bars__fill" :style="'--pct:' + r.pct + '%'"></span>
              </span>
            </li>
          </template>
        </ul>
      </section>
    </div>

    {# ==== Band D: Forecast + upcoming bills ==== #}
    <div class="dashboard__row dashboard__row--2col">
      <section class="card">
        <div class="dashboard__card-head">
          <h2>30-day cashflow</h2>
          <a href="/app/reports/projection/">Full projection &rsaquo;</a>
        </div>
        <div class="chart dashboard__chart" id="dash-chart-proj"></div>
      </section>

      <section class="card">
        <div class="dashboard__card-head">
          <h2>Upcoming bills (14 days)</h2>
          <a href="/app/scheduled/">Manage recurring &rsaquo;</a>
        </div>
        <p x-show="!upcoming14().items.length" x-cloak style="color: var(--fg-muted); margin: 0;">No scheduled items in the next two weeks.</p>
        <ul class="dash-bill-list" x-show="upcoming14().items.length" x-cloak>
          <template x-for="(b, i) in upcoming14().items.slice(0, 8)" :key="i">
            <li class="dash-bill">
              <span class="dash-bill__date" x-text="shortDate(b.date)"></span>
              <span>
                <span class="dash-bill__payee" x-text="b.payeeName || $store.budget.payeeName(b.payeeId) || '—'"></span>
                <span class="dash-bill__meta" x-text="($store.budget.findAccount(b.accountId)?.name || '—') + ' · ' + ($store.budget.categoryName(b.categoryId) || 'Uncategorized')"></span>
              </span>
              <span class="dash-bill__amount" :class="b.amount < 0 ? 'amount--outflow' : 'amount--inflow'" x-text="fmt(b.amount)"></span>
            </li>
          </template>
        </ul>
      </section>
    </div>

    {# ==== Band E: Goals that need attention ==== #}
    <section x-show="$store.budget.profile && $store.budget.profile.goals && $store.budget.profile.goals.length" x-cloak>
      <div class="dashboard__card-head">
        <h2>Goals needing attention</h2>
        <a href="/app/categories/">Manage goals &rsaquo;</a>
      </div>
      <p x-show="!goalsAttention().length" x-cloak style="color: var(--fg-muted); margin: 0 0 var(--space-md);">All goals are on track this month.</p>
      <div class="dashboard__row dashboard__row--3col" x-show="goalsAttention().length" x-cloak>
        <template x-for="g in goalsAttention()" :key="g.goal.id">
          <article class="dash-goal" :class="g.pct < 0.25 ? 'dash-goal--critical' : (g.pct >= 0.75 ? 'dash-goal--close' : '')">
            <h3 class="dash-goal__name" x-text="g.categoryName"></h3>
            <div class="dash-goal__progress">
              <span class="dash-goal__progress-fill" :style="'--pct:' + Math.min(100, Math.max(0, g.pct * 100)) + '%'"></span>
            </div>
            <p class="dash-goal__line">
              <strong x-text="fmt(g.assigned)"></strong>
              <span> of </span>
              <strong x-text="fmt(g.target)"></strong>
              <span x-text="' (' + Math.round(g.pct * 100) + '%)'"></span>
            </p>
            <p class="dash-goal__line" x-show="g.deficit > 0" x-cloak>
              <span>Needs </span>
              <strong x-text="fmt(g.deficit)"></strong>
              <span> more to fully fund this month.</span>
            </p>
          </article>
        </template>
      </div>
    </section>

    {# ==== Band F: Recent activity + alerts ==== #}
    <div class="dashboard__row dashboard__row--2col">
      <section class="card">
        <div class="dashboard__card-head">
          <h2>Recent transactions</h2>
          <a href="/app/register/">Open register &rsaquo;</a>
        </div>
        <p x-show="!recentTransactions().length" x-cloak style="color: var(--fg-muted); margin: 0;">No transactions yet. Press <kbd>N</kbd> to add one.</p>
        <ul class="dash-recent" x-show="recentTransactions().length" x-cloak>
          <template x-for="t in recentTransactions()" :key="t.id">
            <li class="dash-recent__row">
              <span class="dash-recent__date" x-text="shortDate(t.date)"></span>
              <span>
                <span class="dash-recent__payee" x-text="$store.budget.payeeName(t.payeeId) || '—'"></span>
                <span class="dash-recent__meta" x-text="($store.budget.findAccount(t.accountId)?.name || '—') + ' · ' + ($store.budget.categoryName(t.categoryId) || 'Uncategorized')"></span>
              </span>
              <span class="dash-recent__amount" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'" x-text="fmt(t.amount)"></span>
            </li>
          </template>
        </ul>
      </section>

      <section class="card">
        <div class="dashboard__card-head">
          <h2>Alerts</h2>
        </div>
        <p class="dash-alerts__empty" x-show="!alerts().length" x-cloak>Nothing needs attention right now.</p>
        <ul class="dash-alerts" x-show="alerts().length" x-cloak>
          <template x-for="a in alerts()" :key="a.id">
            <li>
              <a class="dash-alert" :class="'dash-alert--' + a.severity" :href="a.href">
                <span x-text="a.text"></span>
                <span class="dash-alert__cta">Open &rsaquo;</span>
              </a>
            </li>
          </template>
        </ul>
      </section>
    </div>

    {# ==== Quick actions cluster (kept for screen-reader users + mouse-only users who prefer buttons) ==== #}
    <section class="card" style="margin-top: var(--space-lg);">
      <h2 class="card__title">Quick actions</h2>
      <div class="cluster">
        <a class="btn btn--primary btn--sm" href="/app/budget/">Open budget</a>
        <a class="btn btn--secondary btn--sm" href="/app/register/">Enter transactions</a>
        <a class="btn btn--secondary btn--sm" href="/app/categories/">Manage categories</a>
        <a class="btn btn--ghost btn--sm" href="/app/settings/">Settings</a>
      </div>
    </section>
  </div>
</div>

<script>
function dashboardView() {
  return {
    chartIE: null,
    chartProj: null,
    /* Inline quick-add state. Pre-populated with today's date + the
       first open account once the profile loads via the quickAccounts
       getter. Auto-rules fire on submit (categorize / normalize-payee)
       so manual entries are normalized just like imports. */
    quickForm: { date: "", payeeName: "", amount: "", accountId: "", categoryId: "" },

    init() {
      var self = this;
      /* Seed the inline quick-add form. Account is filled in lazily
         via the quickAccounts() getter once the profile loads. */
      this.quickForm.date = new Date().toISOString().slice(0, 10);
      /* Wait for the budget store + chart bootstrap script-modules to
         finish loading, then mount the two sparklines. Same polling
         pattern as the report pages so the timing is predictable. */
      var tries = 0;
      var poll = function () {
        var ready = window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart && window.pbDashRenderIE && window.pbDashRenderProj;
        if (!ready) { if (++tries < 600) setTimeout(poll, 50); return; }
        var store = Alpine.store("budget");
        self.chartIE = window.pbMountChart("#dash-chart-ie", window.pbDashRenderIE, function () {
          return store.reportIncomeVsExpense(null, 6);
        });
        self.chartProj = window.pbMountChart("#dash-chart-proj", window.pbDashRenderProj, function () {
          return store.reportProjection(1);
        });
        /* Store mutations trip _listVersion; redraw both charts. */
        Alpine.effect(function () {
          store.profile; store.currentMonth; store._listVersion;
          if (self.chartIE)   self.chartIE.redraw();
          if (self.chartProj) self.chartProj.redraw();
        });
      };
      poll();
    },

    /* ---- Quick-add ---- */
    quickHasAccounts() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      return !!(p && (p.accounts || []).some(function (a) { return !a.closedAt; }));
    },
    quickAccounts() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p) return [];
      var open = (p.accounts || [])
        .filter(function (a) { return !a.closedAt; })
        .sort(function (a, b) { return a.name.localeCompare(b.name); });
      /* Seed accountId on the form once accounts exist. */
      if (open.length && !this.quickForm.accountId) {
        this.quickForm.accountId = open[0].id;
      }
      return open;
    },
    _parseQuickAmount(s) {
      if (s == null || s === "") return 0;
      if (window.PBCalc) {
        var v = window.PBCalc.parseAmountCents(s);
        if (isFinite(v)) return v;
      }
      var clean = String(s).replace(/[$,\s]/g, "").trim();
      if (/^\(.*\)$/.test(clean)) clean = "-" + clean.slice(1, -1);
      var n = Number(clean);
      return isFinite(n) ? Math.round(n * 100) : 0;
    },
    quickAddSubmit() {
      var f = this.quickForm;
      if (!f.accountId) return;
      var amount = this._parseQuickAmount(f.amount);
      if (!amount) { this.$store.budget.pushToast("Amount is required.", "warn"); return; }
      this.$store.budget.addTransaction({
        accountId: f.accountId,
        date: f.date || new Date().toISOString().slice(0, 10),
        payeeName: f.payeeName,
        categoryId: f.categoryId || null,
        amount: amount,
        memo: "",
        cleared: false,
      });
      this.$store.budget.pushToast("Added transaction.", "ok");
      /* Reset just the per-row inputs, preserve account + date so
         entering a batch is fast. */
      this.quickForm.payeeName = "";
      this.quickForm.amount = "";
      this.quickForm.categoryId = "";
      var self = this;
      this.$nextTick(function () {
        var el = document.getElementById("qa-payee");
        if (el) el.focus();
      });
    },

    /* ---- Hero band ---- */
    heroEyebrow() {
      var now = new Date();
      var hour = now.getHours();
      var greeting = hour < 12 ? "Good morning" : (hour < 18 ? "Good afternoon" : "Good evening");
      var profile = this.$store.budget.profile;
      return greeting + (profile && profile.name ? " — " + profile.name : "");
    },
    heroTitle() {
      var d = new Date();
      return d.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" });
    },
    /* One-line, plain-English summary of the most relevant signal
       for this month. Priority order: overdrawn account > overspent
       categories > unassigned RTA > on-track positive net. */
    heroInsight() {
      var s = this.$store.budget;
      if (!s.profile) return "";
      var rta = s.readyToAssign();
      var os = this.overspent();
      var net = this.thisMonthNet();
      if (os.count > 0) {
        return os.count + " categor" + (os.count === 1 ? "y is" : "ies are") + " overspent by " + this.fmt(os.totalDeficit) + " this month.";
      }
      if (rta > 10000) {
        return this.fmt(rta) + " is unassigned for " + s.currentMonth + " — assign every dollar a job.";
      }
      if (net > 0) {
        return "Net positive this month: " + this.fmt(net) + " saved so far.";
      }
      if (net < 0) {
        return "Spending exceeds income this month by " + this.fmt(Math.abs(net)) + ".";
      }
      return "Every dollar is assigned. Keep going.";
    },
    /* Compare current netWorth to netWorth from ~6 months back via the
       netWorthByMonth report. Returns { from, to, pct }. */
    netWorthDelta() {
      void this.$store.budget._listVersion;
      var s = this.$store.budget;
      var to = s.netWorth();
      var series = s.reportNetWorth(null, 7) || [];
      if (!series.length) return { from: to, to: to, pct: 0 };
      var fromRow = series[0];
      var from = fromRow && typeof fromRow.netWorth === "number" ? fromRow.netWorth : (fromRow && fromRow.total) || to;
      var pct = from !== 0 ? ((to - from) / Math.abs(from)) * 100 : 0;
      return { from: from, to: to, pct: pct };
    },

    /* ---- Cash flow this month (mini sankey) ---- */
    /* Aggregates current-month transactions into top-5 income
       sources (categorized inflows) and top-5 expense categories,
       plus totals. Each row carries a `pct` (0..100) relative to
       the column's biggest value so the bars scale proportionally
       without needing JS to set widths beyond a single CSS var. */
    flowThisMonth() {
      void this.$store.budget._listVersion;
      var s = this.$store.budget;
      if (!s.profile) return { sources: [], sinks: [], income: 0, expense: 0, net: 0, total: 0 };
      var month = s.currentMonth;
      var inMap = {};
      var outMap = {};
      var income = 0, expense = 0;
      (s.profile.transactions || []).forEach(function (t) {
        if (!t || !t.date || t.date.slice(0, 7) !== month) return;
        if (t.transferTxnId) return;
        var label = s.categoryName(t.categoryId) || (t.amount >= 0 ? "Uncategorized income" : "Uncategorized");
        if (t.amount > 0) {
          inMap[label] = (inMap[label] || 0) + t.amount;
          income += t.amount;
        } else if (t.amount < 0) {
          var v = -t.amount;
          outMap[label] = (outMap[label] || 0) + v;
          expense += v;
        }
      });
      function topN(map) {
        var arr = Object.keys(map).map(function (k) { return { name: k, value: map[k] }; });
        arr.sort(function (a, b) { return b.value - a.value; });
        arr = arr.slice(0, 5);
        var max = arr.length ? arr[0].value : 1;
        arr.forEach(function (r) { r.pct = Math.round((r.value / max) * 100); });
        return arr;
      }
      return {
        sources: topN(inMap),
        sinks:   topN(outMap),
        income: income,
        expense: expense,
        net: income - expense,
        total: income + expense,
      };
    },

    /* ---- Smart insights ---- */
    /* Walks the recent activity + budget to surface 0–6 plain-
       English signals. Each insight returns
         { id, severity, icon, title, detail, href?, cta? }
       severity = ok | info | warn | danger drives the color rail. */
    insights() {
      void this.$store.budget._listVersion;
      var s = this.$store.budget;
      if (!s.profile) return [];
      var out = [];
      var self = this;

      /* (1) Category whose spending is up >25% vs the prior month
         and is among the top-5 expenses this month. */
      var top = this.topCategoriesRows();
      if (top.length) {
        var thisMonth = s.currentMonth;
        var parts = thisMonth.split("-").map(Number);
        var prevDate = new Date(parts[0], (parts[1] || 1) - 2, 1);
        var prevMonth = prevDate.getFullYear() + "-" + String(prevDate.getMonth() + 1).padStart(2, "0");
        var prevSpending = s.reportSpending(prevMonth, prevMonth) || [];
        var prevByCat = {};
        prevSpending.forEach(function (r) { prevByCat[r.categoryId] = r.value; });
        var biggestMover = null;
        top.forEach(function (r) {
          var prev = prevByCat[r.categoryId] || 0;
          if (prev <= 0) return;
          var pctChange = ((r.value - prev) / prev) * 100;
          if (pctChange > 25 && (!biggestMover || pctChange > biggestMover.pctChange)) {
            biggestMover = { row: r, prev: prev, pctChange: pctChange };
          }
        });
        if (biggestMover) {
          out.push({
            id: "spike-" + biggestMover.row.categoryId,
            severity: "warn",
            icon: "↑",
            title: biggestMover.row.category + " is up " + Math.round(biggestMover.pctChange) + "% vs last month",
            detail: self.fmt(biggestMover.row.value) + " this month, " + self.fmt(biggestMover.prev) + " last.",
            href: "/app/register/?q=" + encodeURIComponent(biggestMover.row.category),
            cta: "View",
          });
        }
      }

      /* (2) Trailing 3-month savings rate trend. */
      var sr = s.reportSavingsRate(null, 3) || [];
      if (sr.length >= 3) {
        var sumInc = 0, sumExp = 0;
        sr.forEach(function (m) { sumInc += m.income || 0; sumExp += m.expense || 0; });
        if (sumInc > 0) {
          var rate = ((sumInc - sumExp) / sumInc) * 100;
          if (rate >= 20) {
            out.push({
              id: "savings-strong",
              severity: "ok",
              icon: "★",
              title: "Saving " + Math.round(rate) + "% of income on average",
              detail: "3-month trailing rate. Keep it going.",
              href: "/app/reports/savings-rate/",
              cta: "Trend",
            });
          } else if (rate < 0) {
            out.push({
              id: "savings-negative",
              severity: "danger",
              icon: "↓",
              title: "Spending exceeds income on a 3-month rolling basis",
              detail: "Trailing savings rate is " + Math.round(rate) + "%. Review the budget.",
              href: "/app/reports/savings-rate/",
              cta: "Open",
            });
          }
        }
      }

      /* (3) Subscriptions detector. */
      var subs = s.reportSubscriptions(6) || [];
      if (subs.length) {
        var monthly = subs.reduce(function (acc, sub) {
          return acc + (sub.monthlyEstimate || 0);
        }, 0);
        if (monthly > 0) {
          out.push({
            id: "subs-summary",
            severity: "info",
            icon: "↻",
            title: subs.length + " recurring charge" + (subs.length === 1 ? "" : "s") + " detected",
            detail: self.fmt(monthly) + " / month estimated — review for anything you don't need.",
            href: "/app/reports/subscriptions/",
            cta: "Audit",
          });
        }
      }

      /* (4) Largest single expense in the current month. */
      var monthTxns = (s.profile.transactions || []).filter(function (t) {
        return t.date && t.date.slice(0, 7) === s.currentMonth && t.amount < 0 && !t.transferTxnId;
      });
      if (monthTxns.length) {
        var biggest = monthTxns.reduce(function (max, t) {
          return Math.abs(t.amount) > Math.abs(max.amount) ? t : max;
        }, monthTxns[0]);
        if (Math.abs(biggest.amount) >= 20000) {
          out.push({
            id: "big-" + biggest.id,
            severity: "info",
            icon: "$",
            title: "Largest expense this month: " + (s.payeeName(biggest.payeeId) || "Unknown"),
            detail: self.fmt(Math.abs(biggest.amount)) + " on " + self.shortDate(biggest.date) + " (" + (s.categoryName(biggest.categoryId) || "Uncategorized") + ").",
            href: "/app/register/?focus=" + biggest.id,
            cta: "Open",
          });
        }
      }

      return out.slice(0, 6);
    },

    /* ---- Account balances grid ---- */
    allAccountsForGrid() {
      void this.$store.budget._listVersion;
      var p = this.$store.budget.profile;
      if (!p || !p.accounts) return [];
      var s = this.$store.budget;
      var groupNameById = {};
      (p.accountGroups || []).forEach(function (g) { groupNameById[g.id] = g.name; });
      return p.accounts
        .filter(function (a) { return !a.closedAt; })
        .map(function (a) {
          return {
            id: a.id,
            name: a.name,
            groupName: groupNameById[a.groupId] || "",
            excludeFromNetWorth: !!a.excludeFromNetWorth,
            balance: s.accountBalance(a.id),
          };
        })
        .sort(function (a, b) {
          if (a.groupName !== b.groupName) return a.groupName.localeCompare(b.groupName);
          return a.name.localeCompare(b.name);
        });
    },

    /* ---- Formatting helpers ---- */
    fmt(c) {
      return ((c || 0) / 100).toLocaleString("en-US", {
        style: "currency", currency: "USD", maximumFractionDigits: 0,
      });
    },
    /* Compact form for sub-labels — "$1.2k" / "$4.5M". */
    /* Magnitude-aware compact format. Drop the decimal once the
       leading value is >=100 so big numbers ($754k, $1.2M) don't
       imply false precision; keep 1 decimal for small/medium
       magnitudes ($1.2k, $57.5k). Math.round = half-up standard
       rounding. */
    fmtCompact(c) {
      var n = (c || 0) / 100;
      var sign = n < 0 ? "-" : "";
      var abs = Math.abs(n);
      if (abs >= 1000000) {
        var m = abs / 1000000;
        return sign + "$" + (m >= 100 ? Math.round(m) : (Math.round(m * 10) / 10)) + "M";
      }
      if (abs >= 1000) {
        var k = abs / 1000;
        return sign + "$" + (k >= 100 ? Math.round(k) : (Math.round(k * 10) / 10)) + "k";
      }
      return sign + "$" + Math.round(abs);
    },
    shortDate(iso) {
      if (!iso) return "";
      var parts = iso.slice(0, 10).split("-");
      var months = ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"];
      return months[Number(parts[1]) - 1] + " " + Number(parts[2]);
    },

    /* ---- This-month flow (1-month report) ---- */
    _thisMonthRow() {
      void this.$store.budget._listVersion;
      var rows = this.$store.budget.reportIncomeVsExpense(null, 1) || [];
      return rows[0] || { income: 0, expense: 0, net: 0 };
    },
    thisMonthIncome()  { return this._thisMonthRow().income; },
    thisMonthExpense() { return this._thisMonthRow().expense; },
    thisMonthNet()     { return this._thisMonthRow().net; },

    /* ---- Savings rate (3-month rolling) ---- */
    _savingsRows() {
      void this.$store.budget._listVersion;
      return this.$store.budget.reportIncomeVsExpense(null, 3) || [];
    },
    savingsRatePct() {
      var rows = this._savingsRows();
      if (!rows.length) return null;
      var sumI = 0, sumE = 0;
      rows.forEach(function (r) { sumI += r.income; sumE += r.expense; });
      if (sumI <= 0) return null;
      return ((sumI - sumE) / sumI) * 100;
    },
    savingsRateLabel() {
      var p = this.savingsRatePct();
      if (p === null) return "—";
      return p.toFixed(0) + "%";
    },
    savingsBandClass() {
      var p = this.savingsRatePct();
      if (p === null) return "rec-summary__tile--accent";
      if (p < 0)      return "rec-summary__tile--outflow";
      if (p >= 20)    return "rec-summary__tile--net";
      return "rec-summary__tile--accent";
    },

    /* ---- Upcoming bills (delegated to store) ---- */
    upcoming7()  { return this.$store.budget.upcomingBills(7); },
    upcoming14() { return this.$store.budget.upcomingBills(14); },

    /* ---- Overspent count ---- */
    overspent() { return this.$store.budget.overspentCount(); },

    /* ---- Top spending categories this month ---- */
    topCategoriesRows() {
      void this.$store.budget._listVersion;
      var m = this.$store.budget.currentMonth;
      var data = this.$store.budget.reportSpending(m, m) || [];
      if (!data.length) return [];
      var max = data[0].value || 1;
      return data.slice(0, 5).map(function (r) {
        return {
          categoryId: r.categoryId,
          category: r.category,
          value: r.value,
          pct: max > 0 ? Math.round((r.value / max) * 100) : 0,
        };
      });
    },

    /* ---- Goals needing attention (delegated to store) ---- */
    goalsAttention() {
      return this.$store.budget.goalsNeedingAttention(3);
    },

    /* ---- Recent transactions (last 10, newest first) ---- */
    recentTransactions() {
      void this.$store.budget._listVersion;
      if (!this.$store.budget.profile) return [];
      var arr = this.$store.budget.profile.transactions.slice();
      arr.sort(function (a, b) { return b.date.localeCompare(a.date); });
      return arr.slice(0, 10);
    },

    /* ---- Alerts (delegated to store) ---- */
    alerts() { return this.$store.budget.dashboardAlerts(); },
  };
}
</script>

<script type="module">
  /* Sparkline-shaped variants of the income-expense + projection
     renderers used by the report pages. Compact: hide the legend
     + axis ticks so the chart reads as a sparkline, not a full
     report visual. */
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { upsert, fmtCents } from "/assets/js/charts/chartjs.js";
  import { colors } from "/assets/js/charts/theme-colors.js";

  function renderIE(el, data) {
    if (!el || !window.Chart) return;
    if (!data || !data.length) {
      el.innerHTML = "<p style=\"padding: var(--space-sm); color: var(--fg-muted); font-size: var(--fs-sm);\">No data yet.</p>";
      return;
    }
    var c = colors();
    upsert(el, {
      type: "bar",
      pbSubType: "dash-bar",
      data: {
        labels: data.map(function (d) { return d.month.slice(5); }),
        datasets: [
          { label: "Income",  data: data.map(function (d) { return d.income; }),  backgroundColor: c["chart-1"], borderRadius: 0 },
          { label: "Expense", data: data.map(function (d) { return d.expense; }), backgroundColor: c["chart-5"], borderRadius: 0 },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: true, position: "bottom", labels: { boxWidth: 10 } } },
        scales: {
          x: { grid: { display: false } },
          y: {
            beginAtZero: true,
            grid: { color: c["border"] },
            ticks: { callback: function (v) { return fmtCents(v); } },
          },
        },
      },
    });
  }

  function renderProj(el, data) {
    if (!el || !window.Chart) return;
    if (!data || !data.length) {
      el.innerHTML = "<p style=\"padding: var(--space-sm); color: var(--fg-muted); font-size: var(--fs-sm);\">Not enough history to project yet.</p>";
      return;
    }
    /* Trim to the next 30 days (~1 month) so this sparkline doesn't
       redraw the same 12-month canvas as the full report. */
    var trimmed = data.slice(0, 2);
    var c = colors();
    upsert(el, {
      type: "line",
      pbSubType: "dash-line",
      data: {
        labels: trimmed.map(function (d) { return d.month; }),
        datasets: [
          { label: "Low",      data: trimmed.map(function (d) { return d.low; }),      borderColor: "transparent", pointRadius: 0, fill: false, tension: 0.25 },
          { label: "High",     data: trimmed.map(function (d) { return d.high; }),     borderColor: "transparent", backgroundColor: "rgba(192, 57, 43, 0.15)", fill: "-1", pointRadius: 0, tension: 0.25 },
          { label: "Expected", data: trimmed.map(function (d) { return d.expected; }), borderColor: c["chart-1"], backgroundColor: c["chart-1"], fill: false, tension: 0.25, pointRadius: 3, pointHoverRadius: 6, borderWidth: 2 },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { filter: function (item) { return item.text === "Expected"; }, boxWidth: 10 } },
        },
        scales: {
          x: { grid: { display: false } },
          y: { grid: { color: c["border"] }, ticks: { callback: function (v) { return fmtCents(v); } } },
        },
      },
    });
  }

  window.pbMountChart = mountChart;
  window.pbDashRenderIE   = renderIE;
  window.pbDashRenderProj = renderProj;
</script>
