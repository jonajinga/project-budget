---
layout: layouts/app.njk
title: "Payees"
description: "Rename, set default categories, merge, or delete payees. Default category auto-fills when you add a new transaction."
permalink: /app/payees/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="payeesView()">
  <header class="app-page__header">
    <h1 class="app-page__title">Payees</h1>
    <div class="cluster">
      <button class="btn btn--icon" type="button"
              @click="showHelp = true"
              aria-label="About payees"
              data-tip="What a payee is, how default categories auto-fill, and how merging works.">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="8"/><line x1="12" y1="12" x2="12" y2="16"/></svg>
      </button>
      <a class="btn btn--ghost btn--sm" href="/app/register/">Open register</a>
    </div>
  </header>

  {# Stat cards. Live snapshot of the payee list — total payees, how
     many have a default category set, top-used payee, and the sum of
     every transaction count. Reuses .rec-summary chrome from the
     other app pages. #}
  <section class="rec-summary" x-show="$store.budget.allPayees().length" x-cloak>
    <div class="rec-summary__tile rec-summary__tile--accent" data-tip="Total payees seen across every transaction.">
      <span class="rec-summary__label">Payees</span>
      <span class="rec-summary__value" x-text="payeeCount()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--inflow" data-tip="Payees that have a default category set. Auto-fill kicks in only when this is set.">
      <span class="rec-summary__label">With category</span>
      <span class="rec-summary__value" x-text="withCategoryCount() + ' / ' + payeeCount()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--net" data-tip="Most-used payee by transaction count.">
      <span class="rec-summary__label">Most used</span>
      <span class="rec-summary__value" style="font-size: var(--fs-base); line-height: 1.3;" x-text="topPayeeLabel()"></span>
    </div>
    <div class="rec-summary__tile rec-summary__tile--accent" data-tip="Total transactions linked to any payee.">
      <span class="rec-summary__label">Linked txns</span>
      <span class="rec-summary__value" x-text="totalUses()"></span>
    </div>
  </section>

  <section class="card">
    <header class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="pay-search">Search payees</label>
        <input class="input" id="pay-search" type="search" x-model="query" placeholder="Search by name…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="rows.length"></span> of <span x-text="$store.budget.allPayees().length"></span> payees
      </p>
    </header>

    <p x-show="!rows.length && !$store.budget.allPayees().length" x-cloak style="color: var(--fg-muted);">
      No payees yet. They're created automatically when you add a transaction.
    </p>

    <table class="table" x-show="rows.length" x-cloak>
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('name')">Name <span class="sort-ind" x-text="sortIndicator('name')"></span></button></th>
          <th>Default category</th>
          <th class="is-sortable num"><button type="button" @click="sortBy('count')">Uses <span class="sort-ind" x-text="sortIndicator('count')"></span></button></th>
          <th class="num">Actions</th>
        </tr>
      </thead>
      <tbody data-no-tippy>
        <template x-for="p in rows" :key="p.id">
          <tr>
            <td>
              <template x-if="editingId !== p.id">
                <button type="button" class="inline-edit-trigger"
                        @click="startRename(p)"
                        data-tip="Click to rename. If the new name matches another payee, they'll merge.">
                  <span x-text="p.name"></span>
                </button>
              </template>
              <template x-if="editingId === p.id">
                {# @click.outside is the reliable exit path — clicking on
                   non-focusable areas of the page doesn't always blur an
                   input on every browser, so we hook the document-level
                   outside-click event too.

                   @focus + setTimeout(select, 0) auto-selects the whole
                   name so a user can start typing immediately. Wrapping
                   in setTimeout outlasts the mouseup that would
                   otherwise clear the selection. #}
                <form @submit.prevent="commitRename(p.id)"
                      @click.outside="commitRename(p.id)"
                      class="cluster" style="gap: var(--space-2xs);">
                  <input class="input" type="text"
                         :ref="'name_' + p.id"
                         x-model="editingName"
                         @focus="setTimeout(() => $event.target.select(), 0)"
                         @keydown.escape.prevent="cancelRename()"
                         @blur="commitRename(p.id)">
                </form>
              </template>
            </td>
            <td>
              <select class="select" :value="p.lastCategoryId || ''"
                      @change="$store.budget.setPayeeCategory(p.id, $event.target.value || null)"
                      data-tip="Auto-fills when this payee is selected on a new transaction.">
                <option value="">(none)</option>
                <template x-for="c in selectableCategories()" :key="c.id">
                  <option :value="c.id" :selected="p.lastCategoryId === c.id" x-text="c.name"></option>
                </template>
              </select>
            </td>
            <td class="num" x-text="p.count"></td>
            <td class="num">
              <div class="cluster" style="justify-content: flex-end;">
                <button class="btn btn--ghost btn--sm" type="button"
                        @click="openMerge(p)"
                        data-tip="Merge this payee into another — every transaction switches to the target.">Merge</button>
                <button class="btn btn--danger btn--sm" type="button"
                        @click="deletePayee(p)">Delete</button>
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </section>

  {# Info / help modal — explains payees, default category auto-fill,
     and what merge / delete do. Previously sat above the table as a
     long lead paragraph. #}
  <div class="modal-backdrop" x-show="showHelp" x-cloak @keydown.escape.window="showHelp = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="pay-help-title" @click.outside="showHelp = false">
      <button class="modal__close" type="button" @click="showHelp = false" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="pay-help-title">About payees</h3>
      <div class="prose">
        <p>Every payee remembers a default category — when you start typing the payee on a new transaction, the category auto-fills.</p>
        <p><strong>Rename:</strong> click a payee's name to edit it inline. Press Enter or click outside to save, Escape to cancel.</p>
        <p><strong>Merge:</strong> joins two payees into one and re-points every transaction that used the source to the target.</p>
        <p><strong>Delete:</strong> leaves the payee's transactions in the register but unlinks them from the payee record.</p>
      </div>
      <div class="form-actions">
        <button class="btn btn--primary" type="button" @click="showHelp = false">Got it</button>
      </div>
    </div>
  </div>

  {# Merge modal — pick target payee #}
  <div class="modal-backdrop" x-show="mergeSrc" x-cloak @keydown.escape.window="mergeSrc = null">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="merge-title"
         @click.outside="mergeSrc = null">
      <button class="modal__close" type="button" @click="mergeSrc = null" aria-label="Close">&times;</button>
      <h3 class="modal__title" id="merge-title">
        Merge <span x-text="mergeSrc?.name"></span>
      </h3>
      <p style="color: var(--fg-muted); margin-bottom: var(--space-sm);">
        Every transaction that uses <strong x-text="mergeSrc?.name"></strong> will be re-pointed to the target payee below. This cannot be undone.
      </p>
      <form @submit.prevent="doMerge()">
        <div class="field">
          <label class="field__label" for="merge-target">Merge into</label>
          <select class="select" id="merge-target" x-model="mergeTargetId" required>
            <option value="">Select target payee</option>
            <template x-for="p in mergeTargets()" :key="p.id">
              <option :value="p.id" x-text="p.name + ' (' + p.count + ' uses)'"></option>
            </template>
          </select>
        </div>
        <div class="form-actions">
          <button class="btn btn--danger" type="submit" :disabled="!mergeTargetId">Merge</button>
          <button class="btn btn--ghost" type="button" @click="mergeSrc = null">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function payeesView() {
  return {
    showHelp: false,
    query: "",
    sortKey: "name",
    sortDir: "asc",
    editingId: null,
    editingName: "",
    mergeSrc: null,
    mergeTargetId: "",

    get rows() {
      void this.$store.budget._listVersion;
      var counts = this.$store.budget.payeeUsageCounts();
      var all = this.$store.budget.allPayees().map(function (p) {
        return { id: p.id, name: p.name, lastCategoryId: p.lastCategoryId, count: counts[p.id] || 0 };
      });
      var q = (this.query || "").trim().toLowerCase();
      var filtered = q
        ? all.filter(function (p) { return p.name.toLowerCase().indexOf(q) !== -1; })
        : all;
      var self = this;
      filtered.sort(function (a, b) {
        var c;
        if (self.sortKey === "count") c = a.count - b.count;
        else c = String(a[self.sortKey] || "").localeCompare(String(b[self.sortKey] || ""));
        return self.sortDir === "asc" ? c : -c;
      });
      return filtered;
    },

    sortBy(key) {
      if (this.sortKey === key) this.sortDir = this.sortDir === "asc" ? "desc" : "asc";
      else { this.sortKey = key; this.sortDir = key === "count" ? "desc" : "asc"; }
    },
    sortIndicator(key) {
      if (this.sortKey !== key) return "";
      return this.sortDir === "asc" ? "▲" : "▼";
    },

    /* ---- Stat-card aggregates ---- */
    payeeCount() {
      void this.$store.budget._listVersion;
      return this.$store.budget.allPayees().length;
    },
    withCategoryCount() {
      void this.$store.budget._listVersion;
      return this.$store.budget.allPayees().filter(function (p) { return !!p.lastCategoryId; }).length;
    },
    totalUses() {
      void this.$store.budget._listVersion;
      var counts = this.$store.budget.payeeUsageCounts();
      var sum = 0;
      Object.keys(counts).forEach(function (k) { sum += counts[k] || 0; });
      return sum;
    },
    topPayeeLabel() {
      void this.$store.budget._listVersion;
      var counts = this.$store.budget.payeeUsageCounts();
      var all = this.$store.budget.allPayees();
      var best = null; var bestCount = 0;
      all.forEach(function (p) {
        var n = counts[p.id] || 0;
        if (n > bestCount) { bestCount = n; best = p; }
      });
      if (!best) return "—";
      return best.name + " · " + bestCount;
    },

    selectableCategories() {
      var s = this.$store.budget;
      if (!s.profile) return [];
      return s.categoriesFlat().filter(function (c) { return !s.isPaymentCategory(c.id); });
    },

    /* Rename: click name → input, Enter/blur commits. */
    startRename(p) {
      this.editingId = p.id;
      this.editingName = p.name;
      var self = this;
      this.$nextTick(function () {
        var input = self.$refs["name_" + p.id];
        if (input) { input.focus(); input.select(); }
      });
    },
    cancelRename() { this.editingId = null; this.editingName = ""; },
    commitRename(id) {
      if (this.editingId !== id) return;
      var trimmed = (this.editingName || "").trim();
      if (trimmed && trimmed !== (this.$store.budget.findPayee(id)?.name || "")) {
        this.$store.budget.renamePayee(id, trimmed);
        this.$store.budget.pushToast("Payee renamed.");
      }
      this.cancelRename();
    },

    deletePayee(p) {
      var self = this;
      window.PBDialog.confirm({
        title: "Delete payee '" + p.name + "'?",
        message: p.count + " transaction" + (p.count === 1 ? "" : "s") + " will lose the payee link but stay in the register. Their categories and amounts are unchanged.",
        confirmLabel: "Delete payee",
        danger: true,
      }).then(function (ok) {
        if (!ok) return;
        self.$store.budget.deletePayee(p.id);
        self.$store.budget.pushToast("Payee deleted.");
      });
    },

    openMerge(p) {
      this.mergeSrc = p;
      this.mergeTargetId = "";
    },
    mergeTargets() {
      if (!this.mergeSrc) return [];
      return this.rows.filter(function (p) { return p.id !== this.mergeSrc.id; }, this);
    },
    doMerge() {
      if (!this.mergeSrc || !this.mergeTargetId) return;
      this.$store.budget.mergePayees(this.mergeSrc.id, this.mergeTargetId);
      this.$store.budget.pushToast("Payees merged.");
      this.mergeSrc = null;
      this.mergeTargetId = "";
    },
  };
}
</script>
