---
layout: layouts/app.njk
title: "Spending by category"
description: "Treemap of category activity over a chosen window."
permalink: /app/reports/spending/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="spendingView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Spending by category</h1>
      <p class="app-page__lead">Outflows by category over the chosen window. Transfers and uncategorized inflows are excluded.</p>
    </div>
    <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
  </header>

  <section class="report">
    <div class="form-row" style="margin-bottom: var(--space-md);">
      <div class="field">
        <label class="field__label" for="from-month">From</label>
        <input class="input" id="from-month" type="month" x-model="from">
      </div>
      <div class="field">
        <label class="field__label" for="to-month">To</label>
        <input class="input" id="to-month" type="month" x-model="to">
      </div>
    </div>

    <div class="kpi-strip">
      <div class="kpi kpi--danger">
        <span class="kpi__label">Total spent</span>
        <span class="kpi__value" x-text="fmt(kpis().total)"></span>
        <span class="kpi__delta" x-text="kpis().months + ' month' + (kpis().months === 1 ? '' : 's')"></span>
      </div>
      <div class="kpi">
        <span class="kpi__label">Avg per month</span>
        <span class="kpi__value" x-text="fmt(kpis().monthlyAvg)"></span>
        <span class="kpi__delta">Across the range</span>
      </div>
      <div class="kpi kpi--warn">
        <span class="kpi__label">Top category</span>
        <span class="kpi__value" style="font-size: var(--fs-lg);" x-text="kpis().topName || '—'"></span>
        <span class="kpi__delta" x-text="kpis().topShare === null ? '—' : (kpis().topShare.toFixed(1) + '% of total')"></span>
      </div>
      <div class="kpi kpi--muted">
        <span class="kpi__label">Categories active</span>
        <span class="kpi__value" x-text="kpis().count"></span>
        <span class="kpi__delta">With at least one outflow</span>
      </div>
    </div>

    <div class="chart-toolbar">
      <span class="chart-toolbar__label">Chart</span>
      <span class="chart-picker" role="group" aria-label="Chart type">
        <template x-for="opt in chartOptions" :key="opt.value">
          <button type="button"
                  class="chart-picker__btn"
                  :class="chartType === opt.value ? 'is-active' : ''"
                  :aria-pressed="(chartType === opt.value).toString()"
                  @click="setChartType(opt.value)"
                  :data-tip="'Render as a ' + opt.label.toLowerCase() + ' chart.'"
                  x-text="opt.label"></button>
        </template>
      </span>
    </div>
    <div class="chart" id="chart-spending" style="min-height: 420px;"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="sp-search">Search</label>
        <input class="input" id="sp-search" type="search" x-model="query" placeholder="Filter by group or category…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportCSV('spending-by-category')"
              data-tip="Download the visible rows as a CSV file.">Export CSV</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('group')">Group <span class="sort-ind" x-text="sortIndicator('group')"></span></button></th>
          <th class="is-sortable"><button type="button" @click="sortBy('category')">Category <span class="sort-ind" x-text="sortIndicator('category')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('value')">Spent <span class="sort-ind" x-text="sortIndicator('value')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.categoryId">
          <tr>
            <td x-text="r.group"></td>
            <td x-text="r.category"></td>
            <td class="num amount--outflow" x-text="'$' + (r.value / 100).toFixed(2)"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="3" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No rows match the filter.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/spending-category.js";
  window.pbMountChart = mountChart;
  window.pbRenderSpending = render;
</script>

<script>
/* Single Alpine factory — replaces the previous pattern of patching
   fields onto a `window.reportTable(...)` result, which silently
   failed when reportTable was undefined at eval time and broke every
   binding on the page. All report-table state is inlined directly. */
function spendingView() {
  /* Initial date window: trailing 3 months ending today. Computed
     synchronously so the first render has valid values. */
  var d = new Date();
  var toInitial = d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0");
  var fromD = new Date(d.getFullYear(), d.getMonth() - 2, 1);
  var fromInitial = fromD.getFullYear() + "-" + String(fromD.getMonth() + 1).padStart(2, "0");

  var savedChartType = "treemap";
  try {
    var st = localStorage.getItem("projectbudget:chart-type:spending");
    if (st && ["treemap","bar","donut"].indexOf(st) !== -1) savedChartType = st;
  } catch (_e) {}
  window.__pbChartType = window.__pbChartType || {};
  window.__pbChartType.spending = savedChartType;

  return {
    from: fromInitial,
    to: toInitial,

    chartType: savedChartType,
    chartOptions: [
      { value: "treemap", label: "Treemap" },
      { value: "bar",     label: "Bar" },
      { value: "donut",   label: "Donut" },
    ],
    setChartType(t) {
      this.chartType = t;
      window.__pbChartType.spending = t;
      try { localStorage.setItem("projectbudget:chart-type:spending", t); } catch (_e) {}
      try { window.dispatchEvent(new CustomEvent("pb:chart-type", { detail: { reportId: "spending", type: t } })); } catch (_e) {}
    },

    /* Report-table state (inlined). */
    query: "",
    sortKey: "value",
    sortDir: "desc",
    _keys: [
      { key: "group",    label: "Group" },
      { key: "category", label: "Category" },
      { key: "value",    label: "Spent", numeric: true },
    ],
    get rows() {
      void this.$store.budget._listVersion;
      var src = this.$store.budget.reportSpending(this.from, this.to) || [];
      var q = (this.query || "").trim().toLowerCase();
      var filtered = q ? src.filter(function (r) {
        return (String(r.group || "") + " " + String(r.category || "")).toLowerCase().indexOf(q) !== -1;
      }) : src;
      var key = this.sortKey, dir = this.sortDir;
      var keyDef = this._keys.find(function (k) { return k.key === key; });
      var numeric = !!(keyDef && keyDef.numeric);
      var copy = filtered.slice();
      copy.sort(function (a, b) {
        if (numeric) {
          var an = Number(a[key]) || 0, bn = Number(b[key]) || 0;
          return dir === "asc" ? an - bn : bn - an;
        }
        var as = String(a[key] == null ? "" : a[key]);
        var bs = String(b[key] == null ? "" : b[key]);
        return dir === "asc" ? as.localeCompare(bs) : bs.localeCompare(as);
      });
      return copy;
    },
    get visibleCount() { return this.rows.length; },
    sortBy(key) {
      if (this.sortKey === key) {
        this.sortDir = this.sortDir === "asc" ? "desc" : "asc";
      } else {
        this.sortKey = key;
        var kd = this._keys.find(function (k) { return k.key === key; });
        this.sortDir = kd && kd.numeric ? "desc" : "asc";
      }
    },
    sortIndicator(key) {
      if (this.sortKey !== key) return "";
      return this.sortDir === "asc" ? "▲" : "▼";
    },
    print() { window.print(); },
    exportCSV(name) {
      var self = this;
      var header = this._keys.map(function (k) { return JSON.stringify(k.label); }).join(",");
      var body = this.rows.map(function (r) {
        return self._keys.map(function (k) {
          var v = r[k.key];
          if (v == null) return "";
          if (k.numeric && Math.abs(v) >= 1000 && Number.isInteger(v)) v = (v / 100).toFixed(2);
          return JSON.stringify(String(v));
        }).join(",");
      }).join("\r\n");
      var blob = new Blob([header + "\r\n" + body], { type: "text/csv;charset=utf-8" });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url;
      a.download = (name || "report") + "-" + new Date().toISOString().slice(0, 10) + ".csv";
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      setTimeout(function () { URL.revokeObjectURL(url); }, 1500);
    },

    fmt(c) { return (c / 100).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }); },
    kpis() {
      var data = this.$store.budget.reportSpending(this.from, this.to) || [];
      var total = data.reduce(function (s, r) { return s + r.value; }, 0);
      var top = data[0];
      var fp = (this.from || "").split("-").map(Number);
      var tp = (this.to   || "").split("-").map(Number);
      var months = 1;
      if (fp.length === 2 && tp.length === 2) {
        months = Math.max(1, (tp[0] - fp[0]) * 12 + (tp[1] - fp[1]) + 1);
      }
      return {
        total: total,
        monthlyAvg: Math.round(total / months),
        topName: top ? top.category : "",
        topShare: top && total > 0 ? (top.value / total) * 100 : null,
        count: data.length,
        months: months,
      };
    },

    init() {
      var self = this;
      /* Snap to active profile's currentMonth once the store is up. */
      var s = window.Alpine && window.Alpine.store && window.Alpine.store("budget");
      if (s && s.currentMonth) {
        self.to = s.currentMonth;
        var parts = s.currentMonth.split("-").map(Number);
        var fd = new Date(parts[0], parts[1] - 3, 1);
        self.from = fd.getFullYear() + "-" + String(fd.getMonth() + 1).padStart(2, "0");
      }
      /* Chart mount — polls for Alpine + chart bootstrap to be ready,
         then wires redraws via $watch on this component's reactive
         state. Uses a closure variable for the chart instance instead
         of putting it on the Alpine proxy. */
      var chart = null;
      var tries = 0;
      var poll = function () {
        var ready = window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart && window.pbRenderSpending;
        if (!ready) { if (++tries < 100) setTimeout(poll, 50); return; }
        var store = Alpine.store("budget");
        chart = window.pbMountChart("#chart-spending", window.pbRenderSpending, function () {
          return store.reportSpending(self.from, self.to);
        });
        self.$watch("from",      function () { chart && chart.redraw(); });
        self.$watch("to",        function () { chart && chart.redraw(); });
        self.$watch("chartType", function () { chart && chart.redraw(); });
        Alpine.effect(function () {
          store.profile; store._listVersion;
          if (chart) chart.redraw();
        });
      };
      poll();
    },
  };
}
</script>
