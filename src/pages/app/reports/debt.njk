---
layout: layouts/app.njk
title: "Debt overview"
description: "Balances and payoff projections for every credit and liability account."
permalink: /app/reports/debt/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="debtView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Debt overview</h1>
      <p class="app-page__lead">Balances on every credit card and tracking liability. Payoff months estimate based on the average payment over the last three months.</p>
    </div>
    <div class="cluster" style="gap: var(--space-2xs);">
      <button class="btn btn--ghost btn--sm" type="button" @click="saveCurrentView()"
              data-tip="Save this chart type + filter + sort as a recall-able view in /app/templates/.">Save view</button>
      <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
    </div>
  </header>

  <section class="report">
    <div class="chart-toolbar">
      <span class="chart-toolbar__label">Chart</span>
      <span class="chart-picker" role="group" aria-label="Chart type">
        <template x-for="opt in chartOptions" :key="opt.value">
          <button type="button"
                  class="chart-picker__btn"
                  :class="chartType === opt.value ? 'is-active' : ''"
                  :aria-pressed="(chartType === opt.value).toString()"
                  @click="setChartType(opt.value)"
                  :data-tip="'Render as a ' + opt.label.toLowerCase() + ' chart.'"
                  x-text="opt.label"></button>
        </template>
      </span>
    </div>
    <div class="chart" id="chart-debt" style="min-height: 220px;"
         role="img" aria-label="Debt overview chart"
         aria-describedby="data-table-debt"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="debt-search">Search</label>
        <input class="input" id="debt-search" type="search" x-model="query" placeholder="Filter by account…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportRowsCSV()"
              data-tip="Download the debt overview as a CSV file.">Export CSV</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportPDF()"
              data-tip="Download a printable PDF of this report.">Export PDF</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table" id="data-table-debt">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('account')">Account <span class="sort-ind" x-text="sortIndicator('account')"></span></button></th>
          <th class="is-sortable"><button type="button" @click="sortBy('type')">Type <span class="sort-ind" x-text="sortIndicator('type')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('balance')">Balance <span class="sort-ind" x-text="sortIndicator('balance')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('avgPayment')">Avg payment (3 mo) <span class="sort-ind" x-text="sortIndicator('avgPayment')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('monthsToPayoff')">Payoff <span class="sort-ind" x-text="sortIndicator('monthsToPayoff')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.accountId">
          <tr>
            <td x-text="r.account"></td>
            <td x-text="r.type === 'credit' ? 'Credit card' : 'Tracking liability'"></td>
            <td class="num amount--outflow" x-text="'$' + (r.balance / 100).toFixed(2)"></td>
            <td class="num" x-text="'$' + (r.avgPayment / 100).toFixed(2)"></td>
            <td class="num" x-text="r.monthsToPayoff ? (r.monthsToPayoff + ' months') : 'No recent payments'"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="5" style="color: var(--fg-muted); text-align: center; padding: var(--space-lg);">No debt accounts.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script>
function debtView() {
  var savedChartType = "bar";
  try {
    var st = localStorage.getItem("projectbudget:chart-type:debt");
    if (st && ["bar","donut"].indexOf(st) !== -1) savedChartType = st;
  } catch (_e) {}
  window.__pbChartType = window.__pbChartType || {};
  window.__pbChartType.debt = savedChartType;

  return {
    chartType: savedChartType,
    chartOptions: [
      { value: "bar",   label: "Bar" },
      { value: "donut", label: "Donut" },
    ],
    setChartType(t) {
      this.chartType = t;
      window.__pbChartType.debt = t;
      try { localStorage.setItem("projectbudget:chart-type:debt", t); } catch (_e) {}
      try { window.dispatchEvent(new CustomEvent("pb:chart-type", { detail: { reportId: "debt", type: t } })); } catch (_e) {}
    },

    query: "",
    sortKey: "balance",
    sortDir: "desc",
    _keys: [
      { key: "account",        label: "Account" },
      { key: "type",           label: "Type" },
      { key: "balance",        label: "Balance",         numeric: true },
      { key: "avgPayment",     label: "Avg payment",     numeric: true },
      { key: "monthsToPayoff", label: "Months to payoff", numeric: true },
    ],
    get rows() {
      void this.$store.budget._listVersion;
      var src = this.$store.budget.reportDebt() || [];
      var q = (this.query || "").trim().toLowerCase();
      var filtered = q ? src.filter(function (r) { return String(r.account || "").toLowerCase().indexOf(q) !== -1; }) : src;
      var key = this.sortKey, dir = this.sortDir;
      var keyDef = this._keys.find(function (k) { return k.key === key; });
      var numeric = !!(keyDef && keyDef.numeric);
      var copy = filtered.slice();
      copy.sort(function (a, b) {
        if (numeric) {
          var an = Number(a[key]) || 0, bn = Number(b[key]) || 0;
          return dir === "asc" ? an - bn : bn - an;
        }
        var as = String(a[key] == null ? "" : a[key]);
        var bs = String(b[key] == null ? "" : b[key]);
        return dir === "asc" ? as.localeCompare(bs) : bs.localeCompare(as);
      });
      return copy;
    },
    get visibleCount() { return this.rows.length; },
    sortBy(key) {
      if (this.sortKey === key) {
        this.sortDir = this.sortDir === "asc" ? "desc" : "asc";
      } else {
        this.sortKey = key;
        var kd = this._keys.find(function (k) { return k.key === key; });
        this.sortDir = kd && kd.numeric ? "desc" : "asc";
      }
    },
    sortIndicator(key) {
      if (this.sortKey !== key) return "";
      return this.sortDir === "asc" ? "▲" : "▼";
    },
    print() { window.print(); },
    exportRowsCSV() {
      if (window.pbExportCSV) {
        /* Use a custom format function for the type column so the CSV
           shows the human label instead of the raw key, and for the
           months-to-payoff column so "no recent payments" lands as a
           string rather than a 0. */
        window.pbExportCSV("debt-overview", this.rows, [
          { key: "account",        label: "Account" },
          { key: "type",           label: "Type",            format: function (v) { return v === "credit" ? "Credit card" : "Tracking liability"; } },
          { key: "balance",        label: "Balance",         numeric: true },
          { key: "avgPayment",     label: "Avg payment (3 mo)", numeric: true },
          { key: "monthsToPayoff", label: "Months to payoff",   format: function (v) { return v ? String(v) : "No recent payments"; } },
        ]);
      }
    },
    exportPDF() {
      if (!window.pbExportReportPDF) return;
      var rows = this.rows || [];
      var totalBalance = rows.reduce(function (s, r) { return s + (r.balance || 0); }, 0);
      var totalPayment = rows.reduce(function (s, r) { return s + (r.avgPayment || 0); }, 0);
      var soonest = rows.reduce(function (best, r) {
        if (!r.monthsToPayoff) return best;
        if (!best || r.monthsToPayoff < best.monthsToPayoff) return r;
        return best;
      }, null);
      var fmt = function (c) { return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD" }); };
      window.pbExportReportPDF({
        title: "Debt overview",
        subtitle: "All credit + tracking-liability accounts",
        filename: "debt-overview",
        kpis: [
          { label: "Total balance",   value: fmt(totalBalance) },
          { label: "Total payments (3 mo avg)", value: fmt(totalPayment) },
          { label: "Accounts tracked", value: String(rows.length) },
          { label: "Next paid off",   value: soonest ? soonest.account : "—", delta: soonest ? (soonest.monthsToPayoff + " months") : "" },
        ],
        chartEl: document.getElementById("chart-debt"),
        columns: [
          { key: "account",        label: "Account" },
          { key: "type",           label: "Type",         format: function (v) { return v === "credit" ? "Credit card" : "Tracking liability"; } },
          { key: "balance",        label: "Balance",      numeric: true },
          { key: "avgPayment",     label: "Avg payment",  numeric: true },
          { key: "monthsToPayoff", label: "Payoff (mo)",  format: function (v) { return v ? String(v) : "—"; } },
        ],
        rows: rows,
      });
    },

    /* URL state sync — write chartType + query + sort back to the
       address bar so the view is shareable + save-able. */
    _syncUrl() {
      try {
        var parts = [];
        if (this.chartType !== "bar")       parts.push("type="  + encodeURIComponent(this.chartType));
        if (this.query)                     parts.push("q="     + encodeURIComponent(this.query));
        if (this.sortKey !== "balance")     parts.push("sort="  + encodeURIComponent(this.sortKey));
        if (this.sortDir !== "desc")        parts.push("dir="   + encodeURIComponent(this.sortDir));
        var qs = parts.length ? ("?" + parts.join("&")) : "";
        history.replaceState(null, "", window.location.pathname + qs);
      } catch (_e) {}
    },
    saveCurrentView() {
      this._syncUrl();
      this.$dispatch("pb:save-view", { kind: "debt", name: "" });
    },

    init() {
      var self = this;
      /* Honor incoming URL params from a recalled saved view. */
      try {
        var p = new URL(window.location.href).searchParams;
        var t = p.get("type");
        if (t && ["bar","donut"].indexOf(t) !== -1) self.chartType = t;
        var q = p.get("q"); if (q) self.query = q;
        var sk = p.get("sort"); if (sk) self.sortKey = sk;
        var sd = p.get("dir");  if (sd && (sd === "asc" || sd === "desc")) self.sortDir = sd;
      } catch (_e) {}
      var chart = null;
      var tries = 0;
      var poll = function () {
        var ready = window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart && window.pbRenderDebt;
        if (!ready) { if (++tries < 100) setTimeout(poll, 50); return; }
        var store = Alpine.store("budget");
        chart = window.pbMountChart("#chart-debt", window.pbRenderDebt, function () {
          return store.reportDebt();
        });
        self.$watch("chartType", function () { chart && chart.redraw(); self._syncUrl(); });
        self.$watch("query",     function () { self._syncUrl(); });
        self.$watch("sortKey",   function () { self._syncUrl(); });
        self.$watch("sortDir",   function () { self._syncUrl(); });
        Alpine.effect(function () {
          store.profile; store._listVersion;
          if (chart) chart.redraw();
        });
      };
      poll();
    },
  };
}
</script>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/debt.js";
  window.pbMountChart = mountChart;
  window.pbRenderDebt = render;
</script>
