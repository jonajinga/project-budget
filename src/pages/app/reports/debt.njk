---
layout: layouts/app.njk
title: "Debt overview"
description: "Balances and payoff projections for every credit and liability account."
permalink: /app/reports/debt/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="reportTable(
  () => ($store.budget.reportDebt() || []),
  { keys: [
      { key: 'account',        label: 'Account' },
      { key: 'type',           label: 'Type' },
      { key: 'balance',        label: 'Balance',         numeric: true },
      { key: 'avgPayment',     label: 'Avg payment',     numeric: true },
      { key: 'monthsToPayoff', label: 'Months to payoff', numeric: true },
    ], defaultSort: { key: 'balance', dir: 'asc' } })">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Debt overview</h1>
      <p class="app-page__lead">Balances on every credit card and tracking liability. Payoff months estimate based on the average payment over the last three months.</p>
    </div>
    <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
  </header>

  <section class="report">
    <div class="chart" id="chart-debt" style="min-height: 120px;"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="debt-search">Search</label>
        <input class="input" id="debt-search" type="search" x-model="query" placeholder="Filter by account…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('account')">Account <span class="sort-ind" x-text="sortIndicator('account')"></span></button></th>
          <th class="is-sortable"><button type="button" @click="sortBy('type')">Type <span class="sort-ind" x-text="sortIndicator('type')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('balance')">Balance <span class="sort-ind" x-text="sortIndicator('balance')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('avgPayment')">Avg payment (3 mo) <span class="sort-ind" x-text="sortIndicator('avgPayment')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('monthsToPayoff')">Payoff <span class="sort-ind" x-text="sortIndicator('monthsToPayoff')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.accountId">
          <tr>
            <td x-text="r.account"></td>
            <td x-text="r.type === 'credit' ? 'Credit card' : 'Tracking liability'"></td>
            <td class="num amount--outflow" x-text="'$' + (r.balance / 100).toFixed(2)"></td>
            <td class="num" x-text="'$' + (r.avgPayment / 100).toFixed(2)"></td>
            <td class="num" x-text="r.monthsToPayoff ? (r.monthsToPayoff + ' months') : 'No recent payments'"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="5" style="color: var(--fg-muted); text-align: center; padding: var(--space-lg);">No debt accounts.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/debt.js";
  function boot() {
    var store = Alpine.store("budget");
    var inst = mountChart("#chart-debt", render, function () { return store.reportDebt(); });
    Alpine.effect(function () { store.profile; inst.redraw(); });
  };
  if (window.Alpine && window.Alpine.store("budget")) boot();
  else document.addEventListener("alpine:initialized", boot);
</script>
