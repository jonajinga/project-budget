---
layout: layouts/app.njk
title: "Cashflow projection"
description: "Forward 3, 6, and 12 month projection from on-budget balance + recurring + goals."
permalink: /app/reports/projection/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="projectionView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Cashflow projection</h1>
      <p class="app-page__lead">
        Starts from the current sum of on-budget account balances. Each future month subtracts net scheduled outflows and goal funding requirements. The shaded band shows the low estimate (after goal funding) and the high estimate (scheduled only).
      </p>
    </div>
    <div class="cluster">
      <button class="btn btn--secondary btn--sm" type="button" @click="horizon = 3" :class="horizon === 3 ? 'is-active' : ''">3 mo</button>
      <button class="btn btn--secondary btn--sm" type="button" @click="horizon = 6" :class="horizon === 6 ? 'is-active' : ''">6 mo</button>
      <button class="btn btn--secondary btn--sm" type="button" @click="horizon = 12" :class="horizon === 12 ? 'is-active' : ''">12 mo</button>
      <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
    </div>
  </header>

  <section class="report">
    <div class="chart" id="chart-proj" style="min-height: 320px;"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="proj-search">Search</label>
        <input class="input" id="proj-search" type="search" x-model="query" placeholder="Filter by month…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('month')">Month <span class="sort-ind" x-text="sortIndicator('month')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('low')">Low <span class="sort-ind" x-text="sortIndicator('low')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('expected')">Expected <span class="sort-ind" x-text="sortIndicator('expected')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('high')">High <span class="sort-ind" x-text="sortIndicator('high')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.month">
          <tr>
            <td x-text="r.month"></td>
            <td class="num" :class="r.low < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.low / 100).toFixed(2)"></td>
            <td class="num" :class="r.expected < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.expected / 100).toFixed(2)"></td>
            <td class="num" :class="r.high < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.high / 100).toFixed(2)"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="4" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No rows match the filter.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/projection.js";
  window.pbMountChart = mountChart;
  window.pbRenderProj = render;
</script>

<script>
function projectionView() {
  /* Extend the generic reportTable() factory with this report's
     horizon state. The chart mount + redraw lifecycle stays in init. */
  var rt = window.reportTable(function () {
    return Alpine.store("budget").reportProjection(this.horizon || 12);
  }, {
    keys: [
      { key: "month",    label: "Month" },
      { key: "low",      label: "Low",      numeric: true },
      { key: "expected", label: "Expected", numeric: true },
      { key: "high",     label: "High",     numeric: true },
    ],
    defaultSort: { key: "month", dir: "asc" },
  });
  rt.horizon = 12;
  rt.init = function () {
    var self = this;
    var ready = function () { return window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart; };
    var tries = 0;
    var poll = function () {
      if (ready()) {
        var store = Alpine.store("budget");
        var inst = window.pbMountChart("#chart-proj", window.pbRenderProj, function () { return store.reportProjection(self.horizon); });
        Alpine.effect(function () { self.horizon; store.profile; inst.redraw(); });
      } else if (++tries < 50) setTimeout(poll, 50);
    };
    poll();
  };
  return rt;
}
</script>
