---
layout: layouts/app.njk
title: "Cashflow projection"
description: "Forward 3, 6, and 12 month projection from on-budget balance + recurring + goals."
permalink: /app/reports/projection/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="projectionView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Cashflow projection</h1>
      <p class="app-page__lead">
        Starts from the current sum of on-budget account balances. Each future month subtracts net scheduled outflows and goal funding requirements. The shaded band shows the low estimate (after goal funding) and the high estimate (scheduled only).
      </p>
    </div>
    <div class="cluster" style="gap: var(--space-2xs);">
      <button class="btn btn--ghost btn--sm" type="button" @click="saveCurrentView()"
              data-tip="Save this horizon + filter as a recall-able view in /app/templates/.">Save view</button>
      <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
    </div>
  </header>

  {# ---- KPI strip ---- #}
  <div class="kpi-strip">
    <div class="kpi" :class="kpis().endExpected < kpis().startBalance ? 'kpi--danger' : 'kpi--ok'">
      <span class="kpi__label">Projected end balance</span>
      <span class="kpi__value"
            :class="kpis().endExpected < 0 ? 'amount--outflow' : ''"
            x-text="fmt(kpis().endExpected)"></span>
      <span class="kpi__delta" x-text="'In ' + horizon + ' months (expected)'"></span>
    </div>
    <div class="kpi kpi--accent">
      <span class="kpi__label">Starting balance</span>
      <span class="kpi__value" x-text="fmt(kpis().startBalance)"></span>
      <span class="kpi__delta">On-budget accounts today</span>
    </div>
    <div class="kpi" :class="kpis().netChange < 0 ? 'kpi--danger' : 'kpi--ok'">
      <span class="kpi__label">Net change</span>
      <span class="kpi__value"
            :class="kpis().netChange < 0 ? 'amount--outflow' : 'amount--inflow'"
            x-text="fmt(kpis().netChange)"></span>
      <span class="kpi__delta" x-text="kpis().netChange < 0 ? 'Burning down' : 'Building up'"></span>
    </div>
    <div class="kpi kpi--muted">
      <span class="kpi__label">Lowest projected</span>
      <span class="kpi__value"
            :class="kpis().lowestLow < 0 ? 'amount--outflow' : ''"
            x-text="fmt(kpis().lowestLow)"></span>
      <span class="kpi__delta" x-text="kpis().lowestMonth || 'No data'"></span>
    </div>
  </div>

  <section class="report">
    <div class="cluster" style="margin-bottom: var(--space-md); gap: var(--space-2xs);">
      <span style="color: var(--fg-muted); font-size: var(--fs-sm); margin-right: var(--space-2xs);">Horizon:</span>
      <template x-for="r in ranges" :key="r.value">
        <button type="button" class="btn btn--sm"
                :class="horizon === r.value ? 'btn--primary' : 'btn--ghost'"
                @click="horizon = r.value"
                x-text="r.label"></button>
      </template>
    </div>

    <div class="chart" id="chart-proj" style="min-height: 320px;"
         role="img" aria-label="Cashflow projection chart"
         aria-describedby="data-table-proj"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="proj-search">Search</label>
        <input class="input" id="proj-search" type="search" x-model="query" placeholder="Filter by month…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportRowsCSV()"
              data-tip="Download the projected balances per month as a CSV file.">Export CSV</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportPDF()"
              data-tip="Download a printable PDF of this report.">Export PDF</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table" id="data-table-proj">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('month')">Month <span class="sort-ind" x-text="sortIndicator('month')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('low')">Low <span class="sort-ind" x-text="sortIndicator('low')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('expected')">Expected <span class="sort-ind" x-text="sortIndicator('expected')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('high')">High <span class="sort-ind" x-text="sortIndicator('high')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.month">
          <tr>
            <td>
              <a class="report-month-link"
                 :href="'/app/calendar/?m=' + r.month + '&v=month'"
                 x-text="r.month"
                 data-tip="Open this month in the calendar."></a>
            </td>
            <td class="num" :class="r.low < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.low / 100).toFixed(2)"></td>
            <td class="num" :class="r.expected < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.expected / 100).toFixed(2)"></td>
            <td class="num" :class="r.high < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.high / 100).toFixed(2)"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="4" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No rows match the filter.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/projection.js";
  window.pbMountChart = mountChart;
  window.pbRenderProj = render;
</script>

<script>
function projectionView() {
  return {
    horizon: 12,
    ranges: [
      { value: 3,  label: "3 mo" },
      { value: 6,  label: "6 mo" },
      { value: 12, label: "12 mo" },
      { value: 24, label: "24 mo" },
    ],

    query: "",
    sortKey: "month",
    sortDir: "asc",
    _keys: [
      { key: "month",    label: "Month" },
      { key: "low",      label: "Low",      numeric: true },
      { key: "expected", label: "Expected", numeric: true },
      { key: "high",     label: "High",     numeric: true },
    ],
    get rows() {
      void this.$store.budget._listVersion;
      var src = this.$store.budget.reportProjection(this.horizon || 12) || [];
      var q = (this.query || "").trim().toLowerCase();
      var filtered = q ? src.filter(function (r) { return String(r.month).toLowerCase().indexOf(q) !== -1; }) : src;
      var key = this.sortKey, dir = this.sortDir;
      var keyDef = this._keys.find(function (k) { return k.key === key; });
      var numeric = !!(keyDef && keyDef.numeric);
      var copy = filtered.slice();
      copy.sort(function (a, b) {
        if (numeric) {
          var an = Number(a[key]) || 0, bn = Number(b[key]) || 0;
          return dir === "asc" ? an - bn : bn - an;
        }
        var as = String(a[key] == null ? "" : a[key]);
        var bs = String(b[key] == null ? "" : b[key]);
        return dir === "asc" ? as.localeCompare(bs) : bs.localeCompare(as);
      });
      return copy;
    },
    get visibleCount() { return this.rows.length; },
    sortBy(key) {
      if (this.sortKey === key) {
        this.sortDir = this.sortDir === "asc" ? "desc" : "asc";
      } else {
        this.sortKey = key;
        var kd = this._keys.find(function (k) { return k.key === key; });
        this.sortDir = kd && kd.numeric ? "desc" : "asc";
      }
    },
    sortIndicator(key) {
      if (this.sortKey !== key) return "";
      return this.sortDir === "asc" ? "▲" : "▼";
    },
    print() { window.print(); },
    fmt(c) {
      return ((c || 0) / 100).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });
    },
    /* KPI computations — reads the raw (unsorted, unfiltered) source
       so the start/end + lowest-month numbers don't shift when the
       user sorts the table. */
    kpis() {
      void this.$store.budget._listVersion;
      var src = this.$store.budget.reportProjection(this.horizon || 12) || [];
      if (!src.length) return { startBalance: 0, endExpected: 0, netChange: 0, lowestLow: 0, lowestMonth: "" };
      var start = src[0];
      var end = src[src.length - 1];
      var startBalance = start.expected != null ? start.expected : (start.low || 0);
      var endExpected  = end.expected != null ? end.expected : (end.low || 0);
      var lowestLow = Infinity, lowestMonth = "";
      src.forEach(function (r) {
        var v = r.low != null ? r.low : (r.expected || 0);
        if (v < lowestLow) { lowestLow = v; lowestMonth = r.month; }
      });
      if (lowestLow === Infinity) lowestLow = 0;
      return {
        startBalance: startBalance,
        endExpected: endExpected,
        netChange: endExpected - startBalance,
        lowestLow: lowestLow,
        lowestMonth: lowestMonth,
      };
    },
    exportRowsCSV() {
      if (window.pbExportCSV) {
        window.pbExportCSV("cashflow-projection", this.rows, [
          { key: "month",    label: "Month" },
          { key: "low",      label: "Low",      numeric: true },
          { key: "expected", label: "Expected", numeric: true },
          { key: "high",     label: "High",     numeric: true },
        ]);
      }
    },
    exportPDF() {
      if (!window.pbExportReportPDF) return;
      var k = this.kpis();
      window.pbExportReportPDF({
        title: "Cashflow projection",
        subtitle: "Next " + this.horizon + " months",
        filename: "cashflow-projection",
        kpis: [
          { label: "Projected end balance", value: this.fmt(k.endExpected), delta: "In " + this.horizon + " months" },
          { label: "Starting balance",      value: this.fmt(k.startBalance) },
          { label: "Net change",            value: this.fmt(k.netChange) },
          { label: "Lowest projected",      value: this.fmt(k.lowestLow), delta: k.lowestMonth || "" },
        ],
        chartEl: document.getElementById("chart-proj"),
        columns: this._keys,
        rows: this.rows,
      });
    },

    _syncUrl() {
      try {
        var parts = [];
        if (this.horizon !== 12) parts.push("horizon=" + this.horizon);
        if (this.query)          parts.push("q="       + encodeURIComponent(this.query));
        var qs = parts.length ? ("?" + parts.join("&")) : "";
        history.replaceState(null, "", window.location.pathname + qs);
      } catch (_e) {}
    },
    saveCurrentView() {
      this._syncUrl();
      this.$dispatch("pb:save-view", { kind: "projection", name: "" });
    },

    init() {
      var self = this;
      try {
        var p = new URL(window.location.href).searchParams;
        var h = Number(p.get("horizon"));
        if (h && [3,6,12,24].indexOf(h) !== -1) self.horizon = h;
        var q = p.get("q"); if (q) self.query = q;
      } catch (_e) {}
      var chart = null;
      var tries = 0;
      var poll = function () {
        var ready = window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart && window.pbRenderProj;
        if (!ready) { if (++tries < 600) setTimeout(poll, 50); return; }
        var store = Alpine.store("budget");
        chart = window.pbMountChart("#chart-proj", window.pbRenderProj, function () {
          return store.reportProjection(self.horizon);
        });
        self.$watch("horizon", function () { chart && chart.redraw(); self._syncUrl(); });
        self.$watch("query",   function () { self._syncUrl(); });
        Alpine.effect(function () {
          store.profile; store._listVersion;
          if (chart) chart.redraw();
        });
      };
      poll();
    },
  };
}
</script>
