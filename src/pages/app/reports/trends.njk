---
layout: layouts/app.njk
title: "Monthly trends"
description: "Mini sparkline per top category over the last twelve months."
permalink: /app/reports/trends/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data>
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Monthly trends</h1>
      <p class="app-page__lead">Sparklines for the top 12 categories over the last twelve months. Each card shows the total spent across the window.</p>
    </div>
    <div class="cluster">
      <button class="btn btn--ghost btn--sm" type="button" onclick="window.print()"
              data-tip="Open the browser print dialog.">Print</button>
      <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
    </div>
  </header>

  <section class="report">
    <div id="chart-trends" style="min-height: 120px;"></div>
  </section>
</div>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/monthly-trends.js";
  function boot() {
    var store = Alpine.store("budget");
    var inst = mountChart("#chart-trends", render, function () { return store.reportTrends(); });
    Alpine.effect(function () { store.profile; store.currentMonth; inst.redraw(); });
  };
  if (window.Alpine && window.Alpine.store("budget")) boot();
  else document.addEventListener("alpine:initialized", boot);
</script>