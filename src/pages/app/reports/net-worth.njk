---
layout: layouts/app.njk
title: "Net worth over time"
description: "Net worth trajectory with growth rate, MoM change, and CSV export."
permalink: /app/reports/net-worth/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="netWorthView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Net worth over time</h1>
      <p class="app-page__lead">All accounts — on-budget plus tracking assets minus liabilities — totaled at the end of each month.</p>
    </div>
    <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
  </header>

  <div class="cluster" style="margin-bottom: var(--space-md); gap: var(--space-2xs);">
    <span style="color: var(--fg-muted); font-size: var(--fs-sm); margin-right: var(--space-2xs);">Range:</span>
    <template x-for="r in ranges" :key="r.value">
      <button type="button" class="btn btn--sm"
              :class="rangeMonths === r.value ? 'btn--primary' : 'btn--ghost'"
              @click="rangeMonths = r.value"
              x-text="r.label"></button>
    </template>
  </div>

  <div class="kpi-strip">
    <div class="kpi" :class="kpis().current < 0 ? 'kpi--danger' : 'kpi--ok'">
      <span class="kpi__label">Current net worth</span>
      <span class="kpi__value" x-text="fmt(kpis().current)"></span>
      <span class="kpi__delta">As of this month</span>
    </div>
    <div class="kpi" :class="kpis().mom >= 0 ? 'kpi--ok' : 'kpi--danger'">
      <span class="kpi__label">vs last month</span>
      <span class="kpi__value" :class="kpis().mom >= 0 ? 'amount--inflow' : 'amount--outflow'"
            x-text="(kpis().mom >= 0 ? '+' : '') + fmt(kpis().mom)"></span>
      <span class="kpi__delta" :class="kpis().mom >= 0 ? 'kpi__delta--up' : 'kpi__delta--down'"
            x-text="kpis().momPct === null ? '—' : ((kpis().momPct >= 0 ? '+' : '') + kpis().momPct.toFixed(1) + '%')"></span>
    </div>
    <div class="kpi" :class="kpis().rangeGrowth >= 0 ? 'kpi--ok' : 'kpi--danger'">
      <span class="kpi__label">Range growth</span>
      <span class="kpi__value" x-text="(kpis().rangeGrowth >= 0 ? '+' : '') + fmt(kpis().rangeGrowth)"></span>
      <span class="kpi__delta" x-text="kpis().rangeGrowthPct === null ? '—' : ('Over the ' + rangeMonths + '-mo window (' + (kpis().rangeGrowthPct >= 0 ? '+' : '') + kpis().rangeGrowthPct.toFixed(1) + '%)')"></span>
    </div>
    <div class="kpi kpi--muted">
      <span class="kpi__label">Avg monthly change</span>
      <span class="kpi__value" :class="kpis().avgMonthly >= 0 ? 'amount--inflow' : 'amount--outflow'"
            x-text="(kpis().avgMonthly >= 0 ? '+' : '') + fmt(kpis().avgMonthly)"></span>
      <span class="kpi__delta" x-text="kpis().forecastNext === null ? '—' : ('Projected next: ' + fmt(kpis().forecastNext))"></span>
    </div>
  </div>

  <section class="report">
    <div class="chart-toolbar">
      <span class="chart-toolbar__label">Chart</span>
      <span class="chart-picker" role="group" aria-label="Chart type">
        <template x-for="opt in chartOptions" :key="opt.value">
          <button type="button"
                  class="chart-picker__btn"
                  :class="chartType === opt.value ? 'is-active' : ''"
                  :aria-pressed="(chartType === opt.value).toString()"
                  @click="setChartType(opt.value)"
                  :data-tip="'Render as a ' + opt.label.toLowerCase() + ' chart.'"
                  x-text="opt.label"></button>
        </template>
      </span>
    </div>
    <div class="chart" id="chart-nw" style="min-height: 420px;"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="nw-search">Filter</label>
        <input class="input" id="nw-search" type="search" x-model="query" placeholder="Filter by month…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportPDF()"
              data-tip="Download a printable PDF of this report.">Export PDF</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportCSV('net-worth')"
              data-tip="Download the visible rows as a CSV file.">Export CSV</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('month')">Month-end <span class="sort-ind" x-text="sortIndicator('month')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('value')">Net worth <span class="sort-ind" x-text="sortIndicator('value')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.month">
          <tr>
            <td>
              <a class="report-month-link"
                 :href="'/app/calendar/?m=' + r.month + '&v=month'"
                 x-text="r.month"
                 data-tip="Open this month in the calendar."></a>
            </td>
            <td class="num" :class="r.value < 0 ? 'amount--outflow' : ''" x-text="'$' + (r.value / 100).toFixed(2)"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="2" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No rows in this range.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script>
function netWorthView() {
  var savedChartType = "line";
  try {
    var st = localStorage.getItem("projectbudget:chart-type:netWorth");
    if (st && ["line","area","bar"].indexOf(st) !== -1) savedChartType = st;
  } catch (_e) {}
  window.__pbChartType = window.__pbChartType || {};
  window.__pbChartType.netWorth = savedChartType;

  return {
    rangeMonths: 12,
    ranges: [
      { value: 6,  label: "6 mo" },
      { value: 12, label: "12 mo" },
      { value: 24, label: "24 mo" },
      { value: 36, label: "36 mo" },
    ],

    chartType: savedChartType,
    chartOptions: [
      { value: "line", label: "Line" },
      { value: "area", label: "Area" },
      { value: "bar",  label: "Bar" },
    ],
    setChartType(t) {
      this.chartType = t;
      window.__pbChartType.netWorth = t;
      try { localStorage.setItem("projectbudget:chart-type:netWorth", t); } catch (_e) {}
      try { window.dispatchEvent(new CustomEvent("pb:chart-type", { detail: { reportId: "netWorth", type: t } })); } catch (_e) {}
    },

    query: "",
    sortKey: "month",
    sortDir: "asc",
    _keys: [
      { key: "month", label: "Month-end" },
      { key: "value", label: "Net worth", numeric: true },
    ],
    get rows() {
      void this.$store.budget._listVersion;
      var src = this.$store.budget.reportNetWorth(null, this.rangeMonths) || [];
      var q = (this.query || "").trim().toLowerCase();
      var filtered = q ? src.filter(function (r) { return String(r.month).toLowerCase().indexOf(q) !== -1; }) : src;
      var key = this.sortKey, dir = this.sortDir;
      var keyDef = this._keys.find(function (k) { return k.key === key; });
      var numeric = !!(keyDef && keyDef.numeric);
      var copy = filtered.slice();
      copy.sort(function (a, b) {
        if (numeric) {
          var an = Number(a[key]) || 0, bn = Number(b[key]) || 0;
          return dir === "asc" ? an - bn : bn - an;
        }
        var as = String(a[key] == null ? "" : a[key]);
        var bs = String(b[key] == null ? "" : b[key]);
        return dir === "asc" ? as.localeCompare(bs) : bs.localeCompare(as);
      });
      return copy;
    },
    get visibleCount() { return this.rows.length; },
    sortBy(key) {
      if (this.sortKey === key) {
        this.sortDir = this.sortDir === "asc" ? "desc" : "asc";
      } else {
        this.sortKey = key;
        var kd = this._keys.find(function (k) { return k.key === key; });
        this.sortDir = kd && kd.numeric ? "desc" : "asc";
      }
    },
    sortIndicator(key) {
      if (this.sortKey !== key) return "";
      return this.sortDir === "asc" ? "▲" : "▼";
    },
    print() { window.print(); },
    exportPDF() {
      if (!window.pbExportReportPDF) return;
      var k = this.kpis();
      window.pbExportReportPDF({
        title: "Net worth over time",
        subtitle: "Trailing " + this.rangeMonths + " months",
        filename: "net-worth",
        kpis: [
          { label: "Current net worth", value: this.fmt(k.current) },
          { label: "Month over month",  value: (k.mom >= 0 ? "+" : "") + this.fmt(k.mom), delta: k.momPct === null ? "" : ((k.momPct >= 0 ? "+" : "") + k.momPct.toFixed(1) + "%") },
          { label: "Window growth",     value: (k.rangeGrowth >= 0 ? "+" : "") + this.fmt(k.rangeGrowth), delta: k.rangeGrowthPct === null ? "" : ((k.rangeGrowthPct >= 0 ? "+" : "") + k.rangeGrowthPct.toFixed(1) + "%") },
          { label: "Avg monthly trend", value: (k.avgMonthly >= 0 ? "+" : "") + this.fmt(k.avgMonthly), delta: k.forecastNext === null ? "" : ("Next: " + this.fmt(k.forecastNext)) },
        ],
        chartEl: document.getElementById("chart-nw"),
        columns: this._keys,
        rows: this.rows,
      });
    },
    exportCSV(name) {
      var self = this;
      var header = this._keys.map(function (k) { return JSON.stringify(k.label); }).join(",");
      var body = this.rows.map(function (r) {
        return self._keys.map(function (k) {
          var v = r[k.key];
          if (v == null) return "";
          if (k.numeric && Math.abs(v) >= 1000 && Number.isInteger(v)) v = (v / 100).toFixed(2);
          return JSON.stringify(String(v));
        }).join(",");
      }).join("\r\n");
      var blob = new Blob([header + "\r\n" + body], { type: "text/csv;charset=utf-8" });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url;
      a.download = (name || "report") + "-" + new Date().toISOString().slice(0, 10) + ".csv";
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      setTimeout(function () { URL.revokeObjectURL(url); }, 1500);
    },

    init() {
      var self = this;
      window.__pbReportState = window.__pbReportState || {};
      window.__pbReportState.netWorth = function () { return self.rangeMonths; };
      var tries = 0;
      var poll = function () {
        var ready = window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart && window.pbRenderNW;
        if (!ready) { if (++tries < 100) setTimeout(poll, 50); return; }
        var store = Alpine.store("budget");
        self.chart = window.pbMountChart("#chart-nw", window.pbRenderNW, function () {
          return store.reportNetWorth(null, self.rangeMonths);
        });
        self.$watch("rangeMonths", function () { self.chart && self.chart.redraw(); });
        self.$watch("chartType",   function () { self.chart && self.chart.redraw(); });
        Alpine.effect(function () {
          store.profile; store.currentMonth; store._listVersion;
          if (self.chart) self.chart.redraw();
        });
      };
      poll();
    },
    fmt(c) { return (c / 100).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }); },
    kpis() {
      var rows = this.$store.budget.reportNetWorth(null, this.rangeMonths) || [];
      if (!rows.length) {
        return { current: 0, mom: 0, momPct: null, rangeGrowth: 0, rangeGrowthPct: null, avgMonthly: 0, forecastNext: null };
      }
      var current = rows[rows.length - 1].value;
      var prev    = rows.length > 1 ? rows[rows.length - 2].value : null;
      var first   = rows[0].value;
      var mom = prev === null ? 0 : (current - prev);
      var momPct = prev ? ((mom / Math.abs(prev)) * 100) : null;
      var rangeGrowth = current - first;
      var rangeGrowthPct = first ? ((rangeGrowth / Math.abs(first)) * 100) : null;
      var avgMonthly = rows.length > 1 ? Math.round(rangeGrowth / (rows.length - 1)) : 0;
      var forecastNext = current + avgMonthly;
      return { current, mom, momPct, rangeGrowth, rangeGrowthPct, avgMonthly, forecastNext };
    },
  };
}
</script>

<script type="module">
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/net-worth.js";
  window.pbMountChart = mountChart;
  window.pbRenderNW = render;
</script>
