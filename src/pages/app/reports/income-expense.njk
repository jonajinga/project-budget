---
layout: layouts/app.njk
title: "Income vs expense"
description: "Monthly income vs expense with savings rate, best/worst month, and CSV export."
permalink: /app/reports/income-expense/
eleventyExcludeFromCollections: true
---
<div class="app-page" x-data="incomeExpenseView()" x-init="init()">
  <header class="app-page__header">
    <div>
      <h1 class="app-page__title">Income vs expense</h1>
      <p class="app-page__lead">Inflows are positive transactions, outflows are negative ones. Transfers are excluded.</p>
    </div>
    <div class="cluster" style="gap: var(--space-2xs);">
      <button class="btn btn--ghost btn--sm" type="button" @click="saveCurrentView()"
              data-tip="Save this range + chart type + filter as a recall-able view in /app/templates/.">Save view</button>
      <a class="btn btn--ghost btn--sm" href="/app/reports/">All reports</a>
    </div>
  </header>

  {# ---- Range picker ---- #}
  <div class="cluster" style="margin-bottom: var(--space-md); gap: var(--space-2xs);">
    <span style="color: var(--fg-muted); font-size: var(--fs-sm); margin-right: var(--space-2xs);">Range:</span>
    <template x-for="r in ranges" :key="r.value">
      <button type="button" class="btn btn--sm"
              :class="rangeMonths === r.value ? 'btn--primary' : 'btn--ghost'"
              @click="rangeMonths = r.value"
              x-text="r.label"></button>
    </template>
    <template x-if="brushFrom !== null">
      <span class="brush-indicator">
        Brushed: <strong x-text="brushFrom + ' → ' + brushTo"></strong>
        <button type="button" class="btn btn--ghost btn--sm" @click="clearBrush()"
                data-tip="Clear the chart selection.">Clear</button>
      </span>
    </template>
    <span x-show="brushFrom === null" x-cloak style="color: var(--fg-subtle); font-size: var(--fs-xs); margin-left: var(--space-sm);">
      Tip: drag across the chart to filter the table to a date range.
    </span>
  </div>

  {# ---- KPI strip ---- #}
  <div class="kpi-strip">
    <div class="kpi kpi--ok">
      <span class="kpi__label">Avg monthly income</span>
      <span class="kpi__value" x-text="fmt(kpis().avgIncome)"></span>
      <span class="kpi__delta" x-text="rangeLabel()"></span>
    </div>
    <div class="kpi kpi--danger">
      <span class="kpi__label">Avg monthly expense</span>
      <span class="kpi__value" x-text="fmt(kpis().avgExpense)"></span>
      <span class="kpi__delta" x-text="rangeLabel()"></span>
    </div>
    <div class="kpi" :class="kpis().netAvg < 0 ? 'kpi--danger' : 'kpi--ok'">
      <span class="kpi__label">Avg monthly net</span>
      <span class="kpi__value" :class="kpis().netAvg < 0 ? 'amount--outflow' : 'amount--inflow'"
            x-text="fmt(kpis().netAvg)"></span>
      <span class="kpi__delta" x-text="'Savings rate ' + (kpis().savingsRate === null ? '—' : (kpis().savingsRate * 100).toFixed(1) + '%')"></span>
    </div>
    <div class="kpi kpi--muted">
      <span class="kpi__label">Best / worst month</span>
      <span class="kpi__value" style="font-size: var(--fs-lg);"
            x-text="kpis().bestMonth ? (kpis().bestMonth + ' / ' + (kpis().worstMonth || '—')) : '—'"></span>
      <span class="kpi__delta">Ranked by net cash flow</span>
    </div>
  </div>

  <section class="report">
    <div class="chart-toolbar">
      <span class="chart-toolbar__label">Chart</span>
      <span class="chart-picker" role="group" aria-label="Chart type">
        <template x-for="opt in chartOptions" :key="opt.value">
          <button type="button"
                  class="chart-picker__btn"
                  :class="chartType === opt.value ? 'is-active' : ''"
                  :aria-pressed="(chartType === opt.value).toString()"
                  @click="setChartType(opt.value)"
                  :data-tip="'Render as a ' + opt.label.toLowerCase() + ' chart.'"
                  x-text="opt.label"></button>
        </template>
      </span>
    </div>
    <div class="chart" id="chart-ie" style="min-height: 420px;"></div>

    <div class="report-toolbar">
      <div class="field report-toolbar__search">
        <label class="visually-hidden" for="ie-search">Filter</label>
        <input class="input" id="ie-search" type="search" x-model="query" placeholder="Filter by month…">
      </div>
      <p class="report-toolbar__count">
        <span x-text="visibleCount"></span> rows
      </p>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportCSV('income-vs-expense')"
              data-tip="Download the visible rows as a CSV file.">Export CSV</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="exportPDF()"
              data-tip="Download a printable PDF of this report.">Export PDF</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="print()"
              data-tip="Open the browser print dialog.">Print</button>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th class="is-sortable"><button type="button" @click="sortBy('month')">Month <span class="sort-ind" x-text="sortIndicator('month')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('income')">Income <span class="sort-ind" x-text="sortIndicator('income')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('expense')">Expense <span class="sort-ind" x-text="sortIndicator('expense')"></span></button></th>
          <th class="is-sortable num"><button type="button" @click="sortBy('net')">Net <span class="sort-ind" x-text="sortIndicator('net')"></span></button></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in rows" :key="r.month">
          <tr>
            <td>
              <a class="report-month-link"
                 :href="'/app/calendar/?m=' + r.month + '&v=month'"
                 x-text="r.month"
                 data-tip="Open this month in the calendar."></a>
            </td>
            <td class="num amount--inflow" x-text="'$' + (r.income / 100).toFixed(2)"></td>
            <td class="num amount--outflow" x-text="'$' + (r.expense / 100).toFixed(2)"></td>
            <td class="num" :class="r.net < 0 ? 'amount--outflow' : 'amount--inflow'" x-text="'$' + (r.net / 100).toFixed(2)"></td>
          </tr>
        </template>
        <tr x-show="!rows.length" x-cloak>
          <td colspan="4" style="text-align: center; color: var(--fg-muted); padding: var(--space-md);">No rows in this range.</td>
        </tr>
      </tbody>
    </table>
  </section>
</div>

<script>
/* Single Alpine factory — replaces the previous
   Object.assign(viewFn(), chartTypePicker(), reportTable(srcFn))
   chain. Inlining the picker + table fields means the x-data
   expression is just a function call, eliminating a class of
   silent-failure modes where one factory was undefined at eval
   time and Object.assign threw, leaving every binding inert. */
function incomeExpenseView() {
  /* Read persisted chart-type up front (the picker's global helper
     may or may not have loaded yet; either way localStorage works). */
  var savedChartType = "bar";
  try {
    var st = localStorage.getItem("projectbudget:chart-type:incomeExpense");
    if (st && ["bar","line","area","stack"].indexOf(st) !== -1) savedChartType = st;
  } catch (_e) {}
  window.__pbChartType = window.__pbChartType || {};
  window.__pbChartType.incomeExpense = savedChartType;

  return {
    /* ---- View state ---- */
    rangeMonths: 12,
    ranges: [
      { value: 3,  label: "3 mo" },
      { value: 6,  label: "6 mo" },
      { value: 12, label: "12 mo" },
      { value: 24, label: "24 mo" },
    ],

    /* ---- Chart picker ---- */
    chartType: savedChartType,
    chartOptions: [
      { value: "bar",   label: "Bar" },
      { value: "line",  label: "Line" },
      { value: "area",  label: "Area" },
      { value: "stack", label: "Stacked" },
    ],
    setChartType(t) {
      this.chartType = t;
      window.__pbChartType.incomeExpense = t;
      try { localStorage.setItem("projectbudget:chart-type:incomeExpense", t); } catch (_e) {}
      try { window.dispatchEvent(new CustomEvent("pb:chart-type", { detail: { reportId: "incomeExpense", type: t } })); } catch (_e) {}
    },

    /* ---- Report table (inlined fields + getters) ---- */
    query: "",
    /* Brushed range — month strings (YYYY-MM) or null. The chart's
       brush plugin onChange writes these via window.pbOnBrush. */
    brushFrom: null,
    brushTo: null,
    clearBrush() {
      this.brushFrom = null; this.brushTo = null;
      /* Also clear the chart's overlay. */
      var canvas = document.querySelector("#chart-ie canvas");
      if (canvas && canvas.__pbChart && canvas.__pbChart.__pbBrush) {
        canvas.__pbChart.__pbBrush.from = null;
        canvas.__pbChart.__pbBrush.to = null;
        canvas.__pbChart.draw();
      }
    },
    sortKey: "month",
    sortDir: "asc",
    _keys: [
      { key: "month",   label: "Month" },
      { key: "income",  label: "Income",  numeric: true },
      { key: "expense", label: "Expense", numeric: true },
      { key: "net",     label: "Net",     numeric: true },
    ],
    get rows() {
      void this.$store.budget._listVersion;
      var src = this.$store.budget.reportIncomeVsExpense(null, this.rangeMonths) || [];
      /* Brush filter — applied before the text query so the count
         reflects the brushed window. */
      if (this.brushFrom !== null && this.brushTo !== null) {
        var bf = this.brushFrom, bt = this.brushTo;
        src = src.filter(function (r) { return r.month >= bf && r.month <= bt; });
      }
      var q = (this.query || "").trim().toLowerCase();
      var filtered = q ? src.filter(function (r) { return String(r.month).toLowerCase().indexOf(q) !== -1; }) : src;
      var key = this.sortKey, dir = this.sortDir;
      var keyDef = this._keys.find(function (k) { return k.key === key; });
      var numeric = !!(keyDef && keyDef.numeric);
      var copy = filtered.slice();
      copy.sort(function (a, b) {
        if (numeric) {
          var an = Number(a[key]) || 0, bn = Number(b[key]) || 0;
          return dir === "asc" ? an - bn : bn - an;
        }
        var as = String(a[key] == null ? "" : a[key]);
        var bs = String(b[key] == null ? "" : b[key]);
        return dir === "asc" ? as.localeCompare(bs) : bs.localeCompare(as);
      });
      return copy;
    },
    get visibleCount() { return this.rows.length; },
    sortBy(key) {
      if (this.sortKey === key) {
        this.sortDir = this.sortDir === "asc" ? "desc" : "asc";
      } else {
        this.sortKey = key;
        var kd = this._keys.find(function (k) { return k.key === key; });
        this.sortDir = kd && kd.numeric ? "desc" : "asc";
      }
    },
    sortIndicator(key) {
      if (this.sortKey !== key) return "";
      return this.sortDir === "asc" ? "▲" : "▼";
    },
    print() { window.print(); },
    exportPDF() {
      if (!window.pbExportReportPDF) return;
      var k = this.kpis();
      window.pbExportReportPDF({
        title: "Income vs expense",
        subtitle: "Trailing " + this.rangeMonths + " months",
        filename: "income-vs-expense",
        kpis: [
          { label: "Avg monthly income",  value: this.fmt(k.avgIncome) },
          { label: "Avg monthly expense", value: this.fmt(k.avgExpense) },
          { label: "Avg monthly net",     value: this.fmt(k.netAvg), delta: k.savingsRate === null ? "" : ("Savings rate " + (k.savingsRate * 100).toFixed(1) + "%") },
          { label: "Best / worst",        value: k.bestMonth ? (k.bestMonth + " / " + (k.worstMonth || "—")) : "—" },
        ],
        chartEl: document.getElementById("chart-ie"),
        columns: this._keys,
        rows: this.rows,
      });
    },
    exportCSV(name) {
      var self = this;
      var header = this._keys.map(function (k) { return JSON.stringify(k.label); }).join(",");
      var body = this.rows.map(function (r) {
        return self._keys.map(function (k) {
          var v = r[k.key];
          if (v == null) return "";
          if (k.numeric && Math.abs(v) >= 1000 && Number.isInteger(v)) v = (v / 100).toFixed(2);
          return JSON.stringify(String(v));
        }).join(",");
      }).join("\r\n");
      var blob = new Blob([header + "\r\n" + body], { type: "text/csv;charset=utf-8" });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url;
      a.download = (name || "report") + "-" + new Date().toISOString().slice(0, 10) + ".csv";
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      setTimeout(function () { URL.revokeObjectURL(url); }, 1500);
    },

    /* URL state sync — write rangeMonths + chartType + brush window
       back to the address bar so the view is shareable + save-able. */
    _syncUrl() {
      try {
        var parts = [];
        if (this.rangeMonths !== 12)             parts.push("range=" + this.rangeMonths);
        if (this.chartType   !== "bar")          parts.push("type="  + encodeURIComponent(this.chartType));
        if (this.brushFrom)                      parts.push("from="  + this.brushFrom);
        if (this.brushTo)                        parts.push("to="    + this.brushTo);
        if (this.query)                          parts.push("q="     + encodeURIComponent(this.query));
        var qs = parts.length ? ("?" + parts.join("&")) : "";
        history.replaceState(null, "", window.location.pathname + qs);
      } catch (_e) {}
    },
    saveCurrentView() {
      this._syncUrl();
      this.$dispatch("pb:save-view", { kind: "income-expense", name: "" });
    },

    /* ---- Lifecycle + KPIs ---- */
    init() {
      var self = this;
      window.__pbReportState = window.__pbReportState || {};
      window.__pbReportState.incomeExpense = function () { return self.rangeMonths; };
      /* Honor incoming URL params from a recalled saved view. */
      try {
        var p = new URL(window.location.href).searchParams;
        var r = Number(p.get("range"));
        if (r && [3,6,12,24].indexOf(r) !== -1) self.rangeMonths = r;
        var t = p.get("type");
        if (t && ["bar","line","area","stack"].indexOf(t) !== -1) self.chartType = t;
        var q = p.get("q"); if (q) self.query = q;
        var bf = p.get("from"), bt = p.get("to");
        if (bf && bt) { self.brushFrom = bf; self.brushTo = bt; }
      } catch (_e) {}
      /* Push state on user changes. */
      self.$watch("rangeMonths", function () { self._syncUrl(); });
      self.$watch("chartType",   function () { self._syncUrl(); });
      self.$watch("query",       function () { self._syncUrl(); });
      self.$watch("brushFrom",   function () { self._syncUrl(); });
      self.$watch("brushTo",     function () { self._syncUrl(); });
      /* Brush plugin callback — translate index range to month range
         (from the chart's source data) and stash on this component. */
      window.pbOnBrush = window.pbOnBrush || {};
      window.pbOnBrush.incomeExpense = function (range, data) {
        if (!range || range.from == null || range.to == null) {
          self.brushFrom = null; self.brushTo = null;
          return;
        }
        var f = data[range.from] && data[range.from].month;
        var t = data[range.to]   && data[range.to].month;
        if (f && t) { self.brushFrom = f; self.brushTo = t; }
      };

      /* Mount the chart from inside the Alpine factory so we can wire
         redraws via $watch on this component's own reactive state.
         The previous boot used a separate <script type="module"> that
         relied on Alpine.effect + click-delegation + custom events —
         too many points of failure. Polling for the chart bootstrap
         globals (window.pbMountChart / window.pbRenderIE) keeps the
         dependency on the inline ESM script that exports them. */
      var tries = 0;
      var poll = function () {
        var ready = window.Alpine && window.Alpine.store && window.Alpine.store("budget") && window.pbMountChart && window.pbRenderIE;
        if (!ready) { if (++tries < 100) setTimeout(poll, 50); return; }
        var store = Alpine.store("budget");
        self.chart = window.pbMountChart("#chart-ie", window.pbRenderIE, function () {
          return store.reportIncomeVsExpense(null, self.rangeMonths);
        });
        /* Native Alpine reactivity — both watches fire whenever the
           tracked property changes, regardless of which UI element
           triggered the change. No event-delegation needed. */
        self.$watch("rangeMonths", function () { self.chart && self.chart.redraw(); });
        self.$watch("chartType",   function () { self.chart && self.chart.redraw(); });
        /* Store mutations (profile switch, new transaction, etc.)
           still trigger redraw via the existing _listVersion tripwire. */
        Alpine.effect(function () {
          store.profile; store.currentMonth; store._listVersion;
          if (self.chart) self.chart.redraw();
        });
      };
      poll();
    },
    fmt(c) { return (c / 100).toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }); },
    rangeLabel() { return "Trailing " + this.rangeMonths + " mo"; },
    kpis() {
      var rows = this.$store.budget.reportIncomeVsExpense(null, this.rangeMonths) || [];
      if (this.brushFrom !== null && this.brushTo !== null) {
        var bf = this.brushFrom, bt = this.brushTo;
        rows = rows.filter(function (r) { return r.month >= bf && r.month <= bt; });
      }
      if (!rows.length) {
        return { avgIncome: 0, avgExpense: 0, netAvg: 0, savingsRate: null, bestMonth: "", worstMonth: "" };
      }
      var sumI = rows.reduce(function (s, r) { return s + r.income; }, 0);
      var sumE = rows.reduce(function (s, r) { return s + r.expense; }, 0);
      var best = rows[0], worst = rows[0];
      rows.forEach(function (r) {
        if (r.net > best.net) best = r;
        if (r.net < worst.net) worst = r;
      });
      return {
        avgIncome: Math.round(sumI / rows.length),
        avgExpense: Math.round(sumE / rows.length),
        netAvg: Math.round((sumI - sumE) / rows.length),
        savingsRate: sumI > 0 ? ((sumI - sumE) / sumI) : null,
        bestMonth: best.month,
        worstMonth: worst.month,
      };
    },
  };
}
</script>

<script type="module">
  /* Export the chart bootstrap + this report's render fn so the
     Alpine factory's init() can mount the chart and wire $watch
     redraws directly. Decouples chart wiring from Alpine timing. */
  import { mountChart } from "/assets/js/charts/bootstrap.js";
  import { render } from "/assets/js/charts/income-expense.js";
  window.pbMountChart = mountChart;
  window.pbRenderIE = render;
</script>
