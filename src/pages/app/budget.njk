---
layout: layouts/app.njk
title: "Budget"
description: "Assign every dollar a job. Monthly envelope budget view."
permalink: /app/budget/
eleventyExcludeFromCollections: true
---
{% from "partials/icon-trash.njk" import iconTrash %}
<div class="app-page" x-data="budgetView()" x-init="init()">

  {# Visually-hidden page heading — SR users land on a clear page
     title; sighted users see the month strip + RTA card as the
     visual title. Replaces the missing h1 the WCAG audit flagged. #}
  <h1 class="visually-hidden">
    Budget — <span x-text="monthHeaderLabel()">this month</span>
  </h1>

  {# Year strip with prev/next year + the 12-month tab row #}
  <div class="month-strip" role="tablist" aria-label="Budget month">
    <button type="button" class="month-strip__year"
            @click="$store.budget.setMonth(prevYearMonth())"
            aria-label="Previous year">
      <span aria-hidden="true">&larr;</span>
      <span x-text="prevYearLabel()"></span>
    </button>
    <div class="month-strip__tabs" role="presentation">
      <template x-for="m in monthsOfYear()" :key="m.value">
        <button type="button"
                role="tab"
                class="month-strip__tab"
                :class="{ 'is-active': m.value === $store.budget.currentMonth, 'is-current': m.value === thisMonthValue() }"
                :aria-selected="(m.value === $store.budget.currentMonth).toString()"
                @click="$store.budget.setMonth(m.value)"
                x-text="m.label"></button>
      </template>
    </div>
    <button type="button" class="month-strip__year"
            @click="$store.budget.setMonth(nextYearMonth())"
            aria-label="Next year">
      <span x-text="nextYearLabel()"></span>
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>

  <div class="rta" :class="rtaCents() < 0 ? 'rta--negative' : ''">
    <p class="rta__label" data-tip="Money received but not yet given a job. See the glossary for the full definition.">Ready to assign</p>
    <p class="rta__value" x-text="formatCents(rtaCents())"></p>
    <p class="rta__hint" x-show="rtaCents() === 0">Every dollar is assigned.</p>
    <p class="rta__hint" x-show="rtaCents() > 0">Inflow not yet given a job.</p>
    <p class="rta__hint" x-show="rtaCents() < 0">You assigned more than you have. Remove some assignments or wait for inflow.</p>
  </div>

  <p class="app-page__lead" x-show="!hasCategories" x-cloak style="margin-top: var(--space-md);">
    Create category groups and categories on the <a href="/app/categories/">categories page</a> to start assigning dollars.
  </p>

  <section class="budget" x-show="hasCategories" x-cloak>
    <div class="budget__toolbar">
      <div class="cluster" style="gap: var(--space-2xs);">
        <button type="button" class="btn btn--ghost btn--sm"
                @click="$store.budget.jumpToThisMonth()"
                data-tip="Jump to the current calendar month.">This month</button>
        <button type="button" class="btn btn--primary btn--sm"
                @click="openAutoAssign({ kind: 'all', name: 'All categories', ids: null })"
                data-tip="Fill in this month's Assigned column for every category — from goal needs, last month's plan, or recent averages.">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align: -2px; margin-right: 4px;">
            <path d="M13 2L4.5 13.5h6L9 22l8.5-11.5h-6L13 2z"/>
          </svg>
          Auto-assign
        </button>
        <button type="button" class="btn btn--ghost btn--sm"
                @click="bulkClearAssigned('all')"
                data-tip="Reset Assigned to $0 for every category in this month. Cmd/Ctrl+Z undoes.">Clear all assigned</button>
        <button type="button" class="btn btn--secondary btn--sm"
                @click="openTemplates()"
                data-tip="Save the current month's assigned values as a template, or apply a saved template to this month.">Templates</button>
        <button type="button" class="btn btn--secondary btn--sm"
                @click="newGroupOpen = true; newGroupName = ''"
                data-tip="Create a new category group (e.g. Subscriptions, Reserves).">+ Group</button>
        <button type="button" class="btn btn--ghost btn--sm"
                @click="$store.budget.setAllCatGroupsCollapsed(!$store.budget.allCatGroupsCollapsed())"
                :data-tip="$store.budget.allCatGroupsCollapsed() ? 'Expand every category group at once.' : 'Collapse every category group at once.'"
                x-text="$store.budget.allCatGroupsCollapsed() ? 'Expand all' : 'Collapse all'">Collapse all</button>
        <a class="btn btn--ghost btn--sm" href="/app/categories/"
           data-tip="Full categories admin (reorder, goals, payment categories).">Manage categories</a>
        <button type="button" class="btn btn--ghost btn--sm"
                @click="saveCurrentView()"
                data-tip="Save this month as a recall-able view in /app/templates/.">Save view</button>
      </div>
      <div class="cluster" style="gap: var(--space-2xs);">
        <p class="budget__total-readout" style="margin: 0;">
          Total assigned this month:
          <strong x-text="formatCents($store.budget.totalAssignedInMonth($store.budget.currentMonth))"></strong>
        </p>
        <button type="button" class="btn btn--icon"
                @click="budgetCollapsed = !budgetCollapsed"
                :aria-label="budgetCollapsed ? 'Expand budget grid' : 'Collapse budget grid'"
                :data-tip="budgetCollapsed ? 'Show every category row again.' : 'Hide every category row and show only the Total Budget summary.'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
               :style="budgetCollapsed ? 'transform: rotate(-90deg); transition: transform 150ms ease;' : 'transition: transform 150ms ease;'">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
      </div>
    </div>

    <div x-show="!budgetCollapsed" x-cloak>
      {# Desktop-only column header — at mobile each cat row carries
         its own micro-labels above the pills, so the header strip is
         redundant. Hidden via the budget__column-header class below. #}
      <div class="budget__group-header budget__column-header">
        <span>Category</span>
        <span class="num" data-tip="Dollars you committed to this category this month.">Assigned</span>
        <span class="num" data-tip="Outflows from this category this month. Inflows show as positive.">Outflow</span>
        <span class="num" data-tip="Carry-in + assigned + outflow. Pill color: green = funded, blue = positive remainder, red = overspent.">Available</span>
      </div>

    <div data-sortable-list data-sortable-kind="cat-group">
      <template x-for="group in $store.budget.categoryGroupsView()" :key="group.group ? group.group.id : '__ungrouped'">
        <div class="budget__group cat-group" :data-sortable-id="group.group?.id">
          <div class="budget__group-header budget__group-header--row" style="background: var(--bg-elevated);">
            <div class="cluster" style="gap: var(--space-2xs); min-width: 0;">
              <input type="checkbox" class="budget__bulk-check"
                     x-show="group.categories.length"
                     :checked="groupAllSelected(group)"
                     :indeterminate.camel="groupSomeSelected(group)"
                     @change="toggleGroupSelected(group)"
                     :aria-label="'Select all categories in ' + (group.group?.name || 'Other')"
                     :data-tip="'Select / deselect every category in ' + (group.group?.name || 'Other categories') + ' for bulk actions.'">
              <span class="dnd-handle dnd-handle--sm"
                    :aria-label="'Reorder group ' + (group.group?.name || '') + '. Drag, or use arrow keys.'"
                    role="button"
                    tabindex="0"
                    x-show="group.group"
                    @keydown.up.prevent="keyboardMoveGroup(group.group, -1)"
                    @keydown.down.prevent="keyboardMoveGroup(group.group, 1)">&#9776;</span>
              <button type="button" class="group-toggle"
                      @click="group.group && $store.budget.toggleCategoryGroupCollapsed(group.group.id)"
                      :aria-expanded="group.group && !$store.budget.isCatGroupCollapsed(group.group.id) ? 'true' : 'false'"
                      :disabled="!group.group">
                <span class="group-toggle__chevron" :class="group.group && $store.budget.isCatGroupCollapsed(group.group.id) ? 'is-collapsed' : ''" aria-hidden="true">&#9662;</span>
                <strong x-text="group.group ? group.group.name : 'Other categories'"></strong>
              </button>
              {# Inline group-edit actions. Always visible on touch, fade
                 in on hover on desktop (via .budget__group-actions CSS). #}
              <div class="cluster budget__group-actions" x-show="group.group" x-cloak>
                <button type="button" class="btn btn--icon"
                        @click="openAutoAssign({ kind: 'group', name: group.group.name, ids: group.categories.map(c => c.id) })"
                        aria-label="Auto-assign this group"
                        data-tip="Auto-assign just the categories in this group.">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M13 2L4.5 13.5h6L9 22l8.5-11.5h-6L13 2z"/>
                  </svg>
                </button>
                <button type="button" class="btn btn--icon" @click="addCategoryTo(group.group)"
                        aria-label="Add category to group"
                        data-tip="Add a new category to this group.">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
                <button type="button" class="btn btn--icon" @click="openRenameGroup(group.group)"
                        aria-label="Rename group"
                        data-tip="Rename this group.">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M17 3a2.85 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5z"></path>
                    <line x1="15" y1="5" x2="19" y2="9"></line>
                  </svg>
                </button>
                <button type="button" class="btn btn--icon"
                        @click="groupClearAssigned(group)"
                        aria-label="Clear assigned for this group"
                        data-tip="Set Assigned to $0 for every category in this group.">
                  {# Lucide "minus-circle" — clear/reset metaphor. #}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"/><line x1="8" y1="12" x2="16" y2="12"/>
                  </svg>
                </button>
                <button type="button" class="btn btn--icon"
                        @click="groupClearAvailable(group)"
                        aria-label="Clear available for this group"
                        data-tip="Push Available to $0 for every category in this group — pulls money back to Ready to Assign.">
                  {# Lucide "rotate-ccw" — undo-like, distinct from refresh. #}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="1 4 1 10 7 10"/>
                    <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                  </svg>
                </button>
                <button type="button" class="btn btn--icon" @click="deleteGroup(group.group)"
                        aria-label="Delete group"
                        data-tip="Delete this group. Categories inside become ungrouped."
                        style="color: var(--danger);">
                  {{ iconTrash(16) }}
                </button>
              </div>
            </div>
            {# Group totals stay as plain bold tabular numerals — no
               pill chrome — so they read as summary lines rather
               than echoing the per-cat pill row. Outflow keeps its
               button affordance but loses the pill border at the
               group level (.budget__group-header override below). #}
            <span class="num budget__group-total" x-text="formatCents(groupTotalAssigned(group.categories))"></span>
            <span class="num budget__group-total">
              <button type="button" class="budget__activity-btn budget__activity-btn--group"
                      :disabled="groupTotalActivity(group.categories) === 0"
                      @click="openActivity({ kind: 'group', id: group.group?.id || '__ungrouped', name: group.group ? group.group.name : 'Other categories', categoryIds: group.categories.map(c => c.id) })"
                      :data-tip="groupTotalActivity(group.categories) === 0 ? '' : ('Click to see every transaction across ' + (group.group ? group.group.name : 'Other categories') + ' this month.')"
                      x-text="formatCents(groupTotalActivity(group.categories))"></button>
            </span>
            <span class="num budget__group-total"
                  :class="groupTotalAvailable(group.categories) < 0 ? 'budget__group-total--neg' : ''"
                  x-text="formatCents(groupTotalAvailable(group.categories))"></span>
          </div>

          <div x-show="!(group.group && $store.budget.isCatGroupCollapsed(group.group.id))" x-cloak>
            <div data-sortable-list data-sortable-kind="budget" :data-sortable-group-id="group.group?.id || ''">
              <template x-for="c in group.categories" :key="c.id">
                <div class="budget__row cat-row" :data-sortable-id="c.id"
                     :class="isCatSelected(c.id) ? 'budget__row--selected' : ''">
                  <div class="budget__category">
                    <div class="budget__category-row">
                      <input type="checkbox" class="budget__bulk-check"
                             :checked="isCatSelected(c.id)"
                             @change="toggleCatSelected(c.id)"
                             :aria-label="'Select ' + c.name + ' for bulk actions'"
                             :data-tip="'Select this category for bulk Clear assigned / Clear available.'">
                      <span class="dnd-handle dnd-handle--sm"
                            :aria-label="'Reorder ' + c.name + '. Drag, or use arrow keys.'"
                            role="button"
                            tabindex="0"
                            @keydown.up.prevent="keyboardMoveCat(c, group, -1)"
                            @keydown.down.prevent="keyboardMoveCat(c, group, 1)">&#9776;</span>
                      <span class="budget__cat-name" x-text="c.name"></span>
                      <span class="goal-badge"
                            x-show="$store.budget.findGoal(c.id)"
                            x-cloak
                            :class="'goal-badge--' + ($store.budget.goalStatus(c.id) || 'needed')"
                            :title="'Goal needs ' + formatCents($store.budget.goalNeeded(c.id)) + ' this month'"
                            x-text="goalLabel(c.id)"></span>
                      {# Per-row inline edit/delete — fades in on hover on
                         desktop, always visible on touch. Skips payment
                         categories (they're managed implicitly). #}
                      {# Per-cat row actions. Order mirrors the per-group
                         actions cluster — Auto-assign, Rename, Clear
                         assigned, Clear available, Delete — with the
                         cat-only Move money + Goal slotted at the
                         front so users find the shared icons in the
                         same positions across both rows. #}
                      <span class="budget__row-actions" x-cloak>
                        <button type="button" class="btn btn--icon"
                                @click="openMoveMoney(c)"
                                aria-label="Move money to or from this category"
                                data-tip="Move money to or from this category (reallocate this month's Assigned dollars between categories or pools).">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="17 1 21 5 17 9"/>
                            <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
                            <polyline points="7 23 3 19 7 15"/>
                            <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                          </svg>
                        </button>
                        <template x-if="!$store.budget.isPaymentCategory(c.id)">
                          <span style="display: contents;">
                            <button type="button" class="btn btn--icon"
                                    @click="openAutoAssign({ kind: 'category', name: c.name, id: c.id })"
                                    aria-label="Auto-assign this category"
                                    data-tip="Auto-assign just this category from a goal, last month, or recent average.">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M13 2L4.5 13.5h6L9 22l8.5-11.5h-6L13 2z"/>
                              </svg>
                            </button>
                            <button type="button" class="btn btn--icon" @click="openGoal(c)"
                                    aria-label="Set goal for category"
                                    data-tip="Set, change, or remove this category's funding goal.">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="9"></circle>
                                <circle cx="12" cy="12" r="5"></circle>
                                <circle cx="12" cy="12" r="1.5" fill="currentColor"></circle>
                              </svg>
                            </button>
                            <button type="button" class="btn btn--icon" @click="openRename(c)"
                                    aria-label="Rename category"
                                    data-tip="Rename this category.">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M17 3a2.85 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5z"></path>
                                <line x1="15" y1="5" x2="19" y2="9"></line>
                              </svg>
                            </button>
                            <button type="button" class="btn btn--icon"
                                    @click="catClearAssigned(c)"
                                    aria-label="Clear assigned for this category"
                                    data-tip="Set Assigned to $0 for this category in this month.">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="9"/><line x1="8" y1="12" x2="16" y2="12"/>
                              </svg>
                            </button>
                            <button type="button" class="btn btn--icon"
                                    @click="catClearAvailable(c)"
                                    aria-label="Clear available for this category"
                                    data-tip="Push Available to $0 for this category — pulls money back to Ready to Assign.">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="1 4 1 10 7 10"/>
                                <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                              </svg>
                            </button>
                            <button type="button" class="btn btn--icon" @click="deleteCategoryRow(c)"
                                    aria-label="Delete category"
                                    data-tip="Delete this category. Activity becomes uncategorized."
                                    style="color: var(--danger);">
                              {{ iconTrash(14) }}
                            </button>
                          </span>
                        </template>
                      </span>
                    </div>
                    <div class="goal-bar"
                         x-show="$store.budget.findGoal(c.id)"
                         x-cloak
                         :class="goalBarClass(c.id)"
                         :style="'--pct:' + goalPercent(c.id)"
                         :data-tip="goalBarTooltip(c.id)"
                         role="progressbar"
                         :aria-valuenow="goalPercent(c.id)"
                         aria-valuemin="0" aria-valuemax="100">
                      <span class="goal-bar__track"><span class="goal-bar__fill"></span></span>
                      <span class="goal-bar__cap"
                            x-text="goalPercent(c.id) >= 100 ? '✓ 100%' : (goalPercent(c.id) + '%')"></span>
                    </div>
                  </div>
                  <div class="budget__assigned" data-label="Assigned">
                    <input type="text" inputmode="decimal"
                           data-touch="compact"
                           :aria-label="'Assigned for ' + c.name"
                           :value="formatAssigned($store.budget.assignedFor(c.id))"
                           @focus="$event.target.value = formatPlain($store.budget.assignedFor(c.id))"
                           @blur="commitAssign(c.id, $event.target.value); $event.target.value = formatAssigned($store.budget.assignedFor(c.id));"
                           @keydown.enter="$event.target.blur()">
                  </div>
                  <div class="budget__activity" data-label="Outflow">
                    <button type="button" class="budget__activity-btn"
                            :disabled="$store.budget.activityFor(c.id) === 0"
                            @click="openActivity({ kind: 'category', id: c.id, name: c.name })"
                            :data-tip="$store.budget.activityFor(c.id) === 0 ? '' : ('Click to see every transaction in ' + c.name + ' this month.')"
                            x-text="formatCents($store.budget.activityFor(c.id))"></button>
                  </div>
                  <div class="budget__available" data-label="Available">
                    <button type="button"
                            class="available-pill available-pill--btn"
                            :class="availablePillClass(c.id)"
                            @click="openMoveMoney(c)"
                            :aria-label="'Move money to or from ' + c.name + ' (available: ' + formatCents(categoryAvailable(c.id)) + ')'"
                            data-tip="Click to move money to or from this category."
                            x-text="formatCents(categoryAvailable(c.id))"></button>
                  </div>
                </div>
              </template>
            </div>

            <p x-show="!group.categories.length" x-cloak style="padding: var(--space-sm); color: var(--fg-muted); font-size: var(--fs-sm);">
              No categories in this group yet. Drag one here from another group, or visit the <a href="/app/categories/">categories page</a>.
            </p>
          </div>
        </div>
      </template>
    </div>

    {# Move-money modal — reallocate Assigned dollars between two
       categories (or payment pools) in one move. Net total assigned
       stays the same; from-row decrements, to-row increments. #}
    <div class="modal-backdrop" x-show="moveMoneyOpen" x-cloak
         @keydown.escape.window="moveMoneyOpen = false">
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="bd-mv-title"
           @click.outside="moveMoneyOpen = false" style="max-width: 680px;">
        <button class="modal__close" type="button" @click="moveMoneyOpen = false" aria-label="Close">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
        </button>
        <header class="auto-assign__header">
          <p class="eyebrow">Move money</p>
          <h3 class="modal__title" id="bd-mv-title" style="margin: 0;">
            Reallocate Assigned in <span x-text="monthHeaderLabel()"></span>
          </h3>
          <p class="auto-assign__lead">
            Decrement one category's Assigned and increment another by the same amount. Total Assigned for the month stays the same. Works for payment pools too.
          </p>
        </header>

        <form @submit.prevent="submitMoveMoney()">
          <div class="form-stack">
            <div class="field">
              <label class="field__label" for="bd-mv-from">From</label>
              <select class="select" id="bd-mv-from" x-model="moveMoneyForm.fromId" required>
                <option value="">Select category</option>
                <template x-for="opt in moveMoneyCategoryOptions()" :key="opt.id">
                  <option :value="opt.id"
                          x-text="opt.label + ' · Available ' + formatCents(opt.available)"></option>
                </template>
              </select>
              <p class="field__hint" x-show="moveMoneyForm.fromId" x-cloak
                 x-text="'Currently Assigned: ' + formatCents(_assignedFor(moveMoneyForm.fromId))"></p>
            </div>
            <div class="field">
              <label class="field__label" for="bd-mv-to">To</label>
              <select class="select" id="bd-mv-to" x-model="moveMoneyForm.toId" required>
                <option value="">Select category</option>
                <template x-for="opt in moveMoneyCategoryOptions()" :key="'to-' + opt.id">
                  <option :value="opt.id"
                          :disabled="opt.id === moveMoneyForm.fromId"
                          x-text="opt.label + ' · Available ' + formatCents(opt.available)"></option>
                </template>
              </select>
            </div>
            <div class="field">
              <label class="field__label" for="bd-mv-amount">Amount</label>
              <input class="input" id="bd-mv-amount" type="text" x-model="moveMoneyForm.amount"
                     placeholder="0.00 · or 100+25" inputmode="decimal" required
                     data-tip="Calculator: type expressions like 100 + 25 — they evaluate on save.">
              <p class="field__hint calc-preview"
                 x-show="calcPreview(moveMoneyForm.amount)" x-cloak
                 x-text="calcPreview(moveMoneyForm.amount)"></p>
            </div>
          </div>
          <div class="form-actions">
            <button class="btn btn--primary" type="submit"
                    :disabled="!moveMoneyForm.fromId || !moveMoneyForm.toId || moveMoneyForm.fromId === moveMoneyForm.toId"
                    data-tip="Apply the move (undoable with Cmd/Ctrl+Z).">Move money</button>
            <button class="btn btn--ghost" type="button" @click="moveMoneyOpen = false">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    {# Auto-assign modal — pick a strategy, see a per-strategy preview
       total, then apply. Each strategy walks every non-payment
       category and sets its Assigned for the active month. #}
    <div class="modal-backdrop" x-show="autoAssignOpen" x-cloak
         @keydown.escape.window="autoAssignOpen = false">
      <div class="modal auto-assign" role="dialog" aria-modal="true" aria-labelledby="bd-auto-title"
           @click.outside="autoAssignOpen = false">
        <button class="modal__close" type="button" @click="autoAssignOpen = false" aria-label="Close">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
        </button>
        <header class="auto-assign__header">
          <p class="eyebrow">Auto-assign · <span x-text="autoAssignScope.name"></span></p>
          <h3 class="modal__title" id="bd-auto-title" style="margin: 0;">
            Fill <span x-text="monthHeaderLabel()"></span> from a template
          </h3>
          <p class="auto-assign__lead">
            Pick a strategy.
            <span x-show="autoAssignScope.kind === 'all'">Categories that don't apply are left unchanged.</span>
            <span x-show="autoAssignScope.kind === 'group'">Only categories in <strong x-text="autoAssignScope.name"></strong> are touched.</span>
            <span x-show="autoAssignScope.kind === 'category'">Only the <strong x-text="autoAssignScope.name"></strong> category is touched.</span>
            <span x-show="autoAssignScope.kind === 'selection'">Only the <strong x-text="autoAssignScope.name"></strong> are touched.</span>
            You can tweak any row after.
          </p>
        </header>

        <ul class="auto-assign__list">
          <template x-for="opt in autoAssignStrategies()" :key="opt.id">
            <li>
              <button type="button"
                      class="auto-assign__opt"
                      :class="{
                        'is-selected': autoAssignChoice === opt.id,
                        'is-disabled': opt.disabled
                      }"
                      @click="!opt.disabled && (autoAssignChoice = opt.id)"
                      :disabled="opt.disabled"
                      :aria-pressed="(autoAssignChoice === opt.id).toString()">
                <div class="auto-assign__opt-head">
                  <span class="auto-assign__opt-radio" aria-hidden="true">
                    <svg x-show="autoAssignChoice === opt.id" width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="8"/></svg>
                  </span>
                  <span class="auto-assign__opt-label" x-text="opt.label"></span>
                  <span class="auto-assign__opt-total"
                        :class="opt.disabled ? 'auto-assign__opt-total--muted' : (opt.preview < 0 ? 'amount--outflow' : 'amount--inflow')"
                        x-text="opt.disabled ? '—' : formatCents(opt.preview)"></span>
                </div>
                <p class="auto-assign__opt-hint" x-text="opt.hint"></p>
              </button>
            </li>
          </template>
        </ul>

        <div class="auto-assign__footer">
          <p class="auto-assign__count" x-show="autoAssignChoice" x-cloak>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span x-text="autoAssignSummary()"></span>
          </p>
          <p class="auto-assign__count auto-assign__count--placeholder" x-show="!autoAssignChoice">
            Select a strategy above to preview the impact.
          </p>
        </div>

        <div class="form-actions">
          <button class="btn btn--primary" type="button"
                  :disabled="!autoAssignChoice"
                  @click="applyAutoAssign()"
                  data-tip="Apply the selected strategy to this month's Assigned column.">Apply auto-assign</button>
          <button class="btn btn--ghost" type="button" @click="autoAssignOpen = false">Cancel</button>
        </div>
      </div>
    </div>

    {# Add-group modal — fired from the toolbar "+ Group" button. #}
    <div class="modal-backdrop" x-show="newGroupOpen" x-cloak @keydown.escape.window="newGroupOpen = false">
      <div class="modal modal--sm" role="dialog" aria-modal="true" aria-labelledby="bd-group-title"
           @click.outside="newGroupOpen = false">
        <h3 class="modal__title" id="bd-group-title">New category group</h3>
        <p style="color: var(--fg-muted); margin: 0 0 var(--space-sm);">
          Groups organize the budget. Examples: Monthly bills, Subscriptions, Reserves.
        </p>
        <form @submit.prevent="submitNewGroup()">
          <div class="field">
            <label class="field__label" for="bd-group-name">Group name</label>
            <input class="input" id="bd-group-name" type="text" x-model="newGroupName" required autofocus>
          </div>
          <div class="form-actions">
            <button class="btn btn--primary" type="submit">Create group</button>
            <button class="btn btn--ghost" type="button" @click="newGroupOpen = false">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    {# Add-category modal — fired from any group header "+" icon. #}
    <div class="modal-backdrop" x-show="newCatOpen" x-cloak @keydown.escape.window="newCatOpen = false">
      <div class="modal modal--sm" role="dialog" aria-modal="true" aria-labelledby="bd-cat-title"
           @click.outside="newCatOpen = false">
        <h3 class="modal__title" id="bd-cat-title">
          New category in <span x-text="newCatGroupName || 'group'"></span>
        </h3>
        <form @submit.prevent="submitNewCategory()">
          <div class="field">
            <label class="field__label" for="bd-cat-name">Category name</label>
            <input class="input" id="bd-cat-name" type="text" x-model="newCatName" required autofocus
                   placeholder="e.g. Groceries, Rent, Coffee">
          </div>
          <div class="form-actions">
            <button class="btn btn--primary" type="submit">Add category</button>
            <button class="btn btn--ghost" type="button" @click="newCatOpen = false">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    {# Delete-group confirm — replaces window.confirm() so the dialog
       matches the rest of the app. #}
    <div class="modal-backdrop" x-show="deleteGroupId" x-cloak @keydown.escape.window="deleteGroupId = null">
      <div class="modal modal--sm" role="alertdialog" aria-modal="true"
           @click.outside="deleteGroupId = null"
           @keydown.enter.window.prevent="confirmDeleteGroup()">
        <h3 class="modal__title">Delete this group?</h3>
        <p style="color: var(--fg-muted); margin: 0 0 var(--space-md);">
          Categories inside <strong x-text="deleteGroupName"></strong> become ungrouped but are kept along with their activity and goals.
        </p>
        <div class="form-actions">
          <button class="btn btn--danger" type="button" @click="confirmDeleteGroup()" autofocus>Delete group</button>
          <button class="btn btn--ghost" type="button" @click="deleteGroupId = null">Cancel</button>
        </div>
      </div>
    </div>

    {# Delete-category confirm — same chrome as the group variant. #}
    <div class="modal-backdrop" x-show="deleteCatId" x-cloak @keydown.escape.window="deleteCatId = null">
      <div class="modal modal--sm" role="alertdialog" aria-modal="true"
           @click.outside="deleteCatId = null"
           @keydown.enter.window.prevent="confirmDeleteCategory()">
        <h3 class="modal__title">Delete this category?</h3>
        <p style="color: var(--fg-muted); margin: 0 0 var(--space-md);">
          <strong x-text="deleteCatName"></strong>'s activity becomes uncategorized but stays in the register. Goals on this category are removed.
        </p>
        <div class="form-actions">
          <button class="btn btn--danger" type="button" @click="confirmDeleteCategory()" autofocus>Delete category</button>
          <button class="btn btn--ghost" type="button" @click="deleteCatId = null">Cancel</button>
        </div>
      </div>
    </div>

    {# Rename modal — works for both groups and categories. #}
    <div class="modal-backdrop" x-show="renameOpen" x-cloak @keydown.escape.window="renameOpen = false">
      <div class="modal modal--sm" role="dialog" aria-modal="true" aria-labelledby="bd-rename-title"
           @click.outside="renameOpen = false">
        <h3 class="modal__title" id="bd-rename-title">
          Rename <span x-text="renameKind"></span>
        </h3>
        <form @submit.prevent="submitRename()">
          <div class="field">
            <label class="field__label" for="bd-rename-name">New name</label>
            <input class="input" id="bd-rename-name" type="text" x-model="renameName" required autofocus
                   @keydown.escape="renameOpen = false">
          </div>
          <div class="form-actions">
            <button class="btn btn--primary" type="submit">Save</button>
            <button class="btn btn--ghost" type="button" @click="renameOpen = false">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    {# Activity drill-down modal — opened by clicking any Outflow
       number on the budget grid. Lists every contributing transaction
       for the selected scope (category, group, or all) in the
       currently-active month, with a total at the bottom. #}
    <div class="modal-backdrop" x-show="activityOpen" x-cloak @keydown.escape.window="activityOpen = false">
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="bd-act-title"
           @click.outside="activityOpen = false" style="max-width: 760px;">
        <button class="modal__close" type="button" @click="activityOpen = false" aria-label="Close">&times;</button>
        <h3 class="modal__title" id="bd-act-title">
          <span x-text="activityScope.name"></span>
          <span style="color: var(--fg-muted); font-weight: 400; font-size: var(--fs-md);"
                x-text="' · ' + monthHeaderLabel()"></span>
        </h3>
        <p style="color: var(--fg-muted); margin: 0 0 var(--space-sm);"
           x-text="activityTxns().length + ' transaction' + (activityTxns().length === 1 ? '' : 's')"></p>

        <div class="table-scroll">
          <table class="table">
            <thead>
              <tr>
                <th scope="col" style="white-space: nowrap;">Date</th>
                <th scope="col">Account</th>
                <th scope="col">Payee</th>
                <th scope="col" x-show="activityScope.kind !== 'category'">Category</th>
                <th scope="col">Memo</th>
                <th scope="col" class="num">Amount</th>
              </tr>
            </thead>
            <tbody>
              <template x-for="t in activityTxns()" :key="t.id + '-' + (t.splitKey || '')">
                <tr class="activity-row"
                    @click="openInRegister(t)"
                    :data-tip="'Open ' + ($store.budget.payeeName(t.payeeId) || 'this transaction') + ' in the register.'"
                    tabindex="0"
                    @keydown.enter="openInRegister(t)"
                    @keydown.space.prevent="openInRegister(t)"
                    role="button"
                    :aria-label="'Open ' + ($store.budget.payeeName(t.payeeId) || 'transaction') + ' from ' + t.date + ' in the register'">
                  <td style="white-space: nowrap;" x-text="t.date"></td>
                  <td x-text="$store.budget.findAccount(t.accountId)?.name || '—'"></td>
                  <td x-text="$store.budget.payeeName(t.payeeId) || '—'"></td>
                  <td x-show="activityScope.kind !== 'category'"
                      x-text="$store.budget.categoryName(t.categoryId) || 'Uncategorized'"
                      style="color: var(--fg-muted);"></td>
                  <td style="color: var(--fg-muted);" x-text="t.memo || ''"></td>
                  <td class="num" :class="t.amount < 0 ? 'amount--outflow' : 'amount--inflow'"
                      x-text="formatCents(t.amount)"></td>
                </tr>
              </template>
              <tr x-show="!activityTxns().length" x-cloak>
                <td :colspan="activityScope.kind !== 'category' ? 6 : 5"
                    style="color: var(--fg-muted); text-align: center; padding: var(--space-md);">
                  No transactions in this scope for the active month.
                </td>
              </tr>
            </tbody>
            <tfoot x-show="activityTxns().length" x-cloak>
              <tr style="border-top: 2px solid var(--border);">
                <td :colspan="activityScope.kind !== 'category' ? 5 : 4"
                    style="font-weight: 600;">Total</td>
                <td class="num" style="font-weight: 700;"
                    :class="activityTotal() < 0 ? 'amount--outflow' : 'amount--inflow'"
                    x-text="formatCents(activityTotal())"></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div class="form-actions" style="margin-top: var(--space-md);">
          <a class="btn btn--secondary btn--sm"
             x-show="activityScope.kind === 'category'"
             :href="'/app/register/?category=' + activityScope.id"
             data-tip="Open these transactions in the full register.">Open in register</a>
          <button class="btn btn--ghost btn--sm" type="button" @click="activityOpen = false">Close</button>
        </div>
      </div>
    </div>

    {# Goal modal — reuses the categories-page form so users can set,
       change, or remove a goal without leaving the budget. Shows a
       live status panel above the form with the current funding %,
       what's assigned this month, and what's still needed. #}
    <div class="modal-backdrop" x-show="goalCatId" x-cloak @keydown.escape.window="goalCatId = null">
      <div class="modal" role="dialog" aria-modal="true" @click.outside="goalCatId = null"
           style="max-width: 620px;">
        <button class="modal__close" type="button" @click="goalCatId = null" aria-label="Close">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
        </button>
        <header class="auto-assign__header">
          <p class="eyebrow">Goal</p>
          <h3 class="modal__title" id="bd-goal-title" style="margin: 0;">
            <span x-text="$store.budget.categoryName(goalCatId)"></span>
            <span style="color: var(--fg-muted); font-weight: 400; font-size: var(--fs-md);">
              · <span x-text="monthHeaderLabel()"></span>
            </span>
          </h3>
        </header>

        {# Current-status snapshot — only when a goal already exists.
           Shows progress bar + 4 stat tiles (target / assigned-MTD /
           needed-this-month / status). #}
        <div class="goal-status" x-show="$store.budget.findGoal(goalCatId)" x-cloak>
          <div class="goal-status__bar-row">
            <span class="goal-status__cap"
                  x-text="goalPctForModal() >= 100 ? '✓ 100% funded' : (goalPctForModal() + '% funded')"></span>
            <div class="goal-status__bar" :data-tip="goalStatusTooltip()"
                 role="progressbar"
                 :aria-valuenow="goalPctForModal()"
                 aria-valuemin="0" aria-valuemax="100">
              <span class="goal-status__fill"
                    :class="goalPctForModal() >= 100 ? 'goal-status__fill--funded' : (goalPctForModal() >= 50 ? 'goal-status__fill--partial' : 'goal-status__fill--low')"
                    :style="'width:' + Math.min(100, goalPctForModal()) + '%'"></span>
            </div>
          </div>

          <dl class="goal-status__stats">
            <div class="goal-status__stat" data-tip="The full amount this goal is asking for this month.">
              <dt>Target</dt>
              <dd x-text="formatCents(goalCurrentTarget())"></dd>
            </div>
            <div class="goal-status__stat" data-tip="Dollars you've assigned to this category in the active month.">
              <dt>Assigned</dt>
              <dd class="amount--inflow"
                  x-text="formatCents($store.budget.assignedFor(goalCatId, $store.budget.currentMonth))"></dd>
            </div>
            <div class="goal-status__stat" data-tip="Total dollars currently sitting in this category (carry-in + this month's assigned + activity).">
              <dt>Available</dt>
              <dd :class="categoryAvailable(goalCatId) < 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="formatCents(categoryAvailable(goalCatId))"></dd>
            </div>
            <div class="goal-status__stat goal-status__stat--needed"
                 data-tip="What's still missing this month to meet the goal target.">
              <dt>Still needed</dt>
              <dd :class="$store.budget.goalNeeded(goalCatId) > 0 ? 'amount--outflow' : 'amount--inflow'"
                  x-text="$store.budget.goalNeeded(goalCatId) > 0 ? formatCents($store.budget.goalNeeded(goalCatId)) : '✓ Funded'"></dd>
            </div>
          </dl>

          <p class="goal-status__hint" x-text="goalNarrative()"></p>
        </div>

        <p class="goal-status__hint goal-status__hint--new"
           x-show="!$store.budget.findGoal(goalCatId)" x-cloak>
          No goal set yet. Pick a goal type and target below — the budget will track funding progress against it every month.
        </p>

        <form @submit.prevent="saveGoal()" style="margin-top: var(--space-md);">
          <div class="form-stack">
            <div class="field">
              <label class="field__label" for="bd-g-type">Goal type</label>
              <select class="select" id="bd-g-type" x-model="goalForm.type">
                <template x-for="t in $store.budget.GOAL_TYPES" :key="t.value">
                  <option :value="t.value" x-text="t.label"></option>
                </template>
              </select>
              <p class="field__hint" x-text="goalTypeHint()"></p>
            </div>
            <div class="form-row">
              <div class="field">
                <label class="field__label" for="bd-g-target">Target amount</label>
                <input class="input" id="bd-g-target" type="text" x-model="goalForm.target"
                       inputmode="decimal" placeholder="0.00" required
                       data-tip="Calculator: type expressions like 250+75 — they evaluate on save.">
                <p class="field__hint calc-preview" x-show="calcPreview(goalForm.target)" x-cloak
                   x-text="calcPreview(goalForm.target)"></p>
              </div>
              <div class="field" x-show="goalForm.type === 'targetByDate'" x-cloak>
                <label class="field__label" for="bd-g-date">By date</label>
                <input class="input" id="bd-g-date" type="date" x-model="goalForm.byDate">
                <p class="field__hint" x-show="goalForm.byDate" x-cloak
                   x-text="goalDateHint()"></p>
              </div>
            </div>
          </div>
          <div class="form-actions">
            <button class="btn btn--primary" type="submit">Save goal</button>
            <button class="btn btn--ghost" type="button" @click="removeGoal()"
                    x-show="$store.budget.findGoal(goalCatId)">Remove goal</button>
            <button class="btn btn--ghost" type="button" @click="goalCatId = null">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    </div> {# /budgetCollapsed wrapper #}

    {# Total budget — bottom summary row matching the columns above. #}
    <div class="budget__group-header budget__total-row" aria-label="Totals for this month">
      <div class="budget__total-label">
        <span class="budget__total-eyebrow">Month total</span>
        <strong x-text="monthHeaderLabel()"></strong>
      </div>
      <span class="num">
        <span class="budget__total-mini-label">Assigned</span>
        <span class="budget__total-value"
              x-text="formatCents($store.budget.totalAssignedInMonth($store.budget.currentMonth))"></span>
      </span>
      <span class="num">
        <span class="budget__total-mini-label">Outflow</span>
        <button type="button" class="budget__activity-btn budget__total-value"
                :disabled="monthlyOutflowTotal() === 0"
                @click="openActivity({ kind: 'all', id: '__all', name: 'All categories' })"
                :data-tip="monthlyOutflowTotal() === 0 ? '' : 'Click to see every transaction this month.'"
                :class="monthlyOutflowTotal() < 0 ? 'amount--outflow' : ''"
                x-text="formatCents(monthlyOutflowTotal())"></button>
      </span>
      <span class="num">
        <span class="budget__total-mini-label">Available</span>
        <span class="budget__total-value"
              :class="monthlyAvailableTotal() < 0 ? 'amount--outflow' : 'amount--inflow'"
              x-text="formatCents(monthlyAvailableTotal())"></span>
      </span>
    </div>
  </section>

  {# Credit-card payment-pool cards. Show one card per credit account with
     a pill of the dollars currently assigned for paying it down vs. the
     amount of debt currently owed. Surfaces the at-a-glance "do I have
     enough set aside to cover this card" answer. #}
  <section class="pool-grid" x-show="hasCategories && paymentPools().length" x-cloak>
    <header class="pool-grid__header">
      <h2 class="pool-grid__title">Credit Card Payment Pools</h2>
      <p class="pool-grid__sub">How much you've set aside in each card's payment category vs. the balance owed.</p>
    </header>
    <div class="pool-grid__cards">
      <template x-for="p in paymentPools()" :key="p.accountId">
        <article class="pool-card" :class="poolCardClass(p)">
          <header class="pool-card__head">
            <h3 class="pool-card__name" x-text="p.accountName"></h3>
            <p class="pool-card__role">Payment Pool</p>
          </header>
          <div class="pool-card__amount">
            <span class="available-pill"
                  :class="poolPillClass(p)"
                  x-text="formatCents(p.pool)"></span>
          </div>
          <div class="pool-card__progress-wrap">
            <div class="pool-card__progress"
                 :data-tip="poolCoverageLabel(p)">
              <div class="pool-card__progress-bar"
                   :class="poolBarClass(p)"
                   :style="'width: ' + Math.min(100, p.coveragePct) + '%;'"
                   role="progressbar"
                   :aria-valuenow="p.coveragePct"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   :aria-label="poolCoverageLabel(p)"></div>
            </div>
            <span class="pool-card__pct"
                  :class="p.coveragePct >= 100 ? 'pool-card__pct--full' : ''"
                  x-text="p.coveragePct >= 100 ? '✓ 100%' : (p.coveragePct + '%')"></span>
          </div>
          <p class="pool-card__hint" x-text="poolCoverageLabel(p)"></p>
        </article>
      </template>
    </div>
  </section>

  {# Floating bulk-actions bar — visible only when at least one category
     is selected. Clear assigned / Clear available apply to the
     selection; Cancel deselects everything. #}
  <div class="bulk-actions-bar" x-show="selectedCatIds.length" x-cloak role="region" aria-label="Bulk actions">
    <div class="bulk-actions-bar__count">
      <strong x-text="selectedCatIds.length"></strong>
      <span x-text="selectedCatIds.length === 1 ? 'category selected' : 'categories selected'"></span>
    </div>
    <div class="cluster" style="gap: var(--space-2xs);">
      <button type="button" class="btn btn--primary btn--sm" @click="bulkAutoAssign()"
              data-tip="Open the auto-assign strategy picker for every selected category.">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align: -2px; margin-right: 4px;">
          <path d="M13 2L4.5 13.5h6L9 22l8.5-11.5h-6L13 2z"/>
        </svg>
        Auto-assign
      </button>
      <button type="button" class="btn btn--secondary btn--sm" @click="bulkClearAssigned('selection')"
              data-tip="Reset Assigned to $0 for every selected category in this month.">Clear assigned</button>
      <button type="button" class="btn btn--secondary btn--sm" @click="bulkClearAvailable('selection')"
              data-tip="Push Available to $0 for every selected category — pulls money back to Ready to Assign.">Clear available</button>
      <button type="button" class="btn btn--ghost btn--sm" @click="clearSelection()"
              data-tip="Deselect everything.">Cancel</button>
    </div>
  </div>

  {# Saved budget templates modal — save current month's assigned
     values as a named template, or apply a saved template to the
     current month. Templates live on the profile under
     `budgetTemplates`. #}
  <div class="modal-backdrop" x-show="templatesOpen" x-cloak @keydown.escape.window="templatesOpen = false">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="tpl-title"
         @click.outside="templatesOpen = false" style="max-width: 560px;">
      <button class="modal__close" type="button" @click="templatesOpen = false" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <h3 class="modal__title" id="tpl-title">Budget templates</h3>
      <p style="color: var(--fg-muted);">
        Save the current month's assigned values as a named template,
        then apply it to any other month with one click. Categories that
        no longer exist when you apply are silently skipped.
      </p>

      <div class="field" style="margin-top: var(--space-sm);">
        <label class="field__label" for="tpl-name">Save current month as template</label>
        <div class="cluster" style="gap: var(--space-2xs); flex-wrap: nowrap;">
          <input class="input" id="tpl-name" type="text" x-model="templateNewName"
                 placeholder="e.g. Standard month" autocomplete="off" style="flex: 1 1 auto; min-width: 0;">
          <button class="btn btn--primary" type="button"
                  :disabled="!templateNewName.trim()"
                  @click="saveTemplate()">Save</button>
        </div>
        <p class="field__hint">
          Captures every non-zero assignment in
          <strong x-text="$store.budget.currentMonth"></strong>.
        </p>
      </div>

      <h4 style="margin-top: var(--space-md);">Saved templates</h4>
      <p x-show="!$store.budget.listBudgetTemplates().length" x-cloak style="color: var(--fg-muted);">
        No templates saved yet.
      </p>
      <ul x-show="$store.budget.listBudgetTemplates().length" x-cloak class="template-list" style="list-style: none; padding: 0; margin: var(--space-2xs) 0 0;">
        <template x-for="tpl in $store.budget.listBudgetTemplates()" :key="tpl.id">
          <li class="template-list__item" style="display: flex; align-items: center; gap: var(--space-2xs); justify-content: space-between; padding: var(--space-2xs) 0; border-bottom: 1px solid var(--border-soft);">
            <div style="min-width: 0;">
              <p style="margin: 0; font-weight: 600;" x-text="tpl.name"></p>
              <p style="margin: 0; color: var(--fg-muted); font-size: var(--fs-xs);"
                 x-text="Object.keys(tpl.assigned || {}).length + ' categories · saved ' + new Date(tpl.createdAt).toLocaleDateString()"></p>
            </div>
            <div class="cluster" style="gap: var(--space-2xs); flex-shrink: 0;">
              <button class="btn btn--primary btn--sm" type="button"
                      @click="applyTemplate(tpl.id)"
                      :data-tip="'Overwrite assignments in ' + $store.budget.currentMonth + ' with this template.'">Apply</button>
              <button class="btn btn--ghost btn--sm" type="button"
                      @click="deleteTemplate(tpl.id, tpl.name)"
                      data-tip="Delete this template.">Delete</button>
            </div>
          </li>
        </template>
      </ul>

      <div class="form-actions" style="margin-top: var(--space-md);">
        <button class="btn btn--ghost" type="button" @click="templatesOpen = false">Close</button>
      </div>
    </div>
  </div>
</div>
