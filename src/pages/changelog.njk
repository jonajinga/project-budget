---
layout: layouts/page.njk
title: "Changelog"
description: "What's new in Project Budget, release by release."
permalink: /changelog/
---
<p>
  Releases are tagged in git and summarized here. Conventional commits in the
  repo provide the raw history.
</p>

{% for entry in changelog %}
<section class="changelog-entry">
  <header class="changelog-entry__header">
    <h2 id="v{{ entry.version }}">{{ entry.version }}</h2>
    <p class="changelog-entry__date">{{ entry.date }}</p>
  </header>
  <p>{{ entry.summary }}</p>
  {% if entry.highlights %}
  <ul>
    {% for h in entry.highlights %}
      <li>{{ h }}</li>
    {% endfor %}
  </ul>
  {% endif %}
</section>
{% endfor %}
